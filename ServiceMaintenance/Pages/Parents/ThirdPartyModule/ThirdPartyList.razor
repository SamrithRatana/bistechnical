    private string GetImagePath(string customerType)
    {
        // ✅ Add null check
        if (string.IsNullOrEmpty(customerType) || customerType == "Unknown")
        {
            return "./images/partner_logo/Default.jpg"; // Default image
        }

        // Clean the customerType name to make it safe for file names
        string cleanedCustomerType = customerType.Replace(" ", "_");

        // Build the image path using the customerType
        return $"./images/partner_logo/{cleanedCustomerType}.jpg";
    }

