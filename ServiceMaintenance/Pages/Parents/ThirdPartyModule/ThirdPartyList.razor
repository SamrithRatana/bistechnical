@page "/third-party"
@page "/third-party/{ReportNo}"

@using ServiceMaintenance.Models
@using Microsoft.AspNetCore.SignalR.Client
@using System.Timers
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@using Syncfusion.Blazor.Cards
@inject RepairItemService RepairItemService
@inject CustomerService CustomerService
@inject NavigationManager NavigationManager
@inject StateManagementAction StateManagementAction
@inject ServiceSparePart SparePartService
@inject IJSRuntime JSRuntime
@inject ThirdPartyRepairService AwaitingSparePartService
@inject IToastNotificationService ToastNotificationService
@inject GlobalUserService GlobalUserCache
<DxToastProvider Name="Customization"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
             @if (CanCreate)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" Click="NewRepairService_Click" IconCssClass="far fa-file" CssClass="toolbar-item" Enabled="false" />
            }
             @if (CanEdit)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" Click="EditRepairService_Click" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="false" />
            }
             @if (CanDelete)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" Click="EditRepairService_Click" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="false" />
            }
             @if (CanExport)
            {
            
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download" Enabled="@exportEnabled">
                <Items>
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ExportToPdf" IconCssClass="fas fa-file-pdf" />
                </Items>
            </DxToolbarItem>
            }
             @if (CanPrint)
            {
            <DxToolbarItem Text="Print Report" Click="() => ShowReportPreview(_selectedRepairService)" CssClass="toolbar-item" IconCssClass="fas fa-print" />       
            }
             @if (CanView)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" Click="ToggleView" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" />
            }
        </DxToolbar>
    </div>
</div>
<br />
<SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>
@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical;

    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical;
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Horizontal;
    }
    else
    {
        enableAdaptiveUIMode = false;
    }
}
@if (CanAccess)
{
@if (CanView)
{
@if (isGridView)
{
    <!-- Search Bar for Grid View -->
    <div style="margin-bottom: 15px; padding: 15px; background-color: #f9f9f9; border-radius: 4px;">
        <div style="display: flex; gap: 10px; align-items: center;">
            <SfTextBox @ref="GridSearchBox"
                       Placeholder="Search by Report No, Company, Serial Number..."
                       ShowClearButton="true"
                       Width="400px"
                       @bind-Value="GridSearchValue"
                       Input="OnGridSearchInput">
            </SfTextBox>
            
            <SfButton Content="Search" 
                      CssClass="e-btn e-primary" 
                      IconCss="fas fa-search"
                      OnClick="PerformGridSearch" />
            
            <SfButton Content="Clear" 
                      CssClass="e-btn e-outline" 
                      IconCss="fas fa-times"
                      OnClick="ClearGridSearch" />
        </div>
        
        @if (!string.IsNullOrEmpty(GridSearchValue))
        {
            <div style="margin-top: 10px; color: #666; font-size: 14px;">
                <i class="fas fa-info-circle"></i> Searching for: <strong>@GridSearchValue</strong>
            </div>
        }
    </div>

    <SfGrid @ref="MyGrid"
            DataSource="@filteredRepairServices2"
            AllowPaging="false"
            AllowSorting="true"
            ShowColumnChooser="true"
            AllowExcelExport="true"
            AllowPdfExport="true"
            SelectionMode="GridSelectionMode.Single"
            Toolbar="@ToolbarItems"
            EnableAdaptiveUI="@enableAdaptiveUIMode"
            RowRenderingMode="@renderingMode"
                    AllowResizing="true"
                    AllowFiltering="true"
            AllowSelection="true">
        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
        <GridEvents RowSelected="RowSelectHandler" TValue="RepairServices"></GridEvents>
        <GridColumns>
            <GridColumn Field="Id" HeaderText="Id" Width="150" Format="d" Visible="false" />
            <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="150" />
            <GridColumn Field="thirdPartyRepairDate"
                        HeaderText="@Loc[nameof(ResourceStrings.TextDate)]"
                        Width="150">
                <Template>
                    @{
                        var item = context as RepairServices;
                        var localTime = item.thirdPartyRepairDate?.ToLocalTime();
                    }
                    @(localTime?.ToString("dd/MM/yyyy hh:mm tt") ?? "N/A")
                </Template>
            </GridColumn>          
            <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" Width="200" />
            <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="200" />
            <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="200" />
            <GridColumn Field="ServiceLocation" HeaderText="@Loc[nameof(ResourceStrings.TextServiceLocation)]" Width="200" />
                    <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="150">
                        <Template>
                            @{
                                var item = context as RepairServices;
                                var khmerStatus = GetKhmerStatus(item?.Status);
                            }
                            @khmerStatus
                        </Template>
                    </GridColumn>
                    <GridColumn Field="thirdPartyRepairBy" HeaderText="@Loc[nameof(ResourceStrings.TesthasThirdParty)]" Width="150">
                <Template>
                    @{
                        var item = context as RepairServices;
                        var username = GetUserNameById(item.thirdPartyRepairBy);
                    }
                    @username
                </Template>
            </GridColumn>
            <GridColumn HeaderText="Actions" Width="120">
                <Template>
                    @{
                        var item = context as RepairServices;
                    }
                    <DxButton IconCssClass="fas fa-eye"
                              CssClass="icon-button info"
                              RenderStyle="ButtonRenderStyle.Info"
                              RenderStyleMode="ButtonRenderStyleMode.Text"
                              Text="@Loc[nameof(ResourceStrings.TextView)]"
                              @onclick="() => ShowRepairServiceDetails(item)" />
                </Template>
            </GridColumn>
        </GridColumns>
    </SfGrid>

    <!-- Custom Pagination -->
    <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; border-top: 1px solid #ddd; margin-top: 10px; background-color: #f9f9f9;">
        <div style="display: flex; align-items: center; gap: 10px;">
            <button class="e-btn e-normal" @onclick="GridFirstPage" disabled="@(currentGridPage == 1)">
                <i class="fas fa-angle-double-left"></i> First
            </button>
            <button class="e-btn e-normal" @onclick="GridPreviousPage" disabled="@(currentGridPage == 1)">
                <i class="fas fa-angle-left"></i> Previous
            </button>

            <span style="padding: 0 15px; font-weight: 500;">
                Page @currentGridPage of @totalGridPages
            </span>

            <button class="e-btn e-normal" @onclick="GridNextPage" disabled="@(currentGridPage >= totalGridPages)">
                Next <i class="fas fa-angle-right"></i>
            </button>
            <button class="e-btn e-normal" @onclick="GridLastPage" disabled="@(currentGridPage >= totalGridPages)">
                Last <i class="fas fa-angle-double-right"></i>
            </button>
        </div>

        <div style="color: #666;">
            Showing @Math.Min((currentGridPage - 1) * gridPageSize + 1, totalGridItems) - @Math.Min(currentGridPage * gridPageSize, totalGridItems) of @totalGridItems items
        </div>
    </div>
}
else
{
    <div class="row">
        @* Properties Panel - Shows first on mobile due to order-first class *@
        <div class="col-lg-3 order-lg-2 order-first property-section">
            <div class="property-panel-section">
                <div class="property-panel-header">Properties</div>
                <div class="property-panel-content">
                    <table class="table">
                        <tr>
                            <td>
                                <SfTextBox Placeholder="Search services"
                                           ShowClearButton="true"
                                           Width="100%"
                                           ValueChange="OnSearch"
                                           @oninput="OnInputClick"
                                           @bind-Value="SearchValue">
                                </SfTextBox>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <SfDropDownList TValue="string"
                                                TItem="string"
                                                DataSource="@SortingType"
                                                Placeholder="Sorting order"
                                                Width="100%"
                                                @bind-Value="SortingValue">
                                    <DropDownListEvents TValue="string" TItem="string" ValueChange="OnSorting"></DropDownListEvents>
                                </SfDropDownList>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <SfMultiSelect TValue="string[]"
                                               TItem="ServiceStatus"
                                               AllowFiltering="true"
                                               DataSource="@_serviceStatuses"
                                               Placeholder="Select Service Statuses"
                                               ShowClearButton="true"
                                               Width="100%"
                                               @bind-Value="FilteringValue">
                                    <MultiSelectFieldSettings Text="Name" Value="Id" />
                                    <MultiSelectEvents TValue="string[]" TItem="ServiceStatus" ValueChange="OnFiltering"></MultiSelectEvents>
                                </SfMultiSelect>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <SfButton Content="Reset" OnClick="OnReset" CssClass="w-100"></SfButton>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        @* Cards Section - Shows second on mobile, first on large screens *@
        <div class="col-lg-9 order-lg-1 order-last">
            <div class="e-card-layout">
                @if (filteredRepairServices == null || !filteredRepairServices.Any())
                {
                    <div class="e-error">
                        <div class="e-error-content">No results found. Please try a different search.</div>
                    </div>
                }
                else
                {
                    <div class="row">
                        @foreach (RepairServices service in PaginatedRepairServices)
                        {
                            var companyName = string.IsNullOrEmpty(service.CompanyName) ? "N/A" : service.CompanyName;
                            var serviceDate = service.ServiceDate != default(DateTime) ? service.ServiceDate.ToString("dd/MM/yyyy HH:mm tt") : "N/A";
                            var customerType = GetCustomerType(service.CompanyName);
                            var imagePath = GetImagePath(customerType);

                            <div class="col-lg-3 col-md-4 col-sm-6" style="padding: 15px;">
                                <div id="card_sample_1" class="card_sample">
                                    <SfCard>
                                        <CardImage Image="@imagePath" />
                                        <CardHeader Title="@companyName" SubTitle="@serviceDate" />
                                        <CardContent>
                                            <div style="display: flex; align-items: center; justify-content: space-between;">
                                                <div>
                                                    <strong>@Loc[nameof(ResourceStrings.Textref)]:</strong>
                                                    <span style="color: red;">@(service.reportNo ?? "N/A")</span>
                                                </div>
                                                <button class="view-icon" @onclick="() => ShowRepairServiceDetails(service)">
                                                    <i class="fa fa-eye" aria-hidden="true"></i> View
                                                </button>
                                            </div>
                                            <div><strong>@Loc[nameof(ResourceStrings.TextItemName)]:</strong> @(service.itemName ?? "N/A")</div>
                                            <div><strong>@Loc[nameof(ResourceStrings.TextSerialNumber)]:</strong> @(service.serialNumber ?? "N/A")</div>
                                            <div><strong>@Loc[nameof(ResourceStrings.TextServiceLocation)]:</strong> @(service.ServiceLocation ?? "N/A")</div>
                                            <div>
                                                <strong>@Loc[nameof(ResourceStrings.TextStatus)]:</strong>
                                                <span class="@GetStatusClass(service.Status)">
                                                    @(service.Status ?? "N/A")
                                                </span>
                                            </div>
                                        </CardContent>
                                        <CardFooter>
                                            <CardFooterContent>
                                                <SfButton CssClass="e-btn e-outline e-primary" @onclick="() => OnApplyButtonClick(service)">
                                                    @Loc[nameof(ResourceStrings.SetThirdParty)]
                                                </SfButton>
                                            </CardFooterContent>
                                        </CardFooter>
                                    </SfCard>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination controls -->
                    <div class="pagination-controls">
                        <SfButton CssClass="e-btn e-outline e-primary" @onclick="GoToPreviousPage" Disabled="@IsFirstPage">
                            @Loc[nameof(ResourceStrings.TextPrevious)]
                        </SfButton>
                        <span>Page @currentPage of @totalPages</span>
                        <SfButton CssClass="e-btn e-outline e-primary" @onclick="GoToNextPage" Disabled="@IsLastPage">
                            @Loc[nameof(ResourceStrings.TextNext)]
                        </SfButton>
                    </div>
                    <br />
                }
            </div>
        </div>
    </div>
    }
  }
}
<SfDialog @ref="ConfirmationDialog"
          IsModal="true"
          Width="400px"
          ShowCloseIcon="true"
          Visible="@isConfirmationDialogVisible">
    <DialogTemplates>
        <Header>
            <h2>@pageTitle</h2>
        </Header>
        <Content>
            <p>@Loc[nameof(ResourceStrings.TextconfirmThirdParty)]</p>
        </Content>
        <FooterTemplate>
            <SfButton CssClass="e-btn custom-button" @onclick="ConfirmThirdPartyRepair">Yes</SfButton>
            <SfButton CssClass="e-btn e-danger" @onclick="CancelConfirmationDialog">No</SfButton>
        </FooterTemplate>
    </DialogTemplates>
</SfDialog>

<SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
    <DialogTemplates>
        <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
        <Content>
            <div class="report-container">
                <div class="report-header">
                    <span>Repair Service Report</span>
                </div>
                <div class="report-body">
                    <table class="report-table">
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.reportNo</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceDate.ToString("yyyy-MM-dd HH:mm tt")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextDate)]:</strong></td>
                            <td class="report-value">
                                @(_selectedRepairService?.thirdPartyRepairDate?.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt") ?? "N/A")
                            </td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCompanyName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CompanyName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextAddress)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Address</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContactName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ContactName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPhoneNumber)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.PhoneNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextItemName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.itemName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextSerialNumber)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.serialNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCustomerReq)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CustomerRequest</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextInspection)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Inspection</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textsolution)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Solution</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextServiceLocation)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceLocation</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPriority)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServicePriority</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextStatus)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Status</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContract)]:</strong></td>
                            <td class="report-value">@(_selectedRepairService?.hasContract == true ? "Yes" : "No")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.SetThirdParty)]:</strong></td>
                            <td class="report-value">
                                @{
                                    var username = GetUserNameById(_selectedRepairService?.thirdPartyRepairBy);
                                }
                                @username
                            </td>
                        </tr>
                    </table>
                    <hr />
                    @if (_selectedRepairService?.SparePartItems != null && _selectedRepairService.SparePartItems.Count > 0)
                    {
                        <h4>SparePart Details</h4>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>@Loc[nameof(ResourceStrings.TextImage)]</th>
                                    <th>@Loc[nameof(ResourceStrings.textDescription)]</th>
                                    <th>@Loc[nameof(ResourceStrings.TextQty)]</th>
                                    <th>@Loc[nameof(ResourceStrings.TextCondition)]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sparePart in _selectedRepairService.SparePartItems)
                                {
                                    var sparePartObject = _spareParts.FirstOrDefault(x => x.Id == sparePart.SparePartId);
                                    <tr>
                                        <td>
                                            @if (sparePartObject != null && !string.IsNullOrEmpty(sparePartObject.PictureUrl))
                                            {
                                                <img src="@sparePartObject.PictureUrl" alt="Spare Part Image" />
                                            }
                                            else
                                            {
                                                <span>No Image</span>
                                            }
                                        </td>
                                        <td>@sparePartObject?.ItemName</td>
                                        <td>@sparePart.Quantity</td>
                                        <td>@sparePart.Condition</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Close" IsPrimary="true" OnClick="@CloseDialog" />
    </DialogButtons>
</SfDialog>

@code {
    [Parameter] public string ReportNo { get; set; }
    private SfGrid<RepairServices> MyGrid;
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;
    private string activeBreakpoint { get; set; }
    public string[] ToolbarItems = new string[] { "ColumnChooser", "Search" };
    private IEnumerable<RepairServices> filteredRepairServices = new List<RepairServices>();
    private IEnumerable<RepairServices> filteredRepairServices2 = new List<RepairServices>();
    private IEnumerable<ServiceStatus> _serviceStatuses;
    private SfTextBox GridSearchBox;
    private string GridSearchValue { get; set; }
    private System.Threading.Timer _gridSearchDebounceTimer;
    private IEnumerable<RepairServices> PaginatedRepairServices = new List<RepairServices>();
    private IEnumerable<SparePartObject> _spareParts = Enumerable.Empty<SparePartObject>();
    private HubConnection hubConnection;
    private string SearchValue { get; set; }
    private string SortingValue { get; set; }
    private string[] FilteringValue { get; set; }
    public List<string> SortingType = new List<string>() { "Ascending", "Descending" };
    private IEnumerable<Customer> _customers = new List<Customer>();
    private SfDialog DialogEdit;
    private bool isViewDialogVisible = false;
    private int currentGridPage = 1;
    private int gridPageSize = 10;
    private int totalGridPages = 0;
    private int totalGridItems = 0;
    private SfDialog ConfirmationDialog;
    private string pageTitle = "Third Party Repair";
    private ThirdPartyRepairRequest awaitingSparePart = new ThirdPartyRepairRequest();
    private RepairServices _selectedRepairService;
    private bool isConfirmationDialogVisible = false;
    private bool isGridView = false;
    private bool exportEnabled = false;
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 0;
    private int totalItems = 0;

    private Dictionary<string, string> _allUsers = new Dictionary<string, string>();
    private bool _usersLoaded = false;
    private string GetKhmerStatus(string englishStatus)
    {
        if (string.IsNullOrEmpty(englishStatus))
            return string.Empty;

        var statusMap = new Dictionary<string, string>
    {
        { "Item Recieved", "ម៉ាស៊ីនចូល" },
        { "Inspection", "កំពុងវិនិច្ឆ័យ" },
        { "Awaiting Customer Confirm", "រង់ចាំយល់ព្រមពីភ្ញៀវ" },
        { "Awaiting Sparepart", "រង់ចាំគ្រឿងបន្លាស់" },
        { "Repairing", "កំពុងជួសជុល" },
        { "Finished", "ជួសជុលរួចរាល់" },
        { "Customer Rejected", "អតិថិជនមិនជួសជុល" },
        { "Unrepairable", "ជួសជុលមិនបាន" },
        { "Repair by Third-Party", "ជួសជុលដោយជាងខាងក្រៅ" }
    };

        if (englishStatus.Contains("(Historical)"))
        {
            var baseStatus = englishStatus.Replace(" (Historical)", "").Trim();
            return statusMap.ContainsKey(baseStatus)
                ? $"{statusMap[baseStatus]} (ប្រវត្តិ)"
                : englishStatus;
        }

        return statusMap.ContainsKey(englishStatus)
            ? statusMap[englishStatus]
            : englishStatus;
    }
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        try
        {
            await LoadAllUsersAsync();

            // ✅ OPTIMIZED Card View (exclude specific statuses)
            var cardViewResult = await RepairItemService.SearchRepairServicesAsync(
                pageNumber: currentPage,
                pageSize: pageSize,
                sortBy: "reportNo",
                sortDescending: true,
                excludedStatuses: new[]
                {
                "Repair by Third-Party",
                "Finished",
                "Repairing"
                }
            );

            filteredRepairServices = cardViewResult.Items ?? new List<RepairServices>(); // ✅ Null-safe
            totalPages = cardViewResult.TotalPages;
            totalItems = cardViewResult.TotalCount;

            // ✅ Grid View (ONLY Awaiting Customer Confirm)
            var gridViewResult = await RepairItemService.SearchRepairServicesAsync(
                pageNumber: currentGridPage,
                pageSize: gridPageSize,
                status: "Repair by Third-Party",
                sortBy: "reportNo",
                sortDescending: true
            );

            filteredRepairServices2 = gridViewResult.Items ?? new List<RepairServices>(); // ✅ Null-safe
            totalGridPages = gridViewResult.TotalPages;
            totalGridItems = gridViewResult.TotalCount;

            UpdatePagination();

            // Load other data



            // ✅ Load customers with null safety
            var customerResult = await CustomerService.GetCustomersPaginatedAsync(pageNumber: 1, pageSize: 10);
            _customers = customerResult?.Data ?? new List<Customer>(); // ✅ Null-safe

            _serviceStatuses = await RepairItemService.GetServiceStatusesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            // ✅ Initialize with empty collections on error
            filteredRepairServices = new List<RepairServices>();
            filteredRepairServices2 = new List<RepairServices>();
            _customers = new List<Customer>();
            PaginatedRepairServices = new List<RepairServices>();
        }

        // SignalR
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/itemHub"))
            .Build();

        hubConnection.On<string>("ReceiveItemUpdate", async (message) =>
        {
            await LoadPageData();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<Guid>("BroadcastItemDelete", async (deletedItemId) =>
        {
            await LoadPageData();
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }
