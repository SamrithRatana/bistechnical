    private async Task ShowReportPreview(RepairServices selectedRepairService)
    {
        try
        {
            _selectedRepairService = selectedRepairService;

            var report = new Report2();

            string repairByUser = GetUserNameById(selectedRepairService.thirdPartyRepairBy);
            string verifiedByUser = GetUserNameById(Guid.Parse("94b0772a-0588-4b37-b31d-51b1e0ea22e5"));

            string repairByPhone = await GetUserPhoneNumberByIdAsync(selectedRepairService.thirdPartyRepairBy);
            string verifiedByPhone = await GetUserPhoneNumberByIdAsync(Guid.Parse("94b0772a-0588-4b37-b31d-51b1e0ea22e5"));

            // ✅ FETCH spare part details using sparepartId from API
            if (_selectedRepairService.SparePartItems != null && _selectedRepairService.SparePartItems.Any())
            {
                foreach (var item in _selectedRepairService.SparePartItems)
                {
                    // Check if sparepartId exists and has a value
                    if (!item.SparePartId.HasValue || item.SparePartId.Value == Guid.Empty)
                    {
                        Console.WriteLine("⚠ Skipping spare part item with no SparePartId");
                        continue;
                    }

                    try
                    {
                        // Call API to get spare part details by ID
                        Console.WriteLine($"🔍 Fetching spare part from API: {item.SparePartId}");
                        var sparePartDetails = await SparePartService.GetSparePartByIdAsync(item.SparePartId.Value);

                        if (sparePartDetails != null)
                        {
                            // Populate the spare part item with data from API
                            item.ItemName = sparePartDetails.ItemName;
                            item.SerialNumber = sparePartDetails.SerialNumber;
                            item.UseFor = sparePartDetails.UseFor;

                            Console.WriteLine($"✅ Successfully fetched: {sparePartDetails.ItemName}");
                            Console.WriteLine($"   - Serial: {sparePartDetails.SerialNumber}");
                            Console.WriteLine($"   - UseFor: {sparePartDetails.UseFor}");
                        }
                        else
                        {
                            Console.WriteLine($"❌ Spare part not found for ID: {item.SparePartId}");
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"❌ Error fetching spare part {item.SparePartId}: {ex.Message}");
                    }
                }
            }

            // Pass parameters to the report
            report.SetParameters(
                _selectedRepairService,
                _selectedRepairService.ServiceLocation,
                _selectedRepairService.SparePartItems,
                _selectedRepairService.hasContract,
                repairByUser,
                verifiedByUser,
                repairByPhone,
                verifiedByPhone
            );

            // Hide parameters
            report.Parameters["Id"].Visible = false;
            report.Parameters["ReportNumber"].Visible = false;
            report.Parameters["CompanyName"].Visible = false;
            report.Parameters["ContactName"].Visible = false;
            report.Parameters["PhoneNumber"].Visible = false;
            report.Parameters["Address"].Visible = false;
            report.Parameters["ItemName"].Visible = false;
            report.Parameters["SerialNumber"].Visible = false;
            report.Parameters["CustomerRequest"].Visible = false;
            report.Parameters["inspection"].Visible = false;
            report.Parameters["Solution"].Visible = false;
            report.Parameters["CompanyServiceChecked"].Visible = false;
            report.Parameters["OnSiteChecked"].Visible = false;
            report.Parameters["HasContract"].Visible = false;
            report.Parameters["Datestart"].Visible = false;
            report.Parameters["Datefinish"].Visible = false;
            report.Parameters["RepairBy"].Visible = false;
            report.Parameters["VerifiedBy"].Visible = false;
            report.Parameters["RepairByPhone"].Visible = false;
            report.Parameters["VerifiedByPhone"].Visible = false;

            // Generate the report as a PDF byte array
            byte[] reportData;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportData = ms.ToArray();
            }

            // Create filename
            string sanitizedReportNo = selectedRepairService.reportNo?.Replace("/", "-").Replace("\\", "-") ?? "Report";
            string filename = $"ServiceReport_{sanitizedReportNo}_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";

            // Convert to base64 and pass to JavaScript
            string base64Data = Convert.ToBase64String(reportData);
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.printReport", base64Data, filename);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error generating report: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Report Error",
                Text = $"Failed to generate report: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

