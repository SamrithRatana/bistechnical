    private async Task LoadCurrentUserFromJwtAsync()
    {
        try
        {
            Console.WriteLine("📥 Loading current user from JWT...");

            // Get user ID from JWT token
            var userId = JwtSessionService.GetCurrentUserId();

            if (userId.HasValue && userId.Value != Guid.Empty)
            {
                currentUserId = userId.Value.ToString();

                // Get username from JWT token
