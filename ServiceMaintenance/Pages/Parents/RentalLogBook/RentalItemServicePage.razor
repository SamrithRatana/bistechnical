   private async Task SearchRentalItemsOptimized()
{
    if (string.IsNullOrWhiteSpace(searchItemNameOrSerial))
    {
        foundRentalItems.Clear();
        return;
    }

    try
    {
        isLoading = true;
        var searchTerm = searchItemNameOrSerial.Trim();

        // Avoid duplicate searches
        if (searchTerm == lastSearchTerm)
        {
            return;
        }
        lastSearchTerm = searchTerm;

        Console.WriteLine($"Searching for: '{searchTerm}'");
        Console.WriteLine($"Available rental items in cache: {allRentalItemDetails.Count}");

        // Debug: Log some serial numbers to see what we have
        foreach (var item in allRentalItemDetails.Take(5))
        {
            Console.WriteLine($"Sample item - Serial: '{item.SerialNumber}', Name: '{item.ItemName}'");
        }

        List<RentalItemDetailResponse> searchResults = new();

        // Try API search for exact serial number
        try
        {
            var serialResult = await RentalItemDetailService.GetRentalItemDetailBySerialNoAsync(searchTerm);
            if (serialResult != null)
            {
                searchResults.Add(serialResult);
                Console.WriteLine($"Found via API: {serialResult.SerialNumber}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API search failed: {ex.Message}");
        }

        // Search in cached data with flexible serial matching
        var cachedMatches = allRentalItemDetails.Where(item => 
            SerialNumberMatches(item.SerialNumber, searchTerm) ||
            (!string.IsNullOrWhiteSpace(item.ItemName) && 
             item.ItemName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrWhiteSpace(item.CustomerName) && 
             item.CustomerName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        ).ToList();

        Console.WriteLine($"Found {cachedMatches.Count} matches in cache");

        // Add cached results if not already present
        foreach (var match in cachedMatches)
        {
            if (!searchResults.Any(r => r.Id == match.Id))
            {
                searchResults.Add(match);
                Console.WriteLine($"Added from cache: Serial='{match.SerialNumber}', Name='{match.ItemName}'");
            }
        }

        // Convert to RentalItem objects for display
        foundRentalItems = searchResults.Select(detail => new RentalItem
        {
            Id = Guid.TryParse(detail.Id, out var id) ? id : Guid.Empty,
            ItemName = detail.ItemName,
            CustomerName = detail.CustomerName,
            SerialNumber = detail.SerialNumber,
            Condition = detail.Condition,
            Location = detail.Location,
            Duration = detail.Duration,
            CreatedBy = Guid.TryParse(detail.CreatedBy, out var createdBy) ? createdBy : Guid.Empty,
            CustomerId = Guid.TryParse(detail.CustomerId, out var customerId) ? customerId : Guid.Empty
        })
        .OrderByDescending(item =>
            // Highest priority: EXACT serial number matches
            SerialNumberMatches(item.SerialNumber, searchTerm)
        )
        .ToList();

        Console.WriteLine($"Final results: {foundRentalItems.Count} items");

    }
    catch (Exception ex)
    {
        Console.WriteLine($"Search error: {ex.Message}");
        errorMessage = $"Search failed: {ex.Message}";
        foundRentalItems.Clear();
    }
    finally
    {
        isLoading = false;
        isSearchingBySerial = false;
        StateHasChanged();
    }
}

    private bool SerialNumberMatches(string serialNumber, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(serialNumber) || string.IsNullOrWhiteSpace(searchTerm))
            return false;

        var cleanSerial = serialNumber.Trim();
        var cleanSearch = searchTerm.Trim();

        // 1. EXACT MATCH - Highest Priority
        if (cleanSerial.Equals(cleanSearch, StringComparison.OrdinalIgnoreCase))
        {
            Console.WriteLine($"Exact match: '{cleanSerial}' == '{cleanSearch}'");
            return true;
        }

        // 2. For NUMERIC searches (like "123"), be more precise
        bool isNumericSearch = cleanSearch.All(char.IsDigit);

        if (isNumericSearch)
        {
            // 2a. Check if serial number IS the search term (handles cases like "123" matching "123")
            if (cleanSerial == cleanSearch)
            {
                Console.WriteLine($"Direct numeric match: '{cleanSerial}' == '{cleanSearch}'");
                return true;
            }

            // 2b. Check if serial starts with the search term followed by non-digit
            // This handles cases like "123ABC" or "123 (something)" matching "123"
            if (cleanSerial.StartsWith(cleanSearch, StringComparison.OrdinalIgnoreCase))
            {
                var remaining = cleanSerial.Substring(cleanSearch.Length);
                // Only match if what follows is NOT another digit (to avoid partial matches like "123" matching "1234")
                if (remaining.Length == 0 || !char.IsDigit(remaining[0]))
                {
                    Console.WriteLine($"Numeric prefix match: '{cleanSerial}' starts with '{cleanSearch}' followed by non-digit");
                    return true;
                }
            }

            // 2c. Check content in parentheses/brackets for numeric searches
            var parenthesesContent = ExtractParenthesesContent(cleanSerial);
            if (!string.IsNullOrWhiteSpace(parenthesesContent))
            {
                // For numeric searches, check if the parentheses content equals or starts with the search term
                if (parenthesesContent.Equals(cleanSearch, StringComparison.OrdinalIgnoreCase) ||
                    (parenthesesContent.StartsWith(cleanSearch, StringComparison.OrdinalIgnoreCase) &&
                     (parenthesesContent.Length == cleanSearch.Length ||
                      !char.IsDigit(parenthesesContent[cleanSearch.Length]))))
                {
                    Console.WriteLine($"Numeric parentheses match: '{parenthesesContent}' matches '{cleanSearch}'");
                    return true;
                }
            }

            // 2d. For numeric searches, also check if it appears as a complete number anywhere in the serial
            // Use word boundary logic to find complete number matches
            if (IsCompleteNumberMatch(cleanSerial, cleanSearch))
            {
                Console.WriteLine($"Complete number match found: '{cleanSerial}' contains complete number '{cleanSearch}'");
                return true;
            }

            // For numeric searches, don't do general "contains" matching to avoid false positives
            return false;
        }

        // 3. For TEXT searches (non-numeric)
        if (cleanSerial.StartsWith(cleanSearch, StringComparison.OrdinalIgnoreCase))
        {
            Console.WriteLine($"Text prefix match: '{cleanSerial}' starts with '{cleanSearch}'");
            return true;
        }

        // 4. Search inside parentheses/brackets content for text searches
        var parenthesesContentText = ExtractParenthesesContent(cleanSerial);
        if (!string.IsNullOrWhiteSpace(parenthesesContentText) &&
            parenthesesContentText.Contains(cleanSearch, StringComparison.OrdinalIgnoreCase))
        {
            Console.WriteLine($"Text parentheses match: '{parenthesesContentText}' contains '{cleanSearch}'");
            return true;
        }

        // 5. General contains search for text (last resort)
        if (cleanSerial.Contains(cleanSearch, StringComparison.OrdinalIgnoreCase))
        {
            Console.WriteLine($"Text general contains match: '{cleanSerial}' contains '{cleanSearch}'");
            return true;
        }

        return false;
    }
    private bool IsCompleteNumberMatch(string text, string number)
    {
        if (string.IsNullOrWhiteSpace(text) || string.IsNullOrWhiteSpace(number))
            return false;

        // Find all occurrences of the number in the text
        int index = 0;
        while ((index = text.IndexOf(number, index, StringComparison.OrdinalIgnoreCase)) != -1)
        {
            // Check if this is a complete number (not part of a larger number)
            bool isCompleteMatch = true;

            // Check character before
            if (index > 0 && char.IsDigit(text[index - 1]))
            {
                isCompleteMatch = false;
            }

            // Check character after
            if (isCompleteMatch && (index + number.Length < text.Length) && char.IsDigit(text[index + number.Length]))
            {
                isCompleteMatch = false;
            }

            if (isCompleteMatch)
            {
                return true;
            }

            index++;
        }

        return false;
    }
    private string ExtractParenthesesContent(string serialNumber)
    {
        if (string.IsNullOrWhiteSpace(serialNumber))
            return string.Empty;

        // Extract content from parentheses like "(BTB)" or "(Noromall 4515)"
        var parenStart = serialNumber.IndexOf('(');
        var parenEnd = serialNumber.IndexOf(')', parenStart + 1);

        if (parenStart >= 0 && parenEnd > parenStart)
        {
            return serialNumber.Substring(parenStart + 1, parenEnd - parenStart - 1).Trim();
        }

        // Extract content from brackets like "[BTB]" or "[Noromall 4515]"
        var bracketStart = serialNumber.IndexOf('[');
        var bracketEnd = serialNumber.IndexOf(']', bracketStart + 1);

        if (bracketStart >= 0 && bracketEnd > bracketStart)
        {
            return serialNumber.Substring(bracketStart + 1, bracketEnd - bracketStart - 1).Trim();
        }

        return string.Empty;
    }


    private bool IsExactSerialNumber(string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm)) return false;

        var term = searchTerm.Trim();

        // Consider it a serial number if:
        // 1. It's all digits (like "123", "4513")
        // 2. It matches common serial patterns exactly
        return term.All(char.IsDigit) || // Pure numbers like "4513", "123"
               (term.Length >= 3 && term.All(c => char.IsLetterOrDigit(c) || c == '-' || c == '_')); // Alphanumeric serials
    }
    private bool IsExactMatch(RentalItemDetailResponse item, string searchTerm)
    {
        if (item == null || string.IsNullOrWhiteSpace(searchTerm)) return false;

        // Only exact matches - no partial matching
        return (!string.IsNullOrWhiteSpace(item.SerialNumber) &&
                item.SerialNumber.Equals(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
               (!string.IsNullOrWhiteSpace(item.ItemName) &&
                item.ItemName.Equals(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
               (!string.IsNullOrWhiteSpace(item.CustomerName) &&
                item.CustomerName.Equals(searchTerm, StringComparison.OrdinalIgnoreCase));
    }


    private bool IsLikelySerialNumber(string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm)) return false;

        var term = searchTerm.Trim();

        // Consider it a serial number if:
        // 1. It's all digits (like "123", "4513")
        // 2. It's all uppercase letters (like "CNDRQBK5KC")
        // 3. It's alphanumeric and looks like a serial pattern (mix of letters and numbers)
        // 4. It has common serial number patterns

        return term.All(char.IsDigit) || // Pure numbers like "4513"
               term.All(char.IsLetter) || // Pure letters like "CNDRQBK5KC"
               (term.All(c => char.IsLetterOrDigit(c) || c == '-' || c == '_') &&
                term.Length >= 3 &&
                (term.Any(char.IsDigit) || term.Any(char.IsLetter))); // Mixed alphanumeric
    }


    private bool ContainsSearchTerm(RentalItemDetailResponse item, string searchTerm)
    {
        if (item == null || string.IsNullOrWhiteSpace(searchTerm)) return false;

        // For serial number matching with flexible patterns
        if (!string.IsNullOrWhiteSpace(item.SerialNumber))
        {
            // Check exact match first
            if (item.SerialNumber.Equals(searchTerm, StringComparison.OrdinalIgnoreCase))
                return true;

            // Check if serial number starts with search term (for cases like "002016 (BTB)" matching "002016")
            if (item.SerialNumber.StartsWith(searchTerm, StringComparison.OrdinalIgnoreCase))
                return true;

            // Extract base serial number and compare
            var baseSerial = ExtractBaseSerialNumber(item.SerialNumber);
            if (!string.IsNullOrWhiteSpace(baseSerial) &&
                baseSerial.Equals(searchTerm, StringComparison.OrdinalIgnoreCase))
                return true;

            // If it's a numeric search, prioritize serial number matching
            if (searchTerm.All(char.IsDigit))
                return false; // For numeric searches, only match serial numbers as handled above
        }

        // For non-numeric searches or when no serial match, check other fields
        if (!searchTerm.All(char.IsDigit))
        {
            // Exact matches first
            if ((!string.IsNullOrWhiteSpace(item.ItemName) &&
                 item.ItemName.Equals(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(item.CustomerName) &&
                 item.CustomerName.Equals(searchTerm, StringComparison.OrdinalIgnoreCase)))
                return true;

            // Then partial matches for text searches only
            return (!string.IsNullOrWhiteSpace(item.ItemName) &&
                    item.ItemName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                   (!string.IsNullOrWhiteSpace(item.CustomerName) &&
                    item.CustomerName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        return false;
    }
