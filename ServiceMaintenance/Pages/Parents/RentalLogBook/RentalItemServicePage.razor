    // ENHANCED SEARCH METHODS - FIXED VERSION
    private void SearchRentalItemsSmart()
    {
        if (string.IsNullOrWhiteSpace(searchItemNameOrSerial))
        {
            foundRentalItems.Clear();
            return;
        }

        var searchTerm = searchItemNameOrSerial.Trim();
        bool isNumericSearch = searchTerm.All(char.IsDigit);

        foundRentalItems = allRentalItems.Where(item =>
        {
            // For serial numbers, use exact match for numbers, contains for text
            if (!string.IsNullOrWhiteSpace(item.SerialNumber))
            {
                if (isNumericSearch)
                {
                    return item.SerialNumber.Equals(searchTerm, StringComparison.OrdinalIgnoreCase);
                }
                else
                {
                    return item.SerialNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase);
                }
            }

            // For names, always use contains for flexibility
            return (!string.IsNullOrWhiteSpace(item.ItemName) &&
                    item.ItemName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                   (!string.IsNullOrWhiteSpace(item.CustomerName) &&
                    item.CustomerName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        })
        .OrderBy(item =>
            (!string.IsNullOrWhiteSpace(item.SerialNumber) &&
             item.SerialNumber.Equals(searchTerm, StringComparison.OrdinalIgnoreCase)) ? 0 : 1
        )
        .ToList();
    }

