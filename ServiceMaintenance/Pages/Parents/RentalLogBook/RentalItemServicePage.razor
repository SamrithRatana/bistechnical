    private async Task LoadServicesWithCache(bool forceRefresh = false)
    {
        if (isLoading && !forceRefresh) return;

        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            StateHasChanged();

            var stopwatch = System.Diagnostics.Stopwatch.StartNew();

            // Load both services and rental item details in parallel
            var servicesTask = RentalServicesService.GetRentalServicesAsync(forceRefresh);
            var detailsTask = forceRefresh ?
                RefreshRentalItemDetails(true) :
                Task.CompletedTask;

            await Task.WhenAll(servicesTask, detailsTask);

            var services = await servicesTask;
            stopwatch.Stop();

            allServices = services?.ToList() ?? new List<RentalServices>();

            // Apply filters if there's a search term
            if (!string.IsNullOrWhiteSpace(searchItemNameOrSerial))
            {
                await ApplyFilters();
            }
            else
            {
                filteredServices = new List<RentalServices>();
            }

            var loadMessage = isInitialLoad
                ? $"Loaded {allServices.Count} service records in {stopwatch.ElapsedMilliseconds}ms"
                : forceRefresh
                    ? $"Force-refreshed {allServices.Count} service records in {stopwatch.ElapsedMilliseconds}ms"
                    : $"Refreshed {allServices.Count} service records in {stopwatch.ElapsedMilliseconds}ms";

            successMessage = loadMessage;

            if (isInitialLoad)
            {
                isInitialLoad = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load service records: {ex.Message}";
            allServices = new List<RentalServices>();
            filteredServices = new List<RentalServices>();
            Console.WriteLine($"Error loading services: {ex}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnRentalItemFiltering(Syncfusion.Blazor.DropDowns.FilteringEventArgs args)
    {
        try
        {
            args.PreventDefaultAction = true;

            if (string.IsNullOrWhiteSpace(args.Text))
            {
                // Show all items when no filter text
                await rentalItemComboBox.FilterAsync(RentalItemOptions);
            }
            else
            {
                var searchTerm = args.Text.Trim().ToLower();

                var filteredItems = RentalItemOptions.Where(item =>
                    // Search in item name
                    (!string.IsNullOrWhiteSpace(item.ItemName) &&
                     item.ItemName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||

                    // Search in customer name
                    (!string.IsNullOrWhiteSpace(item.CustomerName) &&
                     item.CustomerName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||

                    // Search in serial number
                    (!string.IsNullOrWhiteSpace(item.SerialNumber) &&
                     item.SerialNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||

                    // Search in ID
                    item.Id.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                )
                .OrderBy(item =>
                {
                    // Prioritize exact matches in serial number
                    if (!string.IsNullOrWhiteSpace(item.SerialNumber) &&
                        item.SerialNumber.Equals(searchTerm, StringComparison.OrdinalIgnoreCase))
                        return 0;

                    // Then prioritize starts with matches in item name
                    if (!string.IsNullOrWhiteSpace(item.ItemName) &&
                        item.ItemName.StartsWith(searchTerm, StringComparison.OrdinalIgnoreCase))
                        return 1;

                    // Then customer name starts with
                    if (!string.IsNullOrWhiteSpace(item.CustomerName) &&
                        item.CustomerName.StartsWith(searchTerm, StringComparison.OrdinalIgnoreCase))
                        return 2;

                    // Everything else
                    return 3;
                })
                .ThenBy(item => item.ItemName)
                .ToList();

                await rentalItemComboBox.FilterAsync(filteredItems);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error filtering rental items: {ex.Message}");
        }
    }

