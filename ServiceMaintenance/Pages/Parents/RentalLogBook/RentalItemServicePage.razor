<script>
    window.downloadOrPrintReport = function(data, filename) {
        try {
            console.log('downloadOrPrintReport called with data length:', data.length);

            // Convert byte array to blob
            const blob = new Blob([new Uint8Array(data)], { type: 'application/pdf' });
            const url = URL.createObjectURL(blob);

            // Option 1: Download the file
            const link = document.createElement('a');
            link.href = url;
            link.download = filename || 'RentalReport.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            // Option 2: Open in new tab for printing (uncomment if preferred)
            // window.open(url, '_blank');

            // Clean up
            setTimeout(() => URL.revokeObjectURL(url), 1000);

            console.log('Report processed successfully');
            return true;
        } catch (error) {
            console.error('Error processing report:', error);
            return false;
        }
    };

    // Fallback function if the above doesn't work
    window.printReport = function(data) {
        return window.downloadOrPrintReport(data, 'RentalReport.pdf');
    };
</script>