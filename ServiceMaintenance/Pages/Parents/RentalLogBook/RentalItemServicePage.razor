                await Task.Delay(500);
            }

            successMessage = $"Generated {rentalItemIds.Count} rental reports successfully.";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating multiple reports: {ex.Message}");
            errorMessage = $"Failed to generate reports: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // Method for generating report with custom date range (if needed)
    private async Task PrintRentalReportWithDateRange(string rentalItemId, DateTime? startDate, DateTime? endDate)
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            // Get filtered services for this rental item within date range
            var query = allServices.Where(s => s.RentalItemId == rentalItemId);

            if (startDate.HasValue)
                query = query.Where(s => s.Date.Date >= startDate.Value.Date);

            if (endDate.HasValue)
                query = query.Where(s => s.Date.Date <= endDate.Value.Date);

            var servicesForItem = query.OrderBy(s => s.Date).ToList();

            if (!servicesForItem.Any())
            {
                errorMessage = $"No service records found for the specified date range.";
                return;
            }

            // Get rental item details
            var rentalItem = allRentalItems.FirstOrDefault(r => r.Id.ToString() == rentalItemId);

            if (rentalItem == null)
            {
                errorMessage = "Rental item not found.";
                return;
            }

            // Create and configure the report
            var report = new RentalReport();
            var sparePartMap = _spareParts.ToDictionary(sp => sp.Id, sp => sp.ItemName);

            report.SetRentalReportData(
                rentalItem,
                servicesForItem,
                currentUserDisplayName,
                UserMap,
                sparePartMap
            );

            // Generate and show the report
            byte[] reportDataBytes;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportDataBytes = ms.ToArray();
            }

            await JSRuntime.InvokeVoidAsync("printReport", reportDataBytes);

            successMessage = $"Report generated for {rentalItem.ItemName} ({startDate?.ToString("dd/MM/yyyy")} - {endDate?.ToString("dd/MM/yyyy")})";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating date-filtered rental report: {ex.Message}");
            errorMessage = $"Failed to generate report: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SetRentalReportParameters(RentalReport report, RentalItem rentalItem, List<RentalServices> services)
    {
        // Set equipment information parameters
        if (rentalItem != null)
        {
            report.Parameters["pType"].Value = GetItemTypeByItemName(rentalItem.ItemName);
            report.Parameters["pSerialNumber"].Value = rentalItem.SerialNumber ?? "N/A";
            report.Parameters["pItemName"].Value = rentalItem.ItemName ?? "N/A";
            report.Parameters["pCondition"].Value = rentalItem.Condition ?? "N/A";
            report.Parameters["pCompanyName"].Value = rentalItem.CustomerName ?? "N/A";
            report.Parameters["pDuration"].Value = rentalItem.Duration > 0 ?
                $"{rentalItem.Duration} month{(rentalItem.Duration != 1 ? "s" : "")}" : "N/A";
            report.Parameters["pAddress"].Value = rentalItem.Location ?? "N/A";
        }
        else
        {
            // Set default values if rental item not found
            report.Parameters["pType"].Value = "Unknown";
            report.Parameters["pSerialNumber"].Value = "N/A";
            report.Parameters["pItemName"].Value = "Unknown";
            report.Parameters["pCondition"].Value = "N/A";
            report.Parameters["pCompanyName"].Value = "Unknown";
            report.Parameters["pDuration"].Value = "N/A";
            report.Parameters["pAddress"].Value = "N/A";
        }

        // Set other parameters
        report.Parameters["pGeneratedDate"].Value = DateTime.Now.ToString("dd/MM/yyyy");
        report.Parameters["pUser"].Value = currentUserDisplayName;

        // Set data source
        var reportData = PrepareRentalReportData(services, rentalItem);
        report.DataSource = reportData;
    }
    private List<RentalReportData> PrepareRentalReportData(List<RentalServices> services, RentalItem rentalItem)
    {
        var reportData = new List<RentalReportData>();
        int rowNumber = 1;

        foreach (var service in services.OrderBy(s => s.Date))
        {
            var sparePartsText = string.Empty;
            if (service.SpareParts?.Any() == true)
            {
                sparePartsText = string.Join(", ", service.SpareParts.Select(sp =>
                    $"{GetSparePartName(sp.SparePartId)} x{sp.Quantity} ({sp.Condition})"));
            }

            reportData.Add(new RentalReportData
            {
                RowNumber = rowNumber,
                Date = service.Date.ToString("dd/MM/yyyy"),
                Action = service.Action,
                SparePart = sparePartsText,
                Note = service.Note ?? string.Empty,
                Technician = GetUserNameById(service.UserId)
            });

            rowNumber++;
        }

        return reportData;
    }

  

