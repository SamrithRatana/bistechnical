    private async Task PrintRentalReport(string rentalItemId)
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            Console.WriteLine($"PrintRentalReport called with ID: {rentalItemId}");

            // Get the rental item details first
            var rentalItemDetail = await GetRentalItemDetailByIdOptimized(rentalItemId);
            if (rentalItemDetail == null)
            {
                errorMessage = "Rental item details not found.";
                return;
            }

            // Get all services for this rental item from the current filtered/displayed data
            var servicesForItem = filteredServices
                .Where(s => s.RentalItemId == rentalItemId)
                .OrderBy(s => s.Date)
                .ToList();

            // If no services in filtered view, fall back to all services
            if (!servicesForItem.Any())
            {
                servicesForItem = allServices
                    .Where(s => s.RentalItemId == rentalItemId)
                    .OrderBy(s => s.Date)
                    .ToList();
            }

            Console.WriteLine($"Found {servicesForItem.Count} services for item {rentalItemId}");

            if (!servicesForItem.Any())
            {
                errorMessage = $"No service records found for rental item {rentalItemId}";
                return;
            }

            // Create the rental report
            var report = new RentalReport();

            // Create enhanced spare part mapping
            var sparePartMap = new Dictionary<Guid, string>();
            if (_spareParts?.Any() == true)
            {
                foreach (var sparePart in _spareParts)
                {
                    sparePartMap[sparePart.Id] = sparePart.ItemName ?? "Unknown Part";
                }
                Console.WriteLine($"Created spare part map with {sparePartMap.Count} items");
            }

            // Prepare service history with proper formatting using actual grid data
            var serviceHistory = PrepareRentalReportDataFromGridData(servicesForItem, sparePartMap);

            Console.WriteLine($"Prepared {serviceHistory.Count} service history records from grid data");

            // Use the rental item details from API
            report.SetParameters(
                rentalItemDetail.Id,
                GetItemTypeByRentalItemDetail(rentalItemDetail),
                rentalItemDetail.SerialNumber ?? "N/A",
                rentalItemDetail.ItemName ?? "N/A",
                rentalItemDetail.Condition ?? "N/A",
                rentalItemDetail.CustomerName ?? "N/A",
                rentalItemDetail.Duration >= 0 ? $"{rentalItemDetail.Duration} month{(rentalItemDetail.Duration != 1 ? "s" : "")}" : "N/A",
                rentalItemDetail.Location ?? "N/A",
                serviceHistory,
                currentUserDisplayName,
                DateTime.Now
            );

            // Validate the report setup
            report.ValidateReportSetup();

            // Generate and show the report
            byte[] reportDataBytes;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportDataBytes = ms.ToArray();
            }

            // Convert byte array to base64 string for JavaScript
            string base64Report = Convert.ToBase64String(reportDataBytes);

            var filename = $"RentalReport_{rentalItemDetail.CustomerName?.Replace(" ", "_")}_{rentalItemDetail.SerialNumber}_{DateTime.Now:yyyyMMdd}.pdf";

            // Use the existing blazorReportsPrint.printReport function
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.printReport", base64Report, filename);

            successMessage = $"Report generated for {rentalItemDetail.ItemName} - {rentalItemDetail.CustomerName}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating rental report: {ex}");
            errorMessage = $"Failed to generate report: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }


    private string GetItemTypeByRentalItemDetail(RentalItemDetailResponse rentalItemDetail)
    {
        if (rentalItemDetail?.ItemName == null) return "Unknown Type";

        var repair = allItems.FirstOrDefault(r =>
            r.ItemName.Equals(rentalItemDetail.ItemName, StringComparison.OrdinalIgnoreCase));
        return repair?.ItemType ?? "Equipment"; // Default to "Equipment" instead of "Unknown Type"
    }

    private List<RentalReportData> PrepareRentalReportDataFromGridData(List<RentalServices> services, Dictionary<Guid, string> sparePartMap)
    {
        var reportData = new List<RentalReportData>();
        int rowNumber = 1;

        foreach (var service in services.OrderBy(s => s.Date))
        {
            var sparePartsText = string.Empty;

            if (service.SpareParts?.Any() == true)
            {
                var formattedParts = new List<string>();

                foreach (var part in service.SpareParts)
                {
                    string partName = "Unknown Part";

                    // Try to get part name from spare part map
                    if (part.SparePartId.HasValue && sparePartMap.ContainsKey(part.SparePartId.Value))
                    {
                        partName = sparePartMap[part.SparePartId.Value];
                    }
                    else if (!string.IsNullOrWhiteSpace(part.Description))
                    {
                        // Use description if part name not found
                        partName = part.Description;
                    }

                    // Format exactly as shown in the grid: ItemName=Quantity(Condition)
                    var formattedPart = $"{partName}={part.Quantity}({part.Condition ?? "N/A"})";
                    formattedParts.Add(formattedPart);

                    Console.WriteLine($"Formatted spare part for report: {formattedPart}");
                }

                // Join multiple parts with line breaks for better PDF formatting
                sparePartsText = string.Join(Environment.NewLine, formattedParts);
            }

            var reportItem = new RentalReportData
            {
                RowNumber = rowNumber,
                Date = service.Date.ToString("dd/MM/yyyy"),
                Action = service.Action ?? "N/A",
                SparePart = sparePartsText,
                Note = service.Note ?? string.Empty,
                Technician = GetUserNameById(service.UserId)
            };

            reportData.Add(reportItem);
            Console.WriteLine($"Added report data row {rowNumber}: {reportItem.Date} - {reportItem.Action}");
            rowNumber++;
        }

        Console.WriteLine($"Total report data rows created: {reportData.Count}");
        return reportData;
    }
    private List<RentalReportData> PrepareRentalReportDataFromServices(List<RentalServices> services)
    {
        var reportData = new List<RentalReportData>();
        int rowNumber = 1;

        foreach (var service in services.OrderBy(s => s.Date))
        {
            var sparePartsText = string.Empty;
            if (service.SpareParts?.Any() == true)
            {
                sparePartsText = string.Join(", ", service.SpareParts.Select(sp =>
                {
                    var partName = GetSparePartName(sp.SparePartId);
                    return $"{partName} x{sp.Quantity} ({sp.Condition})";
                }));
            }

            reportData.Add(new RentalReportData
            {
                RowNumber = rowNumber,
                Date = service.Date.ToString("dd/MM/yyyy"),
                Action = service.Action ?? "N/A",
                SparePart = sparePartsText,
                Note = service.Note ?? string.Empty,
                Technician = GetUserNameById(service.UserId)
            });

            rowNumber++;
        }

        return reportData;
    }
