</SfDialog>

<!-- Delete Confirmation Dialog -->
<SfDialog @ref="DialogDelete" IsModal="true" Width="400px" ShowCloseIcon="true" Visible="false">
    <DialogTemplates>
        <Header>
            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
            Confirm Delete
        </Header>
        <Content>
            <div class="text-center">
                <p>Are you sure you want to delete this service record?</p>
                @if (currentService != null)
                {
                    <div class="alert alert-warning">
                        <strong>Item ID:</strong> @currentService.RentalItemId<br />
                        <small>Date: @currentService.Date.ToString("MMM dd, yyyy")</small>
                    </div>
                }
                <p class="text-muted">This action cannot be undone.</p>
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Delete" IsPrimary="true" CssClass="e-danger" OnClick="ConfirmDeleteYes" />
        <DialogButton Content="Cancel" OnClick="ConfirmDeleteNo" />
    </DialogButtons>
</SfDialog>

<SfDialog @ref="DialogEdit" IsModal="true" Width="800px" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogTemplates>
        <Header>
            <i class="fas fa-eye me-2"></i>
            Service Details
        </Header>
        <Content>
            @if (selectedViewService != null)
            {
                <div class="container-fluid">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-5">Rental Item ID:</dt>
                                <dd class="col-sm-7">
                                    <code>@selectedViewService.RentalItemId</code>
                                </dd>
                                <dt class="col-sm-5">Service Date:</dt>
                                <dd class="col-sm-7">
                                    <i class="fas fa-calendar text-muted me-1"></i>
                                    @selectedViewService.Date.ToString("MMM dd, yyyy hh:mm tt")
                                </dd>
                                <dt class="col-sm-5">Action:</dt>
                                <dd class="col-sm-7">
                                    <span>
                                        @selectedViewService.Action
                                    </span>
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-5">User:</dt>
                                <dd class="col-sm-7">
                                    <i class="fas fa-user text-muted me-1"></i>
                                    @GetUserNameById(selectedViewService.UserId)
                                </dd>
                                <dt class="col-sm-5">Note:</dt>
                                <dd class="col-sm-7">
                                    @if (!string.IsNullOrWhiteSpace(selectedViewService.Note))
                                    {
                                        @selectedViewService.Note
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No notes</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>

                    @if (selectedViewService.SpareParts?.Any() == true)
                    {
                        <hr class="my-4">
                        <h6><i class="fas fa-cog me-2"></i>Spare Parts Used (@selectedViewService.SpareParts.Count)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Image</th>
                                        <th>Description</th>
                                        <th>Serial Number</th>
                                        <th>Use For</th>
                                        <th>Quantity</th>
                                        <th>Condition</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var part in selectedViewService.SpareParts)
                                    {
                                        var partObj = _spareParts.FirstOrDefault(sp => sp.Id == part.SparePartId);
                                        <tr>
                                            <td>
                                                @if (partObj != null && !string.IsNullOrEmpty(partObj.PictureUrl))
                                                {
                                                    <img src="@partObj.PictureUrl" alt="Spare Part Image" style="width:40px;height:40px;border-radius:4px;" />
                                                }
                                                else
                                                {
                                                    <span class="text-muted fst-italic">No Image</span>
                                                }
                                            </td>
                                            <td>@part.Description</td>
                                            <td>@(partObj?.SerialNumber ?? "-")</td>
