@page "/rentalservice-optimized"
@page "/rentalservice/{rentalItemId}"
@inject RentalServicesService RentalServicesService
@inject RentalItemService RentalItemService
@inject RentalItemDetailService RentalItemDetailService
@inject ServiceSparePart SparePartService
@inject ItemService ItemService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ServiceMaintenance.Services.JWT.JwtSessionService JwtSessionService
@inject ServiceMaintenance.Services.JWT.GlobalUserService GlobalUserCacheService
@using ServiceMaintenance.Models
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Notifications
@using Syncfusion.Blazor.Popups


<DxToastProvider Name="Success"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />

<div class="container-fluid">
    @if (IsDetailView)
    {
        <!-- Individual Service Detail View -->
        <div class="row mb-3">
            <div class="col">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="/rentalservice-optimized" class="text-decoration-none">
                                <i class="fas fa-wrench me-1"></i>Rental Services
                            </a>
                        </li>
                        <li class="breadcrumb-item active">Service Details</li>
                    </ol>
                </nav>
            </div>
        </div>

        @if (selectedService != null)
        {
            <!-- Excel-style header for individual service -->
            <div class="excel-document">
                <!-- Header Section -->
                <div class="excel-header text-center">
                    <h3 class="khmer-title">ទិន្នន័យការជួសជុលម៉ាស៊ីនជួល</h3>
                    <h4 class="english-title">Rental Equipment History</h4>
                </div>

                <!-- Equipment Information Grid -->
                <div class="excel-info-grid">
                    <div class="info-row">
                        <div class="info-cell label">Type</div>
                        <div class="info-cell value">@GetItemTypeByItemName(GetItemName(selectedService.RentalItemId))</div>
                        <div class="info-cell label">Serial No</div>
                        <div class="info-cell value">@GetSerialNumber(selectedService.RentalItemId)</div>
                    </div>
                    <div class="info-row">
                        <div class="info-cell label">Item</div>
                        <div class="info-cell value">@GetItemName(selectedService.RentalItemId)</div>
                        <div class="info-cell label">Condition</div>
                        <div class="info-cell value">@GetCondition(selectedService.RentalItemId)</div>
                    </div>
                    <div class="info-row">
                        <div class="info-cell label">Customer</div>
                        <div class="info-cell value">@GetCustomerName(selectedService.RentalItemId)</div>
                        <div class="info-cell label">Lease Duration</div>
                        <div class="info-cell value">@GetLeaseDuration(selectedService.RentalItemId)</div>
                    </div>
                    <div class="info-row">
                        <div class="info-cell label">Location</div>
                        <div class="info-cell value full-width" colspan="3">@GetLocation(selectedService.RentalItemId)</div>
                    </div>
                </div>

                <!-- Service History Table -->
                <div class="excel-table-container">
                    <table class="excel-table">
                        <thead>
                            <tr>
                                <th class="col-no">No</th>
                                <th class="col-date">Date</th>
                                <th class="col-action">Action</th>
                                <th class="col-sparepart">Sparepart</th>
                                <th class="col-note">Note</th>
                                <th class="col-technician">Technician</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var allServicesForItem = allServices.Where(s => s.RentalItemId == selectedService.RentalItemId)
                                .OrderBy(s => s.Date)
                                .ToList();
                                int rowNumber = 1;
                            }
                            @foreach (var service in allServicesForItem)
                            {
                                <tr class="@(rowNumber % 2 == 0 ? "even-row" : "")">
                                    <td class="text-center">@rowNumber</td>
                                    <td>@service.Date.ToString("dd/MM/yyyy")</td>
                                    <td>@service.Action</td>
                                    <td>
                                        @if (service.SpareParts?.Any() == true)
                                        {
                                            @foreach (var part in service.SpareParts)
                                            {
                                                <div class="spare-part-item">
                                                    @GetSparePartName(part.SparePartId) = @part.Quantity (@part.Condition)
                                                </div>
                                            }
                                        }
                                    </td>
                                    <td>@service.Note</td>
                                    <td>@GetUserNameById(service.UserId)</td>
                                </tr>
                                rowNumber++;
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="() => EditService(selectedService)">
                        <i class="fas fa-edit me-1"></i>Edit
                    </button>
                    <button class="btn btn-outline-danger me-2" @onclick="() => ConfirmDelete(selectedService)">
                        <i class="fas fa-trash me-1"></i>Delete
                    </button>
                    <button class="btn btn-success me-2" @onclick="() => PrintRentalReport(selectedService.RentalItemId)">
                        <i class="fas fa-print me-1"></i>Print Report
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="GoBackToList">
                        <i class="fas fa-arrow-left me-1"></i>Back to List
                    </button>
                </div>
            </div>
        }
        else if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mb-0">Loading service details...</p>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Service record not found or failed to load.
                <button class="btn btn-sm btn-outline-warning ms-2" @onclick="GoBackToList">
                    <i class="fas fa-arrow-left me-1"></i>Back to List
                </button>
            </div>
        }
    }
    else
    {
        <!-- List View Header -->
        <div class="excel-header-section mb-4">
            <div class="text-center mb-3">
                <h3 class="text-primary fw-bold khmer-title">ទិន្នន័យការជួសជុលម៉ាស៊ីនជួល</h3>
                <h4 class="text-dark english-title">Rental Equipment Service Management</h4>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="card shadow-sm rounded-lg mb-3">
            <div class="card-body py-2">
                <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" Click="NewService_Click" IconCssClass="far fa-file" CssClass="toolbar-item" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" Click="EditService_Click" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="@(!string.IsNullOrEmpty(selectedServiceId))" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" Click="DeleteService_Click" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="@(!string.IsNullOrEmpty(selectedServiceId))" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                        <Items>
                            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ExportToPdf" IconCssClass="fas fa-file-pdf" />
                        </Items>
                    </DxToolbarItem>
                    <DxToolbarItem Text="Print Report" Click="PrintRentalReportFromToolbar" CssClass="toolbar-item" IconCssClass="fas fa-print" Enabled="@(!string.IsNullOrEmpty(selectedServiceId))" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" Click="Check_Click" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" Enabled="@(!string.IsNullOrEmpty(selectedServiceId))" />
                </DxToolbar>
            </div>
        </div>

        <!-- Enhanced Filter Section -->
        <!-- Enhanced Filter Section -->
        <div class="card shadow-sm mb-3">
            <div class="card-body py-3">
                <div class="row g-3 align-items-end">

                    <!-- Enhanced Item Search with Serial Number Detection -->
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">
                            <i class="fas fa-search me-1"></i>
                            Smart Search (Name/Serial/Customer)
                            <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <SfTextBox @bind-Value="searchItemNameOrSerial"
                                       Placeholder="Enter item name, serial number, or customer"
                                       ShowClearButton="true"
                                       CssClass="form-control-sm"
                                       @oninput="OnSearchInputChanged">
                            </SfTextBox>
                            @if (isSearchingBySerial)
                            {
                                <span class="input-group-text bg-info text-white">
                                    <i class="fas fa-barcode"></i>
                                </span>
                            }
                        </div>
                        <small class="text-info">
                            <i class="fas fa-lightbulb me-1"></i>
                            @if (isSearchingBySerial)
                            {
                                <span class="text-success">Serial number detected - using optimized search</span>
                            }
                            else if (!string.IsNullOrWhiteSpace(searchItemNameOrSerial))
                            {
                                <span>Searching by name/customer - using smart filters</span>
                            }
                            else
                            {
                                <span>Services will only show after entering search criteria</span>
                            }
                        </small>
                    </div>

                    <!-- Action Filter -->
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">
                            <i class="fas fa-filter me-1"></i>Action Filter
                        </label>
                        <select class="form-select form-select-sm"
                                value="@selectedAction"
                                @onchange="OnActionFilterChanged">
                            <option value="">All Actions</option>
                            <option value="PreCheck">PreCheck</option>
                            <option value="Install">Install</option>
                            <option value="Check">Check</option>
                            <option value="Repair">Repair</option>
                        </select>
                    </div>

                    <!-- Enhanced Start Date with Optimization Indicator -->
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">
                            <i class="fas fa-calendar-alt me-1"></i>
                            Start Date
                            @if (filterStartDate.HasValue)
                            {
                                <small class="text-success">(Optimized)</small>
                            }
                        </label>
                        <SfDatePicker TValue="DateTime?" @bind-Value="filterStartDate"
                                      Placeholder="Select start date"
                                      Format="dd/MM/yyyy"
                                      ShowClearButton="true"
                                      CssClass="form-control-sm">
                        </SfDatePicker>
                    </div>

                    <!-- Enhanced End Date with Optimization Indicator -->
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">
                            <i class="fas fa-calendar-check me-1"></i>
                            End Date
                            @if (filterEndDate.HasValue)
                            {
                                <small class="text-success">(Optimized)</small>
                            }
                        </label>
                        <SfDatePicker TValue="DateTime?" @bind-Value="filterEndDate"
                                      Placeholder="Select end date"
                                      Format="dd/MM/yyyy"
                                      ShowClearButton="true"
                                      CssClass="form-control-sm">
                        </SfDatePicker>                    
                    </div>

                    <!-- Technician Filter -->
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">
                            <i class="fas fa-user-cog me-1"></i>
                            Technician
                        </label>
                        <select class="form-select form-select-sm"
                                value="@selectedUserId"
                                @onchange="OnUserFilterChanged">
                            <option value="">All Users</option>
                            @foreach (var user in UserMap)
                            {
                                <option value="@user.Key">@user.Value</option>
                            }
                        </select>
                    </div>

                    <!-- Enhanced Action Buttons -->
                    <div class="col-md-1">
                        <div class="btn-group-vertical w-100">
                            <button class="btn btn-primary btn-sm mb-1"
                                    @onclick="ApplyFilters"
                                    disabled="@isLoading"
                                    title="Apply Smart Filters">
                                @if (isLoading)
                                {
                                    <i class="fas fa-spinner fa-spin"></i>
                                }
                                else if (isSearchingBySerial)
                                {
                                    <i class="fas fa-barcode"></i>
                                }
                                else
                                {
                                    <i class="fas fa-search"></i>
                                }
                            </button>
                            <button class="btn btn-outline-secondary btn-sm"
                                    @onclick="ClearAllFilters"
                                    title="Clear All Filters">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Enhanced Control Row with API Optimization Info -->
                <div class="row mt-3">
                    <div class="col-md-8">
                        <div class="btn-group">
                            <button class="btn btn-outline-primary btn-sm me-2"
                                    @onclick="() => LoadServicesWithCache(false)"
                                    disabled="@isLoading">
                                <i class="fas fa-sync-alt @(isLoading ? "fa-spin" : "")"></i>
                                @(isLoading ? "Loading..." : "Refresh Data")
                            </button>
                            <button class="btn btn-outline-secondary btn-sm me-2"
                                    @onclick="() => LoadServicesWithCache(true)"
                                    disabled="@isLoading"
                                    title="Force Refresh All Data">
                                <i class="fas fa-redo"></i>
                                Force Refresh
                            </button>
                            <button class="btn btn-outline-info btn-sm"
                                    @onclick="() => RefreshRentalItemDetails(true)"
                                    disabled="@isLoading"
                                    title="Refresh Rental Items from API">
                                <i class="fas fa-database @(isLoading ? "fa-spin" : "")"></i>
                                Refresh Items
                            </button>
                        </div>
                    </div>
                    <div class="col-md-4 text-end">
                        <small class="text-muted">
                            @if (allRentalItemDetails.Any())
                            {
                                <i class="fas fa-check-circle text-success me-1"></i>
                                <span>@allRentalItemDetails.Count items cached</span>
                            }
                            else
                            {
                                <i class="fas fa-exclamation-circle text-warning me-1"></i>
                                <span>No item cache</span>
                            }
                            @if (filterStartDate.HasValue || filterEndDate.HasValue)
                            {
                                <span class="badge bg-success ms-2">API Optimized</span>
                            }
                        </small>
                    </div>
                </div>

                <!-- Search Status and Performance Info -->
                @if (!string.IsNullOrWhiteSpace(searchItemNameOrSerial))
                {
                    <div class="row mt-2">
                        <div class="col-12">
                            <div class="alert alert-info py-2 mb-0">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <small>
                                            <i class="fas fa-info-circle me-1"></i>
                                            <strong>Search Strategy:</strong>
                                            @if (isSearchingBySerial)
                                            {
                                                <span class="text-success">
                                                    Serial Number API (/api/rentalitemdetail/{serialNo})
                                                </span>
                                            }
                                            else if (filterStartDate.HasValue || filterEndDate.HasValue)
                                            {
                                                <span class="text-primary">
                                                    Date-Filtered API (/api/rentalitemdetail?fromDate=...&toDate=...)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-secondary">
                                                    In-Memory Cache Search
                                                </span>
                                            }
                                        </small>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <small class="text-muted">
                                            Found: @foundRentalItems.Count items,
                                            @filteredServices.Count services
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>


        <!-- UPDATED Item Details Display Section - Without Card Background -->
        <div class="mb-3">
            <div class="section-header @(string.IsNullOrEmpty(searchItemNameOrSerial) ? "bg-secondary" : foundRentalItems.Any() ? "bg-info" : "bg-warning") text-white">
                <h6 class="mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    @if (string.IsNullOrEmpty(searchItemNameOrSerial))
                    {
                        <span>Rental Item Information (No search performed)</span>
                    }
                    else if (foundRentalItems.Any())
                    {
                        <span>Found Rental Items (@foundRentalItems.Count)</span>
                    }
                    else
                    {
                        <span>No items found for "@searchItemNameOrSerial"</span>
                    }
                </h6>
            </div>
            <div class="section-content">
                @if (string.IsNullOrEmpty(searchItemNameOrSerial))
                {
                    <!-- Show default template when no search is performed -->
                    <div class="rental-item-info-flat mb-3">
                        <div class="row">
                            <!-- Left Side - Item Info with null values -->
                            <div class="col-md-6">
                                <div class="info-section">
                                    <!-- Always show Item Name label -->
                                    <div class="info-item">
                                        <span class="info-label">Item Name:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>

                                    <!-- Always show Customer Name label -->
                                    <div class="info-item">
                                        <span class="info-label">Customer Name:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>

                                    <!-- Always show Location label -->
                                    <div class="info-item">
                                        <span class="info-label">Location:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Right Side - Technical Info with null values -->
                            <div class="col-md-6">
                                <div class="info-section">
                                    <!-- Always show Serial Number label -->
                                    <div class="info-item">
                                        <span class="info-label">Serial Number:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>

                                    <!-- Always show Condition label -->
                                    <div class="info-item">
                                        <span class="info-label">Condition:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>

                                    <!-- Always show Duration label -->
                                    <div class="info-item">
                                        <span class="info-label">Duration:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Instruction message -->
                        <div class="mt-3 text-center">
                            <small class="text-muted">
                                <i class="fas fa-search me-1"></i>
                                Start typing in the search box above to find rental items
                            </small>
                        </div>
                    </div>
                }
                else if (foundRentalItems.Any())
                {
                    <!-- Show actual found items -->
                    @foreach (var item in foundRentalItems)
                    {
                        <div class="rental-item-info-flat mb-3">
                            <div class="row">
                                <!-- Left Side - Item Info -->
                                <div class="col-md-6">
                                    <div class="info-section">
                                        <!-- Always show Item Name label -->
                                        <div class="info-item">
                                            <span class="info-label">Item Name:</span>
                                            <span class="info-value @(!string.IsNullOrWhiteSpace(item.ItemName) ? "fw-bold text-primary" : "text-muted fst-italic")">
                                                @(!string.IsNullOrWhiteSpace(item.ItemName) ? item.ItemName : "null")
                                            </span>
                                        </div>

                                        <!-- Always show Customer Name label -->
                                        <div class="info-item">
                                            <span class="info-label">Customer Name:</span>
                                            <span class="info-value @(!string.IsNullOrWhiteSpace(item.CustomerName) ? "" : "text-muted fst-italic")">
                                                @(!string.IsNullOrWhiteSpace(item.CustomerName) ? item.CustomerName : "null")
                                            </span>
                                        </div>

                                        <!-- Always show Location label -->
                                        <div class="info-item">
                                            <span class="info-label">Location:</span>
                                            <span class="info-value @(!string.IsNullOrWhiteSpace(item.Location) ? "" : "text-muted fst-italic")">
                                                @(!string.IsNullOrWhiteSpace(item.Location) ? item.Location : "null")
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Right Side - Technical Info -->
                                <div class="col-md-6">
                                    <div class="info-section">
                                        <!-- Always show Serial Number label -->
                                        <div class="info-item">
                                            <span class="info-label">Serial Number:</span>
                                            <span class="info-value @(!string.IsNullOrWhiteSpace(item.SerialNumber) ? "fw-bold text-success" : "text-muted fst-italic")">
                                                @(!string.IsNullOrWhiteSpace(item.SerialNumber) ? item.SerialNumber : "null")
                                            </span>
                                        </div>

                                        <!-- Always show Condition label -->
                                        <div class="info-item">
                                            <span class="info-label">Condition:</span>
                                            <span class="info-value">
                                                @if (!string.IsNullOrWhiteSpace(item.Condition))
                                                {
                                                    <span>@item.Condition</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted fst-italic">null</span>
                                                }
                                            </span>
                                        </div>
                                        <!-- Always show Duration label -->
                                      <div class="info-item">
                                            <span class="info-label">Duration:</span>
                                            <span class="info-value @(item.Duration >= 0 ? "" : "text-muted fst-italic")">
                                                @(item.Duration >= 0 ? $"{item.Duration} month{(item.Duration != 1 ? "s" : "")}" : "null")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- View Services Button -->
                            <div class="mt-3 text-end">
                                <button class="btn btn-outline-primary btn-sm me-2" @onclick="() => ViewServicesForItem(item.Id.ToString())">
                                    <i class="fas fa-eye me-1"></i>View Services
                                </button>
                                <button class="btn btn-success btn-sm" @onclick="() => PrintRentalReportFromFoundItem(item)" disabled="@isLoading">
                                    @if (isLoading)
                                    {
                                        <i class="fas fa-spinner fa-spin me-1"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-print me-1"></i>
                                    }
                                    Print Report
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <!-- Show template when search returns no results -->
                    <div class="rental-item-info-flat mb-3">
                        <div class="row">
                            <!-- Left Side - Item Info with null values -->
                            <div class="col-md-6">
                                <div class="info-section">
                                    <!-- Always show Item Name label -->
                                    <div class="info-item">
                                        <span class="info-label">Item Name:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>

                                    <!-- Always show Customer Name label -->
                                    <div class="info-item">
                                        <span class="info-label">Customer Name:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>

                                    <!-- Always show Location label -->
                                    <div class="info-item">
                                        <span class="info-label">Location:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Right Side - Technical Info with null values -->
                            <div class="col-md-6">
                                <div class="info-section">
                                    <!-- Always show Serial Number label -->
                                    <div class="info-item">
                                        <span class="info-label">Serial Number:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>

                                    <!-- Always show Condition label -->
                                    <div class="info-item">
                                        <span class="info-label">Condition:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>

                                    <!-- Always show Duration label -->
                                    <div class="info-item">
                                        <span class="info-label">Duration:</span>
                                        <span class="info-value text-muted fst-italic">null</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Clear Search Button -->
                        <div class="mt-3 text-end">
                            <button class="btn btn-outline-warning btn-sm" @onclick="ClearSearchInput">
                                <i class="fas fa-times me-1"></i>Clear Search
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>



        <!-- Data Grid -->
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <div class="row align-items-center">
                    <div class="col">
                        <h5 class="card-title mb-0">Rental Services</h5>
                    </div>
                    <div class="col-auto">
                        <small class="text-muted">
                            @if (!string.IsNullOrWhiteSpace(searchItemNameOrSerial))
                            {
                                if (filteredServices?.Any() == true)
                                {
                                    <span>
                                        Found @filteredServices.Count() service record@(filteredServices.Count() != 1 ? "s" : "")
                                        for "@searchItemNameOrSerial"
                                    </span>
                                }
                                else
                                {
                                    <span>No services found for "@searchItemNameOrSerial"</span>
                                }
                            }
                            else
                            {
                                <span>Enter search term to view services</span>
                            }
                        </small>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>

                        <p class="text-muted mb-0">
                            @if (isInitialLoad)
                            {
                                <span>Loading rental services...</span>
                            }
                            else
                            {
                                <span>Refreshing data...</span>
                            }
                        </p>
                    </div>
                }
                else if (filteredServices == null || !filteredServices.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-search fa-3x text-muted mb-3"></i>

                        @if (string.IsNullOrWhiteSpace(searchItemNameOrSerial))
                        {
                            <h5 class="text-muted">Ready to search</h5>
                            <p class="text-muted">
                                Start typing in the search box to find rental items and their service records.
                            </p>
                        }
                    </div>
                }
                else
                {
                    <div class="excel-grid-container">
                        <SfGrid DataSource="@filteredServices"
                                AllowPaging="true"
                                AllowSorting="true"
                                AllowSearching="true"
                                Height="600"
                                Toolbar="@(new List<string>() { "Search" })"
                                @ref="Grid"
                                CssClass="excel-style-grid">
                            <GridPageSettings PageSize="@pageSize"
                                              PageCount="5"
                                              PageSizes="new int[] { 25, 50, 100, 200 }"></GridPageSettings>
                            <GridSearchSettings Fields="@(new string[] { "RentalItemId", "Action", "Note", "UserId" })"
                                                IgnoreCase="true"
                                                Key="@searchKey"
                                                Operator="Syncfusion.Blazor.Operator.Contains"></GridSearchSettings>
                            <GridEvents RowSelected="RowSelectHandler" TValue="RentalServices" />
                            <GridColumns>
                                <GridColumn Field=@nameof(RentalServices.RentalItemId)
                                            HeaderText="RENTAL ITEM ID"
                                            Width="200"
                                            AllowSorting="true"
                                            AllowFiltering="true"
                                            TextAlign="Syncfusion.Blazor.Grids.TextAlign.Left">
                                    <Template>
                                        @{
                                            var service = context as RentalServices;
                                        }
                                        <div class="excel-cell">
                                            <code class="rental-id">@service.RentalItemId</code>
                                        </div>
                                    </Template>
                                </GridColumn>
                                <GridColumn Field=@nameof(RentalServices.Date)
                                            HeaderText="SERVICE DATE"
                                            Width="120"
                                            AllowSorting="true"
                                            AllowFiltering="true"
                                            Type="ColumnType.Date"
                                            TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                    <Template>
                                        @{
                                            var service = context as RentalServices;
                                        }
                                        <div class="excel-cell">
                                            <i class="fas fa-calendar text-muted me-1"></i>
                                            @service.Date.ToString("dd/MM/yyyy")
                                        </div>
                                    </Template>
                                </GridColumn>
                                <GridColumn Field=@nameof(RentalServices.Action)
                                            HeaderText="ACTION"
                                            Width="100"
                                            AllowFiltering="true"
                                            AllowSorting="true"
                                            TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                    <Template>
                                        @{
                                            var service = context as RentalServices;
                                        }
                                        <span>
                                            @service.Action
                                        </span>
                                    </Template>
                                </GridColumn>
                                <GridColumn HeaderText="SPARE PARTS"
                                            Width="100"
                                            AllowFiltering="false"
                                            AllowSorting="false"
                                            TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                    <Template>
                                        @{
                                            var service = context as RentalServices;
                                            var partCount = service.SpareParts?.Count ?? 0;
                                        }
                                        @if (partCount > 0)
                                        {
                                            <span>
                                                @partCount
                                            </span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </Template>
                                </GridColumn>
                                <GridColumn Field=@nameof(RentalServices.Note)
                                            HeaderText="NOTE"
                                            Width="250"
                                            AllowFiltering="true">
                                    <Template>
                                        @{
                                            var service = context as RentalServices;
                                        }
                                        <div class="excel-cell text-truncate" title="@service.Note">
                                            @if (!string.IsNullOrWhiteSpace(service.Note))
                                            {
                                                @service.Note
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">-</span>
                                            }
                                        </div>
                                    </Template>
                                </GridColumn>
                                <GridColumn Field=@nameof(RentalServices.UserId)
                                            HeaderText="USER"
                                            Width="150"
                                            AllowFiltering="true">
                                    <Template>
                                        @{
                                            var service = context as RentalServices;
                                        }
                                        <div class="excel-cell">
                                            <i class="fas fa-user text-muted me-1"></i>
                                            @GetUserNameById(service.UserId)
                                        </div>
                                    </Template>
                                </GridColumn>
                                <GridColumn HeaderText="ACTIONS" Width="120" AllowFiltering="false" AllowSorting="false">
                                    <Template>
                                        @{
                                            var service = context as RentalServices;
                                        }
                                        <button type="button" class="btn btn-outline-primary btn-sm"
                                                @onclick="() => ViewService2(service)"
                                                title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </Template>
                                </GridColumn>
                            </GridColumns>
                        </SfGrid>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- All dialogs and forms remain the same... -->
<SfDialog IsModal="true" Width="900px" ShowCloseIcon="true" Visible="@isAddDialogVisible">
    <DialogTemplates>
        <Header>
            <div class="dialog-header">
                <i class="fas @(string.IsNullOrEmpty(currentService.RentalItemId) ? "fa-plus" : "fa-edit") me-2"></i>
                <h4 class="mb-0">@pageTitle</h4>
            </div>
        </Header>
    </DialogTemplates>
    <EditForm Model="@currentService" OnValidSubmit="SaveService">
        <DataAnnotationsValidator />
        <!-- Form content remains the same... -->
        <div class="container-fluid">
            <!-- First Row: Rental Item ID and Date -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <SfComboBox @ref="rentalItemComboBox"
                                    @onclick="OnRentalItemComboBoxClick"
                                    TValue="string"
                                    TItem="RentalItemOption"
                                    Placeholder="Search by Name, Customer, or Serial Number"
                                    FloatLabelType="FloatLabelType.Always"
                                    FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                    AllowFiltering="true"
                                    AllowCustom="false"
                                    @bind-Value="currentService.RentalItemId"
                                    DataSource="@RentalItemOptions"
                                    Width="100%"
                                    PopupHeight="250px"
                                    PopupWidth="100%">

                            <ComboBoxFieldSettings Value="Id" Text="SearchableText"></ComboBoxFieldSettings>

                            <ComboBoxTemplates TItem="RentalItemOption">
                                <ItemTemplate Context="item">
                                    <!-- Reduced padding and more compact layout -->
                                    <div class="dropdown-item-template-compact" style="padding: 6px 8px; border-bottom: 1px solid #eee;">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="item-details-compact">
                                                <div class="fw-bold text-primary mb-1 small">@item.ItemName</div>
                                                <div class="text-muted" style="font-size: 0.75rem;">
                                                    <i class="fas fa-user me-1"></i>@item.CustomerName
                                                    <span class="ms-2">
                                                        <i class="fas fa-barcode me-1"></i>@item.SerialNumber
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </ItemTemplate>

                                <NoRecordsTemplate>
                                    <div class="text-center py-2 text-muted small">
                                        <i class="fas fa-search me-1"></i>
                                        No matching rental items found.
                                    </div>
                                </NoRecordsTemplate>
                            </ComboBoxTemplates>

                            <ComboBoxEvents TValue="string" TItem="RentalItemOption"
                                            Filtering="OnRentalItemFiltering"
                                            ValueChange="OnRentalItemValueChanged">
                            </ComboBoxEvents>
                        </SfComboBox>

                        <ValidationMessage For="@(() => currentService.RentalItemId)" class="text-danger small" />

                        @if (!string.IsNullOrEmpty(rentalItemIdErrorMessage))
                        {
                            <div class="text-danger small">
                                @rentalItemIdErrorMessage
                            </div>
                        }

                        <!-- Optional: Show search hint -->
                        <small class="text-info">
                            <i class="fas fa-lightbulb me-1"></i>
                            Search by item name, customer name, or serial number
                        </small>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <SfDateTimePicker @bind-Value="currentService.Date"
                                          Placeholder="Service Date & Time"
                                          FloatLabelType="FloatLabelType.Always"
                                          Format="MMM dd, yyyy hh:mm tt">
                        </SfDateTimePicker>
                        <ValidationMessage For="@(() => currentService.Date)" class="text-danger small" />
                    </div>
                </div>
            </div>

            <!-- Second Row: Action and Current User Display -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <SfComboBox @ref="actionComboBox"
                                    @onclick="OnActionComboBoxClick"
                                    TValue="string"
                                    TItem="ActionOption"
                                    Placeholder="Action Type"
                                    FloatLabelType="FloatLabelType.Always"
                                    @bind-Value="currentService.Action"
                                    DataSource="@ActionOptions"
                                    Width="100%">
                            <ComboBoxFieldSettings Value="Value" Text="Text"></ComboBoxFieldSettings>
                        </SfComboBox>
                        <ValidationMessage For="@(() => currentService.Action)" class="text-danger small" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <div class="form-floating">
                            <input type="text"
                                   class="form-control bg-light"
                                   value="@currentUserDisplayName"
                                   readonly
                                   placeholder="Current User"
                                   id="currentUserDisplay" />
                            <label for="currentUserDisplay">
                                <i class="fas fa-user me-1"></i>Current User
                            </label>
                        </div>
                        <small class="form-text text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            Automatically set to your user account
                        </small>
                    </div>
                </div>
            </div>

            <!-- Third Row: Note -->
            <div class="row mb-3">
                <div class="col-12">
                    <div class="form-group">
                        <SfTextBox @bind-Value="currentService.Note"
                                   Placeholder="Service Notes (Optional)"
                                   FloatLabelType="FloatLabelType.Always"
                                   Multiline="true"
                                   RowsCount="3">
                        </SfTextBox>
                        <ValidationMessage For="@(() => currentService.Note)" class="text-danger small" />
                    </div>
                </div>
            </div>

            <!-- Spare Parts Section -->
          <!-- Spare Parts Section - FIXED VERSION -->
<div class="row mb-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">
                        <i class="fas fa-cog me-2"></i>Spare Parts Used
                    </h6>
                    <button type="button"
                            class="btn btn-sm btn-outline-primary"
                            @onclick="AddSparePart">
                        <i class="fas fa-plus me-1"></i>Add Part
                    </button>
                </div>
            </div>
            <div class="card-body">
                @if (currentService.SpareParts?.Any() == true)
                {
                    <!-- REMOVED table-responsive wrapper that was causing scrollbars -->
                    <table class="table table-sm table-bordered spare-parts-table">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 35%; min-width: 280px;">Spare Part</th>
                                <th style="width: 25%; min-width: 180px;">Description</th>
                                <th style="width: 15%; min-width: 120px;">Quantity</th>
                                <th style="width: 15%; min-width: 130px;">Condition</th>
                                <th style="width: 10%; min-width: 80px; text-align: center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < currentService.SpareParts.Count; i++)
                            {
                                var index = i; // Capture for lambda
                                var currentPart = currentService.SpareParts[index];

                                <tr>
                                    <td style="vertical-align: middle; padding: 8px;">
                                        <SfComboBox TValue="Guid?"
                                                    TItem="SparePartObject"
                                                    Placeholder="Select Spare Part"
                                                    @bind-Value="currentPart.SparePartId"
                                                    DataSource="@filteredSpareParts"
                                                    AllowFiltering="true"
                                                    AllowCustom="false"
                                                    FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                                    PopupWidth="450px"
                                                    PopupHeight="250px"
                                                    Width="100%"
                                                    @onclick="@(() => OnComboBoxClick(index))"
                                                    Enabled="@(!isSaving)">

                                            <ComboBoxEvents Filtering="OnFilteringSparePart"
                                                            ValueChange="@((args) => OnSparePartValueChanged(args, index))"
                                                            TValue="Guid?"
                                                            TItem="SparePartObject">
                                            </ComboBoxEvents>

                                            <ComboBoxFieldSettings Value="Id"
                                                                   Text="ItemName">
                                            </ComboBoxFieldSettings>

                                            <ComboBoxTemplates TItem="SparePartObject">
                                                <ItemTemplate Context="sparePartTemplate">
                                                    <div style="display: flex; align-items: center; padding: 8px; min-height: 60px; width: 100%;">
                                                        <img src="@sparePartTemplate.PictureUrl"
                                                             alt="@sparePartTemplate.ItemName"
                                                             style="width: 50px; height: 50px; border-radius: 4px; object-fit: cover; margin-right: 12px; flex-shrink: 0;"
                                                             onerror="this.src='data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNTAiIGhlaWdodD0iNTAiIHZpZXdCb3g9IjAgMCA1MCA1MCIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj4KPHJlY3Qgd2lkdGg9IjUwIiBoZWlnaHQ9IjUwIiBmaWxsPSIjRjVGNUY1Ii8+CjxwYXRoIGQ9Ik0xNSAxNUgzNUgzNUgxNVYxNVoiIGZpbGw9IiNEREREREQiLz4KPC9zdmc+Cg=='" />
                                                        <div style="flex-grow: 1; min-width: 0; margin-right: 8px;">
                                                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2px;">
                                                                <strong style="font-size: 12px; color: #333; font-weight: 600; line-height: 1.2;">
                                                                    @sparePartTemplate.ItemName
                                                                </strong>
                                                                <strong style="font-size: 9px; color: #666; font-weight: 600; margin-left: 8px;">
                                                                    @sparePartTemplate.SerialNumber
                                                                </strong>
                                                            </div>
                                                            <div style="font-size: 11px; color: #666; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                                Description: @sparePartTemplate.Description
                                                                <span style="margin: 0 4px;">|</span>
                                                                Use For: @sparePartTemplate.UseFor
                                                            </div>
                                                        </div>
                                                        <button type="button"
                                                                class="btn btn-link p-1"
                                                                style="flex-shrink: 0; border: none; background: none;"
                                                                @onclick="() => ShowFullDetails(sparePartTemplate)"
                                                                title="View Details">
                                                            <i class="fa fa-eye" style="font-size: 16px; color: #007bff;"></i>
                                                        </button>
                                                    </div>
                                                </ItemTemplate>
                                                <NoRecordsTemplate>
                                                    @if (isSparePartLoading)
                                                    {
                                                        <div style="text-align: center; padding: 10px; color: #6c757d;">
                                                            <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                                                            <span>Searching spare parts...</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div style="text-align: center; padding: 15px; color: #6c757d; font-style: italic;">
                                                            No matching spare parts found.
                                                        </div>
                                                    }
                                                </NoRecordsTemplate>
                                            </ComboBoxTemplates>
                                        </SfComboBox>
                                    </td>

                                    <td style="vertical-align: middle; padding: 8px;">
                                        <SfTextBox @bind-Value="currentPart.Description"
                                                   Placeholder="Description"
                                                   Width="100%"
                                                   Readonly="@(!string.IsNullOrEmpty(currentPart.SparePartId?.ToString()))"
                                                   Enabled="@(!isSaving)">
                                        </SfTextBox>
                                    </td>

                                    <td style="vertical-align: middle; padding: 8px;">
                                        <SfNumericTextBox @bind-Value="currentPart.Quantity"
                                                          Placeholder="Qty"
                                                          Min="1"
                                                          Max="999"
                                                          Format="0"
                                                          Width="100%"
                                                          ShowSpinButton="true"
                                                          Enabled="@(!isSaving)">
                                        </SfNumericTextBox>
                                    </td>

                                    <td style="vertical-align: middle; padding: 8px;">
                                        <SfComboBox TValue="string"
                                                    TItem="ConditionOption"
                                                    @bind-Value="currentPart.Condition"
                                                    DataSource="@ConditionOptions"
                                                    Placeholder="Condition"
                                                    Width="100%"
                                                    Enabled="@(!isSaving)">
                                            <ComboBoxFieldSettings Value="Value" Text="Text"></ComboBoxFieldSettings>
                                        </SfComboBox>
                                    </td>

                                    <td style="vertical-align: middle; padding: 8px; text-align: center;">
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm"
                                                style="width: 100%; max-width: 60px;"
                                                @onclick="() => RemoveSparePart(index)"
                                                title="Remove Part"
                                                disabled="@isSaving">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="no-spare-parts-message">
                        <i class="fas fa-info-circle me-2"></i>
                        No spare parts added yet. Click "Add Part" to add spare parts.
                    </div>
                }
            </div>
        </div>
    </div>
</div></div>


        <!-- Validation Summary -->
        <ValidationSummary class="text-danger mb-3" />

        <!-- Action Buttons -->
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDialog">
                        <i class="fas fa-times me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <i class="fas fa-spinner fa-spin me-1"></i>
                        }
                        else
                        {
                            <i class="fas @(string.IsNullOrEmpty(originalRentalItemId) ? "fa-plus" : "fa-save") me-1"></i>
                        }
                        @(string.IsNullOrEmpty(originalRentalItemId) ? "Create" : "Update")
                    </button>
                </div>
            </div>
        </div>
