    private async Task OnFilteringSparePart(Syncfusion.Blazor.DropDowns.FilteringEventArgs args)
    {
        try
        {
            args.PreventDefaultAction = true;
            isSparePartLoading = true;
            filteredSpareParts = new List<SparePartObject>();
            StateHasChanged();

            if (!allSpareParts.Any())
            {
                allSpareParts = (await SparePartService.GetAllSparePartsAsync())?.ToList() ?? new List<SparePartObject>();
            }

            List<SparePartObject> filtered;

            if (string.IsNullOrWhiteSpace(args.Text))
            {
                filtered = allSpareParts.Take(10).ToList();
            }
            else
            {
                var search = args.Text.Trim().ToLower();
                await Task.Delay(500);

                filtered = allSpareParts
                    .Where(sp => (sp.ItemName ?? "").ToLower().Contains(search)
                              || (sp.SerialNumber ?? "").ToLower().Contains(search)
                              || (sp.UseFor ?? "").ToLower().Contains(search)
                              || (sp.Description ?? "").ToLower().Contains(search))
                    .ToList();
            }

            if (currentService.SpareParts != null)
            {
                foreach (var part in currentService.SpareParts)
                {
                    if (part.SparePartId.HasValue)
                    {
                        var selected = allSpareParts.FirstOrDefault(sp => sp.Id == part.SparePartId.Value);
                        if (selected != null && !filtered.Any(sp => sp.Id == selected.Id))
                        {
                            filtered.Insert(0, selected);
                        }
                    }
                }
            }

            filteredSpareParts = filtered;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in filtering spare parts: {ex.Message}");
        }
        finally
        {
            isSparePartLoading = false;
            StateHasChanged();
        }
    }

