    private async Task ApplyFilters()
    {
        // Start with empty query if no search input
        if (string.IsNullOrWhiteSpace(searchItemNameOrSerial))
        {
            filteredServices = new List<RentalServices>();
            foundRentalItems.Clear();
            StateHasChanged();
            return;
        }

        try
        {
            isLoading = true;
            StateHasChanged();

            // Use the optimized search
            await SearchRentalItemsOptimized();

            // Filter services based on found rental items
            if (foundRentalItems.Any())
            {
                var foundItemIds = foundRentalItems.Select(item => item.Id.ToString()).ToList();

                IEnumerable<RentalServices> query = allServices.Where(service =>
                    foundItemIds.Contains(service.RentalItemId)
                );

                // Apply additional filters
                if (!string.IsNullOrWhiteSpace(selectedAction))
                {
                    query = query.Where(service => service.Action.Equals(selectedAction, StringComparison.OrdinalIgnoreCase));
                }

                if (filterStartDate.HasValue)
                {
                    query = query.Where(service => service.Date.Date >= filterStartDate.Value.Date);
                }

                if (filterEndDate.HasValue)
                {
                    query = query.Where(service => service.Date.Date <= filterEndDate.Value.Date);
                }

                if (!string.IsNullOrWhiteSpace(selectedUserId))
                {
                    query = query.Where(service => service.UserId == selectedUserId);
                }

                filteredServices = query.OrderByDescending(s => s.Date).ToList();

                Console.WriteLine($"Applied filters: {filteredServices.Count} services found for {foundRentalItems.Count} items");
            }
            else
            {
                filteredServices = new List<RentalServices>();
                Console.WriteLine("No items found, clearing services");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error applying filters: {ex.Message}");
            errorMessage = $"Filter error: {ex.Message}";
            filteredServices = new List<RentalServices>();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
