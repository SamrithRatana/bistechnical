    private async Task SaveService()
    {
        try
        {
            isSaving = true;
            rentalItemIdErrorMessage = string.Empty;
            errorMessage = string.Empty;
            StateHasChanged();

            // Primary validation
            if (string.IsNullOrWhiteSpace(currentService.RentalItemId))
            {
                rentalItemIdErrorMessage = "Rental Item is required";
                isSaving = false;
                StateHasChanged();
                return;
            }

            // ✅ CHANGED: Auto-set current user from JWT
            if (!string.IsNullOrEmpty(currentUserId))
            {
                currentService.UserId = currentUserId;
            }
            else
            {
                errorMessage = "Unable to determine current user. Please refresh and try again.";
                isSaving = false;
                StateHasChanged();
                return;
            }

            // Validate rental item exists
            if (!RentalItemOptions.Any(r => r.Id == currentService.RentalItemId))
            {
                rentalItemIdErrorMessage = "Please select a valid rental item from the dropdown";
                return;
            }

            // Handle spare parts
            if (currentService.SpareParts != null && currentService.SpareParts.Any())
            {
                currentService.SpareParts = currentService.SpareParts
                    .Where(sp => sp.SparePartId.HasValue)
                    .ToList();

                foreach (var part in currentService.SpareParts)
                {
                    if (part.SparePartId.HasValue &&
                        !string.IsNullOrEmpty(part.SparePartId.Value.ToString()) &&
                        !SparePartOptions.Any(sp => sp.Id == part.SparePartId.Value.ToString()))
                    {
                        errorMessage = $"Invalid spare part selected: {part.SparePartId}";
                        return;
                    }

                    if (part.Quantity <= 0)
                        part.Quantity = 1;

                    if (string.IsNullOrWhiteSpace(part.Condition))
                        part.Condition = ConditionOptions.FirstOrDefault()?.Value ?? "New";
                }
            }
            else
            {
                currentService.SpareParts = new List<SparePartOb>();
            }

            if (string.IsNullOrWhiteSpace(currentService.Action))
            {
                currentService.Action = ActionOptions.FirstOrDefault()?.Value ?? "Check";
            }

            // Create service
            await RentalServicesService.CreateRentalServiceAsync(currentService);

            // Add to local collection
            var newService = new RentalServices
            {
                RentalItemId = currentService.RentalItemId,
                Date = currentService.Date,
                Action = currentService.Action,
                Note = currentService.Note,
                UserId = currentService.UserId,
                SpareParts = currentService.SpareParts?.Select(sp => new SparePartOb
                {
                    SparePartId = sp.SparePartId,
                    Description = sp.Description,
                    Quantity = sp.Quantity,
                    Condition = sp.Condition
                }).ToList() ?? new List<SparePartOb>()
            };

            allServices.Add(newService);

            if (!string.IsNullOrWhiteSpace(searchItemNameOrSerial))
            {
                await ApplyFilters();
            }

            successMessage = $"Successfully created service record for {currentService.RentalItemId}";

            isAddDialogVisible = false;
            selectedServiceId = null;
            selectedViewService = null;

            currentService = new RentalServices
            {
                Date = DateTime.Now,
                SpareParts = new List<SparePartOb>()
            };
            originalRentalItemId = string.Empty;

            errorMessage = string.Empty;
            rentalItemIdErrorMessage = string.Empty;

        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error saving service: {ex}");
            errorMessage = $"Failed to save service record: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
