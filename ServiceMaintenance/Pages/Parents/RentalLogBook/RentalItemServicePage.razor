    // Helper method to extract base serial number from patterns like "002016 (BTB)"
    private string ExtractBaseSerialNumber(string serialNumber)
    {
        if (string.IsNullOrWhiteSpace(serialNumber))
            return string.Empty;

        // Remove parenthetical suffixes like "(BTB)", "(OLD)", etc.
        var parenIndex = serialNumber.IndexOf('(');
        if (parenIndex > 0)
        {
            return serialNumber.Substring(0, parenIndex).Trim();
        }

        // Remove bracket suffixes like "[BTB]", "[OLD]", etc.
        var bracketIndex = serialNumber.IndexOf('[');
        if (bracketIndex > 0)
        {
            return serialNumber.Substring(0, bracketIndex).Trim();
        }

        return serialNumber.Trim();
    }
