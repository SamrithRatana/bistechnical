    private async Task LoadPageAsync(int pageNumber, bool useCache = true)
    {
        try
        {
            if (useCache && pageCache.ContainsKey(pageNumber))
            {
                Console.WriteLine($"📦 Loading page {pageNumber} from cache");
                currentPageData = pageCache[pageNumber];
                currentPage = pageNumber;
                StateHasChanged();
                return;
            }

            isLoadingPage = true;
            Console.WriteLine($"🔄 Fetching page {pageNumber} from API");

            PaginatedResult<RepairServices> result;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                result = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: pageNumber,
                    pageSize: pageSize,
                    searchTerm: searchText.Trim(),
                    sortBy: "ServiceDate",
                    sortDescending: true
                );
            }
            else
            {
                result = await RepairItemService.GetRepairServicesPagedAsync(
                    pageNumber: pageNumber,
                    pageSize: pageSize
                );
            }

            if (result != null)
            {
                currentPageData = result.Items ?? new List<RepairServices>();
                totalRecords = result.TotalCount;
                totalPages = result.TotalPages;
                currentPage = pageNumber;

                if (!pageCache.ContainsKey(pageNumber))
                {
                    pageCache[pageNumber] = currentPageData;
                }

                Console.WriteLine($"✅ Loaded page {pageNumber}: {currentPageData.Count} records");
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading page: {ex.Message}");
            ShowErrorToast($"Failed to load page");
        }
        finally
        {
            isLoadingPage = false;
        }
    }

    private async Task SetupSignalRAsync()
    {
        try
        {
            Console.WriteLine("🔌 Setting up SignalR connection...");

            // ✅ Dispose existing connection if any
            if (hubConnection != null)
            {
                try
                {
                    await hubConnection.StopAsync();
                    await hubConnection.DisposeAsync();
                }
                catch { }
                hubConnection = null;
            }

            // ✅ GET FRESH JWT TOKEN FOR SIGNALR
            var token = await JwtSessionService.GetOrRefreshTokenAsync();

            if (string.IsNullOrEmpty(token))
            {
                Console.WriteLine("❌ No JWT token available for SignalR");
                throw new Exception("Authentication required. Please log in again.");
            }

            Console.WriteLine($"🔑 JWT Token available: {token.Substring(0, Math.Min(50, token.Length))}...");

            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/chatHub"), options =>
                {
                    // ✅ CRITICAL: Pass token via query string for SignalR
                    options.AccessTokenProvider = () => Task.FromResult(token);

                    // ✅ Configure transports
                    options.Transports = HttpTransportType.WebSockets |
                                        HttpTransportType.ServerSentEvents |
                                        HttpTransportType.LongPolling;

                    options.SkipNegotiation = false;
                })
                .WithAutomaticReconnect(new[]
                {
                    TimeSpan.Zero,
                    TimeSpan.FromSeconds(2),
                    TimeSpan.FromSeconds(10),
                    TimeSpan.FromSeconds(30)
                })
                .ConfigureLogging(logging =>
                {
                    logging.SetMinimumLevel(LogLevel.Debug);
                })
                .Build();

            // ✅ Add connection state handlers
            hubConnection.Closed += async (error) =>
            {
                Console.WriteLine($"❌ SignalR connection closed. Error: {error?.Message}");
            };

            hubConnection.Reconnecting += async (error) =>
            {
                Console.WriteLine($"⚠️ SignalR reconnecting. Error: {error?.Message}");
            };

            hubConnection.Reconnected += async (connectionId) =>
            {
                Console.WriteLine($"✅ SignalR reconnected. Connection ID: {connectionId}");
            };

            // ✅ Setup event handlers
            hubConnection.On<string>("ReceiveItemUpdate", async (message) =>
            {
                pageCache.Clear();
                await LoadPageAsync(currentPage, useCache: false);
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<Guid>("BroadcastItemDelete", async (deletedItemId) =>
            {
                pageCache.Clear();
                await LoadPageAsync(currentPage, useCache: false);
                await InvokeAsync(StateHasChanged);
            });

            // ✅ START CONNECTION WITH ERROR HANDLING
            Console.WriteLine("🔌 Starting SignalR connection...");
            await hubConnection.StartAsync();
            Console.WriteLine($"✅ SignalR connected! State: {hubConnection.State}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ CRITICAL: SignalR connection failed!");
            Console.WriteLine($"   Error: {ex.Message}");
            Console.WriteLine($"   Inner Exception: {ex.InnerException?.Message}");
            Console.WriteLine($"   Stack: {ex.StackTrace}");
            throw; // Re-throw so caller knows connection failed
        }
    }

