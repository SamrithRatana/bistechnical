    private async Task SubmitRequestToAdmin()
    {
        if (string.IsNullOrEmpty(selectedRequestAction))
        {
            ShowErrorToast("Please select an action");
            return;
        }

        try
        {
            Console.WriteLine("═══════════════════════════════════════");
            Console.WriteLine("📤 SUBMITTING REQUEST TO ADMINS VIA API");
            Console.WriteLine($"   Action: {selectedRequestAction}");
            Console.WriteLine($"   Service: {_selectedRepairService.reportNo}");
            Console.WriteLine("═══════════════════════════════════════");

            if (JwtSessionService.IsTokenExpired())
            {
                ShowErrorToast("Your session has expired. Please refresh the page and log in again.");
                Navigation.NavigateTo("/login", true);
                return;
            }

            // ✅ Check if we have any admin users
            if (!adminUserIds.Any())
            {
                ShowErrorToast("No admin users found. Please contact system administrator.");
                Console.WriteLine("❌ No admin users available to send request to");
                return;
            }

            var messageText = $"Request {selectedRequestAction} - ServiceId: {_selectedRepairService.Id} - ReportNo: {_selectedRepairService.reportNo}";

            // ✅ Send message to ALL admin users
            int successCount = 0;
            int failCount = 0;

            foreach (var adminId in adminUserIds)
            {
                try
                {
                    var messageDto = new SendMessageDto
                    {
                        UserID = currentUserId ?? string.Empty,
                        RecipientID = adminId,
                        Text = messageText,
                        UserName = currentUserName ?? "User",
                        FileUrl = null,
                        AudioUrl = null,
                        ReplyToMessageId = null,
                        ReplyToUserName = null,
                        ReplyToText = null
                    };

                    await JwtMessageService.SendMessageAsync(messageDto);
                    successCount++;
                    Console.WriteLine($"✅ Message sent to admin: {adminId}");
                }
                catch (Exception ex)
                {
                    failCount++;
                    Console.WriteLine($"⚠️ Failed to send to admin {adminId}: {ex.Message}");
                }
            }

            if (successCount > 0)
            {
                Console.WriteLine($"✅ Request sent to {successCount} admin(s) successfully");
                ShowSuccessToast($"{selectedRequestAction} request sent to {successCount} admin(s)");
                CloseRequestModal();
            }
            else
            {
                Console.WriteLine($"❌ Failed to send request to any admins");
                ShowErrorToast("Failed to send request to admins. Please try again.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ CRITICAL ERROR: {ex.Message}");
            ShowErrorToast("An unexpected error occurred. Please try again.");
        }
    }

