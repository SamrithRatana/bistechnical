@page "/repairservices"
@using DevExpress.XtraReports.UI
@using Microsoft.AspNetCore.Http.Connections
@using Microsoft.AspNetCore.SignalR.Client
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Buttons
@inject RepairItemService RepairItemService
@inject ServiceSparePart SparePartService
@inject CustomerService CustomerService
@inject GlobalUserService UserCacheService
@inject JwtUserManagementService JwtUserManagementService
@inject JwtSessionService JwtSessionService
@inject JwtMessageService JwtMessageService
@inject IJSRuntime JSRuntime
@inject StateManagementAction StateManagementAction
@using System.Security.Claims

@inherits PermissionBase

<style>
    .request-modal-content {
        padding: 20px;
    }

    .request-options {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin: 20px 0;
    }

    .option-card {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .option-card:hover {
            border-color: #2563eb;
            background-color: #f0f4ff;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
        }

        .option-card.selected {
            border-color: #2563eb;
            background-color: #e0edff;
        }

    .option-icon {
        font-size: 2rem;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background-color: #f0f4ff;
    }

    .option-card.selected .option-icon {
        background-color: #2563eb;
        color: white;
    }

    .option-content {
        flex: 1;
    }

    .option-title {
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 5px;
        color: #333;
    }

    .option-description {
        font-size: 0.9rem;
        color: #666;
    }

    .option-radio {
        width: 20px;
        height: 20px;
    }

    .selected-service-info {
        background-color: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

        .selected-service-info h5 {
            margin-bottom: 10px;
            color: #333;
            font-weight: 600;
        }

    .service-detail {
        display: flex;
        justify-content: space-between;
        padding: 5px 0;
        border-bottom: 1px solid #e0e0e0;
    }

        .service-detail:last-child {
            border-bottom: none;
        }

    .service-label {
        font-weight: 500;
        color: #666;
    }

    .service-value {
        color: #333;
    }
</style>
@{
    bool enableAdaptiveUIMode = activeBreakpoint == "Small" || activeBreakpoint == "Medium";
    RowDirection renderingMode = activeBreakpoint == "Small" ? RowDirection.Vertical : RowDirection.Horizontal;
}
@if (CanAccess)
{
    <DxToastProvider Name="Customization"
                     MaxToastCount="5"
                     HorizontalAlignment="HorizontalAlignment.Right"
                     VerticalAlignment="VerticalEdge.Top"
                     AnimationType="@Animation" />

    <div class="card shadow-sm rounded-lg">
        <div class="card-body">
            <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
                <DxToolbarItem Text="Request Admin"
                               Click="ShowRequestModal"
                               IconCssClass="fas fa-user-shield"
                               CssClass="toolbar-item"
                               Enabled="true" />
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]"
                               IconCssClass="fas fa-download">
                    <Items>
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]"
                                       Click="ExportToExcel"
                                       IconCssClass="fas fa-file-excel" />
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]"
                                       Click="ExportToPdf"
                                       IconCssClass="fas fa-file-pdf" />
                    </Items>
                </DxToolbarItem>
                <DxToolbarItem Text="Print Report"
                               Click="@(async () => await Print(_selectedRepairService))"
                               CssClass="toolbar-item" />
                <DxToolbarItem>
                    <Template>
                        <div class="d-flex justify-content-end align-items-center">
                            <SfTextBox Placeholder="Search..."
                                       @bind-Value="searchText"
                                       CssClass="form-control me-2"
                                       Width="250px"
                                       Input="OnSearchInput">
                            </SfTextBox>
                            <button @onclick="PerformSearch" class="btn btn-primary">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </Template>
                </DxToolbarItem>
            </DxToolbar>
        </div>
    </div>

    <hr>

    <!-- Request Admin Modal -->
    <SfDialog @ref="DialogRequestAdmin"
              Width="600px"
              IsModal="true"
              ShowCloseIcon="true"
              @bind-Visible="@isRequestModalVisible">
        <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
        <DialogTemplates>
            <Header>
                <i class="fas fa-user-shield"></i> Request Admin Action
            </Header>
            <Content>
                <div class="request-modal-content">
                    @if (_selectedRepairService != null && _selectedRepairService.Id != Guid.Empty)
                    {
                        <div class="selected-service-info">
                            <h5>Selected Service</h5>
                            <div class="service-detail">
                                <span class="service-label">Report No:</span>
                                <span class="service-value">@_selectedRepairService.reportNo</span>
                            </div>
                            <div class="service-detail">
                                <span class="service-label">Company:</span>
                                <span class="service-value">@_selectedRepairService.CompanyName</span>
                            </div>
                            <div class="service-detail">
                                <span class="service-label">Item:</span>
                                <span class="service-value">@_selectedRepairService.itemName</span>
                            </div>
                            <div class="service-detail">
                                <span class="service-label">Status:</span>
                                <span class="service-value">@_selectedRepairService.Status</span>
                            </div>
                        </div>

                        <p style="margin-bottom: 15px; color: #666;">
                            Please select the action you want the admin to perform:
                        </p>

                        <div class="request-options">
                            <div class="option-card @(selectedRequestAction == "Edit" ? "selected" : "")"
                                 @onclick="@(() => SelectRequestAction("Edit"))">
                                <div class="option-icon">
                                    <i class="fas fa-edit"></i>
                                </div>
                                <div class="option-content">
                                    <div class="option-title">Request Edit</div>
                                    <div class="option-description">
                                        Ask admin to edit this service record
                                    </div>
                                </div>
                                <input type="radio"
                                       class="option-radio"
                                       checked="@(selectedRequestAction == "Edit")"
                                       @onchange="@(() => SelectRequestAction("Edit"))" />
                            </div>

                            <div class="option-card @(selectedRequestAction == "Delete" ? "selected" : "")"
                                 @onclick="@(() => SelectRequestAction("Delete"))">
                                <div class="option-icon">
                                    <i class="fas fa-trash-alt"></i>
                                </div>
                                <div class="option-content">
                                    <div class="option-title">Request Delete</div>
                                    <div class="option-description">
                                        Ask admin to delete this service record
                                    </div>
                                </div>
                                <input type="radio"
                                       class="option-radio"
                                       checked="@(selectedRequestAction == "Delete")"
                                       @onchange="@(() => SelectRequestAction("Delete"))" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(selectedRequestAction))
                        {
                            <div class="alert alert-info mt-3">
                                <i class="fas fa-info-circle"></i>
                                You have selected: <strong>@selectedRequestAction</strong>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i>
                            Please select a service from the list first.
                        </div>
                    }
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Cancel"
                          OnClick="CloseRequestModal"
                          CssClass="btn btn-secondary" />
            <DialogButton Content="Submit Request"
                          OnClick="SubmitRequestToAdmin"
                          CssClass="btn btn-primary"
                          Disabled="@(string.IsNullOrEmpty(selectedRequestAction))" />
        </DialogButtons>
    </SfDialog>

    <SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>


    <div class="h-100 grid-wrapper">
        @if (isLoading)
        {
            <div class="card-body w-100">
                <div class="card-header border-0 p-2 rounded">
                    <DxLoadingPanel IndicatorAnimationType="WaitIndicatorAnimationType.Pulse"
                                    CssClass="w-100"
                                    IndicatorVisible="true"
                                    IndicatorAreaVisible="true"
                                    Visible="true"
                                    Text="Loading services..."
                                    TextAlignment="LoadingPanelTextAlignment.Right">
                        <div style="min-height: 250px;"></div>
                    </DxLoadingPanel>
                </div>
            </div>
        }
        else
        {
            <SfGrid @ref="MyGrid"
                    DataSource="@currentPageData"
                    AllowPaging="true"
                    AllowSorting="true"
                    ShowColumnChooser="true"
                    AllowExcelExport="true"
                    AllowPdfExport="true"
                    AllowResizing="true"
                    AllowFiltering="true"
                    Height="600"
                    SelectionMode="GridSelectionMode.Single"
                    Toolbar="@ToolbarItems"
                    EnableAdaptiveUI="@enableAdaptiveUIMode"
                    RowRenderingMode="@renderingMode"
                    AllowSelection="true">

                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>

                <GridEvents RowSelected="RowSelectHandler"
                            OnRecordDoubleClick="RowDoubleClickHandler"
                            TValue="RepairServices"
                            OnActionBegin="OnActionBegin">
                </GridEvents>

                <GridPageSettings PageSize="@pageSize"
                                  PageCount="5">
                </GridPageSettings>

                <GridColumns>
                    <GridColumn Field="@nameof(RepairServices.Id)" HeaderText="Id" Width="150" Visible="false" />
                    <GridColumn Field="@nameof(RepairServices.reportNo)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextReports)]"
                                Width="150" />
                    <GridColumn Field="@nameof(RepairServices.ServiceDate)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextReceiveDate)]"
                                Width="150"
                                Format="dd/MM/yyyy HH:mm" />
                    <GridColumn Field="@nameof(RepairServices.CompanyName)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]"
                                Width="200" />
                    <GridColumn Field="@nameof(RepairServices.Address)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextAddress)]"
                                Width="200" />
                    <GridColumn Field="@nameof(RepairServices.ContactName)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextContactName)]"
                                Width="200"
                                Visible="false" />
                    <GridColumn Field="@nameof(RepairServices.PhoneNumber)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextPhoneNumber)]"
                                Width="200" />
                    <GridColumn Field="@nameof(RepairServices.itemName)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]"
                                Width="200" />
                    <GridColumn Field="@nameof(RepairServices.serialNumber)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]"
                                Width="200" />
                    <GridColumn Field="@nameof(RepairServices.ServiceLocation)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextServiceLocation)]"
                                Width="200" />
                    <GridColumn Field="@nameof(RepairServices.Status)"
                                HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]"
                                Width="150">
                        <Template>
                            @{
                                var item = context as RepairServices;
                                var khmerStatus = GetKhmerStatus(item?.Status);
                            }
                            @khmerStatus
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" IsFrozen="true" Freeze="FreezeDirection.Right" Width="100">
                        <Template>
                            <DxButton IconCssClass="fas fa-eye"
                                      CssClass="icon-button info"
                                      RenderStyle="ButtonRenderStyle.Info"
                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                      Text="@Loc[nameof(ResourceStrings.TextView)]"
                                      @onclick="() => ShowRepairServiceDetails(context as RepairServices)" />
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>

            <!-- Custom Pagination Controls -->
            <div class="mt-3 d-flex justify-content-between align-items-center">
                <div>
                    <span>Showing @((currentPage - 1) * pageSize + 1) to @Math.Min(currentPage * pageSize, totalRecords) of @totalRecords records</span>
                </div>
                <div class="btn-group">
                    <button class="btn btn-outline-primary"
                            @onclick="() => GoToPage(1)"
                            disabled="@(currentPage == 1 || isLoadingPage)">
                        <i class="fas fa-angle-double-left"></i> First
                    </button>
                    <button class="btn btn-outline-primary"
                            @onclick="PreviousPage"
                            disabled="@(currentPage == 1 || isLoadingPage)">
                        <i class="fas fa-angle-left"></i> Previous
                    </button>
                    <span class="btn btn-light disabled">Page @currentPage of @totalPages</span>
                    <button class="btn btn-outline-primary"
                            @onclick="NextPage"
                            disabled="@(currentPage >= totalPages || isLoadingPage)">
                        Next <i class="fas fa-angle-right"></i>
                    </button>
                    <button class="btn btn-outline-primary"
                            @onclick="() => GoToPage(totalPages)"
                            disabled="@(currentPage >= totalPages || isLoadingPage)">
                        Last <i class="fas fa-angle-double-right"></i>
                    </button>
                </div>
                <div>
                    <label class="me-2">Page Size:</label>
                    <select class="form-select d-inline-block w-auto" @onchange="OnPageSizeChange">
                        <option value="10" selected="@(pageSize == 10)">10</option>
                        <option value="20" selected="@(pageSize == 20)">20</option>
                        <option value="50" selected="@(pageSize == 50)">50</option>
                        <option value="100" selected="@(pageSize == 100)">100</option>
                    </select>
                </div>
            </div>
        }
</div>

<SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
    <DialogTemplates>
        <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
        <Content>
            <div class="report-container">
                <div class="report-header">
                    <span>Repair Service Report</span>
                </div>
                <div class="report-body">
                    <table class="report-table">
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.reportNo</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceDate.ToString("yyyy-MM-dd HH:mm tt")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairDate)]:</strong></td>
                            <td class="report-value">
                                @(_selectedRepairService?.repairDate.HasValue == true
                                                                ? _selectedRepairService.repairDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                                                : "N/A")
                            </td>
                        </tr>

                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCompanyName)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.CompanyName</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextAddress)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.Address</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContactName)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.ContactName</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPhoneNumber)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.PhoneNumber</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextItemName)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.itemName</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextSerialNumber)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.serialNumber</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCustomerReq)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.CustomerRequest</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextInspection)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.Inspection</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textsolution)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.Solution</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextServiceLocation)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.ServiceLocation</td>
                            </tr>

                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPriority)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.ServicePriority</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextStatus)]:</strong></td>
                                <td class="report-value">@_selectedRepairService?.Status</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContract)]:</strong></td>
                                <td class="report-value">@(_selectedRepairService?.hasContract == true ? "Yes" : "No")</td>
                            </tr>

                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairBy)]:</strong></td>
                                <td class="report-value">
                                @{
                                        var username = GetUserNameById(_selectedRepairService?.repairBy);
                                    }
                                    @username
                                </td>
                            </tr>
                        </table>
                        <hr />
                        @if (_selectedRepairService?.SparePartItems != null && _selectedRepairService.SparePartItems.Count > 0)
                        {
                            <h4>SparePart Details</h4>
                            <table class="report-table">
                                <thead>
                                    <tr>
                                        <th>@Loc[nameof(ResourceStrings.TextImage)]</th>
                                        <th>@Loc[nameof(ResourceStrings.textDescription)]</th>
                                        <th>@Loc[nameof(ResourceStrings.TextQty)]</th>
                                        <th>@Loc[nameof(ResourceStrings.TextCondition)]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sparePart in _selectedRepairService.SparePartItems)
                                    {
                                        var sparePartObject = _spareParts.FirstOrDefault(x => x.Id == sparePart.SparePartId);

                                        <tr>
                                            <td>
                                                @if (sparePartObject != null && !string.IsNullOrEmpty(sparePartObject.PictureUrl))
                                                {
                                                    <img src="@sparePartObject.PictureUrl" alt="Spare Part Image" />
                                                }
                                                else
                                                {
                                                    <span>No Image</span>
                                                }
                                            </td>
                                            <td>@sparePartObject?.ItemName</td>
                                            <td>@sparePart.UseFor</td>
                                            <td>@sparePart.Quantity</td>
                                            <td>@sparePart.Condition</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Close" IsPrimary="true" OnClick="@CloseDialog" />
        </DialogButtons>
    </SfDialog>

}

@code {
    private HubConnection hubConnection;
    private string currentUserId;
    private string currentUserName;
    // ✅ REMOVED: Hardcoded admin ID
    // private readonly string adminId = "e8732e93-4881-48d6-821d-702e51764593";

    // ✅ NEW: List of admin user IDs (loaded dynamically)
    private List<string> adminUserIds = new();

    // Grid and UI references
    private SfGrid<RepairServices> MyGrid;
    private SfDialog DialogRequestAdmin;
    private DxReportViewer reportViewer;
    private SfDialog DialogEdit;

    // State management
    private bool isLoading = true;
    private bool isLoadingPage = false;
    private bool isRequestModalVisible = false;
    private bool isViewDialogVisible = false;
    private string selectedRequestAction = string.Empty;

    // Search and filtering
    private string searchText = string.Empty;
    private string activeBreakpoint { get; set; }
    private System.Threading.Timer searchDebounceTimer;

    // Selected items
    private RepairServices _selectedRepairService = new RepairServices();

    // Pagination state
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalRecords = 0;
    private int totalPages = 0;
    private List<RepairServices> currentPageData = new List<RepairServices>();

    // Data caching
    private Dictionary<int, List<RepairServices>> pageCache = new Dictionary<int, List<RepairServices>>();
    private List<SparePartObject> _spareParts = new List<SparePartObject>();

    // Other settings
    public string[] ToolbarItems = new string[] { "ColumnChooser" };
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;

    private Dictionary<string, GlobalUserService.UserFullInfo> UserDetailsMap = new();
    private Dictionary<string, string> _userCache = new();
    private bool _usersLoaded = false;

    private SfDialog DialogNoRecordSelected;
    private string GetKhmerStatus(string englishStatus)
    {
        if (string.IsNullOrEmpty(englishStatus))
            return string.Empty;

        var statusMap = new Dictionary<string, string>
    {
        { "Item Recieved", "ម៉ាស៊ីនចូល" },
        { "Inspection", "កំពុងវិនិច្ឆ័យ" },
        { "Awaiting Customer Confirm", "រង់ចាំយល់ព្រមពីភ្ញៀវ" },
        { "Awaiting Sparepart", "រង់ចាំគ្រឿងបន្លាស់" },
        { "Repairing", "កំពុងជួសជុល" },
        { "Finished", "ជួសជុលរួចរាល់" },
        { "Customer Rejected", "អតិថិជនមិនជួសជុល" },
        { "Unrepairable", "ជួសជុលមិនបាន" },
        { "Repair by Third-Party", "ជួសជុលដោយជាងខាងក្រៅ" }
    };

        if (englishStatus.Contains("(Historical)"))
        {
            var baseStatus = englishStatus.Replace(" (Historical)", "").Trim();
            return statusMap.ContainsKey(baseStatus)
                ? $"{statusMap[baseStatus]} (ប្រវត្តិ)"
                : englishStatus;
        }

        return statusMap.ContainsKey(englishStatus)
            ? statusMap[englishStatus]
            : englishStatus;
    }
    // Lookups
    private IEnumerable<ServiceType> _serviceTypes;
    private IEnumerable<ServicePriority> _servicePriorities;
    private IEnumerable<ServiceStatus> _serviceStatuses;

    protected override async Task OnPermissionsLoadedAsync()
    {
        Console.WriteLine($"🔐 RepairServicesPage - CanAccess: {CanAccess}");
        Console.WriteLine($"🔐 RepairServicesPage - PermissionsLoaded: {PermissionsLoaded}");

        if (!CanAccess)
        {
            Console.WriteLine("❌ Access Denied - User does not have RepairServicesPage.Access permission");
            ShowError("You don't have permission to access this page");
            return;
        }

        await InitializePageData();
    }

    private async Task InitializePageData()
    {
        try
        {
            Console.WriteLine("═══════════════════════════════════════");
            Console.WriteLine("🔧 REPAIR SERVICES PAGE INITIALIZATION");
            Console.WriteLine("═══════════════════════════════════════");

            isLoading = true;

            if (JwtSessionService.IsTokenExpired())
            {
                Console.WriteLine("❌ JWT token expired - redirecting to login");
                Navigation.NavigateTo("/login", true);
                return;
            }

            await LoadEssentialDataAsync();

            currentUserId = JwtSessionService.GetCurrentUserId()?.ToString();
            currentUserName = JwtSessionService.GetCurrentUsername();

            if (string.IsNullOrEmpty(currentUserId) || string.IsNullOrEmpty(currentUserName))
            {
                Console.WriteLine("❌ No user ID or username in JWT - redirecting to login");
                Navigation.NavigateTo("/login", true);
                return;
            }

            Console.WriteLine($"✅ Current User: {currentUserName} ({currentUserId})");

            // ✅ NEW: Load admin user IDs
            await LoadAdminUserIdsAsync();

            await LoadPageAsync(1);

            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(3000);
                    await SetupSignalRAsync();
                    Console.WriteLine("✅ Background SignalR connection established for real-time updates");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Background SignalR connection failed (non-critical): {ex.Message}");
                    Console.WriteLine("   Real-time updates disabled, but all other features work normally");
                }
            });

            Console.WriteLine("✅ Page initialization complete");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error initializing: {ex.Message}");
            ShowErrorToast("Failed to initialize page");
        }
        finally
        {
            isLoading = false;
        }
    }
    private async Task LoadAdminUserIdsAsync()
    {
        try
        {
            Console.WriteLine("📥 Loading admin users from JWT API");

            var usersResponse = await JwtUserManagementService.GetAllUsersAsync(page: 1, pageSize: 100);

            if (usersResponse?.Status == "Success" && usersResponse.Data != null)
            {
                // Filter users who have "Admin" role
                adminUserIds = usersResponse.Data
                    .Where(u => u.Roles != null && u.Roles.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase)))
                    .Select(u => u.Id)
                    .ToList();

                Console.WriteLine($"✅ Found {adminUserIds.Count} admin users");

                if (adminUserIds.Count == 0)
                {
                    Console.WriteLine("⚠️ WARNING: No admin users found in system!");
                }
            }
            else
            {
                Console.WriteLine($"❌ Failed to load users: {usersResponse?.Message}");
                adminUserIds = new List<string>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading admin users: {ex.Message}");
            adminUserIds = new List<string>();
        }
    }
    private async Task LoadAllUsersAsync()
