@page "/inspect-item"
@page "/inspect-item/{ReportNo}"

@using ServiceMaintenance.Models
@using Microsoft.AspNetCore.SignalR.Client
@using ServiceMaintenance.Services.Filters.GlobalSecurity
@using System.Timers
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@inject RepairItemService RepairItemService
@inject ServiceSparePart SparePartService
@inject InspectItemService InspectItemService
@inject AwaitingCustomerConfirmService AwaitingCustomerConfirmService
@inject AwaitingSparePartService AwaitingSparePartService
@inject JwtSessionService JwtSessionService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject StateManagementAction StateManagementAction
@inject GlobalUserService GlobalUserCache
@inject IToastNotificationService ToastNotificationService
@inject CacheHelper Cache
@inject MessageQueueHelper MQ

<DxToastProvider Name="Customization"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />

<!-- Loading Overlay -->
@if (isSaving)
{
    <div class="loading-overlay">
        <div class="loading-container">
            <div class="loading-spinner"></div>
            <div class="loading-text">
                <h4>Processing Inspection...</h4>
                <p>Please wait while we save your inspection data</p>
                <div class="loading-progress">
                    <div class="loading-bar"></div>
                </div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">

            @if (CanCreate)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]"
                               Click="NewRepairService_Click"
                               IconCssClass="far fa-file"
                               CssClass="toolbar-item"
                               Enabled="false" />
            }

            @if (CanEdit)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]"
                               Click="EditRepairService_Click"
                               IconCssClass="far fa-edit"
                               CssClass="toolbar-item"
                               Enabled="@isRowSelected" />
            }

            @if (CanDelete)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]"
                               IconCssClass="fas fa-trash-alt"
                               CssClass="toolbar-item"
                               Enabled="false" />
            }

            @if (CanExport)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                    <Items>
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]"
                                       Click="ExportToExcel"
                                       IconCssClass="fas fa-file-excel" />
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]"
                                       Click="ExportToPdf"
                                       IconCssClass="fas fa-file-pdf" />
                    </Items>
                </DxToolbarItem>
            }

            @if (CanPrint)
            {
                <DxToolbarItem Text="Print Report"
                               Click="() => ShowReportPreview(_selectedRepairService)"
                               CssClass="toolbar-item"
                               IconCssClass="fas fa-print"
                               Enabled="@isRowSelected" />
            }

            @if (CanView)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]"
                               Click="@ShowCheckListDialog"
                               CssClass="toolbar-item"
                               IconCssClass="fas fa-check-circle"
                               Enabled="@isRowSelected" />
            }

        </DxToolbar>
    </div>
</div>

<br />

<SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>
@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical;

    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical;
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Horizontal;
    }
    else
    {
        enableAdaptiveUIMode = false;
    }
}

@if (CanAccess)
{
    @if (CanView)
    {
        <h2>@Loc[nameof(ResourceStrings.TextInspectingItemLists)]</h2>

        <div style="margin-bottom: 15px; padding: 15px; background-color: #f9f9f9; border-radius: 4px;">
            <div style="display: flex; gap: 10px; align-items: center;">
                <SfTextBox @ref="ReceivedSearchBox"
                           Placeholder="Search by Report No, Company, Serial Number..."
                           ShowClearButton="true"
                           Width="400px"
                           @bind-Value="ReceivedSearchValue"
                           Input="OnReceivedSearchInput">
                </SfTextBox>
                <SfButton Content="Search"
                          CssClass="e-btn e-primary"
                          IconCss="fas fa-search"
                          OnClick="PerformReceivedSearch" />
                <SfButton Content="Clear"
                          CssClass="e-btn e-outline"
                          IconCss="fas fa-times"
                          OnClick="ClearReceivedSearch" />
            </div>
            @if (!string.IsNullOrEmpty(ReceivedSearchValue))
            {
                <div style="margin-top: 10px; color: #666; font-size: 14px;">
                    <i class="fas fa-info-circle"></i>
                    Searching for: <strong>@ReceivedSearchValue</strong>
                </div>
            }
        </div>

        <SfGrid @ref="MyGrid"
                DataSource="@filteredRepairServices"
                AllowPaging="true"
                AllowSorting="true"
                ShowColumnChooser="true"
                AllowExcelExport="true"
                AllowPdfExport="true"
                AllowResizing="true"
                AllowFiltering="true"
                Height="400"
                SelectionMode="GridSelectionMode.Single"
                Toolbar=@ToolbarItems
                EnableAdaptiveUI="@enableAdaptiveUIMode"
                RowRenderingMode="@renderingMode"
                AllowSelection="true">
            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
            <GridEvents TValue="RepairServices" RowSelected="@ReceivedRowSelectHandler"></GridEvents>
            <GridPageSettings PageSize="10"></GridPageSettings>
            <GridColumns>
                <GridColumn Field="Id" HeaderText="Id" Width="150" Format="d" Visible="false" />
                <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="150" />
                <GridColumn Field="ServiceDate" HeaderText="@Loc[nameof(ResourceStrings.TextReceiveDate)]" Width="150" Format="dd/MM/yyyy HH:mm tt" />
                <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" CustomAttributes="@(new Dictionary<string, object>() { { "class", "e-attr" } })" Width="200" />
                <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="200" />
                <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="200" />
                <GridColumn Field="CustomerRequest" HeaderText="@Loc[nameof(ResourceStrings.TextCustomerReq)]" Width="250" Visible="false" />
                <GridColumn Field="ServiceLocation" HeaderText="@Loc[nameof(ResourceStrings.TextServiceLocation)]" Width="200" />
                <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="150">
                    <Template>
                        @{
                            var item = context as RepairServices;
                        }
                        @(item.Status == "Inspecting" ? "កំពុងវិនិច្ឆ័យ" : item.Status)
                    </Template>
                </GridColumn>
                <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" IsFrozen="true" Freeze="FreezeDirection.Right" Width="200">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.createby);
                        }
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span>@username</span>
                            <button class="material-btn accept-btn" @onclick="() => OnAcceptButtonClick(item)" disabled="@isSaving">
                                <i class="fas fa-check"></i>
                                <span>@Loc[nameof(ResourceStrings.TextAccept)]</span>
                            </button>
                        </div>
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>

        <!-- Pagination -->
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; border-top: 1px solid #ddd; margin-top: 10px;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <button class="e-btn e-normal" @onclick="FirstPage" disabled="@(currentPage == 1)">
                    <i class="fas fa-angle-double-left"></i> First
                </button>
                <button class="e-btn e-normal" @onclick="PreviousPage" disabled="@(currentPage == 1)">
                    <i class="fas fa-angle-left"></i> Previous
                </button>
                <span style="padding: 0 15px; font-weight: 500;">
                    Page @currentPage of @totalPages
                </span>
                <button class="e-btn e-normal" @onclick="NextPage" disabled="@(currentPage >= totalPages)">
                    Next <i class="fas fa-angle-right"></i>
                </button>
                <button class="e-btn e-normal" @onclick="LastPage" disabled="@(currentPage >= totalPages)">
                    Last <i class="fas fa-angle-double-right"></i>
                </button>
            </div>
            <div style="color: #666;">
                Showing @Math.Min((currentPage - 1) * pageSize + 1, totalItems) - @Math.Min(currentPage * pageSize, totalItems) of @totalItems items
            </div>
        </div>
    }
}

<!-- ═══════════════════════════════════════════════════════ -->
<!-- EDIT DIALOG (Accept → Inspect)                        -->
<!-- ═══════════════════════════════════════════════════════ -->
<SfDialog @ref="DialogEdit"
          IsModal="true"
          Width="1200px"
          ShowCloseIcon="true"
          Visible="@isEditDialogVisible">
    <DialogTemplates>
        <Header>
            <div class="dialog-header" style="position: relative;">
                <h2>@Loc[nameof(ResourceStrings.TextEditRepair)]</h2>
            </div>
        </Header>
    </DialogTemplates>

    @if (!string.IsNullOrEmpty(saveErrorMessage))
    {
        <div class="alert alert-warning" role="alert" style="margin: 1rem; padding: 1rem; background-color: #fff3cd; border: 1px solid #ffc107; border-radius: 0.25rem; color: #856404;">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>Warning:</strong>
                <span>@saveErrorMessage</span>
            </div>
        </div>
    }

    <EditForm Model="@inspectItem" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="form-grid">
            <div class="form-group">
                <label class="font" for="Inspection">@Loc[nameof(ResourceStrings.TextInspection)]</label>
                <SfTextBox id="Inspection" @bind-Value="inspectItem.Inspection" class="form-control e-attr" Multiline="true" Enabled="@(!isSaving)" />
            </div>
            <div class="form-group">
                <label class="font" for="Solution">@Loc[nameof(ResourceStrings.Textsolution)]</label>
                <SfTextBox id="Solution" @bind-Value="inspectItem.Solution" class="form-control e-attr" Multiline="true" Enabled="@(!isSaving)" />
            </div>
            <div class="form-group">
                <label class="font" for="ServiceType">@Loc[nameof(ResourceStrings.TextServiceType)]</label>
                <SfDropDownList TValue="int?"
                                TItem="ServiceType"
                                @bind-Value="inspectItem.ServiceTypeId"
                                DataSource="@_serviceTypes"
                                Placeholder="Select Service Type"
                                Enabled="@(!isSaving)"
                                CssClass="form-control e-attr">
                    <DropDownListFieldSettings Value="Id" Text="Name"></DropDownListFieldSettings>
                    <DropDownListTemplates TItem="ServiceType">
                        <ItemTemplate Context="serviceType">
                            <span class="font">@GetLocalizedServiceTypeName(serviceType.Name)</span>
                        </ItemTemplate>
                        <ValueTemplate Context="serviceType">
                            <span class="font">@GetLocalizedServiceTypeName(serviceType.Name)</span>
                        </ValueTemplate>
                    </DropDownListTemplates>
                </SfDropDownList>
            </div>
        </div>

        <hr />

        <div class="form-group">
            <div class="spare-parts-container">
                <!-- Desktop Table View -->
                <div class="table-responsive d-none d-lg-block">
                    <table class="modern-table">
                        <thead>
                            <tr class="font">
                                <th>@Loc[nameof(ResourceStrings.TextSparePart)]</th>
                                <th class="text-center">@Loc[nameof(ResourceStrings.TextQty)]</th>
                                <th class="text-center">@Loc[nameof(ResourceStrings.TextCondition)]</th>
                                <th class="text-center">@Loc[nameof(ResourceStrings.TextAction)]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (inspectItem.SpareParts != null && inspectItem.SpareParts.Any())
                            {
                                @for (int index = 0; index < inspectItem.SpareParts.Count; index++)
                                {
                                    var sparePart = inspectItem.SpareParts[index];
                                    var currentIndex = index;
                                    <tr class="table-row">
                                        <td class="spare-part-cell">
                                            <SfComboBox TValue="Guid" TItem="SparePartObject"
                                                        Placeholder="Select Spare Part"
                                                        @bind-Value="sparePart.SparePartId"
                                                        DataSource="@filteredSpareParts"
                                                        AllowFiltering="true"
                                                        AllowCustom="false"
                                                        FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                                        PopupWidth="500px"
                                                        @onclick="@(() => OnComboBoxClick(currentIndex))"
                                                        Enabled="@(!isSaving)"
                                                        CssClass="modern-combo">
                                                <ComboBoxEvents Filtering="OnFilteringSparePart" TValue="Guid" TItem="SparePartObject"></ComboBoxEvents>
                                                <ComboBoxFieldSettings Value="Id" Text="ItemName"></ComboBoxFieldSettings>
                                                <ComboBoxTemplates TItem="SparePartObject">
                                                    <ItemTemplate Context="sparePartItem">
                                                        <div class="combo-item">
                                                            <img src="@sparePartItem.PictureUrl" alt="@sparePartItem.ItemName" class="combo-item-image" />
                                                            <div class="combo-item-details">
                                                                <div class="combo-item-header">
                                                                    <strong class="item-name">@sparePartItem.ItemName</strong>
                                                                    <span class="serial-number">@sparePartItem.SerialNumber</span>
                                                                </div>
                                                                <div class="combo-item-info">
                                                                    <span>@sparePartItem.Description</span>
                                                                    <span class="divider">|</span>
                                                                    <span>Use: @sparePartItem.UseFor</span>
                                                                </div>
                                                                <div class="stock-indicator-row">
                                                                    @{
                                                                        var stockLevel = sparePartItem.Quantity;
                                                                        var stockColor = GetStockColorForCombo(stockLevel);
                                                                        var stockIcon = GetStockIconForCombo(stockLevel);
                                                                        var stockText = GetStockTextForCombo(stockLevel);
                                                                    }
                                                                    <span class="stock-badge" style="background-color: @stockColor; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">
                                                                        <i class="@stockIcon"></i> @stockText (@stockLevel available)
                                                                    </span>
                                                                </div>
                                                            </div>
                                                            <button type="button"
                                                                    class="btn-view-details"
                                                                    @onclick="() => ShowFullDetails(sparePartItem)"
                                                                    @onclick:stopPropagation="true">
                                                                <i class="fa fa-eye"></i>
                                                            </button>
                                                        </div>
                                                    </ItemTemplate>
                                                    <NoRecordsTemplate>
                                                        @if (isSparePartLoading)
                                                        {
                                                            <div class="loading-state">
                                                                <span class="spinner-border spinner-border-sm"></span>
                                                                <span>Searching spare parts...</span>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="no-records">
                                                                <i class="fas fa-search"></i>
                                                                <span>No matching spare parts found</span>
                                                            </div>
                                                        }
                                                    </NoRecordsTemplate>
                                                </ComboBoxTemplates>
                                            </SfComboBox>
                                        </td>
                                        <td class="quantity-cell">
                                            <InputNumber @bind-Value="sparePart.Quantity"
                                                         class="form-control modern-input"
                                                         disabled="@isSaving"
                                                         min="1"
                                                         @oninput="@(e => { if (int.TryParse(e.Value?.ToString(), out int v) && v < 1) sparePart.Quantity = 1; })" />
                                        </td>
                                        <td class="condition-cell">
                                            <SfComboBox TValue="string" TItem="string"
                                                        Placeholder="Select Condition"
                                                        @bind-Value="sparePart.Condition"
                                                        DataSource="@_repairConditions"
                                                        AllowFiltering="true"
                                                        @onclick="@(() => OnComboBoxClick2(currentIndex))"
                                                        FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                                        Enabled="@(!isSaving)"
                                                        CssClass="modern-combo">
                                            </SfComboBox>
                                        </td>
                                        <td class="action-cell">
                                            <button type="button"
                                                    class="btn-remove"
                                                    @onclick="() => RemoveSparePart(sparePart)"
                                                    disabled="@isSaving"
                                                    title="Remove spare part">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="empty-state">
                                        <i class="fas fa-inbox"></i>
                                        <p>No spare parts added yet</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Mobile Card View -->
                <div class="d-block d-lg-none">
                    @if (inspectItem.SpareParts != null && inspectItem.SpareParts.Any())
                    {
                        @for (int index = 0; index < inspectItem.SpareParts.Count; index++)
                        {
                            var sparePart = inspectItem.SpareParts[index];
                            var currentIndex = index;
                            <div class="spare-part-card">
                                <div class="card-header-mobile">
                                    <button type="button"
                                            class="btn-remove-mobile"
                                            @onclick="() => RemoveSparePart(sparePart)"
                                            disabled="@isSaving">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                                <div class="card-body-mobile">
                                    <div class="mobile-field">
                                        <label>@Loc[nameof(ResourceStrings.TextSparePart)]</label>
                                        <SfComboBox TValue="Guid" TItem="SparePartObject"
                                                    Placeholder="Select Spare Part"
                                                    @bind-Value="sparePart.SparePartId"
                                                    DataSource="@filteredSpareParts"
                                                    AllowFiltering="true"
                                                    AllowCustom="false"
                                                    FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                                    PopupWidth="@(isXSmallScreen ? "95%" : "500px")"
                                                    @onclick="@(() => OnComboBoxClick(currentIndex))"
                                                    Enabled="@(!isSaving)"
                                                    CssClass="modern-combo">
                                            <ComboBoxEvents Filtering="OnFilteringSparePart" TValue="Guid" TItem="SparePartObject"></ComboBoxEvents>
                                            <ComboBoxFieldSettings Value="Id" Text="ItemName"></ComboBoxFieldSettings>
                                            <ComboBoxTemplates TItem="SparePartObject">
                                                <ItemTemplate Context="sparePartItem">
                                                    <div class="combo-item @(isXSmallScreen ? "combo-item-mobile" : "")">
                                                        <img src="@sparePartItem.PictureUrl" alt="@sparePartItem.ItemName" class="combo-item-image" />
                                                        <div class="combo-item-details">
                                                            <div class="combo-item-header">
                                                                <strong class="item-name">@sparePartItem.ItemName</strong>
                                                                <span class="serial-number">@sparePartItem.SerialNumber</span>
                                                            </div>
                                                            <div class="combo-item-info">
                                                                <span>@sparePartItem.Description</span>
                                                                @if (!isXSmallScreen)
                                                                {
                                                                    <span class="divider">|</span>
                                                                    <span>Use: @sparePartItem.UseFor</span>
                                                                }
                                                            </div>
                                                            <div class="stock-indicator-row">
                                                                @{
                                                                    var stockLevel = sparePartItem.Quantity;
                                                                    var stockColor = GetStockColorForCombo(stockLevel);
                                                                    var stockIcon = GetStockIconForCombo(stockLevel);
                                                                    var stockText = GetStockTextForCombo(stockLevel);
                                                                }
                                                                <span class="stock-badge" style="background-color: @stockColor; color: white;">
                                                                    <i class="@stockIcon"></i>
                                                                    @if (isXSmallScreen)
                                                                    {
                                                                        <span>@stockLevel</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span>@stockText (@stockLevel available)</span>
                                                                    }
                                                                </span>
                                                            </div>
                                                        </div>
                                                        @if (!isXSmallScreen)
                                                        {
                                                            <button type="button"
                                                                    class="btn-view-details"
                                                                    @onclick="() => ShowFullDetails(sparePartItem)"
                                                                    @onclick:stopPropagation="true">
                                                                <i class="fa fa-eye"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                </ItemTemplate>
                                                <NoRecordsTemplate>
                                                    @if (isSparePartLoading)
                                                    {
                                                        <div class="loading-state">
                                                            <span class="spinner-border spinner-border-sm"></span>
                                                            <span>@(isXSmallScreen ? "Searching..." : "Searching spare parts...")</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="no-records">
                                                            <i class="fas fa-search"></i>
                                                            <span>@(isXSmallScreen ? "No results" : "No matching spare parts found")</span>
                                                        </div>
                                                    }
                                                </NoRecordsTemplate>
                                            </ComboBoxTemplates>
                                        </SfComboBox>
                                    </div>
                                    <div class="mobile-row">
                                        <div class="mobile-field">
                                            <label>@Loc[nameof(ResourceStrings.TextQty)]</label>
                                            <InputNumber @bind-Value="sparePart.Quantity"
                                                         class="form-control modern-input"
                                                         disabled="@isSaving"
                                                         min="1"
                                                         @oninput="@(e => { if (int.TryParse(e.Value?.ToString(), out int v) && v < 1) sparePart.Quantity = 1; })" />
                                        </div>
                                        <div class="mobile-field">
                                            <label>@Loc[nameof(ResourceStrings.TextCondition)]</label>
                                            <SfComboBox TValue="string" TItem="string"
                                                        Placeholder="Select"
                                                        @bind-Value="sparePart.Condition"
                                                        DataSource="@_repairConditions"
                                                        AllowFiltering="true"
                                                        @onclick="@(() => OnComboBoxClick2(currentIndex))"
                                                        FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                                        Enabled="@(!isSaving)"
                                                        CssClass="modern-combo">
                                            </SfComboBox>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-mobile">
                            <i class="fas fa-inbox"></i>
                            <p>No spare parts added yet</p>
                        </div>
                    }
                </div>

                <button type="button"
                        class="btn-add-spare"
                        @onclick="AddSparePart"
                        disabled="@isSaving">
                    <i class="fas fa-plus"></i>
                    <span>@Loc[nameof(ResourceStrings.TextAddSparePart)]</span>
                </button>
            </div>
        </div>

        <div class="e-footer-content">
            <SfButton type="submit" class="material-btn primary" disabled="@isSaving">
                @if (isSaving)
                {
                    <i class="fas fa-spinner fa-spin"></i>
                    <span>Saving...</span>
                }
                else
                {
                    <i class="fas fa-save"></i>
                    <span>@Loc[nameof(ResourceStrings.TextSave)]</span>
                }
            </SfButton>
            <SfButton type="button" class="material-btn danger" @onclick="CancelEditDialog" disabled="@isSaving">
                <i class="fas fa-times"></i>
                <span>@Loc[nameof(ResourceStrings.TextDecline)]</span>
            </SfButton>
        </div>
    </EditForm>
</SfDialog>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- SPARE PART DETAILS DIALOG                              -->
<!-- ═══════════════════════════════════════════════════════ -->
<SfDialog IsModal="true" @bind-Visible="isSparePartDialogVisible" Width="600px" Header="Spare Part Details" ShowCloseIcon="true">
    <DialogEvents OnOverlayModalClick="OnOverlayModalClickHandler"></DialogEvents>
    <div class="modal-content" style="padding: 20px; font-family: Arial, sans-serif;">
        <div class="row">
            <div class="col-md-4">
                <img src="@selectedSparePart.PictureUrl" alt="@selectedSparePart.ItemName" style="width: 100%; height: auto; border-radius: 8px; object-fit: cover;" />
            </div>
            <div class="col-md-8">
                <div style="margin-top: 10px;">
                    <p><strong>Item Name:</strong> @selectedSparePart.ItemName</p>
