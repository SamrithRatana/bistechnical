@code {
    [Parameter] public string ReportNo { get; set; }
    [Inject] protected NavigationManager Navigation { get; set; }

    // ── Grid ──
    private SfGrid<RepairServices> MyGrid;
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;
    private string activeBreakpoint { get; set; }
    private IEnumerable<RepairServices> filteredRepairServices;
    private HubConnection hubConnection;
    public string[] ToolbarItems = new string[] { "ColumnChooser", "Search" };

    // ── Dialogs ──
    private SfDialog DialogEdit;
    private SfDialog DialogView;
    private bool isViewDialogVisible = false;
    private bool isEditDialogVisible = false;

    // ── Row selection ──
    private bool isRowSelected = false;
    private RepairServices _selectedRepairService;

    // ── Edit / Inspect form ──
    private InspectItemRequest inspectItem = new InspectItemRequest();
    private bool isEditMode = false;
    private string saveErrorMessage = string.Empty;
    private IEnumerable<ServiceType> _serviceTypes;
    private List<string> _repairConditions = new List<string> { "Fix", "Replace", "Free" };

    // ── Spare parts ──
    private IEnumerable<SparePartObject> _spareParts = Enumerable.Empty<SparePartObject>();
    private List<SparePartObject> filteredSpareParts = new();
    private bool isSparePartLoading = false;
    private SparePartObject selectedSparePart = new SparePartObject();
    private bool isSparePartDialogVisible = false;
    private bool isXSmallScreen;

    // ── Save state ──
    private bool isSaving = false;

    // ── Pagination ──
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 0;
    private int totalItems = 0;

    // ── Search ──
    private SfTextBox ReceivedSearchBox;
    private string ReceivedSearchValue { get; set; }
    private System.Threading.Timer _receivedSearchDebounceTimer;
    private System.Threading.Timer _sparePartSearchDebounceTimer;

    // ── Users ──
    private Dictionary<string, string> _allUsers = new Dictionary<string, string>();
    private bool _usersLoaded = false;

    // ── Misc ──
    private Timer colorChangeTimer;
    private bool isRed = true;

    // ─────────────────────────────────────────────────────
    // LIFECYCLE
    // ─────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        try
        {
            await LoadAllUsersAsync();
            await LoadPageData();
            _serviceTypes = await RepairItemService.GetServiceTypesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading data: {ex.Message}");
        }

        var routeData = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Split('/');
        string reportNoFromRoute = routeData.Length > 1 ? routeData[1] : null;

        if (!string.IsNullOrEmpty(reportNoFromRoute))
        {
            var result = await RepairItemService.SearchRepairServicesAsync(
                pageNumber: 1, pageSize: 10, status: "Inspecting", searchTerm: reportNoFromRoute);
            filteredRepairServices = result.Items;

            var selected = filteredRepairServices.FirstOrDefault();
            if (selected != null)
                await OnAcceptButtonClick(selected);
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/itemHub"))
            .Build();

        hubConnection.On<string>("ReceiveItemUpdate", async (message) =>
        {
            await Cache.InvalidateManyAsync(
                CacheKeys.InspectItem(currentPage, pageSize),
                CacheKeys.DashboardStats
            );
            await LoadPageData();

            if (isEditDialogVisible && filteredSpareParts.Any())
            {
                var result = await SparePartService.GetSparePartsPagedAsync(1, 10);
                filteredSpareParts = result.Items.ToList();
                await EnsureSelectedSparePartsInFilteredList();
            }

            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<Guid>("BroadcastItemDelete", (deletedItemId) =>
        {
            filteredRepairServices = filteredRepairServices
                .Where(item => item.Id != deletedItemId).ToList();
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();

        hubConnection.Closed += async (error) =>
        {
            await Task.Delay(new Random().Next(0, 5) * 1000);
            try { await hubConnection.StartAsync(); }
            catch (Exception ex) { Console.WriteLine($"Reconnection failed: {ex.Message}"); }
        };

        colorChangeTimer = new Timer(1000);
        colorChangeTimer.Elapsed += OnTimerElapsed;
        colorChangeTimer.Start();
    }
    // ─────────────────────────────────────────────────────
    // DATA LOADING
    // ─────────────────────────────────────────────────────
  private async Task LoadAllUsersAsync()
{
    if (_usersLoaded) return;
    try
    {
        _allUsers = await GlobalUserCache.GetUsersAsync();
        _usersLoaded = true;
    }
    catch (Exception ex)
    {
        Console.WriteLine($"❌ Error loading users: {ex.Message}");
        _allUsers = new Dictionary<string, string>();
    }
}

    private async Task LoadPageData()
    {
        try
        {
            var result = await Cache.GetOrSetAsync(
                CacheKeys.InspectItem(currentPage, pageSize),
                () => RepairItemService.SearchRepairServicesAsync(
                    pageNumber: currentPage,
                    pageSize: pageSize,
                    status: "Inspecting",
                    sortBy: "reportNo",
                    sortDescending: true),
                TimeSpan.FromMinutes(3)
            );

            filteredRepairServices = result?.Items ?? new List<RepairServices>();
            totalPages = result?.TotalPages ?? 0;
            totalItems = result?.TotalCount ?? 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading page data: {ex.Message}");
        }
    }

    // ─────────────────────────────────────────────────────
    // PAGINATION
    // ─────────────────────────────────────────────────────
    private async Task NextPage() { if (currentPage < totalPages) { currentPage++; await LoadPageData(); StateHasChanged(); } }
    private async Task PreviousPage() { if (currentPage > 1) { currentPage--; await LoadPageData(); StateHasChanged(); } }
    private async Task FirstPage() { currentPage = 1; await LoadPageData(); StateHasChanged(); }
    private async Task LastPage() { currentPage = totalPages; await LoadPageData(); StateHasChanged(); }

    // ─────────────────────────────────────────────────────
    // HELPERS
    // ─────────────────────────────────────────────────────
    private string GetUserNameById(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty) return "Unknown";
        if (!_usersLoaded) return "Loading...";
        return _allUsers.TryGetValue(userId.Value.ToString(), out string username) ? username : "Unknown User";
    }

    private string GetLocalizedServiceTypeName(string serviceTypeName)
    {
        if (string.IsNullOrEmpty(serviceTypeName)) return "Unknown";
        return serviceTypeName switch
        {
            "Free" => Loc[nameof(ResourceStrings.TextServiceTypeFree)],
            "Charge" => Loc[nameof(ResourceStrings.TextServiceTypeCharge)],
            _ => serviceTypeName
        };
    }

    private string GetStockColorForCombo(int q) => q <= 0 ? "#dc3545" : q <= 5 ? "#ff6b6b" : q <= 10 ? "#ffc107" : "#28a745";
    private string GetStockIconForCombo(int q) => q <= 0 ? "fas fa-exclamation-triangle" : q <= 5 ? "fas fa-exclamation-circle" : q <= 10 ? "fas fa-info-circle" : "fas fa-check-circle";
    private string GetStockTextForCombo(int q) => q <= 0 ? "OUT OF STOCK" : q <= 5 ? "CRITICAL" : q <= 10 ? "LOW STOCK" : "IN STOCK";

    private SparePartObject GetSparePartById(Guid? sparePartId)
    {
        if (!sparePartId.HasValue || sparePartId.Value == Guid.Empty) return null;
        return _spareParts.FirstOrDefault(sp => sp.Id == sparePartId.Value);
    }

    private void OnTimerElapsed(object sender, ElapsedEventArgs e)
    {
        isRed = !isRed;
        InvokeAsync(StateHasChanged);
    }

    // ─────────────────────────────────────────────────────
    // GRID EVENTS
    // ─────────────────────────────────────────────────────
    private async Task ReceivedRowSelectHandler(RowSelectEventArgs<RepairServices> args)
    {
        _selectedRepairService = args.Data;
        isRowSelected = _selectedRepairService != null;
        await Task.CompletedTask;
        StateHasChanged();
    }

    // ─────────────────────────────────────────────────────
    // ACCEPT BUTTON → opens edit/inspect dialog inline
    // ─────────────────────────────────────────────────────
    private async Task OnAcceptButtonClick(RepairServices item)
    {
        _selectedRepairService = item;
        isRowSelected = true;

        isEditMode = true;
        inspectItem = new InspectItemRequest
        {
            Id = item.Id,
            Inspection = item.Inspection,
            Solution = item.Solution,
            InspectBy = item.inspectBy ?? Guid.Empty,
            ServiceTypeId = item.ServiceTypeId ?? 1
        };

        if (item.SparePartItems != null && item.SparePartItems.Any())
        {
            inspectItem.SpareParts = item.SparePartItems
                .Where(sp => sp.SparePartId.HasValue && sp.SparePartId.Value != Guid.Empty)
                .Select(sp => new SparePart
                {
                    Id = sp.Id,
                    SparePartId = sp.SparePartId.Value,
                    Description = sp.Description ?? string.Empty,
                    Quantity = sp.Quantity,
                    Condition = sp.Condition ?? string.Empty
                }).ToList();
            await LoadSelectedSparePartsOnly(inspectItem.SpareParts);
        }
        else
        {
            inspectItem.SpareParts = new List<SparePart>();
            filteredSpareParts.Clear();
        }

        isEditDialogVisible = true;
        StateHasChanged();
    }

    // ─────────────────────────────────────────────────────
    // TOOLBAR ACTIONS
    // ─────────────────────────────────────────────────────
    private void NewRepairService_Click() { /* disabled per toolbar */ }

    private void EditRepairService_Click()
    {
        if (_selectedRepairService != null)
            _ = OnAcceptButtonClick(_selectedRepairService);
    }

    private void ShowCheckListDialog()
    {
        if (_selectedRepairService != null) { isViewDialogVisible = true; StateHasChanged(); }
    }

    // ─────────────────────────────────────────────────────
    // EDIT DIALOG — SPARE PARTS
    // ─────────────────────────────────────────────────────
    private async Task AddSparePart()
    {
        inspectItem.SpareParts ??= new List<SparePart>();
        inspectItem.SpareParts.Add(new SparePart
        {
            Id = Guid.Empty,
            SparePartId = Guid.Empty,
            Description = string.Empty,
            Quantity = 1,
            Condition = string.Empty
        });
        await EnsureSelectedSparePartsInFilteredList();
        StateHasChanged();
    }

    private async Task RemoveSparePart(SparePart sparePart)
    {
        if (inspectItem.SpareParts == null) return;

        if (sparePart.Id == Guid.Empty)
        {
            inspectItem.SpareParts.Remove(sparePart);
            StateHasChanged();
            return;
        }

        if (inspectItem.Id != Guid.Empty)
        {
            try
            {
                await InspectItemService.DeleteSparepartItemAsync(inspectItem.Id, sparePart.Id);
                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = "Spare part removed successfully",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });
            }
            catch (Exception ex)
            {
                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Error",
                    Title = "Error",
                    Text = $"Failed to remove spare part: {ex.Message}",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Danger
                });
                return;
            }
        }

        inspectItem.SpareParts.Remove(sparePart);
        StateHasChanged();
    }

    private async Task EnsureSelectedSparePartsInFilteredList()
    {
        if (inspectItem?.SpareParts == null || !inspectItem.SpareParts.Any()) return;

        var selectedIds = inspectItem.SpareParts
            .Where(sp => sp.SparePartId != Guid.Empty)
            .Select(sp => sp.SparePartId)
            .ToList();

        foreach (var selectedId in selectedIds)
        {
            if (!filteredSpareParts.Any(sp => sp.Id == selectedId))
            {
                try
                {
                    var sp = await SparePartService.GetSparePartByIdAsync(selectedId);
                    if (sp != null) filteredSpareParts.Insert(0, sp);
                }
                catch (Exception ex) { Console.WriteLine($"❌ Error fetching {selectedId}: {ex.Message}"); }
            }
        }
    }

    private async Task LoadSelectedSparePartsOnly(List<SparePart> spareParts)
    {
        try
        {
            filteredSpareParts.Clear();
            if (spareParts == null || !spareParts.Any()) return;

            var sparePartIds = spareParts
                .Where(sp => sp.SparePartId != Guid.Empty)
                .Select(sp => sp.SparePartId)
                .Distinct()
                .ToList();

            if (!sparePartIds.Any()) return;

            var loaded = new List<SparePartObject>();
            foreach (var id in sparePartIds)
            {
                try
                {
                    var sp = await SparePartService.GetSparePartByIdAsync(id);
                    if (sp != null) loaded.Add(sp);
                }
                catch (Exception ex) { Console.WriteLine($"❌ Error loading {id}: {ex.Message}"); }
            }

            filteredSpareParts = loaded;
            _spareParts = loaded;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in LoadSelectedSparePartsOnly: {ex.Message}");
            filteredSpareParts.Clear();
        }
    }

    private async Task OnComboBoxClick(int index)
    {
        if (!filteredSpareParts.Any())
        {
            try
            {
                var result = await SparePartService.GetSparePartsPagedAsync(pageNumber: 1, pageSize: 10);
                filteredSpareParts = result.Items.ToList();
                StateHasChanged();
            }
            catch (Exception ex) { Console.WriteLine($"Error loading spare parts: {ex.Message}"); }
        }
    }

    private async Task OnComboBoxClick2(int index) => await Task.CompletedTask;

    public async Task OnFilteringSparePart(Syncfusion.Blazor.DropDowns.FilteringEventArgs args)
    {
        args.PreventDefaultAction = true;
        _sparePartSearchDebounceTimer?.Dispose();
        isSparePartLoading = true;
        StateHasChanged();

        if (string.IsNullOrWhiteSpace(args.Text))
        {
            isSparePartLoading = false;
            await EnsureSelectedSparePartsInFilteredList();
            StateHasChanged();
            return;
        }

        _sparePartSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    var result = await SparePartService.SearchSparePartsAsync(
                        pageNumber: 1, pageSize: 50, searchTerm: args.Text.Trim());
                    filteredSpareParts = result.Items.ToList();
                    await EnsureSelectedSparePartsInFilteredList();
                    isSparePartLoading = false;
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ Search error: {ex.Message}");
                isSparePartLoading = false;
                StateHasChanged();
            }
        }, null, 300, Timeout.Infinite);
    }

    // ─────────────────────────────────────────────────────
    // EDIT DIALOG — SAVE
    // ─────────────────────────────────────────────────────
    private async Task Save()
    {
        try
        {
            saveErrorMessage = string.Empty;
            isSaving = true;
            StateHasChanged();

            if (inspectItem == null || inspectItem.Id == Guid.Empty)
                throw new InvalidOperationException("Invalid inspection data.");

            inspectItem.SpareParts ??= new List<SparePart>();

            var currentUserId = JwtSessionService.GetCurrentUserId();
            if (!currentUserId.HasValue)
            {
                saveErrorMessage = "Your session has expired. Please login again.";
                isSaving = false;
                StateHasChanged();
                return;
            }

            inspectItem.InspectBy = currentUserId.Value;
            Guid repairServiceId = inspectItem.Id;

            var validSpareParts = inspectItem.SpareParts
                .Where(sp => sp.SparePartId != Guid.Empty && sp.Quantity > 0)
                .ToList();

            foreach (var sp in validSpareParts)
            {
                sp.ServiceId = repairServiceId;
                sp.IsHoldStatus = true;
            }

            inspectItem.SpareParts = validSpareParts;

            if (isEditMode)
                await InspectItemService.UpdateInspectItemAsync(repairServiceId, inspectItem);
            else
                await InspectItemService.CreateInspectItemAsync(repairServiceId, inspectItem);

            // ✅ Cache Invalidation
            await Cache.InvalidateManyAsync(
                CacheKeys.InspectItem(currentPage, pageSize),
                CacheKeys.InspectItem(1, pageSize),
                CacheKeys.DashboardStats
            );

            // ✅ RabbitMQ Publish
            // ✅ RabbitMQ Publish
            if (isEditMode)
            {
                await MQ.PublishUpdateAsync(
                    MessageQueueHelper.Queues.InspectItem,
                    repairServiceId,
                    _selectedRepairService?.reportNo,
                    currentUserId.Value
                );
            }
            else
            {
                await MQ.PublishCreateAsync(
                    MessageQueueHelper.Queues.InspectItem,
                    repairServiceId,
                    _selectedRepairService?.reportNo,
                    currentUserId.Value
                );
            }

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Customization",
                Title = "Success",
                Text = isEditMode ? "Inspection updated successfully" : "Inspection created successfully",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Success
            });

            bool wasEditMode = isEditMode;

            isEditDialogVisible = false;
            isEditMode = false;
            _selectedRepairService = null;
            isRowSelected = false;
            filteredSpareParts.Clear();
            _spareParts = Enumerable.Empty<SparePartObject>();
            isSaving = false;
            StateHasChanged();

            _ = Task.Run(async () =>
            {
                try
                {
                    if (hubConnection?.State == HubConnectionState.Connected)
                        await hubConnection.SendAsync("BroadcastItemUpdate",
                            wasEditMode ? "ItemUpdated" : "ItemCreated");

                    currentPage = 1;
                    await Cache.InvalidateManyAsync(CacheKeys.InspectItem(1, pageSize));
                    await LoadPageData();
                    await InvokeAsync(StateHasChanged);
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Background error: {ex.Message}");
                }
            });
        }
        catch (HttpRequestException httpEx)
        {
            var fullError = httpEx.Message;
            string display = "An error occurred while saving.";
            try
            {
                if (fullError.Contains("Insufficient stock"))
                {
                    var match = System.Text.RegularExpressions.Regex.Match(
                        fullError,
                        @"Insufficient stock for[^:]*: ([^.]+)\.\s*Available: (\d+),?\s*Required: (\d+)");
                    display = match.Success
                        ? $"Insufficient stock for: {match.Groups[1].Value}. Available: {match.Groups[2].Value}, Required: {match.Groups[3].Value}"
                        : "Insufficient stock. Please check inventory.";
                }
            }
            catch { }

            saveErrorMessage = display;
            isSaving = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            saveErrorMessage = ex.Message;
            isSaving = false;
            StateHasChanged();
            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = $"Failed to save: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

    private void CancelEditDialog()
    {
        isEditDialogVisible = false;
        _selectedRepairService = null;
        isRowSelected = false;
        isEditMode = false;
        filteredSpareParts.Clear();
        _spareParts = Enumerable.Empty<SparePartObject>();
        saveErrorMessage = string.Empty;
    }

    // ─────────────────────────────────────────────────────
    // SPARE PART DETAILS DIALOG
    // ─────────────────────────────────────────────────────
    private void ShowFullDetails(SparePartObject sparePart)
    {
        selectedSparePart = sparePart;
        isSparePartDialogVisible = true;
    }

    private void CloseSparePartDialog() => isSparePartDialogVisible = false;
    private void OnOverlayModalClickHandler(OverlayModalClickEventArgs args) => isSparePartDialogVisible = false;

    // ─────────────────────────────────────────────────────
    // CHECK-LIST / VIEW DIALOG
    // ─────────────────────────────────────────────────────
    private void CloseViewDialog() => isViewDialogVisible = false;
    private void OverlayClick(OverlayModalClickEventArgs args) => isViewDialogVisible = false;

    // ─────────────────────────────────────────────────────
    // SEARCH
    // ─────────────────────────────────────────────────────
    private async Task PerformReceivedSearch()
    {
        if (string.IsNullOrWhiteSpace(ReceivedSearchValue))
        {
            await LoadPageData();
            return;
        }
        await PerformReceivedSearchInternal(ReceivedSearchValue);
    }

    private async Task PerformReceivedSearchInternal(string searchValue)
    {
        try
        {
            var result = await RepairItemService.SearchRepairServicesAsync(
                pageNumber: 1,
                pageSize: pageSize,
                status: "Inspecting",
                searchTerm: searchValue.Trim(),
                sortBy: "reportNo",
                sortDescending: true);

            filteredRepairServices = result.Items;
            totalPages = result.TotalPages;
            totalItems = result.TotalCount;
            currentPage = 1;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Received items search error: {ex.Message}");
            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Search Error",
                Text = $"Failed to search: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

    private void OnReceivedSearchInput(InputEventArgs args)
    {
        _receivedSearchDebounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(args.Value))
        {
            _ = Task.Run(async () =>
                await InvokeAsync(async () =>
                {
                    await Cache.InvalidateManyAsync(
                        CacheKeys.InspectItem(currentPage, pageSize));
                    await LoadPageData();
                    StateHasChanged();
                }));
            return;
        }

        _receivedSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                    await PerformReceivedSearchInternal(args.Value));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Search error: {ex.Message}");
            }
        }, null, 300, Timeout.Infinite);
    }

    private async Task ClearReceivedSearch()
    {
        ReceivedSearchValue = string.Empty;
        currentPage = 1;
        await Cache.InvalidateManyAsync(
            CacheKeys.InspectItem(currentPage, pageSize),
            CacheKeys.InspectItem(1, pageSize)
        );
        await LoadPageData();
        StateHasChanged();
    }

    // ─────────────────────────────────────────────────────
    // PRINT
    // ─────────────────────────────────────────────────────
    private async Task ShowReportPreview(RepairServices selectedRepairService)
    {
        if (selectedRepairService == null) return;
        try
        {
            var report = new Report2();
            string repairByUser = GetUserNameById(selectedRepairService.repairBy);
            string verifiedByUser = GetUserNameById(selectedRepairService.verifiedBy);

            var phones = await Task.WhenAll(
                GlobalUserCache.GetUserPhoneNumberByIdAsync(selectedRepairService.repairBy, autoLoad: true),
                GlobalUserCache.GetUserPhoneNumberByIdAsync(selectedRepairService.verifiedBy, autoLoad: true)
            );

            if (selectedRepairService.SparePartItems != null)
            {
                var validParts = selectedRepairService.SparePartItems
                    .Where(i => i.SparePartId.HasValue && i.SparePartId.Value != Guid.Empty)
                    .ToList();
                var fetchTasks = validParts.Select(async item =>
                {
                    try
                    {
                        var details = await SparePartService.GetSparePartByIdAsync(item.SparePartId.Value);
                        if (details != null)
                        {
                            item.ItemName = details.ItemName;
                            item.SerialNumber = details.SerialNumber;
                            item.UseFor = details.UseFor;
                        }
                    }
                    catch { }
                }).ToList();
                await Task.WhenAll(fetchTasks);
            }

            report.SetParameters(selectedRepairService, selectedRepairService.ServiceLocation,
                selectedRepairService.SparePartItems, selectedRepairService.hasContract,
                repairByUser, verifiedByUser, phones[0], phones[1]);

            foreach (var param in new[] { "Id", "ReportNumber", "CompanyName", "ContactName", "PhoneNumber", "Address", "ItemName", "SerialNumber", "CustomerRequest", "inspection", "Solution", "CompanyServiceChecked", "OnSiteChecked", "HasContract", "Datestart", "Datefinish", "RepairBy", "VerifiedBy", "RepairByPhone", "VerifiedByPhone" })
                report.Parameters[param].Visible = false;

            byte[] reportData;
            using (var ms = new MemoryStream()) { report.ExportToPdf(ms); reportData = ms.ToArray(); }

            string sanitized = selectedRepairService.reportNo?.Replace("/", "-").Replace("\\", "-") ?? "Report";
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.printReport",
                Convert.ToBase64String(reportData),
                $"ServiceReport_{sanitized}_{DateTime.Now:yyyyMMdd_HHmmss}.pdf");
        }
        catch (Exception ex)
        {
            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Report Error",
                Text = $"Failed: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

    // ─────────────────────────────────────────────────────
    // EXPORT
    // ─────────────────────────────────────────────────────
    public async Task ExportToExcel() => await MyGrid.ExportToExcelAsync();
    public async Task ExportToPdf() => await MyGrid.ExportToPdfAsync();

    // ─────────────────────────────────────────────────────
    // DISPOSE
    // ─────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        _receivedSearchDebounceTimer?.Dispose();
        _sparePartSearchDebounceTimer?.Dispose();
        colorChangeTimer?.Dispose();
        if (hubConnection != null) await hubConnection.DisposeAsync();
    }
}

