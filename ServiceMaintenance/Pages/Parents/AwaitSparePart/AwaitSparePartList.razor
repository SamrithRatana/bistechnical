    private async Task LoadGridData()
    {
        try
        {
            if (!string.IsNullOrWhiteSpace(GridSearchValue))
            {
                // Active search bypasses cache
                var result = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: currentGridPage,
                    pageSize: gridPageSize,
                    status: "Awaiting SparePart",
                    searchTerm: GridSearchValue.Trim(),
                    sortBy: "reportNo",
                    sortDescending: true
                );

                filteredRepairServices2 = result.Items;
                totalGridPages = result.TotalPages;
                totalGridItems = result.TotalCount;
            }
            else
            {
                var result = await Cache.GetOrSetAsync(
                    CacheKeys.AwaitSparePart(currentGridPage, gridPageSize),
                    () => RepairItemService.SearchRepairServicesAsync(
                        pageNumber: currentGridPage,
                        pageSize: gridPageSize,
                        status: "Awaiting SparePart",
                        sortBy: "reportNo",
                        sortDescending: true),
                    TimeSpan.FromMinutes(3)
                );

                filteredRepairServices2 = result?.Items ?? new List<RepairServices>();
                totalGridPages = result?.TotalPages ?? 0;
                totalGridItems = result?.TotalCount ?? 0;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading grid data: {ex.Message}");
        }
    }

    private void OnGridSearchInput(InputEventArgs args)
    {
        _gridSearchDebounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(args.Value))
        {
            _ = Task.Run(async () =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadGridData();
                    StateHasChanged();
                });
            });
            return;
        }

        _gridSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await PerformGridSearchInternal(args.Value);
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Grid search error: {ex.Message}");
            }
        }, null, 500, Timeout.Infinite);
    }

