<DxToastProvider Name="Customization"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
           @if (CanCreate)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" Click="NewRepairService_Click" IconCssClass="far fa-file" CssClass="toolbar-item" Enabled="false" />
            }
            @if (CanEdit)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" Click="EditRepairService_Click" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="false" />
            }
          @if (CanDelete)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" Click="EditRepairService_Click" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="false" />
            }
            @if (CanExport)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download" Enabled="@exportEnabled">
                <Items>
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ExportToPdf" IconCssClass="fas fa-file-pdf" />
                </Items>
            </DxToolbarItem>
            }
            @if (CanPrint)
            {
            <DxToolbarItem Text="Print Report" Click="() => ShowReportPreview(_selectedRepairService)" CssClass="toolbar-item" IconCssClass="fas fa-print" />      
            }
            @if (CanView)
            {
              <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" Click="ToggleView" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" Visible="false"/>
            }
           
        </DxToolbar>
    </div>
</div>
<br />
<SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>
@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical; // Default rendering mode

    // Set properties based on the active breakpoint
    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical; // Stack items vertically
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true; // Enable adaptive UI for medium screens
        renderingMode = RowDirection.Horizontal; // Use horizontal layout
    }
    else
    {
        enableAdaptiveUIMode = false; // Disable adaptive UI for larger screens
    }
}

@if (CanAccess)
{
@if (CanView)
{
     @if (isGridView)
{
    <!-- Search Bar for Grid View -->
    <div style="margin-bottom: 15px; padding: 15px; background-color: #f9f9f9; border-radius: 4px;">
        <div style="display: flex; gap: 10px; align-items: center;">
            <SfTextBox @ref="GridSearchBox"
                       Placeholder="Search by Report No, Company, Serial Number..."
                       ShowClearButton="true"
                       Width="400px"
                       @bind-Value="GridSearchValue"
                       Input="OnGridSearchInput">
            </SfTextBox>
            
            <SfButton Content="Search" 
                      CssClass="e-btn e-primary" 
                      IconCss="fas fa-search"
                      OnClick="PerformGridSearch" />
            
            <SfButton Content="Clear" 
                      CssClass="e-btn e-outline" 
                      IconCss="fas fa-times"
                      OnClick="ClearGridSearch" />
        </div>
        
        @if (!string.IsNullOrEmpty(GridSearchValue))
        {
            <div style="margin-top: 10px; color: #666; font-size: 14px;">
                <i class="fas fa-info-circle"></i> Searching for: <strong>@GridSearchValue</strong>
            </div>
        }
    </div>

    <SfGrid @ref="MyGrid"
            DataSource="@filteredRepairServices2"
            AllowPaging="false"
            AllowSorting="true"
            ShowColumnChooser="true"
            AllowExcelExport="true"
            AllowPdfExport="true"
            SelectionMode="GridSelectionMode.Single"
            Toolbar="@ToolbarItems"
            EnableAdaptiveUI="@enableAdaptiveUIMode"
            RowRenderingMode="@renderingMode"
                    AllowResizing="true"
                    AllowFiltering="true"
            AllowSelection="true">
        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
        <GridEvents RowSelected="RowSelectHandler" TValue="RepairServices"></GridEvents>
        <GridColumns>
            <GridColumn Field="Id" HeaderText="Id" Width="150" Format="d" Visible="false" />
            <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="150" />
            <GridColumn Field="awaitingSparepartDate" HeaderText="@Loc[nameof(ResourceStrings.Textwaitsparepart)]" Width="150" Format="dd/MM/yyyy HH:mm tt" />
            <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" Width="200" />
            <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="200" />
            <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="200" />
            <GridColumn Field="ServiceLocation" HeaderText="@Loc[nameof(ResourceStrings.TextServiceLocation)]" Width="200" />
                    <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="220">
                        <Template>
                            @{
                                var item = context as RepairServices;
                                var currentStatus = item?.Status ?? "Awaiting SparePart";
                                var bgColor = currentStatus == "Awaiting Customer Confirm" ? "#5bc8c8" : "#cce5ff";
                                var textColor = currentStatus == "Awaiting Customer Confirm" ? "#003d3d" : "#004085";
                                var borderColor = currentStatus == "Awaiting Customer Confirm" ? "#3aa8a8" : "#b8daff";
                            }
                            <select style="background-color: @bgColor;
                   color: @textColor;
                   border: 1px solid @borderColor;
                   border-radius: 20px;
                   padding: 4px 10px;
                   font-size: 12px;
                   font-weight: 600;
                   cursor: pointer;
                   outline: none;
                   font-family: 'Khmer OS', sans-serif;"
                                    @key="@item?.Id"
                                    @onchange="async (e) => await OnAwaitStatusChanged(item, e.Value?.ToString())">
                                <option value="Awaiting SparePart"
                                        selected="@(currentStatus == "Awaiting SparePart")"
                                        style="background-color:#ffffff; color:#212529;">
                                    រង់ចាំគ្រឿងបន្លាស់
                                </option>                      
                                <option value="Inspecting"
                                        selected="@(currentStatus == "Inspecting")"
                                        style="background-color:#ffffff; color:#212529;">
                                    បញ្ជូនទៅផ្នែកជាងវិញ
                                </option>
                                <option value="Awaiting Customer Confirm"
                                        selected="@(currentStatus == "Awaiting Customer Confirm")"
                                        style="background-color:#ffffff; color:#212529;">
                                    បញ្ជូនទៅផ្នែកទីផ្សារ
                                </option>
                            </select>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="setAwaitingCustomerConfirmBy" HeaderText="@Loc[nameof(ResourceStrings.TextsetAwaitingSparePartBy)]" Width="150">
                <Template>
                    @{
                        var item = context as RepairServices;
                        var username = GetUserNameById(item.setAwaitingSparepartBy);
                    }
                    @username
                </Template>
            </GridColumn>
            <GridColumn HeaderText="Actions" Width="120">
                <Template>
                    @{
                        var item = context as RepairServices;
                    }
                    <DxButton IconCssClass="fas fa-eye"
                              CssClass="icon-button info"
                              RenderStyle="ButtonRenderStyle.Info"
                              RenderStyleMode="ButtonRenderStyleMode.Text"
                              Text="@Loc[nameof(ResourceStrings.TextView)]"
                              @onclick="() => ShowRepairServiceDetails(item)" />
                </Template>
            </GridColumn>
        </GridColumns>
    </SfGrid>

    <!-- Custom Pagination -->
    <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; border-top: 1px solid #ddd; margin-top: 10px; background-color: #f9f9f9;">
        <div style="display: flex; align-items: center; gap: 10px;">
            <button class="e-btn e-normal" @onclick="GridFirstPage" disabled="@(currentGridPage == 1)">
                <i class="fas fa-angle-double-left"></i> First
            </button>
            <button class="e-btn e-normal" @onclick="GridPreviousPage" disabled="@(currentGridPage == 1)">
                <i class="fas fa-angle-left"></i> Previous
            </button>

            <span style="padding: 0 15px; font-weight: 500;">
                Page @currentGridPage of @totalGridPages
            </span>

            <button class="e-btn e-normal" @onclick="GridNextPage" disabled="@(currentGridPage >= totalGridPages)">
                Next <i class="fas fa-angle-right"></i>
            </button>
            <button class="e-btn e-normal" @onclick="GridLastPage" disabled="@(currentGridPage >= totalGridPages)">
                Last <i class="fas fa-angle-double-right"></i>
            </button>
        </div>

        <div style="color: #666;">
            Showing @Math.Min((currentGridPage - 1) * gridPageSize + 1, totalGridItems) - @Math.Min(currentGridPage * gridPageSize, totalGridItems) of @totalGridItems items
        </div>
    </div>
}
    else
    {
    @* Replace your current row div structure (around line 180) with this: *@

    <div class="row">
        @* Properties Panel - Shows first on mobile due to order-first class *@
        <div class="col-lg-3 order-lg-2 order-first property-section">
            <div class="property-panel-section">
                <div class="property-panel-header">Properties</div>
                <div class="property-panel-content">
                    <table class="table">
                        <tr>
                            <td>
                                <SfTextBox Placeholder="Search services"
                                           ShowClearButton="true"
                                           Width="100%"
                                           ValueChange="OnSearch"
                                           @oninput="OnInputClick"
                                           @bind-Value="SearchValue">
                                </SfTextBox>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <SfDropDownList TValue="string"
                                                TItem="string"
                                                DataSource="@SortingType"
                                                Placeholder="Sorting order"
                                                Width="100%"
                                                @bind-Value="SortingValue">
                                    <DropDownListEvents TValue="string" TItem="string" ValueChange="OnSorting"></DropDownListEvents>
                                </SfDropDownList>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <SfMultiSelect TValue="string[]"
                                               TItem="ServiceStatus"
                                               AllowFiltering="true"
                                               DataSource="@_serviceStatuses"
                                               Placeholder="Select Service Statuses"
                                               ShowClearButton="true"
                                               Width="100%"
                                               @bind-Value="FilteringValue">
                                    <MultiSelectFieldSettings Text="Name" Value="Id" />
                                    <MultiSelectEvents TValue="string[]" TItem="ServiceStatus" ValueChange="OnFiltering"></MultiSelectEvents>
                                </SfMultiSelect>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <SfButton Content="Reset" OnClick="OnReset" CssClass="w-100"></SfButton>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        @* Cards Section - Shows second on mobile, first on large screens *@
        <div class="col-lg-9 order-lg-1 order-last">
            <div class="e-card-layout">
                @if (filteredRepairServices == null || !filteredRepairServices.Any())
                {
                    <div class="e-error">
                        <div class="e-error-content">No results found. Please try a different search.</div>
                    </div>
                }
                else
                {
                    <div class="row">
                        @foreach (RepairServices service in PaginatedRepairServices)
                        {
                            var companyName = string.IsNullOrEmpty(service.CompanyName) ? "N/A" : service.CompanyName;
                            var serviceDate = service.ServiceDate != default(DateTime) ? service.ServiceDate.ToString("dd/MM/yyyy HH:mm tt") : "N/A";
                            var customerType = GetCustomerType(service.CompanyName);
                            var imagePath = GetImagePath(customerType);

                            <div class="col-lg-3 col-md-4 col-sm-6">
                                <div id="card_sample_1" class="card_sample">
                                    <SfCard>
                                        <CardImage Image="@imagePath" />
                                        <CardHeader Title="@companyName" SubTitle="@serviceDate" />
                                        <CardContent>
                                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                                                <div>
                                                    <strong>@Loc[nameof(ResourceStrings.Textref)]:</strong>
                                                    <span style="color: red;">@(service.reportNo ?? "N/A")</span>
                                                </div>
                                                <button class="view-icon" @onclick="() => ShowRepairServiceDetails(service)">
                                                    <i class="fa fa-eye" aria-hidden="true"></i> View
                                                </button>
                                            </div>
                                            <div><strong>@Loc[nameof(ResourceStrings.TextItemName)]:</strong> @(service.itemName ?? "N/A")</div>
                                            <div><strong>@Loc[nameof(ResourceStrings.TextSerialNumber)]:</strong> @(service.serialNumber ?? "N/A")</div>
                                            <div><strong>@Loc[nameof(ResourceStrings.TextServiceLocation)]:</strong> @(service.ServiceLocation ?? "N/A")</div>
                                            <div>
                                                <strong>@Loc[nameof(ResourceStrings.TextStatus)]:</strong>
                                                <span class="@GetStatusClass(service.Status)">
                                                    @(service.Status ?? "N/A")
                                                </span>
                                            </div>
                                        </CardContent>
                                        <CardFooter>
                                            <CardFooterContent>
                                                <SfButton CssClass="e-btn e-outline e-primary" @onclick="() => OnApplyButtonClick(service)">
                                                    @Loc[nameof(ResourceStrings.TextSetWaitSparePart)]
                                                </SfButton>
                                            </CardFooterContent>
                                        </CardFooter>
                                    </SfCard>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination controls -->
                    <div class="pagination-controls">
                        <SfButton CssClass="e-btn e-outline e-primary" @onclick="GoToPreviousPage" Disabled="@IsFirstPage">
                            @Loc[nameof(ResourceStrings.TextPrevious)]
                        </SfButton>
                        <span>Page @currentPage of @totalPages</span>
                        <SfButton CssClass="e-btn e-outline e-primary" @onclick="GoToNextPage" Disabled="@IsLastPage">
                            @Loc[nameof(ResourceStrings.TextNext)]
                        </SfButton>
                    </div>
                }
            </div>
        </div>
    </div>
    }  
   }
 }

<SfDialog @ref="ConfirmationDialog"
          IsModal="true"
          Width="400px"
          ShowCloseIcon="true"
          Visible="@isConfirmationDialogVisible">
    <DialogTemplates>
        <Header>
            <h2>@pageTitle</h2>
        </Header>
        <Content>
            <p>@Loc[nameof(ResourceStrings.TextConfirmsparedialog)]</p>
        </Content>
        <FooterTemplate>
            <SfButton CssClass="e-btn custom-button" @onclick="ConfirmCustomerConfirm">Yes</SfButton>
            <SfButton CssClass="e-btn e-danger" @onclick="CancelConfirmationDialog">No</SfButton>
        </FooterTemplate>
    </DialogTemplates>
</SfDialog>
<SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true"
          ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
    <DialogTemplates>
        <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
        <Content>
            <div class="report-container">
                <div class="report-body">
                    <table class="report-table">

                        @* Reference No *@
                        @if (!string.IsNullOrEmpty(_selectedRepairService?.reportNo))
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong></td>
                                <td class="report-value">@_selectedRepairService.reportNo</td>
                            </tr>
                        }

                        @* Service Date + Created By *@
                        @if (_selectedRepairService?.ServiceDate != default(DateTime))
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.ServiceDate.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var createdByUser = GetUserNameById(
                                        _selectedRepairService?.createby == Guid.Empty
                                        ? (Guid?)null
                                        : _selectedRepairService.createby);
                                    }
                                    @if (!string.IsNullOrEmpty(createdByUser) && createdByUser != "Unknown" && createdByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @createdByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Inspect Date + Inspect By *@
                        @if (_selectedRepairService?.inspectDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextInspection)]:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.inspectDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var inspectByUser = GetUserNameById(_selectedRepairService?.inspectBy);
                                    }
                                    @if (!string.IsNullOrEmpty(inspectByUser) && inspectByUser != "Unknown" && inspectByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @inspectByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Awaiting Customer Confirm Date + By *@
                        @if (_selectedRepairService?.awaitingCustomerConfirmDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextawaitingCustomerConfirmDate)]:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.awaitingCustomerConfirmDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var confirmByUser = GetUserNameById(_selectedRepairService?.setAwaitingCustomerConfirmBy);
                                    }
                                    @if (!string.IsNullOrEmpty(confirmByUser) && confirmByUser != "Unknown" && confirmByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @confirmByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Awaiting SparePart Date + By *@
                        @if (_selectedRepairService?.awaitingSparepartDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textwaitsparepart)]:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.awaitingSparepartDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var setByUser = GetUserNameById(_selectedRepairService?.setAwaitingSparepartBy);
                                    }
                                    @if (!string.IsNullOrEmpty(setByUser) && setByUser != "Unknown" && setByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @setByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Repair Date + Repair By *@
                        @if (_selectedRepairService?.repairDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairDate)]:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.repairDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var repairByUser = GetUserNameById(_selectedRepairService?.repairBy);
                                    }
                                    @if (!string.IsNullOrEmpty(repairByUser) && repairByUser != "Unknown" && repairByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @repairByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Third Party Repair Date + By *@
                        @if (_selectedRepairService?.thirdPartyRepairDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>Third-party date:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.thirdPartyRepairDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var thirdPartyByUser = GetUserNameById(_selectedRepairService?.thirdPartyRepairBy);
                                    }
                                    @if (!string.IsNullOrEmpty(thirdPartyByUser) && thirdPartyByUser != "Unknown" && thirdPartyByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @thirdPartyByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Finished Date + Verified By *@
                        @if (_selectedRepairService?.finishedDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextFinishDate)]:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.finishedDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var verifiedByUser = GetUserNameById(_selectedRepairService?.verifiedBy);
                                    }
                                    @if (!string.IsNullOrEmpty(verifiedByUser) && verifiedByUser != "Unknown" && verifiedByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @verifiedByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Sale Confirmed Date + By *@
                        @if (_selectedRepairService?.saleConfirmedDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>Sale confirmed date:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.saleConfirmedDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var saleConfirmedByUser = GetUserNameById(_selectedRepairService?.setSaleConfirmedBy);
                                    }
                                    @if (!string.IsNullOrEmpty(saleConfirmedByUser) && saleConfirmedByUser != "Unknown" && saleConfirmedByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @saleConfirmedByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Customer Rejected Date + By *@
                        @if (_selectedRepairService?.customerRejectedDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCustomerReject)]:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.customerRejectedDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var rejectedByUser = GetUserNameById(_selectedRepairService?.setCustomerRejectedBy);
                                    }
                                    @if (!string.IsNullOrEmpty(rejectedByUser) && rejectedByUser != "Unknown" && rejectedByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @rejectedByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Unrepairable Date + By *@
                        @if (_selectedRepairService?.unrepairableDate.HasValue == true)
                        {
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextUnrepairable)]:</strong></td>
                                <td class="report-value">
                                    @_selectedRepairService.unrepairableDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                    @{
                                        var unrepairableByUser = GetUserNameById(_selectedRepairService?.setUnrepairableBy);
                                    }
                                    @if (!string.IsNullOrEmpty(unrepairableByUser) && unrepairableByUser != "Unknown" && unrepairableByUser != "Unknown User")
                                    {
                                        <span style="color: var(--text-secondary); margin-left: 8px;">| @unrepairableByUser</span>
                                    }
                                </td>
                            </tr>
                        }

                        @* Days Taken *@
                        @if (_selectedRepairService?.DaysTaken.HasValue == true)
                        {
