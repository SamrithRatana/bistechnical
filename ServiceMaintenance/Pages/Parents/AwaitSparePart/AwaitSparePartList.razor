    private async Task Save()
    {
        try
        {
            // ✅ Get current user ID from authentication state
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (!user.Identity.IsAuthenticated)
            {
                Console.WriteLine("❌ User is not authenticated");
                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Error",
                    Title = "Authentication Error",
                    Text = "User is not authenticated",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Danger
                });
                return;
            }

            // ✅ Get user ID from claims
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userIdClaim))
            {
                Console.WriteLine("❌ No user ID found in claims");
                awaitingSparePart.SetAwaitingSparepartBy = Guid.Empty;
            }
            else if (Guid.TryParse(userIdClaim, out Guid userGuid))
            {
                awaitingSparePart.SetAwaitingSparepartBy = userGuid;
            }
            else
            {
                Console.WriteLine("❌ Invalid user ID format");
                awaitingSparePart.SetAwaitingSparepartBy = Guid.Empty;
            }

            await AwaitingSparePartService.SetAwaitingSparePartAsync(awaitingSparePart);

            await MQ.PublishStatusChangeAsync(
      MessageQueueHelper.Queues.AwaitSparePart,
      "AwaitingSparePart",
      awaitingSparePart.Id,
      "Awaiting SparePart",
      _selectedRepairService?.reportNo,
      awaitingSparePart.SetAwaitingSparepartBy
  );

            // ✅ Invalidate Redis cache
            await Cache.InvalidateManyAsync(
                CacheKeys.AwaitSparePart(currentGridPage, gridPageSize),
                CacheKeys.AwaitSparePart(1, gridPageSize),
                CacheKeys.DashboardStats
            );

            // ✅ SignalR notification
            if (hubConnection != null)
            {
                if (hubConnection.State == HubConnectionState.Disconnected)
                {
                    await hubConnection.StartAsync();
                }

                if (hubConnection.State == HubConnectionState.Connected)
                {
                    await hubConnection.SendAsync("BroadcastItemUpdate", "ItemCreated");
                }
            }

            string reportNo = !string.IsNullOrEmpty(ReportNo)
                ? ReportNo
                : _selectedRepairService?.reportNo;

            await StateManagementAction.SendNotificationForInspectItem("create", reportNo);

            // ✅ Refresh to first page after save
            currentPage = 1;
            await LoadPageData();
            await LoadGridData();

            isConfirmationDialogVisible = false;

            // ✅ Success notification
            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Customization",
                Title = "Success",
                Text = "Spare part waiting status set successfully",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Success
            });
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"❌ Error during save: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Save Error",
                Text = $"Failed to save: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

