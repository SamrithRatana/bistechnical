    private void UpdatePagination()
    {
        try
        {
            if (isGridView)
            {
                // ✅ Null-safe grid view pagination
                var gridItems = filteredRepairServices2 ?? new List<RepairServices>();
                totalPages = (int)Math.Ceiling((double)gridItems.Count() / pageSize);
                PaginatedRepairServices = gridItems
                    .Skip((currentPage - 1) * pageSize)
                    .Take(pageSize)
                    .ToList();
            }
            else
            {
                // ✅ Null-safe card view pagination
                var cardItems = filteredRepairServices ?? new List<RepairServices>();
                totalPages = (int)Math.Ceiling((double)cardItems.Count() / pageSize);
                PaginatedRepairServices = cardItems
                    .Skip((currentPage - 1) * pageSize)
                    .Take(pageSize)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in UpdatePagination: {ex.Message}");
            PaginatedRepairServices = new List<RepairServices>();
            totalPages = 0;
        }
    }

