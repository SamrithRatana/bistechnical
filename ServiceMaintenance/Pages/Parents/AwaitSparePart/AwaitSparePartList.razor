    private async Task OnAwaitStatusChanged(RepairServices item, string newStatus)
    {
        if (string.IsNullOrEmpty(newStatus) || newStatus == item.Status)
            return;

        string previousStatus = item.Status;

        try
        {
            if (newStatus == "Awaiting Customer Confirm")
            {
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;

                if (!user.Identity.IsAuthenticated)
                {
                    ToastNotificationService.ShowToast(new ToastOptions
                    {
                        ProviderName = "Error",
                        Title = "Authentication Error",
                        Text = "User is not authenticated",
                        ThemeMode = ToastThemeMode.Pastel,
                        RenderStyle = ToastRenderStyle.Danger
                    });
                    return;
                }

                Guid currentUserId = Guid.Empty;
                var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userIdClaim))
                    Guid.TryParse(userIdClaim, out currentUserId);

                var request = new AwaitingCustomerConfirmRequest
                {
                    Id = item.Id,
                    SetAwaitingCustomerConfirmBy = currentUserId
                };
                await AwaitingCustomerConfirmService.SetAwaitingCustomerConfirmAsync(request);

                await MQ.PublishStatusChangeAsync(
      MessageQueueHelper.Queues.AwaitSparePart,
      "AwaitingSparePart",
      item.Id,
      "Awaiting Customer Confirm",
      item.reportNo,
      currentUserId
  );

                // ✅ Invalidate both lists this item moves between
                await Cache.InvalidateManyAsync(
                    CacheKeys.AwaitSparePart(currentGridPage, gridPageSize),
                    CacheKeys.AwaitSparePart(1, gridPageSize),
                    CacheKeys.AwaitCustomer(1, gridPageSize),
                    CacheKeys.DashboardStats
                );

                if (hubConnection?.State == HubConnectionState.Connected)
                    await hubConnection.SendAsync("BroadcastItemUpdate", "ItemUpdated");

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = $"{item.reportNo} → រង់ចាំយល់ព្រមពីភ្ញៀវ",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });
            }
            else if (newStatus == "Inspecting")
            {
                // GET current record then PUT back with Inspecting statusId
                await RepairItemService.MoveBackToInspectingAsync(item.Id);

                // ✅ Publish to RabbitMQ
                await MQ.PublishStatusChangeAsync(
                    MessageQueueHelper.Queues.InspectItem,
                    "AwaitingSparePart",
                    item.Id,
                    "Inspecting",
                    item.reportNo,
                    null
                );

                // ✅ Invalidate both lists this item moves between
                await Cache.InvalidateManyAsync(
                    CacheKeys.AwaitSparePart(currentGridPage, gridPageSize),
                    CacheKeys.AwaitSparePart(1, gridPageSize),
                    CacheKeys.InspectItem(1, gridPageSize),
                    CacheKeys.DashboardStats
                );

                if (hubConnection?.State == HubConnectionState.Connected)
                    await hubConnection.SendAsync("BroadcastItemUpdate", "ItemUpdated");

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = $"{item.reportNo} → បញ្ជូនទៅផ្នែកជាងវិញ",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });
            }

            await LoadGridData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            item.Status = previousStatus;
            StateHasChanged();

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = $"Failed: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }
