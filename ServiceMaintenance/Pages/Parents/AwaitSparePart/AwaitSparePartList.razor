                                            @{

                                                var grandTotal = _selectedRepairService.SparePartItems.Sum(sp =>

                                                {

                                                    var obj = _spareParts.FirstOrDefault(x => x.Id == sp.SparePartId);

                                                    return (obj?.DefaultPrice ?? 0) * sp.Quantity;

                                                });

                                            }

                                            $@grandTotal.ToString("N2")

                                        </td>

                                        <td></td>  @* Stock Status *@

                                    </tr>

                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </Content>
