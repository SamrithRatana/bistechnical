                                            </td>
                                            @* Stock Status *@
                                            <td style="padding:5px 4px; text-align:center; vertical-align:middle;">
                                                <span class="stock-status-badge"
                                                      style="background:@stockBg; color:@stockFg;
                                 padding:2px 8px; border-radius:8px;
