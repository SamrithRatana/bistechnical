    private string GetUserNameById(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty)
            return "Unknown";

        string userIdString = userId.Value.ToString();

        if (!_usersLoaded)
            return "Loading...";

        if (_allUsers.TryGetValue(userIdString, out string username))
            return username;

        return "Unknown User";
    }
   
