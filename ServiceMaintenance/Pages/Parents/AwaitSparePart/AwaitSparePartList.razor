@page "/await-sparepart"
@page "/await-sparepart/{ReportNo}"

@using ServiceMaintenance.Components
@using ServiceMaintenance.Models
@using Microsoft.AspNetCore.SignalR.Client
@using ServiceMaintenance.Services.Filters.GlobalSecurity
@using System.Timers
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
