        currentPage = 1;
        await LoadItemsPagedAsync(currentPage, pageSize);
    }

    // ==================== PAGINATION METHODS ====================

    private async Task NextPage()
    {
        if (!IsLastPage())
        {
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var result = await ItemService.SearchItemsAsync(
                    pageNumber: currentPage + 1,
                    pageSize: pageSize,
                    searchTerm: searchQuery
                );
                items = result.Items ?? new List<Repairs>();
                totalCount = result.TotalCount;
                currentPage = result.PageNumber;
            }
            else
            {
                await LoadItemsPagedAsync(currentPage + 1, pageSize);
            }
        }
    }

    private async Task PreviousPage()
    {
        if (!IsFirstPage())
        {
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var result = await ItemService.SearchItemsAsync(
                    pageNumber: currentPage - 1,
                    pageSize: pageSize,
                    searchTerm: searchQuery
                );
                items = result.Items ?? new List<Repairs>();
                totalCount = result.TotalCount;
                currentPage = result.PageNumber;
            }
            else
            {
                await LoadItemsPagedAsync(currentPage - 1, pageSize);
            }
        }
    }

    private async Task FirstPage()
    {
        if (!IsFirstPage())
        {
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var result = await ItemService.SearchItemsAsync(
                    pageNumber: 1,
                    pageSize: pageSize,
                    searchTerm: searchQuery
                );
                items = result.Items ?? new List<Repairs>();
                totalCount = result.TotalCount;
                currentPage = result.PageNumber;
            }
            else
            {
                await LoadItemsPagedAsync(1, pageSize);
            }
        }
    }

    private async Task LastPage()
    {
        if (!IsLastPage())
        {
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var result = await ItemService.SearchItemsAsync(
                    pageNumber: totalPages,
                    pageSize: pageSize,
                    searchTerm: searchQuery
                );
                items = result.Items ?? new List<Repairs>();
                totalCount = result.TotalCount;
                currentPage = result.PageNumber;
            }
            else
            {
                await LoadItemsPagedAsync(totalPages, pageSize);
            }
        }
    }

    private async Task OnPageSizeChanged(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newSize))
        {
            pageSize = newSize;
            currentPage = 1;
            await LoadItemsPagedAsync(currentPage, pageSize);
        }
    }

    private bool IsFirstPage() => currentPage <= 1;
    private bool IsLastPage() => currentPage >= totalPages;
    private int GetStartRecord() => totalCount == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int GetEndRecord() => Math.Min(currentPage * pageSize, totalCount);

