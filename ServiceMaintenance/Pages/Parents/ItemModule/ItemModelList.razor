    private System.Threading.Timer _serialValidationTimer;

    private void OnSerialNumberInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        var serialNumber = e.Value?.ToString();

        // Cancel previous timer
        _serialValidationTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(serialNumber))
        {
            serialNumberErrorMessage = "";
            return;
        }

        // Debounce: wait 500ms before validating
        _serialValidationTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    bool isDuplicate = await IsSerialNumberDuplicate(serialNumber, currentItem.Id);

                    if (isDuplicate)
                    {
                        serialNumberErrorMessage = "សូមអភ័យទោស Serial Number របស់លោកអ្នកមានរួចទៅហើយ";
                    }
                    else
                    {
                        serialNumberErrorMessage = "";
                    }

                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error in serial validation: {ex.Message}");
            }
        }, null, 500, Timeout.Infinite);
    }

