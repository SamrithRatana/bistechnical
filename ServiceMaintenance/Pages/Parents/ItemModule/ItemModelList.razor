                // Add default types if none exist
                if (!Country.Any())
                {
                    Country = new List<Countries>
                {
                    new Countries() { Name = "Printer", Code = "PR" },
                    new Countries() { Name = "Copier", Code = "CP" },
                    new Countries() { Name = "Scanner", Code = "SC" },
                    new Countries() { Name = "Bill Counter", Code = "BC" },
                };
                }

                Console.WriteLine($"Loaded {Country.Count} default item types");
            }
            else
            {
                // Load filtered item types using the optimized API
                var uniqueTypes = await ItemService.GetUniqueItemTypesAsync(searchTerm, pageNumber: 1, pageSize: 50);

                Country = uniqueTypes
                    .Select(name => new Countries
                    {
                        Name = name,
                        Code = GenerateItemTypeCode(name)
                    })
