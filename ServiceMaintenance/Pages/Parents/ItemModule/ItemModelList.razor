@page "/itemModel"
@using Microsoft.AspNetCore.SignalR.Client
@using ServiceMaintenance.Services
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Notifications
@using Syncfusion.Blazor.Notifications.Internal
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Buttons
@implements IDisposable
@inject NavigationManager NavigationManager
@inject ItemService ItemService
@inject StateManagementAction StateManagementAction
@inject IJSRuntime JSRuntime
@inject CacheHelper Cache
@inject MessageQueueHelper MQ
@using ServiceMaintenance.Infrastructure.Shared.Caching
@using ServiceMaintenance.Infrastructure.Shared.Messaging

<DxToastProvider Name="Customization"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
             @if (CanCreate)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" Click="NewItem_Click" IconCssClass="far fa-file" CssClass="toolbar-item" />
            }
             @if (CanEdit)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" Click="EditItem_Click" IconCssClass="far fa-edit" CssClass="toolbar-item" />
            }
             @if (CanDelete)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" Click="DeleteItem_Click" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" />
            }
             @if (CanExport)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                <Items>
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ExportToPdf" IconCssClass="fas fa-file-pdf" />
                </Items>
            </DxToolbarItem>
            }
             @if (CanPrint)
            {
            <DxToolbarItem Text="Print Report" CssClass="toolbar-item" IconCssClass="fas fa-print" Enabled="false" />
            }
             @if (CanView)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" Click="Check_Click" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" />
            }
        </DxToolbar>
    </div>
</div>

<hr>
@if (CanAccess)
{
@if (CanView)
{
<!-- Custom Search Box -->
<div class="card shadow-sm rounded-lg mb-3">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fas fa-search"></i>
                    </span>
                    <input type="text"
                           class="form-control"
                           placeholder="Search by Item Name, Serial Number, or Item Type..."
                           @bind="searchQuery"
                           @bind:event="oninput"
                           @onkeyup="OnSearchKeyUp" />
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="fas fa-times"></i>
                        </button>
                    }
                </div>
            </div>
            <div class="col-md-4 text-end">
                @if (isSearching)
                {
                    <span class="text-muted">
                        <i class="fas fa-spinner fa-spin"></i> Searching...
                    </span>
                }
                else if (!string.IsNullOrEmpty(searchQuery))
                {
                    <span class="text-success">
                        <i class="fas fa-check-circle"></i> Found @totalCount results
                    </span>
                }
            </div>
        </div>
    </div>
</div>

<div class="h-100 grid-wrapper">
    @if (items == null)
    {
        <div class="card-body w-100">
            <div class="card-header border-0 p-2 rounded">
                <DxLoadingPanel IndicatorAnimationType="WaitIndicatorAnimationType.Pulse"
                                CssClass="w-100"
                                IndicatorVisible="@indicatorVisible"
                                IndicatorAreaVisible="@indicatorAreaVisible"
                                Visible="true"
                                Text="Processing..."
                                TextAlignment="LoadingPanelTextAlignment.Right">
                    <div style="min-height: 250px;"></div>
                </DxLoadingPanel>
            </div>
        </div>
    }
    else
    {
        <SfGrid @ref="MyGrid"
                DataSource="@items"
                AllowSorting="true"
                AllowPaging="false"
                AllowExcelExport="true"
                AllowSelection="true"
                AllowPdfExport="true"
                Height="500">

            <GridEvents RowSelected="RowSelectHandler" TValue="Repairs" />
            <GridColumns>
                <GridColumn Field="Id" HeaderText="ID" Width="50" IsPrimaryKey="true" Visible="false"></GridColumn>
                <GridColumn Field="ItemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="150"></GridColumn>
                <GridColumn Field="SerialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="150"></GridColumn>
                <GridColumn Field="ItemType" HeaderText="@Loc[nameof(ResourceStrings.TextItemType)]" Width="150"></GridColumn>
                <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" Width="120">
                    <Template>
                        @{
                            var item = context as Repairs;
                        }
                        <DxButton IconCssClass="fas fa-eye"
                                  CssClass="icon-button info"
                                  RenderStyle="ButtonRenderStyle.Info"
                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                  @onclick="() => ShowRepairServiceDetails(item)" />
                        <DxButton IconCssClass="fas fa-file-invoice" CssClass="icon-button secondary" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" Click="PrintReport_Click" />
                        <DxButton IconCssClass="fas fa-trash-alt" CssClass="icon-button danger" RenderStyle="ButtonRenderStyle.Danger" RenderStyleMode="ButtonRenderStyleMode.Text" />
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>

        <div class="card shadow-sm rounded-lg mt-3">
            <div class="card-body">
                <div class="pagination-controls d-flex justify-content-between align-items-center">
                    <div class="pagination-info">
                        <span>Showing @GetStartRecord() to @GetEndRecord() of @totalCount items</span>
                    </div>
                    <div class="pagination-buttons">
                        <button class="btn btn-sm btn-outline-primary" @onclick="FirstPage" disabled="@IsFirstPage()">
                            <i class="fas fa-angle-double-left"></i> First
                        </button>
                        <button class="btn btn-sm btn-outline-primary" @onclick="PreviousPage" disabled="@IsFirstPage()">
                            <i class="fas fa-angle-left"></i> Previous
                        </button>
                        <span class="mx-3">Page @currentPage of @totalPages</span>
                        <button class="btn btn-sm btn-outline-primary" @onclick="NextPage" disabled="@IsLastPage()">
                            Next <i class="fas fa-angle-right"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-primary" @onclick="LastPage" disabled="@IsLastPage()">
                            Last <i class="fas fa-angle-double-right"></i>
                        </button>
                    </div>
                    <div class="page-size-selector">
                        <label>Items per page:</label>
                        <select class="form-select form-select-sm" @onchange="OnPageSizeChanged" style="width: 80px; display: inline-block;">
                            <option value="10" selected="@(pageSize == 10)">10</option>
                            <option value="20" selected="@(pageSize == 20)">20</option>
                            <option value="50" selected="@(pageSize == 50)">50</option>
                            <option value="100" selected="@(pageSize == 100)">100</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    }

    <SfDialog @ref="DialogDelete" IsModal="true" Width="250px" ShowCloseIcon="true" Visible="false">
        <DialogTemplates>
            <Header> Confirm Delete </Header>
            <Content> Please confirm that you want to delete this record. </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Delete" IsPrimary="true" OnClick="ConfirmDeleteYes" />
            <DialogButton Content="Cancel" OnClick="ConfirmDeleteNo" />
        </DialogButtons>
    </SfDialog>

    <SfDialog @ref="DialogNoRecordSelected" IsModal="true" Width="250px" ShowCloseIcon="true" Visible="false">
        <DialogTemplates>
            <Header> Warning! </Header>
            <Content> You must select a record. </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="OK" IsPrimary="true" OnClick="CloseDialogNoRecordSelected" />
        </DialogButtons>
    </SfDialog>

    <!-- Main Add/Edit Dialog with Camera Button -->
    <SfDialog IsModal="true" Width="600px" ShowCloseIcon="true" Visible="@isAddDialogVisible">
        <DialogTemplates>
            <Header>
                <div class="dialog-header">
                    <h2>@pageTitle</h2>
                </div>
            </Header>
        </DialogTemplates>
        <EditForm Model="@currentItem" OnValidSubmit="SaveItem">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="form-group row">
                <!-- First Row: Serial Number with Camera Button and Item Selection -->
                <div class="col-md-6">
                    <div class="serial-input-container">
                        <div class="serial-wrapper">
                            <SfTextBox @ref="serialNumberTextBox"
                                       Placeholder="@Loc[nameof(ResourceStrings.TextSerialNumber)]"
                                       FloatLabelType="FloatLabelType.Always"
                                       @bind-Value="currentItem.SerialNumber">
                            </SfTextBox>
                        </div>
                        <button type="button"
                                @onclick="OpenCameraScanner"
                                class="btn-camera"
                                title="Scan with Camera">
                            <i class="fas fa-camera"></i>
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(serialNumberErrorMessage))
                    {
                        <div class="text-danger">@serialNumberErrorMessage</div>
                    }
                </div>

                <div class="col-md-6">
                    <div class="combo-input-container">
                        <div class="combo-wrapper">
                            <SfComboBox @ref="comboObj"
                                        @onclick="OnComboBoxClick"
                                        TValue="string"
                                        TItem="string"
                                        Placeholder="@Loc[nameof(ResourceStrings.TextselectItem)]"
                                        FloatLabelType="FloatLabelType.Always"
                                        FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                        AllowFiltering="true"
                                        AllowCustom="false"
                                        IgnoreAccent="true"
                                        @bind-Value="currentItem.ItemName"
                                        DataSource="@UniqueItemNames"
                                        Width="100%"
                                        PopupWidth="auto"
                                        PopupHeight="300px">
                                <ComboBoxEvents TValue="string"
                                                TItem="string"
                                                Filtering="OnFilteringItemNames">
                                </ComboBoxEvents>
                            </SfComboBox>
                        </div>
                        <button type="button" class="btn-plus" @onclick="OpenManualInputDialog">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(itemNameErrorMessage))
                    {
                        <div class="text-danger">@itemNameErrorMessage</div>
                    }
                </div>
            </div>

            <div class="form-group row">
                <!-- Second Row: Item Type and Save/Cancel -->
                <div class="col-md-6">

                    <div class="combo-input-container">

                        <div class="combo-wrapper">

                            <SfComboBox TValue="string"
                                        Placeholder="@Loc[nameof(ResourceStrings.TextItemType)]"
                                        FloatLabelType="FloatLabelType.Always"
                                        TItem="Countries"
                                        @bind-Value="currentItem.ItemType"
                                        DataSource="@Country"
                                        Width="100%">

                                <ComboBoxFieldSettings Value="Name" Text="Name"></ComboBoxFieldSettings>

                            </SfComboBox>

                        </div>

                        <button type="button" class="btn-plus" @onclick="OpenItemTypeDialog">

                            <i class="fas fa-plus"></i>

                        </button>

                    </div>

                    @if (!string.IsNullOrEmpty(itemTypeErrorMessage))

                    {

                        <div class="text-danger">@itemTypeErrorMessage</div>

                    }

                </div>



                <div class="e-footer-content">
                    <button type="submit" class="e-btn e-normal e-primary">@Loc[nameof(ResourceStrings.TextSave)]</button>
                    <button type="button" class="e-btn e-normal" @onclick="CancelDialog">@Loc[nameof(ResourceStrings.TextDecline)]</button>
                </div>
            </div>
        </EditForm>

        <SfToast @ref="toastObj" Timeout="3000"></SfToast>
    </SfDialog>
    <SfDialog @ref="DialogCameraScanner"
              IsModal="true"
              Width="90%"
              Height="90vh"
              ShowCloseIcon="true"
              Visible="@isCameraScannerVisible"
              CssClass="camera-scanner-dialog"
              CloseOnEscape="true">

        <DialogEvents Closed="OnCameraScannerClosed"></DialogEvents>

        <DialogTemplates>
            <Header>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <h3 style="margin: 0;">
                        <i class="fas fa-barcode"></i> Scan Barcode
                    </h3>

                    @if (isScanning)
                    {
                        <span style="color: #28a745;">
                            <i class="fas fa-circle" style="animation: pulse 1s infinite;"></i>
                            Scanning...
                        </span>
                    }
                </div>
            </Header>


            <Content>
                <div style="display: flex; flex-direction: column; align-items: center; height: 100%;">

                    <!-- Camera Preview -->
                    <div id="camera-preview-container"
                         style="
                        width: 100%;
                        max-width: 640px;
                        height: 480px;
                        background: #000;
                        border-radius: 8px;
                        margin-bottom: 15px;
                        position: relative;
                        overflow: hidden;">

                        <video id="camera-preview"
                               autoplay
                               playsinline
                               style="width: 100%; height: 100%; object-fit: cover;">
                        </video>

                        <!-- Scan Overlay -->
                        <div style="
                        position: absolute; inset: 0;
                        border: 2px solid #28a745;
                        pointer-events: none;
                        box-shadow: inset 0 0 0 9999px rgba(0,0,0,0.3);">

                            <div style="
                            position: absolute;
                            top: 50%; left: 50%;
                            transform: translate(-50%, -50%);
                            width: 80%; height: 60%;
                            border: 2px solid #28a745;
                            border-radius: 8px;">

                                <div style="position: absolute; top: -2px; left: -2px; width: 20px; height: 20px; border-top: 4px solid #28a745; border-left: 4px solid #28a745;"></div>
                                <div style="position: absolute; top: -2px; right: -2px; width: 20px; height: 20px; border-top: 4px solid #28a745; border-right: 4px solid #28a745;"></div>
                                <div style="position: absolute; bottom: -2px; left: -2px; width: 20px; height: 20px; border-bottom: 4px solid #28a745; border-left: 4px solid #28a745;"></div>
                                <div style="position: absolute; bottom: -2px; right: -2px; width: 20px; height: 20px; border-bottom: 4px solid #28a745; border-right: 4px solid #28a745;"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Scanned Result -->
                    @if (!string.IsNullOrEmpty(scannedBarcode))
                    {
                        <div style="
                                    width: 100%; max-width: 640px;
                                    padding: 15px;
                                    background: #d4edda;
                                    border: 1px solid #c3e6cb;
                                    border-radius: 8px;
                                    margin-bottom: 15px;">

                            <div style="display: flex; align-items: center; justify-content: space-between;">
                                <div>
                                    <strong style="color: #155724;">
                                        <i class="fas fa-check-circle"></i> Scanned:
                                    </strong>

                                    <span style="
                                                font-size: 18px;
                                                margin-left: 10px;
                                                font-family: monospace;">
                                        @scannedBarcode
                                    </span>
                                </div>

                                <button type="button"
                                        class="btn btn-sm btn-success"
                                        @onclick="UseScannedBarcode">
                                    <i class="fas fa-check"></i> Use This
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Instructions -->
                    <div style="text-align: center; color: #666; max-width: 500px;">
                        <p style="margin-bottom: 10px;">
                            <i class="fas fa-info-circle"></i>
                            Position the barcode within the green frame
                        </p>
                        <p style="font-size: 14px;">
                            The scanner will automatically detect and read the barcode
                        </p>
                    </div>
                </div>
            </Content>
        </DialogTemplates>

        <DialogButtons>
            <DialogButton Content="Close"
                          CssClass="e-btn e-normal"
                          OnClick="CloseCameraScanner" />
        </DialogButtons>
    </SfDialog>


    <!-- Manual Input Dialog -->
    <SfDialog @ref="ManualInputDialog" IsModal="true" Width="400px" ShowCloseIcon="true" Visible="@isManualInputDialogVisible">
        <DialogTemplates>
            <Header>Add New Item Manually</Header>
            <Content>
                <div class="form-group">
                    <SfTextBox Placeholder="Enter Item Name"
                               FloatLabelType="FloatLabelType.Always"
                               @bind-Value="manualInputItem.ItemName"></SfTextBox>

                    <div class="text-danger mt-2" style="font-size: 16px;font-family: 'Khmer OS Battambang'">
                        សូមស្វែងរកក្នុង Website ជាឈ្មោះស្តង់ដាររបស់ម៉ាស៊ីន ជាឈ្មោះពេញ និង Brand ត្រូវតែអក្សរធំ
                    </div>

                    @if (!string.IsNullOrEmpty(manualInputErrorMessage))
                    {
                        <div class="text-danger mt-1">@manualInputErrorMessage</div>
                    }
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Add" IsPrimary="true" OnClick="SaveManualInputItem" />
            <DialogButton Content="Cancel" OnClick="CancelManualInputDialog" />
        </DialogButtons>
    </SfDialog>
    <!-- Add Item Type Dialog -->
    <SfDialog @ref="ItemTypeDialog" IsModal="true" Width="400px" ShowCloseIcon="true" Visible="@isItemTypeDialogVisible">
        <DialogTemplates>
            <Header>Add New Item Type</Header>
            <Content>
                <div class="form-group">
                    <SfTextBox Placeholder="Enter Item Type Name"
                               FloatLabelType="FloatLabelType.Always"
                               @bind-Value="newItemTypeName"></SfTextBox>

                    <div class="text-muted mt-2" style="font-size: 14px;">
                        Example: Laptop, Monitor, UPS, etc.
                    </div>

                    @if (!string.IsNullOrEmpty(itemTypeErrorMessage))
                    {
                        <div class="text-danger mt-1">@itemTypeErrorMessage</div>
                    }
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Add" IsPrimary="true" OnClick="SaveItemType" />
            <DialogButton Content="Cancel" OnClick="CancelItemTypeDialog" />
        </DialogButtons>
    </SfDialog>
    <!-- View Details Dialog -->
    <SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
        <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
        <DialogTemplates>
            <Header>View Information</Header>
            <Content>
                <div class="report-container">
                    <div class="report-header">
                    </div>
                    <div class="report-body">
                        <table class="report-table">
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextItemName)]</strong></td>
                                <td class="report-value">@selectedItem?.ItemName</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextSerialNumber)]</strong></td>
                                <td class="report-value">@selectedItem?.SerialNumber</td>
                            </tr>
                            <tr>
                                <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextItemType)]</strong></td>
                                <td class="report-value">@selectedItem?.ItemType</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Close" IsPrimary="true" OnClick="@CloseDialog" />
        </DialogButtons>
    </SfDialog>
</div>
}
}
@code {
    private SfGrid<Repairs> MyGrid;
    private SfDialog DialogDelete;
    private SfDialog DialogNoRecordSelected;
    private SfDialog ManualInputDialog;
    private SfTextBox serialNumberTextBox;
    private System.Threading.Timer _debounceTimer;
    private string _lastSearchTerm = string.Empty;
    private bool isAddDialogVisible = false;
    private bool isManualInputDialogVisible = false;
    private bool isScannerDialogVisible = false;
    private string pageTitle = "Add Item";
    private Repairs currentItem = new Repairs();
    private Repairs manualInputItem = new Repairs();
    private string searchQuery = "";
    private bool isSearching = false;
    private System.Threading.Timer _searchDebounceTimer;



    private SfDialog ItemTypeDialog;
    private bool isItemTypeDialogVisible = false;
    private string newItemTypeName = "";
    private string itemTypeErrorMessage = "";
    // Paginated data
    private List<Repairs> items = new List<Repairs>();
    private int totalCount = 0;
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => totalCount > 0 ? (int)Math.Ceiling(totalCount / (double)pageSize) : 0;

    // Unique names for ComboBox
    private List<string> UniqueItemNames = new List<string>();

    private Guid? selectedItemId;
    bool indicatorVisible = false;
    bool indicatorAreaVisible = true;
    public string DropVal = "Please Select Type";
    private HubConnection hubConnection;
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;

    private SfComboBox<string, string> comboObj;

    private string serialNumberErrorMessage;
    private string manualInputErrorMessage = "";
    private bool showComboBox = true;
    private SfDialog DialogEdit;
    private bool isViewDialogVisible = false;
    private Repairs selectedItem;
    private SfToast toastObj;
    private string toastTitle = "";
    private string toastMessage = "";
    private string itemNameErrorMessage = "";
    private SfDialog DialogCameraScanner;
    private bool isCameraScannerVisible = false;
    private bool isScanning = false;
    private string scannedBarcode = string.Empty;
    private DotNetObjectReference<ItemModelList> objRef;



    [Inject] protected NavigationManager Navigation { get; set; }
    [Inject] protected AuthenticationStateProvider AuthenticationStateProvider { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        objRef = DotNetObjectReference.Create(this);


        // Load first page
        await LoadItemsPagedAsync(currentPage, pageSize);

        // Load unique item names for ComboBox
        await LoadUniqueItemNamesAsync();

        await LoadUniqueItemTypesAsync();


        // Setup SignalR
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/itemHub"))
            .Build();

        hubConnection.On<string>("ReceiveItemUpdate", async (message) =>
        {
            await LoadItemsPagedAsync(currentPage, pageSize);
            await LoadUniqueItemNamesAsync();
            await LoadUniqueItemTypesAsync(); // ⭐ ADD THIS LINE TOO

            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<Guid>("BroadcastItemDelete", async (deletedItemId) =>
        {
            await LoadItemsPagedAsync(currentPage, pageSize);
            await LoadUniqueItemNamesAsync();
            await LoadUniqueItemTypesAsync(); // ⭐ ADD THIS LINE TOO
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    // ==================== BARCODE SCANNER METHODS ====================
    private async Task OpenCameraScanner()
    {
        try
        {
            scannedBarcode = string.Empty;
            isCameraScannerVisible = true;

            StateHasChanged();

            // Allow dialog to fully render
            await Task.Delay(500);

            // Initialize camera and barcode scanner
            await JSRuntime.InvokeVoidAsync("barcodeScanner.startScanner", objRef);

            isScanning = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error opening camera scanner: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Camera Error",
                Text = "Failed to open camera scanner. Please check camera permissions.",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });

            isCameraScannerVisible = false;
            StateHasChanged();
        }
    }

    private async Task CloseCameraScanner()
    {
        try
        {
            isScanning = false;
            isCameraScannerVisible = false;

            // Stop camera
            await JSRuntime.InvokeVoidAsync("barcodeScanner.stopScanner");

            // Clear scanned barcode
            scannedBarcode = string.Empty;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error closing camera scanner: {ex.Message}");

            // Ensure dialog is closed even if there's an error
            isCameraScannerVisible = false;

            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnBarcodeDetected(string barcode)
    {
