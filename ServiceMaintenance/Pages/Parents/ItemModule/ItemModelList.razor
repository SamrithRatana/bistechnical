    private async Task SaveItem()
    {
        serialNumberErrorMessage = "";
        itemNameErrorMessage = "";

        // Validate serial number is not empty
        if (string.IsNullOrWhiteSpace(currentItem.SerialNumber))
        {
            serialNumberErrorMessage = "Serial Number is required";
            return;
        }

        // Check for duplicate serial number across ALL pages (optimized)
        bool isDuplicate = await IsSerialNumberDuplicate(currentItem.SerialNumber, currentItem.Id);

        if (isDuplicate)
        {
            serialNumberErrorMessage = "សូមអភ័យទោស Serial Number របស់លោកអ្នកមានរួចទៅហើយ";

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Duplicate Serial Number",
                Text = "This serial number already exists in the system",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Warning
            });

            return;
        }

        // Validate item name exists in the list
        if (!UniqueItemNames.Any(name => name.Equals(currentItem.ItemName, StringComparison.OrdinalIgnoreCase)))
        {
            itemNameErrorMessage = "សូមជ្រើសរើសឈ្មោះដែលមាន";
            return;
        }

        try
        {
            bool isNew = currentItem.Id == Guid.Empty;

            if (isNew)
            {
                currentItem.Id = Guid.NewGuid();
                await ItemService.CreateItemAsync(currentItem);
                await hubConnection.SendAsync("BroadcastItemUpdate", "ItemCreated");
                await Cache.InvalidateByPrefixAsync(CacheKeys.PrefixItemModule);
                await MQ.PublishCreateAsync(MessageQueueHelper.Queues.ItemModule, currentItem.Id);
            }
            else
            {
                await ItemService.UpdateItemAsync(currentItem);
                await hubConnection.SendAsync("BroadcastItemUpdate", "ItemUpdated");
                await Cache.InvalidateByPrefixAsync(CacheKeys.PrefixItemModule);
                await MQ.PublishUpdateAsync(MessageQueueHelper.Queues.ItemModule, currentItem.Id);
            }

            isAddDialogVisible = false;
            await LoadItemsPagedAsync(currentPage, pageSize);

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Customization",
                Title = "Success",
                Text = isNew ? "Item created successfully" : "Item updated successfully",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Success
            });
        }
        catch (Exception ex)
        {
            itemNameErrorMessage = $"Error saving item: {ex.Message}";

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = "Failed to save item",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

    private async Task<bool> IsSerialNumberDuplicate(string serialNumber, Guid? currentItemId = null)
    {
        try
        {
            // Use SearchItemsAsync to quickly check if serial number exists
            var result = await ItemService.SearchItemsAsync(
                pageNumber: 1,
                pageSize: 1,
                searchTerm: serialNumber
            );

            // Check if any items were found
            if (result.Items != null && result.Items.Any())
            {
                // If editing, exclude the current item from duplicate check
                if (currentItemId.HasValue)
                {
                    return result.Items.Any(i => i.SerialNumber == serialNumber && i.Id != currentItemId.Value);
                }

                // For new items, any match is a duplicate
                return result.Items.Any(i => i.SerialNumber == serialNumber);
            }

            return false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking serial number: {ex.Message}");
            return false;
        }
    }
