    private async Task LoadItemsPagedAsync(int page, int size)
    {
        try
        {
            indicatorVisible = true;
            var result = await Cache.GetOrSetAsync(
                CacheKeys.ItemModule(page, size),
                () => ItemService.GetItemsPagedAsync(page, size),
                TimeSpan.FromMinutes(3));
            items = result.Items ?? new List<Repairs>();
            totalCount = result.TotalCount;
            currentPage = page;
            pageSize = size;
            indicatorVisible = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading items: {ex.Message}");
            items = new List<Repairs>();
            indicatorVisible = false;
        }
    }

