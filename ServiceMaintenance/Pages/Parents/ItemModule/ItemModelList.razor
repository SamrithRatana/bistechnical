    public void OnFilteringItemNames(Syncfusion.Blazor.DropDowns.FilteringEventArgs args)
    {
        args.PreventDefaultAction = true;

        // Cancel previous search timer
        _debounceTimer?.Dispose();

        var searchText = args.Text;

        // Only search if text has at least 2 characters
        if (string.IsNullOrWhiteSpace(searchText) || searchText.Length < 2)
        {
            InvokeAsync(async () =>
            {
                await LoadUniqueItemNamesAsync(null);
                StateHasChanged();
            });
            return;
        }

        // Debounce: wait 300ms before searching
        _debounceTimer = new System.Threading.Timer(_ =>
        {
            try
            {
                InvokeAsync(async () =>
                {
                    await LoadUniqueItemNamesAsync(searchText);
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error in debounced search: {ex.Message}");
            }
        }, null, 300, Timeout.Infinite);
    }
