    private async Task SaveItemType()
    {
        itemTypeErrorMessage = "";

        // Validate input
        if (string.IsNullOrWhiteSpace(newItemTypeName))
        {
            itemTypeErrorMessage = "Item Type name is required.";
            return;
        }

        // Check if already exists (case-insensitive)
        if (Country.Any(c => c.Name.Equals(newItemTypeName.Trim(), StringComparison.OrdinalIgnoreCase)))
        {
            itemTypeErrorMessage = "This Item Type already exists.";
            return;
        }

        try
        {
            // Create a temporary item with the new ItemType
            var tempItem = new Repairs
            {
                Id = Guid.NewGuid(),
                SerialNumber = GenerateRandomSerialNumber(),
                ItemName = "Generate", // Mark as auto-generated
                ItemType = newItemTypeName.Trim()
            };

            // Save to database
            await ItemService.CreateItemAsync(tempItem);

            // Add to local list
            Country.Add(new Countries
            {
                Name = newItemTypeName.Trim(),
                Code = GenerateItemTypeCode(newItemTypeName)
            });

            // Set it as the selected value
            currentItem.ItemType = newItemTypeName.Trim();

            // Broadcast update via SignalR
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("BroadcastItemUpdate", "ItemTypeCreated");
            }

            // Close dialog
            isItemTypeDialogVisible = false;

            // Reload data to include new ItemType
            await LoadItemsPagedAsync(currentPage, pageSize);
            await LoadUniqueItemTypesAsync();

            // Show success message
            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Customization",
                Title = "Success",
                Text = $"Item Type '{newItemTypeName}' added successfully",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Success
            });

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            itemTypeErrorMessage = $"Error saving Item Type: {ex.Message}";

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = "Failed to save Item Type",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }
    private async Task LoadUniqueItemTypesAsync(string searchTerm = null)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < 2)
            {
                // Load default item types using the optimized API
                var uniqueTypes = await ItemService.GetUniqueItemTypesAsync(null, pageNumber: 1, pageSize: 50);

                Country = uniqueTypes
                    .Select(name => new Countries
