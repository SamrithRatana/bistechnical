    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        // Cancel previous timer
        _searchDebounceTimer?.Dispose();

        // Debounce: wait 500ms before searching
        _searchDebounceTimer = new System.Threading.Timer(_ =>
        {
            try
            {
                InvokeAsync(async () =>
                {
                    await PerformSearch();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error in debounced search: {ex.Message}");
            }
        }, null, 500, Timeout.Infinite);
    }

    private async Task PerformSearch()
    {
        try
        {
            isSearching = true;
            StateHasChanged();

            currentPage = 1;

            if (string.IsNullOrWhiteSpace(searchQuery))
            {
                await LoadItemsPagedAsync(currentPage, pageSize);
            }
            else
            {
                var result = await ItemService.SearchItemsAsync(
                    pageNumber: currentPage,
                    pageSize: pageSize,
                    searchTerm: searchQuery
                );

                items = result.Items ?? new List<Repairs>();
                totalCount = result.TotalCount;
                currentPage = result.PageNumber;

                Console.WriteLine($"Search completed: Found {totalCount} results for '{searchQuery}'");
            }

            isSearching = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in PerformSearch: {ex.Message}");
            isSearching = false;

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Search Error",
                Text = "Failed to search items",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

