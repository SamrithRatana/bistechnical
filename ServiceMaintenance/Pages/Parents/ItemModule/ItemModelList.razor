    private string GenerateItemTypeCode(string itemTypeName)
    {
        // Generate a simple code based on the name
        // You can customize this logic as needed
        string code = new string(itemTypeName.Where(char.IsLetter).Take(2).ToArray()).ToUpper();

        // Ensure uniqueness by adding a number if needed
        int counter = 1;
        string finalCode = code;
        while (Country.Any(c => c.Code == finalCode))
        {
            finalCode = code + counter;
            counter++;
        }

        return finalCode;
    }
