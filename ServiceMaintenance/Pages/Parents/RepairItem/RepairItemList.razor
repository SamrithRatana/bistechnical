<DxToastProvider Name="Customization"
                 MaxToastCount="10"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation"
                 ShowCloseButton="true"
                 DisplayTime="TimeSpan.Zero" />

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
              @if (CanCreate)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" Click="NewRepairService_Click" IconCssClass="far fa-file" CssClass="toolbar-item" Enabled="false" />
            }
              @if (CanEdit)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" Click="EditRepairService_Click" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="false" />
            }
              @if (CanDelete)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" Click="EditRepairService_Click" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="false" />
            }
              @if (CanExport)
            {
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                <Items>
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ExportToPdf" IconCssClass="fas fa-file-pdf" />
                </Items>
            </DxToolbarItem>
            }
              @if (CanPrint)
            {
            <DxToolbarItem Text="Print Report" Click="() => ShowReportPreview(_selectedRepairService)" CssClass="toolbar-item" IconCssClass="fas fa-print" Enabled="@isRow" />
            }
              @if (CanView)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" Enabled="false" />
            }
        </DxToolbar>
    </div>
</div>
<br />
<SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>
@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical;

    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical;
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Horizontal;
    }
    else
    {
        enableAdaptiveUIMode = false;
    }
}
@if (CanAccess)
{
@if (CanView)
{
<div style="margin-bottom: 15px; padding: 15px; background-color: #f9f9f9; border-radius: 4px;">
    <div style="display: flex; gap: 10px; align-items: center;">

        <SfTextBox @ref="RepairSearchBox"
                   Placeholder="Search by Report No, Company, Serial Number..."
                   ShowClearButton="true"
                   Width="400px"
                   @bind-Value="RepairSearchValue"
                   Input="OnRepairSearchInput">
        </SfTextBox>

        <SfButton Content="Search"
                  CssClass="e-btn e-primary"
                  IconCss="fas fa-search"
                  OnClick="PerformRepairSearch" />

        <SfButton Content="Clear"
                  CssClass="e-btn e-outline"
                  IconCss="fas fa-times"
                  OnClick="ClearRepairSearch" />
    </div>

    @if (!string.IsNullOrEmpty(RepairSearchValue))
    {
        <div style="margin-top: 10px; color: #666; font-size: 14px;">
            <i class="fas fa-info-circle"></i>
            Searching for: <strong>@RepairSearchValue</strong>
        </div>
    }
</div>

<SfGrid @ref="MyGrid"
        DataSource="@filteredRepairServices"
        AllowSorting="true"
        ShowColumnChooser="true"
        AllowExcelExport="true"
        AllowPdfExport="true"
        AllowResizing="true"
        AllowFiltering="true"
        Height="450"
        SelectionMode="GridSelectionMode.Single"
        Toolbar="@ToolbarItems"
        EnableAdaptiveUI="@enableAdaptiveUIMode"
        RowRenderingMode="@renderingMode"
        AllowSelection="true">
    <GridEvents TValue="RepairServices" RowSelected="RowSelectHandler" OnRecordDoubleClick="RowDoubleClickHandler"></GridEvents>
    <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
    <GridColumns>
        <GridColumn Field="Id" HeaderText="Id" Width="150" Format="d" Visible="false" />
        <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="150" />
        <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" CustomAttributes="@(new Dictionary<string, object>() { { "class", "e-attr" } })" Width="200" />
        <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="200" />
        <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="200" />
        <GridColumn Field="CustomerRequest" HeaderText="@Loc[nameof(ResourceStrings.TextCustomerReq)]" Width="250" Visible="false" />
        <GridColumn Field="ServiceLocation" HeaderText="@Loc[nameof(ResourceStrings.TextServiceLocation)]" Width="200" />
                <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="220">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var currentStatus = item?.Status ?? "Sale Confirmed";

                            string bgColor, textColor, borderColor;
                            switch (currentStatus)
                            {
                                case "Inspecting":
                                    bgColor = "#d4edda"; textColor = "#155724"; borderColor = "#c3e6cb";
                                    break;
                                default: // Sale Confirmed
                                    bgColor = "#cce5ff"; textColor = "#004085"; borderColor = "#b8daff";
                                    break;
                            }
                        }
                        <select style="background-color: @bgColor;
                               color: @textColor;
                               border: 1px solid @borderColor;
                               border-radius: 20px;
                               padding: 4px 10px;
                               font-size: 12px;
                               font-weight: 600;
                               cursor: pointer;
                               outline: none;
                               min-width: 180px;
                               font-family: 'Khmer OS', sans-serif;"
                                @key="@item?.Id"
                                @onchange="async (e) => await OnRepairStatusChanged(item, e.Value?.ToString())">
                            <option value="Sale Confirmed"
                                    selected="@(currentStatus == "Sale Confirmed")"
                                    style="background-color:#ffffff; color:#212529; font-size:12px;">
                                Sale Confirmed
                            </option>
                            <option value="Inspecting"
                                    selected="@(currentStatus == "Inspecting")"
                                    style="background-color:#ffffff; color:#212529; font-size:12px;">
                                កែតម្រូវគ្រឿងបន្លាស់ម្ដងទៀត
                            </option>
                        </select>
                    </Template>
                </GridColumn>
                <GridColumn Field="repairDate" HeaderText="@Loc[nameof(ResourceStrings.TextRepairDate)]" Width="150" Format="dd/MM/yyyy HH:mm tt" Visible="@HasRepairDate()" />
                <GridColumn Field="setSaleConfirmedBy" HeaderText="Confirmed By" Width="150">
            <Template>
                @{
                    var item = context as RepairServices;
                    var username = GetUserNameById(item.setSaleConfirmedBy);
                }
                @username
            </Template>
        </GridColumn>
        <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" IsFrozen="true" Freeze="FreezeDirection.Right" Width="200">
            <Template>
                @if ((context as RepairServices)?.repairDate == null)
                {
                    <DxButton IconCssClass="fas fa-check"
                              CssClass="icon-button danger"
                              RenderStyle="ButtonRenderStyle.Primary"
                              RenderStyleMode="ButtonRenderStyleMode.Text"
                              Text="@Loc[nameof(ResourceStrings.TextApproved)]"
                              @onclick="() => OnApplyButtonClick(context as RepairServices)" />
                    <DxButton IconCssClass="fas fa-eye"
                              CssClass="icon-button info"
                              RenderStyle="ButtonRenderStyle.Info"
                              RenderStyleMode="ButtonRenderStyleMode.Text"
                              Text="@Loc[nameof(ResourceStrings.TextView)]"
                              @onclick="() => ShowRepairServiceDetails(context as RepairServices)" />
                }
                else
                {
                    <DxButton IconCssClass="fas fa-eye"
                              CssClass="icon-button info"
                              RenderStyle="ButtonRenderStyle.Info"
                              RenderStyleMode="ButtonRenderStyleMode.Text"
                              Text="@Loc[nameof(ResourceStrings.TextView)]"
                              @onclick="() => ShowRepairServiceDetails(context as RepairServices)" />
                }
            </Template>
        </GridColumn>
    </GridColumns>
</SfGrid>
<!-- Pagination Controls -->
<div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; border-top: 1px solid #ddd; margin-top: 10px;">
    <div style="display: flex; align-items: center; gap: 10px;">
        <button class="e-btn e-normal" @onclick="FirstPage" disabled="@(currentPage == 1)">
            <i class="fas fa-angle-double-left"></i> First
        </button>
        <button class="e-btn e-normal" @onclick="PreviousPage" disabled="@(currentPage == 1)">
            <i class="fas fa-angle-left"></i> Previous
        </button>

        <span style="padding: 0 15px; font-weight: 500;">
            Page @currentPage of @totalPages
        </span>

        <button class="e-btn e-normal" @onclick="NextPage" disabled="@(currentPage >= totalPages)">
            Next <i class="fas fa-angle-right"></i>
        </button>
        <button class="e-btn e-normal" @onclick="LastPage" disabled="@(currentPage >= totalPages)">
            Last <i class="fas fa-angle-double-right"></i>
        </button>
    </div>

    <div style="color: #666;">
        Showing @Math.Min((currentPage - 1) * pageSize + 1, totalItems) - @Math.Min(currentPage * pageSize, totalItems) of @totalItems items
    </div>
</div>
<SfDialog @ref="ConfirmationDialog"
          IsModal="true"
          Width="400px"
          ShowCloseIcon="true"
          Visible="@isConfirmationDialogVisible">
    <DialogTemplates>
        <Header>
            <h2>@pageTitle</h2>
        </Header>
        <Content>
            @if (isProcessing)
            {
                <div class="loading-container">
                    <div class="spinner-border text-primary" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                    <p class="mt-3">Processing repair item... Please wait.</p>
                </div>
            }
            else
            {
                <p>@Loc[nameof(ResourceStrings.Textconfirmrepairdia)]</p>
            }
        </Content>
        <FooterTemplate>
            <SfButton CssClass="e-btn custom-button"
                      @onclick="ConfirmCustomerConfirm"
                      Disabled="@isProcessing">
                @(isProcessing ? "Processing..." : "Yes")
            </SfButton>
            <SfButton CssClass="e-btn e-danger"
                      @onclick="CancelConfirmationDialog"
                      Disabled="@isProcessing">
                No
            </SfButton>
        </FooterTemplate>
    </DialogTemplates>
</SfDialog>

