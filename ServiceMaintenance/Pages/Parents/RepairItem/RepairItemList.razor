    private async Task PerformRepairSearch()
    {
        if (string.IsNullOrWhiteSpace(RepairSearchValue))
        {
            await LoadPageData();
            return;
        }

        await PerformRepairSearchInternal(RepairSearchValue);
    }

    // Method 2: Internal search method with multi-status support
    private async Task PerformRepairSearchInternal(string searchValue)
    {
        try
        {
            var statusesToSearch = new[]
{
    "Sale Confirmed",
   
};

            // Execute searches in parallel for all statuses
            var tasks = statusesToSearch.Select(status =>
                RepairItemService.SearchRepairServicesAsync(
                    pageNumber: 1,
                    pageSize: pageSize,
                    status: status,
                    searchTerm: searchValue.Trim(),
                    sortBy: "reportNo",
                    sortDescending: true
                )
            ).ToList();

            var results = await Task.WhenAll(tasks);

            // Combine all results
            var allResults = new List<RepairServices>();
            int combinedTotalCount = 0;

            foreach (var result in results)
            {
                if (result.Items != null && result.Items.Any())
                {
                    allResults.AddRange(result.Items);
                    combinedTotalCount += result.TotalCount;
                }
            }

            // Remove duplicates and sort
            filteredRepairServices = allResults
                .GroupBy(x => x.Id)
                .Select(g => g.First())
                .OrderByDescending(x => x.reportNo)
                .ToList();

            totalItems = combinedTotalCount;
            totalPages = totalItems > 0 ? (int)Math.Ceiling(totalItems / (double)pageSize) : 0;
            currentPage = 1;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Repair search error: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Search Error",
                Text = $"Failed to search: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

    // Method 3: Real-time search as user types (with debouncing)
    private void OnRepairSearchInput(InputEventArgs args)
    {
        // Cancel previous timer
        _repairSearchDebounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(args.Value))
        {
            // If search is cleared, reload original data
            _ = Task.Run(async () =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadPageData();
                    StateHasChanged();
                });
            });
            return;
        }

        // Debounce: wait 500ms before searching
        _repairSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await PerformRepairSearchInternal(args.Value);
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Repair search error: {ex.Message}");
            }
        }, null, 500, Timeout.Infinite);
    }

