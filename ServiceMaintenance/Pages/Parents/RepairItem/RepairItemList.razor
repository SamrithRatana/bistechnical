                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });

                await LoadPageData();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            item.Status = previousStatus;
            StateHasChanged();

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = $"Failed: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }
    private async Task LoadPageData()
    {
        try
        {
            var statusesToFetch = new[]
            {
            "Sale Confirmed",
        };

            // ✅ Cache each status's page independently
            var tasks = statusesToFetch.Select(status =>
                Cache.GetOrSetAsync(
                    CacheKeys.RepairItem(currentPage, pageSize) + $":{status}",
                    () => RepairItemService.SearchRepairServicesAsync(
                        pageNumber: currentPage,
                        pageSize: pageSize,
                        status: status,
                        sortBy: "reportNo",
                        sortDescending: true),
                    TimeSpan.FromMinutes(3)
                )
            ).ToList();

            // Wait for all calls to complete simultaneously
            var results = await Task.WhenAll(tasks);

            // Combine all results
            var allResults = new List<RepairServices>();
            int combinedTotalCount = 0;

            foreach (var result in results)
            {
                if (result?.Items != null && result.Items.Any())
                {
                    allResults.AddRange(result.Items);
                    combinedTotalCount += result.TotalCount;
                }
            }

            // Remove duplicates and sort
            filteredRepairServices = allResults
                .GroupBy(x => x.Id)
                .Select(g => g.First())
                .OrderByDescending(x => x.reportNo)
                .ToList();

            totalItems = combinedTotalCount;
            totalPages = totalItems > 0 ? (int)Math.Ceiling(totalItems / (double)pageSize) : 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading page data: {ex.Message}");
        }
    }
