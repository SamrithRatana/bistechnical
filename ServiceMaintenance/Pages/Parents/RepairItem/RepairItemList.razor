    private async Task OnRepairStatusChanged(RepairServices item, string newStatus)
    {
        if (string.IsNullOrEmpty(newStatus) || newStatus == item.Status)
            return;

        string previousStatus = item.Status;

        try
        {
            if (newStatus == "Inspecting")
            {
                await RepairItemService.MoveBackToInspectingAsync(item.Id);

                // ✅ Publish to RabbitMQ
                await MQ.PublishStatusChangeAsync(
                    MessageQueueHelper.Queues.InspectItem,
                    "RepairItem",
                    item.Id,
                    "Inspecting",
                    item.reportNo,
                    null
                );

                // ✅ Invalidate Redis cache for both lists this item moves between
                await Cache.InvalidateManyAsync(
                    CacheKeys.RepairItem(currentPage, pageSize) + ":Sale Confirmed",
                    CacheKeys.RepairItem(1, pageSize) + ":Sale Confirmed",
                    CacheKeys.InspectItem(1, pageSize),
                    CacheKeys.DashboardStats
                );

                if (hubConnection?.State == HubConnectionState.Connected)
                    await hubConnection.SendAsync("BroadcastItemUpdate", "ItemUpdated");

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "សម្រេច",
