    private async Task SearchCustomers(string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < 2)
        {
            searchedCustomers = new List<Customer>();
            return;
        }

        try
        {
            isSearchingCustomers = true;
            StateHasChanged();

            // ✅ Use paginated API with search
            var result = await CustomerService.GetCustomersPaginatedAsync(
                pageNumber: 1,
                pageSize: 20,
                searchTerm: searchTerm,
                isActive: true
            );

            searchedCustomers = result.Data?.ToList() ?? new List<Customer>();
            Console.WriteLine($"Found {searchedCustomers.Count} customers matching '{searchTerm}'");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error searching customers: {ex.Message}");
            searchedCustomers = new List<Customer>();
        }
        finally
        {
            isSearchingCustomers = false;
            StateHasChanged();
        }
    }

    // ============================================
    // UPDATED: GetCustomerType with on-demand search
    // ============================================
    private string GetCustomerType(string companyName)
    {
        if (string.IsNullOrEmpty(companyName))
            return "Unknown";

        // First check searched customers
        var customer = searchedCustomers?.FirstOrDefault(c =>
            c.CompanyName != null &&
            c.CompanyName.Equals(companyName, StringComparison.OrdinalIgnoreCase));

        if (customer != null)
            return customer.CustomerType ?? "Unknown";

        // If not found in searched customers, trigger a search
        // Note: This should ideally be done proactively when loading repair services
        _ = Task.Run(async () => await SearchCustomers(companyName));

        return "Unknown";
    }


