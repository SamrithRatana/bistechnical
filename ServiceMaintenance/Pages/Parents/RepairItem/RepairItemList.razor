                // ✅ 4. NO USER CACHE REFRESH - Not needed since we're not adding users
                // The user who performed the repair is already in the cache
                // We only need to refresh user cache when NEW users are added to the system
                Console.WriteLine("ℹ️ Skipping user cache refresh - not needed for repair updates");
            });

            Console.WriteLine("✅ Repair operation completed successfully");
        }
        catch (HttpRequestException ex) when (ex.Message.Contains("timed out"))
        {
            Console.WriteLine($"⏱️ Repair operation timed out: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Timeout",
                Text = "Operation is taking longer than expected. Refreshing data...",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Warning
            });

            // Reload data to ensure consistency
            await LoadPageData();
            isConfirmationDialogVisible = false;
            isProcessing = false;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"❌ Failed to process repair item: {ex.Message}");

            string userMessage = ParseFriendlyErrorMessage(ex.Message);

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "មិនអាចអនុម័តបាន",
                Text = userMessage,
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });

            await LoadPageData();
            isConfirmationDialogVisible = false;
            isProcessing = false;
        }
        finally
        {
            // ✅ Ensure processing flag is always reset
            if (isProcessing)
            {
                isProcessing = false;
                StateHasChanged();
            }

            Console.WriteLine("🏁 Repair operation finalized");
        }
    }

    private string ParseFriendlyErrorMessage(string rawError)
    {
        try
        {
            if (rawError.Contains("Insufficient stock") || rawError.Contains("Insufficient stock when releasing hold"))
            {
                var itemMatch = System.Text.RegularExpressions.Regex.Match(
                    rawError, @"Item:\s*(.+?)\s*\|");
                var availableMatch = System.Text.RegularExpressions.Regex.Match(
                    rawError, @"Available:\s*(\d+)");
                var requiredMatch = System.Text.RegularExpressions.Regex.Match(
                    rawError, @"Required:\s*(\d+)");
                var barcodeMatch = System.Text.RegularExpressions.Regex.Match(
                    rawError, @"(?:Barcode|Serial|SKU|Code):\s*([A-Za-z0-9\-]+)",
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase);

                string itemName = itemMatch.Success ? itemMatch.Groups[1].Value.Trim() : "គ្រឿងបន្លាស់";
                string available = availableMatch.Success ? availableMatch.Groups[1].Value : "0";
                string required = requiredMatch.Success ? requiredMatch.Groups[1].Value : "?";

                // ✅ Try barcode from regex first, fallback to spare part items in the current service
                string barcode = barcodeMatch.Success
                    ? barcodeMatch.Groups[1].Value.Trim()
                    : GetBarcodeFromCurrentService(itemName);

                string barcodeInfo = !string.IsNullOrEmpty(barcode)
                    ? $"Id: {barcode} | "
                    : "";

                return $"ស្តុកគ្រឿងបន្លាស់មិនគ្រប់គ្រាន់ សូមពិនិត្យឡើងវិញ! " +
                       $"ឈ្មោះ: {itemName} | " +
                       $"{barcodeInfo}" +
                       $"មានក្នុងស្តុក: {available} | " +
                       $"ត្រូវការ: {required}. " +
                       $"សូមបញ្ចូលស្តុកជាមុនសិន។";
            }

            if (rawError.Contains("DbUpdateException") || rawError.Contains("SqlException"))
            {
                return "មានបញ្ហាក្នុងការរក្សាទុកទិន្នន័យ។ សូមព្យាយាមម្តងទៀត។";
            }

            if (rawError.Contains("timed out") || rawError.Contains("timeout"))
            {
                return "ការតភ្ជាប់យឺតពេក។ សូមព្យាយាមម្តងទៀត។";
            }

            if (rawError.Contains("InternalServerError") || rawError.Contains("500"))
            {
                return "មានបញ្ហានៅម៉ាស៊ីនមេ។ សូមទាក់ទងអ្នកគ្រប់គ្រង។";
            }

            return "មិនអាចអនុម័តការជួសជុលបាន។ សូមពិនិត្យម្តងទៀត ឬទាក់ទងអ្នកគ្រប់គ្រង។";
        }
        catch
        {
            return "មិនអាចអនុម័តការជួសជុលបាន។ សូមទាក់ទងអ្នកគ្រប់គ្រង។";
        }
    }

    // ✅ Helper: look up barcode from the current selected service's spare parts
    private string GetBarcodeFromCurrentService(string itemName)
    {
        try
        {
            if (_selectedRepairService?.SparePartItems == null)
                return string.Empty;

            foreach (var sp in _selectedRepairService.SparePartItems)
            {
                var sparePartObj = _spareParts.FirstOrDefault(x =>
                    x.Id == sp.SparePartId &&
                    (x.ItemName?.Equals(itemName, StringComparison.OrdinalIgnoreCase) == true ||
                     itemName.Contains(x.ItemName ?? "", StringComparison.OrdinalIgnoreCase)));

                if (sparePartObj != null)
                    return sparePartObj.Id.ToString(); // ✅ Use Id instead of SerialNumber
            }

            // ✅ Fallback: if name match fails, just return the first spare part Id
            var firstSparePart = _selectedRepairService?.SparePartItems?.FirstOrDefault();
            if (firstSparePart?.SparePartId != null)
                return firstSparePart.SparePartId.ToString();

            return string.Empty;
        }
        catch
        {
            return string.Empty;
        }
    }
