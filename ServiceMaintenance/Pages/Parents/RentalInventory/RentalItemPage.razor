    private async Task SaveManualInputItem()
    {
        try
        {
            // Clear previous error messages
            manualInputErrorMessage = "";

            // Validate input
            if (string.IsNullOrWhiteSpace(manualInputItem.ItemName))
            {
                manualInputErrorMessage = "Item name is required.";
                return;
            }

            if (string.IsNullOrWhiteSpace(manualInputItem.ItemType))
            {
                manualInputErrorMessage = "Item type is required.";
                return;
            }

            // Check if item name already exists
            if (ItemTemplates.Any(p => p.ItemName.Equals(manualInputItem.ItemName, StringComparison.OrdinalIgnoreCase)))
            {
                manualInputErrorMessage = "Item name already exists.";
                return;
            }

            // Auto-generate serial number with Generate- prefix
            string generatedSerial;
            do
            {
                generatedSerial = GenerateSerialNumberWithPrefix();
            }
            while (allItems?.Any(i => i.SerialNumber == generatedSerial) == true);

            manualInputItem.SerialNumber = generatedSerial;

            // Set default values
            manualInputItem.Id = Guid.NewGuid();

            // Save to database using the service
            await ItemService.CreateItemAsync(manualInputItem);

            // Add to local ItemTemplates list for immediate UI update
            ItemTemplates.Add(new RentalItemTemplate
            {
                ItemName = manualInputItem.ItemName,
                Category = manualInputItem.ItemType ?? "General"
            });

            // Set the current item's ItemName to the newly added item
            currentItem.ItemName = manualInputItem.ItemName;

            // Close the manual input dialog
            isManualInputDialogVisible = false;

            // Refresh the ItemTemplates from service
            await LoadItemTemplatesFromService();

            // Force UI update
            await InvokeAsync(StateHasChanged);

            // Show success message
            successMessage = $"Item added successfully with serial: {generatedSerial}";
        }
        catch (Exception ex)
        {
            manualInputErrorMessage = $"Error saving item: {ex.Message}";
            errorMessage = "Failed to save item";
        }
    }

