    private IEnumerable<Customer> FilteredCustomers =>
        Customers.Where(c => string.IsNullOrEmpty(searchTerm) || c.CompanyName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
    private void OnSearchTermInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;

        // Cancel previous search timer
        _customerSearchDebounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < CUSTOMER_SEARCH_MIN_CHARS)
        {
            // If search is cleared or too short, load initial customers
            _ = Task.Run(async () =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadInitialCustomers();
                    IsDropdownVisible = false;
                    StateHasChanged();
                });
            });
            return;
        }

        // Debounce: wait 300ms before searching
        _customerSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await SearchCustomersOptimized(searchTerm);
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error in customer search: {ex.Message}");
            }
        }, null, 300, Timeout.Infinite);

        IsDropdownVisible = true;
    }

    // ✅ NEW: Load initial customers (first 10)
    private async Task LoadInitialCustomers()
    {
        try
        {
            var pagedResponse = await CustomerService.GetCustomersPaginatedAsync(
                pageNumber: 1,
                pageSize: 10,
                searchTerm: null,
                isActive: true
            );

            if (pagedResponse?.Data != null && pagedResponse.Data.Any())
            {
                Customers = pagedResponse.Data.ToList();
                Console.WriteLine($"Loaded {Customers.Count} initial customers");
            }
            else
            {
                Customers = new List<Customer>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load initial customers: {ex.Message}");
            Customers = new List<Customer>();
        }
    }

  
    private async Task<List<Customer>> SearchCustomersByTerm(string term)
    {
        if (string.IsNullOrWhiteSpace(term) || term.Length < CUSTOMER_SEARCH_MIN_CHARS)
        {
            return new List<Customer>();
        }

        try
        {
            Console.WriteLine($"🔍 API Call - Searching for: '{term}'");

            var result = await CustomerService.GetCustomersPaginatedAsync(
                pageNumber: 1,
                pageSize: CUSTOMER_SEARCH_PAGE_SIZE,
                searchTerm: term,  // ✅ Uses the term parameter
                isActive: true
            );

            var customers = result.Data?.ToList() ?? new List<Customer>();

            Console.WriteLine($"📊 API Response: {customers.Count} customers found");

            return customers;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Search failed: {ex.Message}");
            return new List<Customer>();
        }
    }

    // New optimized search method
    private async Task SearchCustomersOptimized(string searchTerm)
    {
        try
        {
            var searchResult = await CustomerService.GetCustomersPaginatedAsync(
                pageNumber: 1,
                pageSize: CUSTOMER_SEARCH_PAGE_SIZE,
                searchTerm: searchTerm,
                isActive: true
            );

            Customers = searchResult.Data?.ToList() ?? new List<Customer>();
            IsDropdownVisible = Customers.Any();

            if (!Customers.Any())
            {
                Console.WriteLine($"No customers found matching '{searchTerm}'");
            }
            else
            {
                Console.WriteLine($"Found {Customers.Count} customers matching '{searchTerm}'");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error searching customers: {ex.Message}");
            Customers = new List<Customer>();
            IsDropdownVisible = false;
        }
    }
