    private async Task ShowReportPreview()
    {
        try
        {
            // Get current user name
            string currentUserName = await UserService.GetCurrentUserNameAsync();

            // Create an instance of the report
            var report = new RentalItemReport();

            // Use filtered items instead of all items
            var reportData = filteredItems.ToList();

            // Pass the selected customer name to the report
            string customerNameForReport = selectedCustomerForReport?.CompanyName;

            // Set data source with customer name and current user name parameters
            report.SetDataSource(reportData, customerNameForReport, currentUserName);

            // Export the report to PDF format
            byte[] reportBytes;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportBytes = ms.ToArray();
            }

            // Convert byte array to base64 string for JavaScript
            string base64Report = Convert.ToBase64String(reportBytes);

            // Use the existing blazorReportsPrint.printReport function
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.printReport", base64Report, "RentalItemReport.pdf");

            // Show success message with filter info
            var filterInfo = selectedCustomerForReport != null
                ? $"for {selectedCustomerForReport.CompanyName}"
                : "for all customers";

            successMessage = $"Report generated successfully {filterInfo} ({reportData.Count} items) by {currentUserName}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating report: {ex.Message}");
            errorMessage = $"Error generating report: {ex.Message}";
        }
    }

    private void ApplyFilters()
    {
        // Start with all items
        IEnumerable<RentalItem> query = allItems ?? new List<RentalItem>();

        // Filter by selected customer (only if one is selected)
        if (selectedCustomerForReport != null)
        {
            query = query.Where(item =>
                item.CustomerId == selectedCustomerForReport.Id ||
                item.CustomerName.Equals(selectedCustomerForReport.CompanyName, StringComparison.OrdinalIgnoreCase));
        }

        // Filter by action type (only if one is selected)
        if (!string.IsNullOrWhiteSpace(selectedActionType))
        {
            query = query.Where(item => item.Condition == selectedActionType);
        }

        // ✅ FIX: Always assign to filteredItems
        filteredItems = query.ToList();

        // ✅ DEBUGGING: Log filter results
        Console.WriteLine($"ApplyFilters: {allItems?.Count ?? 0} total items, {filteredItems.Count} after filters");
        Console.WriteLine($"  - Customer filter: {selectedCustomerForReport?.CompanyName ?? "None"}");
        Console.WriteLine($"  - Action type filter: {selectedActionType ?? "None"}");

        StateHasChanged();
    }


