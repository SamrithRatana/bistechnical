    private async Task LoadItemsWithCache(bool forceRefresh = false)
    {
        if (isLoading && !forceRefresh) return;

        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            StateHasChanged();

            var stopwatch = System.Diagnostics.Stopwatch.StartNew();

            // ✅ Use paginated API call instead of loading all
            var pagedResult = await RepairItemService.GetRentalItemsPagedAsync(
                page: currentPage,
                pageSize: pageSize,
                filter: selectedActionType,
                forceRefresh: forceRefresh
            );

            stopwatch.Stop();

            if (pagedResult != null)
            {
                allItems = pagedResult.Items?.ToList() ?? new List<RentalItem>();
                totalRecords = pagedResult.TotalCount;
                totalPages = pagedResult.TotalPages;
            }
            else
            {
                allItems = new List<RentalItem>();
                totalRecords = 0;
                totalPages = 0;
            }

            ApplyFilters();

            Console.WriteLine($"Loaded page {currentPage}/{totalPages}: {allItems.Count} items (Total: {totalRecords})");

            var loadMessage = $"Loaded page {currentPage} ({allItems.Count} items) in {stopwatch.ElapsedMilliseconds}ms";
            successMessage = loadMessage;

            if (isInitialLoad)
            {
                isInitialLoad = false;
            }

            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                await InvokeAsync(() =>
                {
                    if (successMessage == loadMessage)
                    {
                        successMessage = string.Empty;
                        StateHasChanged();
                    }
                });
            });
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load items: {ex.Message}";
            allItems = new List<RentalItem>();
            filteredItems = new List<RentalItem>();
            Console.WriteLine($"Error loading items: {ex}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages || page == currentPage) return;

        currentPage = page;
        await LoadItemsWithCache(false);
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadItemsWithCache(false);
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadItemsWithCache(false);
        }
    }

