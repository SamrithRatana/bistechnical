@page "/rentalitem-optimized"
@page "/rentalitem/{id:guid}"
@inject ServiceMaintenance.Services.BISServices.RentalItemService RepairItemService
@inject ItemService ItemService
@inject CustomerService CustomerService
@inject UserService UserService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@using ServiceMaintenance.Models
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Notifications
@using Syncfusion.Blazor.Popups

<DxToastProvider Name="Success"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" Click="NewItem_Click" IconCssClass="far fa-file" CssClass="toolbar-item" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" Click="EditItem_Click" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="false" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" Click="DeleteItem_Click" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="false" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                <Items>
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ExportToPdf" IconCssClass="fas fa-file-pdf" />
                </Items>
            </DxToolbarItem>
            <DxToolbarItem Text="Print Report" Click="ShowReportPreview" CssClass="toolbar-item" IconCssClass="fas fa-print" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" Click="Check_Click" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" Enabled="false" />
        </DxToolbar>
    </div>
</div>
<!-- Add this to your existing filter controls section, replace the existing customer filter -->
<div class="row mb-3">
    <!-- Customer Search Filter -->
    <!-- Customer Search Filter -->
    <div class="col-md-4">
        <label class="font-weight-bold" style="font-family:'Khmer OS'">
            @Loc[nameof(ResourceStrings.TextCompanyName)]:
        </label>

        <div class="form-item" style="display: flex; flex-direction: column; align-items: flex-start; position: relative;">
            <p style="margin: 0; padding: 0; font-size: 14px;">
                @Loc[nameof(ResourceStrings.TextCompanyName)]
            </p>

            <input type="text"
                   @bind="searchTerm"
                   @oninput="OnSearchTermInput"
                   @onclick="OnInputClick"
                   @onblur="OnInputBlur"
                   placeholder="Type to search company (min 2 characters)..."
                   class="form-control"
                   style="height: 35px; font-size: 14px; margin-top: 2px; padding: 0; font-family: 'Khmer OS'" />

            @if (IsDropdownVisible && FilteredCustomers.Any())
            {
                <div class="custom-dropdown"
                     @onmousedown:preventDefault
                     style="position: absolute; width: 100%; max-height: 260px; overflow-y: auto;
                        border: 1px solid #ccc; background-color: white; z-index: 1000;
                        margin-top: 55px; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                        font-family: 'Khmer OS'">

                    <!-- Dropdown header with close button -->
                    <div style="display: flex; justify-content: space-between; align-items: center;
                            padding: 8px 12px; background-color: #f8f9fa; border-bottom: 1px solid #dee2e6;">
                        <span style="font-size: 12px; color: #6c757d;">
                            <strong>Select a company (showing @FilteredCustomers.Count() results)</strong>
                        </span>
                        <button class="btn btn-sm btn-link p-0"
                                @onclick="CloseCustomerDropdown"
                                style="font-size: 16px; color: #dc3545; border: none; background: none;
                                   font-weight: bold; line-height: 1;">
                            ×
                        </button>
                    </div>

                    <!-- Dropdown list -->
                    @foreach (var company in FilteredCustomers)
                    {
                        <div class="dropdown-item px-3 py-2"
                             @onclick="() => OnCompanySelect(company)"
                             style="cursor: pointer; border-bottom: 1px solid #f0f0f0;">
                            <div class="fw-medium">
                                @company.CompanyName
                            </div>
                            @if (!string.IsNullOrEmpty(company.Address))
                            {
                                <small class="text-muted">@company.Address</small>
                            }
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(searchTerm) && searchTerm.Length >= 2 && !FilteredCustomers.Any())
            {
                <div style="position: absolute; width: 100%; margin-top: 55px; padding: 10px;
                        background-color: #fff3cd; border: 1px solid #ffc107;
                        border-radius: 4px; color: #856404; font-size: 14px; z-index: 1000;">
                    <i class="fas fa-exclamation-triangle"></i> No customers found matching "@searchTerm"
                </div>
            }

        
        </div>
    </div>


    <!-- Action Type Filter -->
    <div class="col-md-3">
        <label class="font-weight-bold">Action Type:</label>
        <select class="form-select" value="@selectedActionType" @onchange="OnActionTypeChanged">
            <option value="">All Action Types</option>
            <option value="New">New</option>
            <option value="Second-hand">Second-hand</option>
        </select>
    </div>

    <!-- Refresh Button -->
    <div class="col-md-3">
        <label class="d-block">&nbsp;</label>
        <div class="btn-group w-100">
            <button class="btn btn-primary"
                    @onclick="() => LoadItemsWithCache(false)"
                    disabled="@isLoading">
                <i class="fas fa-sync-alt @(isLoading ? "fa-spin" : "")"></i>
                @(isLoading ? "Loading..." : "Refresh")
            </button>
            <button class="btn btn-outline-primary"
                    @onclick="() => LoadItemsWithCache(true)"
                    disabled="@isLoading"
                    title="Force Refresh">
                <i class="fas fa-redo"></i>
            </button>
        </div>
    </div>

    <!-- Print Report Button -->
    <div class="col-md-2">
        <label class="d-block">&nbsp;</label>
        <button class="btn btn-success w-100"
                @onclick="ShowReportPreview"
                disabled="@(isLoading || !filteredItems.Any())">
            <i class="fas fa-print me-1"></i>Print Report
        </button>
    </div>
</div>

<!-- Filter Summary -->
@if (selectedCustomerForReport != null || !string.IsNullOrEmpty(selectedActionType))
{
    <div class="row mb-3">
        <div class="col-12">
            <div class="alert alert-info d-flex justify-content-between align-items-center">
                <div>
                    <i class="fas fa-filter me-2"></i>
                    <strong>Active Filters:</strong>

                    @if (selectedCustomerForReport != null)
                    {
                        <span class="badge bg-primary ms-2">
                            Customer: @selectedCustomerForReport.CompanyName
                        </span>
                    }

                    @if (!string.IsNullOrEmpty(selectedActionType))
                    {
                        <span class="badge bg-warning text-dark ms-2">
                            Type: @selectedActionType
                        </span>
                    }

                    <small class="ms-2 text-muted">(@filteredItems.Count items found)</small>
                </div>

                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="ClearAllFilters">
                    <i class="fas fa-times me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>
}

<hr>
<div class="container-fluid py-4">
    @if (IsDetailView)
    {
        <!-- Individual Item Detail View -->
        <div class="row mb-3">
            <div class="col">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="/rentalitem-optimized" class="text-decoration-none">
                                <i class="fas fa-list me-1"></i>Repair Items
                            </a>
                        </li>
                        <li class="breadcrumb-item active">@(selectedItem?.ItemName ?? "Item Details")</li>
                    </ol>
                </nav>
            </div>
        </div>

        @if (selectedItem != null)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <div class="row align-items-center">
                        <div class="col">
                            <h4 class="card-title mb-0">
                                <i class="fas fa-box me-2"></i>@selectedItem.ItemName
                            </h4>
                        </div>
                        <div class="col-auto">
                            <div class="btn-group">
                                <button class="btn btn-light btn-sm" @onclick="() => EditItem(selectedItem)">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </button>
                                <button class="btn btn-outline-light btn-sm" @onclick="() => ConfirmDelete(selectedItem)">
                                    <i class="fas fa-trash me-1"></i>Delete
                                </button>
                                <button class="btn btn-outline-light btn-sm" @onclick="GoBackToList">
                                    <i class="fas fa-arrow-left me-1"></i>Back to List
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Customer:</dt>
                                <dd class="col-sm-8">
                                    <strong>@selectedItem.CustomerName</strong>
                                    <br><small class="text-muted">ID: @selectedItem.CustomerId.ToString()[..8]...</small>
                                </dd>
                                <dt class="col-sm-4">Serial Number:</dt>
                                <dd class="col-sm-8">
                                    <code>@selectedItem.SerialNumber</code>
                                </dd>
                                <dt class="col-sm-4">Condition:</dt>
                                <dd class="col-sm-8">
                                    @selectedItem.Condition
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Location:</dt>
                                <dd class="col-sm-8">
                                    <i class="fas fa-map-marker-alt text-muted me-1"></i>
                                    @selectedItem.Location
                                </dd>
                                <dt class="col-sm-4">Duration:</dt>
                                <dd class="col-sm-8">
                                    <span class="fw-bold">@selectedItem.Duration</span>
                                    month@(selectedItem.Duration != 1 ? "s" : "")
                                </dd>
                                <dt class="col-sm-4">Item ID:</dt>
                                <dd class="col-sm-8">
                                    <small class="font-monospace text-muted">@selectedItem.Id</small>
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mb-0">Loading item details...</p>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Item not found or failed to load.
                <button class="btn btn-sm btn-outline-warning ms-2" @onclick="GoBackToList">
                    <i class="fas fa-arrow-left me-1"></i>Back to List
                </button>
            </div>
        }
    }
    else
    {
        <!-- List View -->
        <!-- Top Controls Row -->
        <div class="row mb-3">
            <div class="col-md-3">
                <select class="form-select" value="@selectedActionType" @onchange="OnActionTypeChanged">
                    <option value="">All Action Types</option>
                    <option value="New">New</option>
                    <option value="Second-hand">Second-hand</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="btn-group w-100">
                    <button class="btn btn-primary" @onclick="() => LoadItemsWithCache(false)" disabled="@isLoading">
                        <i class="fas fa-sync-alt @(isLoading ? "fa-spin" : "")"></i>
                        @(isLoading ? "Loading..." : "Refresh")
                    </button>
                    <button class="btn btn-outline-primary" @onclick="() => LoadItemsWithCache(true)" disabled="@isLoading" title="Force Refresh">
                        <i class="fas fa-redo"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(selectedActionType))
                {
                    <div class="alert alert-info d-flex justify-content-between align-items-center mb-0">
                        <div>
                            <i class="fas fa-filter me-2"></i>
                            <span class="badge bg-warning text-dark">Type: @selectedActionType</span>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ClearAllFilters">
                            <i class="fas fa-times me-1"></i>Clear
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }

        <!-- Success Message -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle me-2"></i>
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
            </div>
        }

        <!-- Syncfusion DataGrid -->
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <div class="row align-items-center">
                    <div class="col">
                        <h5 class="card-title mb-0">Repair Items</h5>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted mb-0">
                            @if (isInitialLoad)
                            {
                                <span>Loading repair items...</span>
                            }
                            else
                            {
                                <span>Refreshing data...</span>
                            }
                        </p>
                    </div>
                }
                else if (filteredItems == null || !filteredItems.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No repair items found</h5>
                        <p class="text-muted">
                            @if (!string.IsNullOrEmpty(selectedActionType))
                            {
                                <span>Try adjusting your filter criteria.</span>
                                <br />
                                <button class="btn btn-sm btn-outline-primary mt-2" @onclick="ClearAllFilters">
                                    <i class="fas fa-times me-1"></i>Clear Filters
                                </button>
                            }
                            else if (allItems?.Any() != true)
                            {
                                <span>Click "Refresh" to load items.</span>
                            }
                        </p>
                    </div>
                }
                else
                {
                    <SfGrid DataSource="@filteredItems"
                            AllowSorting="true"
                            AllowExcelExport="true"
                            AllowPdfExport="true"
                            AllowSearching="true"
                            Height="600"
                            Toolbar="@(new List<string>() { "Search" })"
                            @ref="Grid">

                        <!-- REMOVE GridPageSettings - we're doing server-side pagination -->

                        <GridSearchSettings Fields="@(new string[] { "CustomerName", "ItemName", "SerialNumber", "Condition", "Location" })"
                                            IgnoreCase="true"
                                            Key="@searchKey"
                                            Operator="Syncfusion.Blazor.Operator.Contains"></GridSearchSettings>

                        <GridEvents RowSelected="RowSelectHandler" TValue="RentalItem" />

                        <GridColumns>
                            <!-- Your existing columns here -->
                            <GridColumn Field=@nameof(RentalItem.CustomerName) HeaderText="Customer" Width="200" AllowSorting="true" AllowFiltering="true">
                                <Template>
                                    @{
                                        var item = context as RentalItem;
                                    }
                                    <div>
                                        <div class="fw-medium">@item.CustomerName</div>
                                        <small class="text-muted">ID: @item.CustomerId.ToString()[..8]...</small>
                                    </div>
                                </Template>
                            </GridColumn>

                            <GridColumn Field=@nameof(RentalItem.ItemName) HeaderText="Item" Width="200" AllowSorting="true" AllowFiltering="true">
                                <Template>
                                    @{
                                        var item = context as RentalItem;
                                    }
                                    <div class="fw-medium">@item.ItemName</div>
                                </Template>
                            </GridColumn>

                            <GridColumn Field=@nameof(RentalItem.SerialNumber) HeaderText="Serial Number" Width="150" AllowFiltering="true">
                                <Template>
                                    @{
                                        var item = context as RentalItem;
                                    }
                                    <code class="small">@item.SerialNumber</code>
                                </Template>
                            </GridColumn>

                            <GridColumn Field=@nameof(RentalItem.Condition) HeaderText="Condition" Width="130" AllowFiltering="true" AllowSorting="true" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                            </GridColumn>

                            <GridColumn Field=@nameof(RentalItem.Location) HeaderText="Location" Width="150" AllowFiltering="true">
                                <Template>
                                    @{
                                        var item = context as RentalItem;
                                    }
                                    <div>
                                        <i class="fas fa-map-marker-alt text-muted me-1"></i>
                                        @item.Location
                                    </div>
                                </Template>
                            </GridColumn>

                            <GridColumn Field=@nameof(RentalItem.Duration) HeaderText="Duration" Width="100" AllowSorting="true">
                                <Template>
                                    @{
                                        var item = context as RentalItem;
                                    }
                                    <div>
                                        <span class="fw-medium">@item.Duration</span>
                                        <small class="text-muted d-block">month@(item.Duration != 1 ? "s" : "")</small>
                                    </div>
                                </Template>
                            </GridColumn>

                            <GridColumn HeaderText="Actions" Width="140" AllowFiltering="false" AllowSorting="false">
                                <Template>
                                    @{
                                        var item = context as RentalItem;
                                    }
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-outline-info"
                                                @onclick="() => ViewItem(item)"
                                                title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                </Template>
                            </GridColumn>
                        </GridColumns>
                    </SfGrid>

                    <!-- ✅ NEW: Custom Pagination Controls -->
                    <div class="card-footer bg-white border-top">
                        <div class="row align-items-center">
                            <!-- Page Size Selector -->
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <label class="me-2 mb-0 text-muted">Items per page:</label>
                                    <select class="form-select form-select-sm" style="width: auto;"
                                            value="@pageSize"
                                            @onchange="OnPageSizeChanged"
                                            disabled="@isLoading">
                                        <option value="10">10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                        <option value="100">100</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Page Info -->
                            <div class="col-md-6 text-center">
                                <div class="pagination-info">
                                    <span class="text-muted">
                                        Showing
                                        <strong>@((currentPage - 1) * pageSize + 1)</strong>
                                        to
                                        <strong>@Math.Min(currentPage * pageSize, totalRecords)</strong>
                                        of
                                        <strong>@totalRecords</strong>
                                        items
                                    </span>
                                </div>
                            </div>

                            <!-- Pagination Buttons -->
                            <div class="col-md-3">
                                <nav aria-label="Page navigation">
                                    <ul class="pagination pagination-sm justify-content-end mb-0">
                                        <!-- First Page -->
                                        <li class="page-item @(currentPage == 1 || isLoading ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(1)" disabled="@(currentPage == 1 || isLoading)">
                                                <i class="fas fa-angle-double-left"></i>
                                            </button>
                                        </li>

                                        <!-- Previous Page -->
                                        <li class="page-item @(currentPage == 1 || isLoading ? "disabled" : "")">
                                            <button class="page-link" @onclick="PreviousPage" disabled="@(currentPage == 1 || isLoading)">
                                                <i class="fas fa-angle-left"></i>
                                            </button>
                                        </li>

                                        <!-- Page Numbers (show 5 pages max) -->
                                        @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                        {
                                            var pageNum = i; // Capture for closure
                                                             <li class="page-item @(currentPage == pageNum ? "active" : "") @(isLoading ? "disabled" : "")">
                                                                 <button class="page-link"
                                                                         @onclick="() => GoToPage(pageNum)"
                                                                         disabled="@(currentPage == pageNum || isLoading)">
                                                                     @pageNum
                                                                 </button>
                                                             </li>
                                        }

                                        <!-- Next Page -->
                                        <li class="page-item @(currentPage >= totalPages || isLoading ? "disabled" : "")">
                                            <button class="page-link" @onclick="NextPage" disabled="@(currentPage >= totalPages || isLoading)">
                                                <i class="fas fa-angle-right"></i>
                                            </button>
                                        </li>

                                        <!-- Last Page -->
                                        <li class="page-item @(currentPage >= totalPages || isLoading ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(totalPages)" disabled="@(currentPage >= totalPages || isLoading)">
                                                <i class="fas fa-angle-double-right"></i>
                                            </button>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Delete Confirmation Dialog -->
<SfDialog @ref="DialogDelete" IsModal="true" Width="400px" ShowCloseIcon="true" Visible="false">
    <DialogTemplates>
        <Header>
            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
            Confirm Delete
        </Header>
        <Content>
            <div class="text-center">
                <p>Are you sure you want to delete this repair item?</p>
                @if (currentItem != null)
                {
                    <div class="alert alert-warning">
                        <strong>@currentItem.ItemName</strong><br />
                        <small>Serial: @currentItem.SerialNumber</small>
                    </div>
                }
                <p class="text-muted">This action cannot be undone.</p>
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Delete" IsPrimary="true" CssClass="e-danger" OnClick="ConfirmDeleteYes" />
        <DialogButton Content="Cancel" OnClick="ConfirmDeleteNo" />
    </DialogButtons>
</SfDialog>

<!-- No Record Selected Dialog -->
<SfDialog @ref="DialogNoRecordSelected" IsModal="true" Width="350px" ShowCloseIcon="true" Visible="false">
    <DialogTemplates>
        <Header>
            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
            Warning
        </Header>
        <Content>
            <div class="text-center">
                <p>Please select a record from the grid first.</p>
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="OK" IsPrimary="true" OnClick="CloseDialogNoRecordSelected" />
    </DialogButtons>
</SfDialog>

<!-- Add/Edit Item Dialog -->
<SfDialog IsModal="true" Width="800px" ShowCloseIcon="true" Visible="@isAddDialogVisible">
    <DialogTemplates>
        <Header>
            <div class="dialog-header">
                <i class="fas @(currentItem.Id == Guid.Empty ? "fa-plus" : "fa-edit") me-2"></i>
                <h4 class="mb-0">@pageTitle</h4>
            </div>
        </Header>
    </DialogTemplates>
    <EditForm Model="@currentItem" OnValidSubmit="SaveItem">
        <DataAnnotationsValidator />
        <div class="container-fluid">
            <!-- First Row: Customer and Item Name -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-item" style="display: flex; flex-direction: column; align-items: flex-start; position:relative;">
                        <p style="margin: 0; padding: 0; font-size: 14px;">@Loc[nameof(ResourceStrings.TextCompanyName)]</p>
                        <input type="text" @bind="searchTerm"
                               @oninput="OnSearchTermInput"
                               @onclick="OnInputClick"
                               @onblur="OnInputBlur"
                               placeholder="Search by company..."
                               class="form-control"
                               style="height: 35px; font-size: 14px; margin-top: 2px; padding: 0;font-family: 'Khmer OS'" />
                        @if (IsDropdownVisible && FilteredCustomers.Any())
                        {
                            <div class="custom-dropdown" style="position: absolute; width: 380px; max-height: 250px; overflow-y: auto; border: 1px solid #ccc; background-color: white; z-index: 1000; margin-top: 55px;font-family: 'Khmer OS'">
                                @foreach (var company in FilteredCustomers)
                                {
                                    <div class="dropdown-item" @onclick="() => OnCompanySelect(company)">
                                        @company.CompanyName
                                    </div>
                                }
                            </div>
                        }
                        <ValidationMessage For="@(() => currentItem.CustomerName)" class="text-danger small" />
                        @if (!string.IsNullOrEmpty(customerNameErrorMessage))
                        {
                            <div class="text-danger small">@customerNameErrorMessage</div>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <div class="combo-input-container">
                            <div class="combo-wrapper">
                                <SfComboBox @ref="itemComboBox"
                                            @onclick="OnItemComboBoxClick"
                                            TValue="string"
                                            TItem="RentalItemTemplate"
                                            Placeholder="Select Item"
                                            FloatLabelType="FloatLabelType.Always"
                                            FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                            AllowFiltering="true"
                                            @bind-Value="currentItem.ItemName"
                                            DataSource="@ItemTemplates"
                                            Width="100%"
                                            PopupHeight="300px"
                                            PopupWidth="100%">

                                    <ComboBoxFieldSettings Value="ItemName" Text="ItemName"></ComboBoxFieldSettings>

                                    <ComboBoxTemplates TItem="RentalItemTemplate">
                                        <ItemTemplate Context="template">
                                            <div class="dropdown-item-template">
                                                <div class="fw-medium">@template.ItemName</div>
                                                <small class="text-muted">@template.Category</small>
                                            </div>
                                        </ItemTemplate>
                                    </ComboBoxTemplates>
                                </SfComboBox>
                            </div>

                            <button type="button" class="btn-plus" @onclick="OpenManualInputDialog">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>

                        <ValidationMessage For="@(() => currentItem.ItemName)" class="text-danger small" />

                        @if (!string.IsNullOrEmpty(itemNameErrorMessage))
                        {
                            <div class="text-danger small">
                                @itemNameErrorMessage
                            </div>
                        }
                    </div>
                </div>

            </div>

            <!-- Second Row: Serial Number and Condition -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <SfTextBox @bind-Value="currentItem.SerialNumber"
                                   Placeholder="Serial Number"
                                   FloatLabelType="FloatLabelType.Always">
                        </SfTextBox>
                        <ValidationMessage For="@(() => currentItem.SerialNumber)" class="text-danger small" />
                        @if (!string.IsNullOrEmpty(serialNumberErrorMessage))
                        {
                            <div class="text-danger small">@serialNumberErrorMessage</div>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <SfComboBox @ref="itemActionType"
                                    @onclick="OnActionComboBoxClick"
                                    TValue="string"
                                    TItem="ActionTypeOption"
                                    Placeholder="Action Type"
                                    FloatLabelType="FloatLabelType.Always"
                                    @bind-Value="currentItem.Condition"
                                    DataSource="@ActionTypes"
                                    Width="100%">
                            <ComboBoxFieldSettings Value="Value" Text="Text"></ComboBoxFieldSettings>
                        </SfComboBox>
                        <ValidationMessage For="@(() => currentItem.Condition)" class="text-danger small" />
                    </div>
                </div>
            </div>

            <!-- Third Row: Location and Duration -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <SfTextBox @bind-Value="currentItem.Location"
                                   Placeholder="Location"
                                   FloatLabelType="FloatLabelType.Always"
                                   Readonly="@isLocationReadonly">
                        </SfTextBox>
                        <ValidationMessage For="@(() => currentItem.Location)" class="text-danger small" />
                        @if (isLocationReadonly)
                        {
                            <small class="text-muted">Location auto-filled from selected customer address</small>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <SfNumericTextBox @bind-Value="currentItem.Duration"
                                          Placeholder="Duration (Months)"
                                          FloatLabelType="FloatLabelType.Always"
                                          Min="0"
                                          Max="60"
                                          Format="0">
                        </SfNumericTextBox>
                        <ValidationMessage For="@(() => currentItem.Duration)" class="text-danger small" />
                    </div>
                </div>
            </div>

            <!-- Validation Summary -->
            <ValidationSummary class="text-danger mb-3" />

            <!-- Action Buttons -->
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary" @onclick="CancelDialog">
                            <i class="fas fa-times me-1"></i>Cancel
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <i class="fas fa-spinner fa-spin me-1"></i>
                            }
                            else
                            {
                                <i class="fas @(currentItem.Id == Guid.Empty ? "fa-plus" : "fa-save") me-1"></i>
                            }
                            @(currentItem.Id == Guid.Empty ? "Create" : "Update")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </EditForm>
</SfDialog>

