    private RentalItem selectedViewItem = null;
    private Guid? selectedItemId;
    private System.Threading.Timer _customerSearchDebounceTimer;
    private const int CUSTOMER_SEARCH_MIN_CHARS = 2;
    private const int CUSTOMER_SEARCH_PAGE_SIZE = 20;
    // Grid configuration

    // Search and filter
    private string searchKey = string.Empty;
    private string selectedActionType = string.Empty;

    // State management
    private bool isLoading = false;
