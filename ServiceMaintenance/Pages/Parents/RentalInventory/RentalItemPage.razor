    private async Task SaveItem()
    {
        try
        {
            isSaving = true;
            serialNumberErrorMessage = string.Empty;
            itemNameErrorMessage = string.Empty;
            customerNameErrorMessage = string.Empty;

            // Validation
            if (string.IsNullOrWhiteSpace(currentItem.CustomerName))
            {
                customerNameErrorMessage = "Customer is required";
                return;
            }

            if (string.IsNullOrWhiteSpace(currentItem.SerialNumber))
            {
                serialNumberErrorMessage = "Serial Number is required";
                return;
            }

            if (string.IsNullOrWhiteSpace(currentItem.ItemName))
            {
                itemNameErrorMessage = "Item Name is required";
                return;
            }

            // Check for duplicate serial numbers
            if (allItems.Any(i => i.SerialNumber.Equals(currentItem.SerialNumber, StringComparison.OrdinalIgnoreCase) && i.Id != currentItem.Id))
            {
                serialNumberErrorMessage = "This Serial Number already exists";
                return;
            }

            // Validate customer exists
            var selectedCustomer = Customers.FirstOrDefault(c => c.CompanyName.Equals(currentItem.CustomerName, StringComparison.OrdinalIgnoreCase));
            if (selectedCustomer == null)
            {
                customerNameErrorMessage = "Please select a valid customer from the dropdown";
                return;
            }

            // Check if item name exists in templates
            if (!ItemTemplates.Any(t => t.ItemName.Equals(currentItem.ItemName, StringComparison.OrdinalIgnoreCase)))
            {
                itemNameErrorMessage = "Please select a valid item from the dropdown";
                return;
            }

            // Ensure CustomerId is set correctly
            currentItem.CustomerId = selectedCustomer.Id;

            if (currentItem.Id == Guid.Empty)
            {
                // Create new item
                currentItem.Id = Guid.NewGuid();
                currentItem.CreatedBy = Guid.NewGuid();

                await RepairItemService.CreateRentalItemAsync(currentItem);

                // Add to local collection
                allItems.Add(currentItem);
                ApplyFilters();

                successMessage = $"Successfully created: {currentItem.ItemName}";
            }
            else
            {
                // Update existing item
                await RepairItemService.UpdateRentalItemAsync(currentItem);

                // Update in local collection
                var existingIndex = allItems.FindIndex(i => i.Id == currentItem.Id);
                if (existingIndex >= 0)
                {
                    allItems[existingIndex] = new RentalItem
                    {
                        Id = currentItem.Id,
                        CreatedBy = currentItem.CreatedBy,
                        CustomerId = currentItem.CustomerId,
                        CustomerName = currentItem.CustomerName,
                        ItemName = currentItem.ItemName,
                        SerialNumber = currentItem.SerialNumber,
                        Condition = currentItem.Condition,
                        Location = currentItem.Location,
                        Duration = currentItem.Duration
                    };
                }
                ApplyFilters();

                successMessage = $"Successfully updated: {currentItem.ItemName}";
            }

            isAddDialogVisible = false;

            // Clear selection
            selectedItemId = null;
            selectedViewItem = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save item: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

