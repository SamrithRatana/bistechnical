    // Method to generate random serial number
    private string GenerateRandomSerialNumber()
    {
        const string letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        const string numbers = "0123456789";
        var random = new Random();

        // Generate format: A12345 (1 letter + 5 numbers)
        string letter = letters[random.Next(letters.Length)].ToString();
        string numberPart = new string(
            Enumerable.Repeat(numbers, 5)
                      .Select(s => s[random.Next(s.Length)])
                      .ToArray()
        );

        return letter + numberPart;
    }

    // Alternative method for different serial number formats
    private string GenerateRandomSerialNumberAlternative()
    {
        var random = new Random();

        // Option 1: Format like "SN240815001" (SN + date + counter)
        // return $"SN{DateTime.Now:yyMMdd}{random.Next(1, 1000):D3}";

        // Option 2: Pure random alphanumeric (8 characters)
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
        return new string(
            Enumerable.Repeat(chars, 8)
                      .Select(s => s[random.Next(s.Length)])
                      .ToArray()
        );
    }

