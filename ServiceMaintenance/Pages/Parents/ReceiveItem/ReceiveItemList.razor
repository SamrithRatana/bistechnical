<style>

    .form-item {
        width: 100%; /* Full width for form items */
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(80%, 300px), 1fr));
        gap: 1rem;
    }

    .camera-scanner-dialog .e-dlg-content {
        padding: 20px;
    }

    .btn-primary {
        background-color: #007bff;
        border-color: #007bff;
        color: white;
    }

        .btn-primary:hover {
            background-color: #0056b3;
            border-color: #004085;
        }

    @@keyframes pulse {
        0%, 100%

    {
        opacity: 1;
    }

    50% {
        opacity: 0.5;
    }

    }

    .pulse-animation {
        animation: pulse 2s infinite;
    }


    #camera-preview {
        /* transform: scaleX(-1); /* Mirror the camera */ 
    }
    /* Add to your CSS file */
    #camera-preview-container {
        position: relative;
        width: 100%;
        max-width: 640px;
        height: 480px;
        background: #000;
        border-radius: 8px;
        margin: 0 auto 15px;
        overflow: hidden;
    }

        #camera-preview-container video,
        #camera-preview-container canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
    /* Scanning overlay guides */
    .drawingBuffer {
        position: absolute;
        top: 0;
        left: 0;
    }

    @@media (max-width: 768px) {
        #camera-preview-container

    {
        height: 350px !important;
        max-width: 100%;
    }

    }

    #target {
        background-color: transparent;
        color: black;
    }

    .customtooltip.e-tooltip-wrap.e-popup {
        background-color: #EDEFEE;
        border: 2px solid #000;
    }

    .custom-table td:first-child {
        white-space: nowrap;
        width: 1%;
        padding-right: 8px;
        text-align: left;
    }

    .custom-table .field-label {
        text-align: left;
        white-space: nowrap;
        position: relative;
        padding-right: 20px;
    }

        .custom-table .field-label::after {
            content: ":";
            position: absolute;
            right: 2px;
        }

    .button-checkbox-container {
        display: flex;
        align-items: center;
    }

    .small-circle-button {
        padding: 0;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #007bff;
        color: white;
        border: none;
        font-size: 20px;
        cursor: pointer;
        width: 1px;
        height: 80px;
        line-height: 40px;
        left: 0;
        margin-right: 50px;
    }

    /* Styling for the tooltip content */
    .tooltip-content {
        display: flex;
        justify-content: space-between; /* To place content and image side by side */
        align-items: flex-start; /* Align content at the top */
        overflow: hidden; /* Prevent overflow */
        gap: 20px; /* Add space between the table and image */
    }

    .tooltip-image-container {
        flex-shrink: 0; /* Prevent image from shrinking */
        border: 2px solid #000; /* Rectangular border for the image container */
        width: 90px; /* Fixed width for the image container */
        height: 100px; /* Set height of the container */
        overflow: hidden; /* Ensure no overflow in the container */
    }

    .tooltip-image {
        width: 100%; /* Ensure the image fills the container */
        height: 100%; /* Ensure the image fills the container */
        object-fit: contain; /* Maintain aspect ratio */
    }

    .full-image {
        width: 100%;
        height: auto;
        object-fit: contain;
    }

    /* Ensure that the modal overlay takes up the full height of the screen */
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: none;
        z-index: 1050;
        background-color: rgba(0, 0, 0, 0.5); /* Background overlay */
        align-items: center;
        justify-content: center;
        display: flex; /* This ensures the modal content is centered */
        margin-left: 300px;
    }

    /* The modal dialog box */
    .modal-dialog {
        width: 80%; /* You can adjust this value based on your design */
        max-width: 1500px; /* Optional: Maximum width of the modal */
        height: auto;
        margin: 0;
    }

    /* Modal content box */
    .modal-content {
        background-color: white;
        border-radius: 5px;
        padding: 20px;
        overflow: hidden; /* Prevent overflow that causes scrollbars */
    }

    .report-container {
        padding: 20px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .report-header {
        text-align: center;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid #0078d4;
    }

        .report-header h3 {
            color: #333;
            font-size: 20px;
            font-weight: bold;
            margin: 0;
        }

    .report-body {
        padding: 10px 0;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
    }

        .report-table td {
            padding: 12px;
            vertical-align: top;
            font-size: 14px;
            line-height: 1.6;
            border: 1px solid #ddd;
        }

    .report-label {
        width: 40%;
        text-align: right;
        font-weight: bold;
        color: #333;
    }

    .report-value {
        width: 60%;
        color: #555;
    }

    .sf-dialog-header {
        background-color: #0078d4;
        color: white;
        font-size: 18px;
        font-weight: bold;
        padding: 10px;
        text-align: center;
    }

    .sf-dialog-content {
        background-color: #f9f9f9;
    }

    .dialog-button {
        text-align: center;
    }

    /* Styling for the "Close" button */
    .sf-dialog-button {
        padding: 10px 20px;
        background-color: #0078d4;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }

        .sf-dialog-button:hover {
            background-color: #005a9c;
        }

    /* Add Item Service Button Styles */
    .btn-icon {
        padding: 8px 12px;
        border: 1px solid #ccc;
        background-color: #f8f9fa;
        color: #333;
        border-radius: 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        transition: all 0.2s;
    }

        .btn-icon:hover {
            background-color: #e9ecef;
            border-color: #adb5bd;
        }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

        .btn-success:hover {
            background-color: #218838;
            border-color: #1e7e34;
        }

    .form-container {
        padding: 20px 0;
    }

    .dialog-header h3 {
        margin: 0;
        color: #333;
        font-size: 18px;
    }

    .e-footer-content {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding: 10px 0;
        border-top: 1px solid #dee2e6;
    }

    /* Custom dropdown styles */
    .custom-dropdown {
        font-family: 'Khmer OS';
    }

    .dropdown-item {
        padding: 8px 12px;
        cursor: pointer;
        border-bottom: 1px solid #eee;
    }

        .dropdown-item:hover {
            background-color: #f8f9fa;
        }

        .dropdown-item:last-child {
            border-bottom: none;
        }

    .readonly-input {
        background-color: #f8f9fa !important;
        color: #6c757d !important;
    }

    .dialog-header h3 {
        margin: 0;
        color: #333;
        font-size: 18px;
    }

    .alert {
        padding: 10px;
        border-radius: 4px;
        border: 1px solid transparent;
    }

    .alert-danger {
        background-color: #f8d7da;
        border-color: #f5c6cb;
        color: #721c24;
    }

    .e-footer-content {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding: 10px 0;
        border-top: 1px solid #dee2e6;
    }

    .e-btn i {
        margin-right: 5px;
    }

    .hidden-field {
        display: none !important;
    }

    .invisible-field {
        visibility: hidden !important;
    }

    .status-badge-select {
        border: none;
        border-radius: 20px;
        padding: 4px 10px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        outline: none;
        appearance: auto;
    }

    .badge-received {
        background-color: #cce5ff;
        color: #004085;
    }

    .badge-inspecting {
        background-color: #fff3cd;
        color: #856404;
    }

    .badge-default {
        background-color: #e2e3e5;
        color: #383d41;
    }
</style>
@page "/receive-item"
@page "/receive-item/{ReportNo}"
@using Microsoft.AspNetCore.SignalR.Client
@using ServiceMaintenance.Pages.Reports
