        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Report error: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Report Error",
                Text = $"Failed: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

    private string GetUserNameById(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty)
            return "Unknown";

        try
        {
            return GlobalUserCache.GetUserNameById(userId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            return "Error";
        }
    }

    private async Task<string> GetUserPhoneNumberByIdAsync(Guid? userId)
    {
        return await GlobalUserCache.GetUserPhoneNumberByIdAsync(userId, autoLoad: true);
    }

