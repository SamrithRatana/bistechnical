    private async Task SaveNewItemType()
    {
        try
        {
            IsCreateNewItemValidationErrorVisible = false;
            CreateNewItemValidationMessage = string.Empty;

            if (string.IsNullOrWhiteSpace(newItemType.ItemName))
            {
                CreateNewItemValidationMessage = "Item name required.";
                IsCreateNewItemValidationErrorVisible = true;
                StateHasChanged();
                return;
            }

            newItemType.ItemType = "Generate";

            if (string.IsNullOrWhiteSpace(newItemType.SerialNumber))
            {
                newItemType.SerialNumber = GenerateUniqueSerialNumberFromMemory();
            }

            try
            {
                await ItemService.CreateItemAsync(newItemType);

                var createdItem = new Repairs
                {
                    Id = newItemType.Id != Guid.Empty ? newItemType.Id : Guid.NewGuid(),
                    SerialNumber = newItemType.SerialNumber,
                    ItemName = newItemType.ItemName,
                    ItemType = newItemType.ItemType
                };

                _repairItems = _repairItems.Append(createdItem).ToList();
                allExistingItems = allExistingItems.Append(createdItem).ToList();

                if (!uniqueItems.Any(i => i.ItemName.Equals(createdItem.ItemName, StringComparison.OrdinalIgnoreCase)))
                {
                    uniqueItems = uniqueItems.Append(createdItem).ToList();
                }

                Console.WriteLine($"✅ Created locally: {createdItem.SerialNumber}");

                newItemService.ItemName = newItemType.ItemName;

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = $"Created! Name: '{newItemType.ItemName}', Serial: '{newItemType.SerialNumber}'",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });

                _ = Task.Run(async () =>
                {
                    try
                    {
                        if (hubConnection?.State == HubConnectionState.Connected)
                        {
                            await hubConnection.SendAsync("BroadcastItemUpdate", "NewItemTypeCreated");
                            Console.WriteLine("📡 SignalR sent");
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"⚠️ SignalR failed: {ex.Message}");
                    }
                });

                Console.WriteLine($"Created: {newItemType.SerialNumber} -> {newItemType.ItemName}");

                CancelCreateNewItemDialog();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                CreateNewItemValidationMessage = $"Failed: {ex.Message}";
                IsCreateNewItemValidationErrorVisible = true;
                Console.WriteLine($"Create error: {ex.Message}");
                StateHasChanged();
                return;
            }
        }
        catch (Exception ex)
        {
            CreateNewItemValidationMessage = $"Error: {ex.Message}";
            IsCreateNewItemValidationErrorVisible = true;

            Console.WriteLine($"Exception: {ex}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = $"Failed: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });

            StateHasChanged();
        }
    }

    private string GenerateUniqueSerialNumberFromMemory()
    {
        string randomSerial;
        int attempts = 0;
        const int maxAttempts = 20;

        do
        {
            randomSerial = GenerateRandomSerialNumber();
            attempts++;

            if (attempts >= maxAttempts)
            {
                randomSerial = GenerateTimestampBasedSerialNumber();
                break;
            }
        }
        while (allExistingItems.Any(i => i.SerialNumber.Equals(randomSerial, StringComparison.OrdinalIgnoreCase)));

        return randomSerial;
    }

    private Task<string> GenerateUniqueSerialNumber()
    {
        return Task.FromResult(GenerateUniqueSerialNumberFromMemory());
    }

    private string GenerateTimestampBasedSerialNumber()
    {
        var random = new Random();
        var timestamp = DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString();
        var randomPart = random.Next(100, 999).ToString();

        return timestamp.Substring(Math.Max(0, timestamp.Length - 6)) + randomPart;
    }

