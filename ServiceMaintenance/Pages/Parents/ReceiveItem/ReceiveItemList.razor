    private async Task ConfirmDelete()
    {
        if (selectedRepairService == null) return;

        try
        {
            IsSaving = true;
            IsLoading = true;
            StateHasChanged();

            string reportNo = selectedRepairService.reportNo;
            Guid deletedItemId = selectedRepairService.Id;

            await ReceiveItemService.DeleteReceiveItemAsync(deletedItemId);

            // ✅ Publish MQ
            await MQ.PublishDeleteAsync(
    MessageQueueHelper.Queues.ReceiveItem,
    deletedItemId,
    reportNo
);

            // ✅ Invalidate Cache
            await Cache.InvalidateManyAsync(
                CacheKeys.ReceiveItem(currentPage, pageSize),
                CacheKeys.ReceiveItem(1, pageSize),
                CacheKeys.DashboardStats
            );

            // ✅ Update local list
            filteredRepairServices = filteredRepairServices
                .Where(item => item.Id != deletedItemId)
                .ToList();

            totalItems--;
            totalPages = totalItems > 0
                ? (int)Math.Ceiling(totalItems / (double)pageSize)
                : 0;

            if (currentPage > totalPages && totalPages > 0)
                currentPage = totalPages;

            selectedRepairService = null;
            isRow = false;
            isDeleteDialogVisible = false;
            StateHasChanged();

            // ✅ Background tasks
            _ = Task.Run(async () =>
            {
                try
                {
                    if (hubConnection?.State == HubConnectionState.Connected)
                        await hubConnection.SendAsync("BroadcastItemDelete", deletedItemId);
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ SignalR failed: {ex.Message}");
                }

                try
                {
                    await StateManagementAction.SendNotificationReceiveItem("delete", reportNo);
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Notification failed: {ex.Message}");
                }
            });

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Customization",
                Title = "Deleted",
                Text = $"{reportNo} deleted",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Success
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Delete failed: {ex.Message}");
            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Delete Failed",
                Text = $"Failed: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
            await LoadPageData();
        }
        finally
        {
            IsSaving = false;
            IsLoading = false;
            StateHasChanged();
        }
    }

