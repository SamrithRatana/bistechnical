    private static DateTime _lastGeneratedDate = DateTime.MinValue;
    private static int _monthlySequence = 0;

    public string GenerateReportNumber()
    {
        string datePart = DateTime.UtcNow.ToString("yyyyMM");

        if (_lastGeneratedDate.ToString("yyyyMM") != datePart)
        {
            _monthlySequence = 1;
            _lastGeneratedDate = DateTime.UtcNow;
        }
        else
        {
            _monthlySequence++;
        }

        string sequencePart = _monthlySequence.ToString("D4");
        return $"{datePart}{DateTime.UtcNow.ToString("dd")}-{sequencePart}";
    }

    private async void OnBarcodeScanInput(ChangeEventArgs e)
    {
        barcodeScan = e.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(barcodeScan))
        {
            IsDropdownItemVisible = false;
            IsValidationErrorVisible = false;
            StateHasChanged();
            return;
        }

        try
        {
            var searchResult = await ItemService.SearchItemsAsync(
                pageNumber: 1,
                pageSize: 20,
                searchTerm: barcodeScan
            );

            _repairItems = searchResult.Items;

            var matchingItems = _repairItems.Where(item =>
                item.SerialNumber.Contains(barcodeScan, StringComparison.OrdinalIgnoreCase) ||
                item.ItemName.Contains(barcodeScan, StringComparison.OrdinalIgnoreCase)
            ).ToList();

            if (matchingItems.Any())
            {
                IsDropdownItemVisible = true;
                IsValidationErrorVisible = false;

                var exactMatch = matchingItems.FirstOrDefault(item =>
                    item.SerialNumber.Equals(barcodeScan, StringComparison.OrdinalIgnoreCase)
                );

                if (exactMatch != null)
                {
                    searchItem = $"{exactMatch.ItemName}";
                    selectedItem = exactMatch.SerialNumber;
                    _selectedItem = exactMatch;
                    receiveItem.ItemId = exactMatch.Id;
                }
            }
            else
            {
                IsDropdownItemVisible = false;
                IsValidationErrorVisible = true;
                ValidationMessage = "លេខម៉ាស៊ីននេះមិនទាន់មានទេ សូមបញ្ចូលម៉ាស៊ីនថ្មីជាមុនសិន!";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error searching items: {ex.Message}");
        }
    }
