    private string GenerateRandomSerialNumber()
    {
        const string letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        const string numbers = "0123456789";
        var random = new Random();

        string letter = letters[random.Next(letters.Length)].ToString();
        string numberPart = new string(Enumerable.Repeat(numbers, 5)
            .Select(s => s[random.Next(s.Length)]).ToArray());

        return letter + numberPart;
    }

    private string GenerateRandomSerialNumberAlternative()
    {
        var random = new Random();
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
        return new string(Enumerable.Repeat(chars, 8)
            .Select(s => s[random.Next(s.Length)]).ToArray());
    }

    // ✅ PRIORITY 5: OPTIMIZED Save with batched state updates
    private async Task SaveNewItemService()
    {
        try
        {
            // ✅ Reset validation state
            IsValidationErrorVisible = false;
            ValidationMessage = string.Empty;

            if (string.IsNullOrWhiteSpace(newItemService.ItemName))
            {
                ValidationMessage = "Item name is required.";
                IsValidationErrorVisible = true;
                StateHasChanged(); // Single state update
                return;
            }

            if (isUpdateMode)
            {
                Console.WriteLine($"Updating: {newItemService.SerialNumber} -> {newItemService.ItemName}");

                if (string.IsNullOrWhiteSpace(newItemService.SerialNumber))
                {
                    ValidationMessage = "Serial number required.";
                    IsValidationErrorVisible = true;
                    StateHasChanged();
                    return;
                }

                try
                {
                    await ItemService.UpdateItemNameBySerialNumberAsync(
                        serialNumber: newItemService.SerialNumber,
                        newItemName: newItemService.ItemName
                    );

                    // ✅ Update local state
                    var existing = _repairItems.FirstOrDefault(i =>
                        i.SerialNumber.Equals(newItemService.SerialNumber, StringComparison.OrdinalIgnoreCase));
                    if (existing != null)
                    {
                        existing.ItemName = newItemService.ItemName;
                    }

                    var existingAll = allExistingItems.FirstOrDefault(i =>
                        i.SerialNumber.Equals(newItemService.SerialNumber, StringComparison.OrdinalIgnoreCase));
                    if (existingAll != null)
                    {
                        existingAll.ItemName = newItemService.ItemName;
                    }

                    var existingUnique = uniqueItems.FirstOrDefault(i =>
                        i.SerialNumber.Equals(newItemService.SerialNumber, StringComparison.OrdinalIgnoreCase));
                    if (existingUnique != null)
                    {
                        existingUnique.ItemName = newItemService.ItemName;
                    }

                    Console.WriteLine($"✅ Updated locally: {newItemService.SerialNumber}");

                    ToastNotificationService.ShowToast(new ToastOptions
                    {
                        ProviderName = "Customization",
                        Title = "Success",
                        Text = $"'{newItemService.SerialNumber}' updated!",
                        ThemeMode = ToastThemeMode.Pastel,
                        RenderStyle = ToastRenderStyle.Success
                    });
                }
                catch (KeyNotFoundException ex)
                {
                    ValidationMessage = $"Serial '{newItemService.SerialNumber}' not found.";
                    IsValidationErrorVisible = true;
                    Console.WriteLine($"Not found: {ex.Message}");
                    StateHasChanged();
                    return;
                }
                catch (Exception ex)
                {
                    ValidationMessage = $"Update failed: {ex.Message}";
                    IsValidationErrorVisible = true;
                    Console.WriteLine($"Update error: {ex.Message}");
                    StateHasChanged();
                    return;
                }
            }
            else
            {
                Console.WriteLine($"Creating: {newItemService.ItemName}");

                if (string.IsNullOrWhiteSpace(newItemService.SerialNumber))
                {
                    newItemService.SerialNumber = GenerateUniqueSerialNumberFromMemory();
                    Console.WriteLine($"Generated serial: {newItemService.SerialNumber}");
                }
                else
                {
                    if (allExistingItems.Any(i => i.SerialNumber.Equals(newItemService.SerialNumber, StringComparison.OrdinalIgnoreCase)))
                    {
                        ValidationMessage = $"Serial '{newItemService.SerialNumber}' exists.";
                        IsValidationErrorVisible = true;
                        StateHasChanged();
                        return;
                    }
                }

                newItemService.ItemType = "Generate";

                try
                {
                    await ItemService.CreateItemAsync(newItemService);

                    var createdItem = new Repairs
                    {
                        Id = newItemService.Id != Guid.Empty ? newItemService.Id : Guid.NewGuid(),
                        SerialNumber = newItemService.SerialNumber,
                        ItemName = newItemService.ItemName,
                        ItemType = newItemService.ItemType
                    };

                    _repairItems = _repairItems.Append(createdItem).ToList();
                    allExistingItems = allExistingItems.Append(createdItem).ToList();

                    if (!uniqueItems.Any(i => i.ItemName.Equals(createdItem.ItemName, StringComparison.OrdinalIgnoreCase)))
                    {
                        uniqueItems = uniqueItems.Append(createdItem).ToList();
                    }

                    Console.WriteLine($"✅ Created locally: {createdItem.SerialNumber}");

                    ToastNotificationService.ShowToast(new ToastOptions
                    {
                        ProviderName = "Customization",
                        Title = "Success",
                        Text = $"Created! Serial: '{newItemService.SerialNumber}'",
                        ThemeMode = ToastThemeMode.Pastel,
                        RenderStyle = ToastRenderStyle.Success
                    });
                }
                catch (Exception ex)
                {
                    ValidationMessage = $"Create failed: {ex.Message}";
                    IsValidationErrorVisible = true;
                    Console.WriteLine($"Create error: {ex.Message}");
                    StateHasChanged();
                    return;
                }
            }

            // ✅ Update search selection
            if (isUpdateMode || !string.IsNullOrWhiteSpace(newItemService.SerialNumber))
            {
                var updatedItem = _repairItems.FirstOrDefault(i =>
                    i.SerialNumber.Equals(newItemService.SerialNumber, StringComparison.OrdinalIgnoreCase));

                if (updatedItem != null)
                {
                    searchItem = $"{updatedItem.ItemName}";
                    OnItemSelect(updatedItem);
                }
            }

            // ✅ Fire-and-forget SignalR
            _ = Task.Run(async () =>
            {
                try
                {
                    if (hubConnection?.State == HubConnectionState.Connected)
                    {
                        await hubConnection.SendAsync("BroadcastItemUpdate", isUpdateMode ? "ItemUpdated" : "ItemCreated");
                        Console.WriteLine("📡 SignalR sent");
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ SignalR failed: {ex.Message}");
                }
            });

            // ✅ Single batched state update at the end
            ResetDialog();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ValidationMessage = $"Error: {ex.Message}";
            IsValidationErrorVisible = true;
            Console.WriteLine($"Exception: {ex}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = $"Failed: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });

            StateHasChanged();
        }
    }

