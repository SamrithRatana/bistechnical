    private async Task Save()
    {
        if (IsSaving || IsLoading)
        {
            Console.WriteLine("⚠️ Save in progress");
            return;
        }

        try
        {
            IsSaving = true;
            IsLoading = true;
            StateHasChanged();

            Console.WriteLine("💾 Starting save...");

            // ✅ Validate ServicePriorityId
            Console.WriteLine($"🔍 DEBUG: ServicePriorityId = {receiveItem.ServicePriorityId}");
            Console.WriteLine($"🔍 DEBUG: Valid Priorities = {string.Join(", ", _servicePriorities.Select(p => $"{p.Id}:{p.Name}"))}");

            if (receiveItem.ServicePriorityId <= 0)
            {
                ValidationMessage = "Please select a Service Priority.";
                IsValidationErrorVisible = true;
                IsSaving = false;
                IsLoading = false;
                StateHasChanged();
                return;
            }

            if (!_servicePriorities.Any(p => p.Id == receiveItem.ServicePriorityId))
            {
                ValidationMessage = $"Invalid Service Priority (ID: {receiveItem.ServicePriorityId}). Please select a valid one.";
                IsValidationErrorVisible = true;
                IsSaving = false;
                IsLoading = false;
                StateHasChanged();
                return;
            }

            // ✅ Validate Item
            var selectedRepair = _repairItems.FirstOrDefault(r => r.Id == receiveItem.ItemId);
            if (selectedRepair == null)
            {
                ValidationMessage = "Invalid item.";
                IsValidationErrorVisible = true;
                Console.WriteLine("❌ No item selected");
                StateHasChanged();
                return;
            }

            string selectedItemName = selectedRepair.ItemName;
            string serialNumber = selectedRepair.SerialNumber;
            Console.WriteLine($"📦 Item: {selectedItemName} ({serialNumber})");

            // ✅ Validate User
            var currentUserId = JwtSessionService.GetCurrentUserId();
            if (!currentUserId.HasValue)
            {
                ValidationMessage = "Unable to identify user. Please login.";
                IsValidationErrorVisible = true;
                Console.WriteLine("❌ No user ID from JWT");
                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Error",
                    Title = "Authentication Error",
                    Text = "Session expired. Please login.",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Danger
                });
                StateHasChanged();
                return;
            }

            Guid userGuid = currentUserId.Value;
            string reportNo = receiveItem.ReportNo;
            Console.WriteLine($"✅ User ID: {userGuid}");

            // ════════════════════════════════
            // UPDATE MODE
            // ════════════════════════════════
            if (isEditMode)
            {
                Console.WriteLine("📝 UPDATE MODE...");
                Console.WriteLine($"📝 Sending ServicePriorityId = {receiveItem.ServicePriorityId} to API");

                await ReceiveItemService.UpdateReceiveItemAsync(receiveItem);
                Console.WriteLine($"✅ Updated: {receiveItem.ReportNo}");

                reportNo = receiveItem.ReportNo;

                await MQ.PublishUpdateAsync(
                    MessageQueueHelper.Queues.ReceiveItem,
                    receiveItem.Id,
                    reportNo,
                    userGuid
                );
                Console.WriteLine($"📨 Published Update to RabbitMQ: {reportNo}");

                await Cache.InvalidateManyAsync(
                    CacheKeys.ReceiveItem(currentPage, pageSize),
                    CacheKeys.ReceiveItem(1, pageSize),
                    CacheKeys.DashboardStats
                );
                Console.WriteLine("🗑️ Cache invalidated");

                var indexToUpdate = ((List<RepairServices>)filteredRepairServices)
                    .FindIndex(x => x.Id == receiveItem.Id);

                if (indexToUpdate >= 0)
                {
                    ((List<RepairServices>)filteredRepairServices)[indexToUpdate] = new RepairServices
                    {
                        Id = receiveItem.Id,
                        reportNo = receiveItem.ReportNo,
                        ServiceDate = receiveItem.ServiceDate,
                        CompanyName = receiveItem.CompanyName,
                        Address = receiveItem.Address,
                        ContactName = receiveItem.ContactName,
                        PhoneNumber = receiveItem.PhoneNumber,
                        itemName = selectedItemName,
                        serialNumber = serialNumber,
                        CustomerRequest = receiveItem.CustomerRequest,
                        ServiceLocation = receiveItem.ServiceLocation,
                        ServicePriorityId = receiveItem.ServicePriorityId,
                        hasContract = receiveItem.HasContract,
                        Status = "Item Recieved",
                        createby = receiveItem.CreateBy,
                        CustomerId = receiveItem.CustomerId
                    };
                    Console.WriteLine("✅ Local list updated");
                }

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = "Service updated",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });
            }
            // ════════════════════════════════
            // CREATE MODE
            // ════════════════════════════════
            else
            {
                Console.WriteLine("➕ CREATE MODE...");

                Console.WriteLine("🔍 Checking duplicates...");
                var restrictedStatuses = new[]
                {
                "Item Recieved",
                "Inspection",
                "Awaiting Customer Confirm",
                "Awaiting Sparepart",
                "Repairing",
                "Repair by Third-Party"
            };

                var existingStatusResult = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: 1,
                    pageSize: 1,
                    serialNumber: serialNumber
                );

                if (existingStatusResult.Items.Any())
                {
                    var existingService = existingStatusResult.Items.First();
                    if (restrictedStatuses.Contains(existingService.Status))
                    {
                        ValidationMessage = $"ម៉ាស៊ុនមួយនេះ '{serialNumber}' កំពុងស្ថិតនៅក្នុងស្ថានភាព '{existingService.Status}' មិនអាចបញ្ចូលម្ដងទៀតបានទេ។";
                        IsValidationErrorVisible = true;
                        Console.WriteLine($"❌ Duplicate: '{serialNumber}' in '{existingService.Status}'");
                        ToastNotificationService.ShowToast(new ToastOptions
                        {
                            ProviderName = "Error",
                            Title = "Duplicate",
                            Text = $"'{serialNumber}' in '{existingService.Status}'",
                            ThemeMode = ToastThemeMode.Pastel,
                            RenderStyle = ToastRenderStyle.Warning
                        });
                        StateHasChanged();
                        return;
                    }
                    Console.WriteLine($"✅ '{serialNumber}' in '{existingService.Status}' - allowing");
                }
                else
                {
                    Console.WriteLine($"✅ No existing service for '{serialNumber}'");
                }

                receiveItem.CreateBy = userGuid;
                receiveItem.ReportNo = null;
                Console.WriteLine($"✅ Set CreateBy: {userGuid}");

                await ReceiveItemService.CreateReceiveItemAsync(receiveItem);
                Console.WriteLine("✅ Created in DB");

                try
                {
                    reportNo = await RepairItemService.GetLatestReportNoAsync();
                    receiveItem.ReportNo = reportNo;
                    Console.WriteLine($"✅ Report No: {reportNo}");
                }
                catch (HttpRequestException ex)
                {
                    ErrorMessage = ex.Message.Contains("404")
                        ? "ReportNo endpoint not found."
                        : ex.Message;
                    Console.WriteLine($"❌ HTTP Error: {ex.Message}");
                    StateHasChanged();
                    return;
                }

                await MQ.PublishCreateAsync(
                    MessageQueueHelper.Queues.ReceiveItem,
                    receiveItem.Id,
                    reportNo,
                    userGuid
                );
                Console.WriteLine($"📨 Published Create to RabbitMQ: {reportNo}");

                await Cache.InvalidateManyAsync(
                    CacheKeys.ReceiveItem(currentPage, pageSize),
                    CacheKeys.ReceiveItem(1, pageSize),
                    CacheKeys.DashboardStats
                );
                Console.WriteLine("🗑️ Cache invalidated");

                var newService = new RepairServices
                {
                    Id = receiveItem.Id != Guid.Empty ? receiveItem.Id : Guid.NewGuid(),
                    reportNo = reportNo,
                    ServiceDate = receiveItem.ServiceDate,
                    CompanyName = receiveItem.CompanyName,
                    Address = receiveItem.Address,
                    ContactName = receiveItem.ContactName,
                    PhoneNumber = receiveItem.PhoneNumber,
                    itemName = selectedItemName,
                    serialNumber = serialNumber,
                    CustomerRequest = receiveItem.CustomerRequest,
                    ServiceLocation = receiveItem.ServiceLocation,
                    ServicePriorityId = receiveItem.ServicePriorityId,
                    hasContract = receiveItem.HasContract,
                    Status = "Item Recieved",
                    createby = userGuid,
                    CustomerId = receiveItem.CustomerId
                };

                var localList = filteredRepairServices.ToList();
                localList.Insert(0, newService);
                if (localList.Count > pageSize)
                    localList.RemoveAt(localList.Count - 1);

                filteredRepairServices = localList;
                totalItems++;
                totalPages = (int)Math.Ceiling(totalItems / (double)pageSize);
                Console.WriteLine("✅ Local list updated");

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = "Service created",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });
            }

            // ✅ Close Dialog
            isEditDialogVisible = false;

            // ✅ FIXED — Capture state "BEFORE" resetting isEditMode/isThirdPartyService.
            // Previously these were captured AFTER reset, so capturedIsEdit/capturedThirdParty
            // were ALWAYS false inside the background Task.Run, causing Notification/SignalR/
            // Third-Party logic to behave incorrectly on Edit/Third-Party flows.
            var capturedReportNo = reportNo;
            var capturedIsEdit = isEditMode;
            var capturedThirdParty = isThirdPartyService;

            // ✅ Now safe to reset
            isEditMode = false;
            editingServiceId = Guid.Empty;
            isThirdPartyService = false;
            StateHasChanged();
            Console.WriteLine("✅ Dialog closed");

            // ✅ Background tasks — fire and forget
            _ = Task.Run(async () =>
            {
                // Notification
                try
                {
                    string action = capturedIsEdit ? "update" : "create";
                    await StateManagementAction.SendNotificationReceiveItem(action, capturedReportNo);
                    Console.WriteLine($"📧 Notification sent: {capturedReportNo}");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Notification failed: {ex.Message}");
                }

                // Third-party
                try
                {
                    if (capturedThirdParty)
                    {
                        Console.WriteLine("🔧 Processing third-party...");
                        RepairServices serviceToUpdate;

                        if (capturedIsEdit)
                        {
                            serviceToUpdate = selectedRepairService;
                        }
                        else
                        {
                            serviceToUpdate = (await RepairItemService.SearchRepairServicesAsync(
                                pageNumber: 1,
                                pageSize: 1,
                                searchTerm: capturedReportNo
                            )).Items.FirstOrDefault();
                        }

                        if (serviceToUpdate != null)
                        {
                            var thirdPartyRequest = new ThirdPartyRepairRequest
                            {
                                Id = serviceToUpdate.Id,
                                ThirdPartyRepairBy = receiveItem.CreateBy
                            };
                            await ThirdPartyRepairService.SetThirdPartyRepairAsync(thirdPartyRequest);
                            Console.WriteLine($"✅ Third-party assigned: {receiveItem.CreateBy}");
                        }
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Third-party failed: {ex.Message}");
                }

                // SignalR
                try
                {
                    if (hubConnection?.State == HubConnectionState.Connected)
                    {
                        string eventType = capturedIsEdit ? "ItemUpdated" : "ItemCreated";
                        await hubConnection.SendAsync("BroadcastItemUpdate", eventType);
                        Console.WriteLine($"📡 SignalR sent: {eventType}");
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ SignalR failed: {ex.Message}");
                }

                // Refresh User Cache
                try
                {
                    await GlobalUserCache.RefreshUsersAsync();
                    Console.WriteLine("✅ User cache refreshed");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Cache refresh failed: {ex.Message}");
                }
            });

            Console.WriteLine("✅ SAVE COMPLETE");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Console.WriteLine($"❌ SAVE FAILED: {ex.Message}");
            Console.WriteLine($"Stack: {ex.StackTrace}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = ex.Message,
                ThemeMode = ToastThemeMode.Pastel,
