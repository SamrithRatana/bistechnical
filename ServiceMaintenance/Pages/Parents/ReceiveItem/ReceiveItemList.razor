    private async void ShowAddItemDialog()
    {
        try
        {
            var allItemsResult = await ItemService.GetItemsPagedAsync(pageNumber: 1, pageSize: 10);
            allExistingItems = allItemsResult.Items;

            string serialNumberToUse = GetSerialNumberFromInput();

            if (!string.IsNullOrWhiteSpace(serialNumberToUse))
            {
                var existingItem = allExistingItems.FirstOrDefault(item =>
                    item.SerialNumber.Equals(serialNumberToUse, StringComparison.OrdinalIgnoreCase));

                if (existingItem != null)
                {
                    SetUpdateMode(existingItem);
                    Console.WriteLine($"Update mode: {existingItem.SerialNumber}");
                }
                else
                {
                    SetCreateModeWithSerial(serialNumberToUse);
                    Console.WriteLine($"Create mode with serial: {serialNumberToUse}");
                }
            }
            else
            {
                SetCreateModeEmpty();
                Console.WriteLine("Create mode: new item");
            }

            await LoadUniqueItems();
            isAddItemDialogVisible = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in ShowAddItemDialog: {ex.Message}");
            ShowErrorToast($"Error: {ex.Message}");
        }
    }

    private string GetSerialNumberFromInput()
    {
        if (_selectedItem != null && !string.IsNullOrWhiteSpace(_selectedItem.SerialNumber))
        {
            return _selectedItem.SerialNumber;
        }
        else if (!string.IsNullOrWhiteSpace(barcodeScan))
        {
            return barcodeScan.Trim();
        }
        else if (!string.IsNullOrWhiteSpace(searchItem))
        {
            string searchText = searchItem.Trim();

            if (searchText.Contains(" | "))
            {
                var parts = searchText.Split(" | ");
                if (parts.Length > 1)
                {
                    return parts[1].Trim();
                }
            }
            else
            {
                var foundBySerial = allExistingItems.FirstOrDefault(item =>
                    item.SerialNumber.Equals(searchText, StringComparison.OrdinalIgnoreCase));

                if (foundBySerial != null)
                {
                    return foundBySerial.SerialNumber;
                }
                else
                {
                    var foundByName = allExistingItems.FirstOrDefault(item =>
                        item.ItemName.Equals(searchText, StringComparison.OrdinalIgnoreCase));

                    if (foundByName != null)
                    {
                        return foundByName.SerialNumber;
                    }
                }
            }
        }

        return string.Empty;
    }

