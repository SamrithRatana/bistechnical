<!-- Delete Confirmation Dialog -->
<SfDialog @ref="DialogDelete"
          IsModal="true"
          Width="400px"
          ShowCloseIcon="true"
          Visible="@isDeleteDialogVisible">
    <DialogTemplates>
        <Header>
            <div class="dialog-header">
                <h3><i class="fas fa-exclamation-triangle" style="color: #dc3545;"></i> Confirm Delete</h3>
            </div>
        </Header>
        <Content>
            <div style="padding: 20px;">
                <p style="font-size: 16px; margin-bottom: 15px;">
                    Are you sure you want to delete this service?
                </p>
                @if (selectedRepairService != null)
                {
                    <div style="background-color: #f8f9fa; padding: 15px; border-radius: 4px;">
                        <p><strong>Report No:</strong> @selectedRepairService.reportNo</p>
                        <p><strong>Company:</strong> @selectedRepairService.CompanyName</p>
                        <p><strong>Item:</strong> @selectedRepairService.itemName</p>
                        <p><strong>Serial Number:</strong> @selectedRepairService.serialNumber</p>
                    </div>
                }
                <div class="alert alert-danger" style="margin-top: 15px;">
                    <i class="fas fa-exclamation-circle"></i> This action cannot be undone.
                </div>
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Delete"
                      CssClass="e-btn e-danger"
                      OnClick="ConfirmDelete"
                      Disabled="@(IsSaving || IsLoading)">
        </DialogButton>
        <DialogButton Content="Cancel"
                      CssClass="e-btn e-normal"
                      OnClick="@(() => isDeleteDialogVisible = false)">
        </DialogButton>
    </DialogButtons>
</SfDialog>
<SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
    <DialogTemplates>
        <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
        <Content>
            <div class="report-container">
                <div class="report-header">
                    <h3>@Loc[nameof(ResourceStrings.TextReceviceDetail)]</h3>
                    <p><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong> @selectedRepairService?.reportNo</p>
                </div>
                <div class="report-body">
                    <table class="report-table">
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.ServiceDate.ToString("dd/MM/yyyy HH:mm tt")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCompanyName)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.CompanyName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextAddress)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.Address</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContactName)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.ContactName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPhoneNumber)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.PhoneNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextItemName)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.itemName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextSerialNumber)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.serialNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCustomerReq)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.CustomerRequest</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContract)]:</strong></td>
                            <td class="report-value">@(@selectedRepairService?.hasContract == true ? "Yes" : "No")</td>
                        </tr>

                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPriority)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.ServicePriority</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextActivities)]:</strong></td>
                            <td class="report-value">@selectedRepairService?.Status</td>
