    // ✅ Non-blocking SignalR initialization
    private async Task InitializeSignalRAsync()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/itemHub"))
                .Build();

            hubConnection.On<string>("ReceiveItemUpdate", async (message) =>
            {
                // ✅ Invalidate Cache → Reload ថ្មី
                await Cache.InvalidateManyAsync(
                    CacheKeys.ReceiveItem(currentPage, pageSize),
                    CacheKeys.DashboardStats
                );
                await LoadPageData();
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<Guid>("BroadcastItemDelete", async (deletedItemId) =>
            {
                await Cache.InvalidateManyAsync(
                    CacheKeys.ReceiveItem(currentPage, pageSize)
                );
                filteredRepairServices = filteredRepairServices
                    .Where(item => item.Id != deletedItemId)
                    .ToList();
                await InvokeAsync(StateHasChanged);
            });

            await hubConnection.StartAsync();
            Console.WriteLine("✅ SignalR connected");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ SignalR failed: {ex.Message}");
        }
    }

