    private async Task HandleSetInspecting(RepairServices item)
    {
        try
        {
            var currentUserId = JwtSessionService.GetCurrentUserId();
            if (!currentUserId.HasValue) return;

            item.Status = "Inspecting";
            StateHasChanged();

            var request = new SetInspectingRequest
            {
                Id = item.Id,
                InspectingBy = currentUserId.Value
            };

            await InspectingService.SetInspectingAsync(request);

            // ✅ Publish MQ + Invalidate Cache
            await MQ.PublishStatusChangeAsync(
    MessageQueueHelper.Queues.ReceiveItem,
    "ReceiveItem",
    item.Id,
    "Inspecting",
    item.reportNo,
    currentUserId.Value
);

            await Cache.InvalidateManyAsync(
                CacheKeys.ReceiveItem(currentPage, pageSize),
                CacheKeys.InspectItem(1, pageSize),
                CacheKeys.DashboardStats
            );

            filteredRepairServices = filteredRepairServices
                .Where(x => x.Id != item.Id)
                .ToList();

            totalItems--;
            totalPages = totalItems > 0
                ? (int)Math.Ceiling(totalItems / (double)pageSize)
                : 0;

            StateHasChanged();

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Customization",
                Title = "Success",
                Text = $"{item.reportNo} set to Inspecting",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Success
            });
        }
        catch (Exception ex)
        {
            item.Status = "Item Recieved";
            StateHasChanged();
            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = $"Failed: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }
