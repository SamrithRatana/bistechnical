            _repairItems = searchResult.Items;

            var matchingItems = _repairItems.Where(item =>
                item.SerialNumber.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                item.ItemName.Contains(value, StringComparison.OrdinalIgnoreCase)
            ).ToList();

            if (matchingItems.Any())
            {
                IsDropdownItemVisible = true;
                IsValidationErrorVisible = false;

                var exactMatch = matchingItems.FirstOrDefault(item =>
                    item.SerialNumber.Equals(value, StringComparison.OrdinalIgnoreCase)
                );

                if (exactMatch != null)
                {
                    searchItem = $"{exactMatch.ItemName}";
                    selectedItem = exactMatch.SerialNumber;
                    _selectedItem = exactMatch;
                    receiveItem.ItemId = exactMatch.Id;
                }
            }
            else
            {
                IsDropdownItemVisible = false;
                IsValidationErrorVisible = true;
                ValidationMessage = "លេខម៉ាស៊ីននេះមិនទាន់មានទេ សូមបញ្ចូលម៉ាស៊ីនថ្មីជាមុនសិន!";
