    // ✅ PRIORITY 1: COMPLETELY REWRITTEN - TRUE PARALLEL LOADING
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        try
        {
            Console.WriteLine("🚀 Starting optimized parallel initialization...");
            var totalStartTime = DateTime.UtcNow;

            // ✅ Start all tasks immediately (parallel execution begins)
            var prioritiesTask = LoadServicePriorities();
            var usersTask = LoadAllUsersAsync();
            var sparePartsTask = LoadSpareParts();
            var customersTask = GetCustomersWithCache();
            var itemsTask = GetItemsWithCache();
            var statusesTask = LoadServiceStatuses();

            // ✅ Wait for all tasks to complete
            await Task.WhenAll(
                prioritiesTask,
                usersTask,
                sparePartsTask,
                customersTask,
                itemsTask,
                statusesTask
            );

            // ✅ Get results (instant - tasks already completed)
            _servicePriorities = await prioritiesTask;
            _allUsers = await usersTask;
            _spareParts = await sparePartsTask;
            _customers = await customersTask;
            _repairItems = await itemsTask;
            allExistingItems = _repairItems;
            _serviceStatuses = await statusesTask;
            _usersLoaded = true;

            var refDataTime = (DateTime.UtcNow - totalStartTime).TotalMilliseconds;
            Console.WriteLine($"✅ Reference data loaded in {refDataTime}ms");

            // ✅ Load page data
            var pageLoadStart = DateTime.UtcNow;
            await LoadPageData();
            var pageDataTime = (DateTime.UtcNow - pageLoadStart).TotalMilliseconds;
            Console.WriteLine($"✅ Page data loaded in {pageDataTime}ms");

            var totalTime = (DateTime.UtcNow - totalStartTime).TotalMilliseconds;
            Console.WriteLine($"✅ ALL DATA LOADED IN {totalTime}ms");

            // ✅ Handle route parameter
            var routeData = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Split('/');
            ReportNoFromRoute = routeData.Length > 1 ? routeData[1] : null;

            if (!string.IsNullOrEmpty(ReportNoFromRoute))
            {
                await PerformItemReceivedSearchInternal(ReportNoFromRoute);
            }

            // ✅ Initialize SignalR in background (fire-and-forget)
            _ = InitializeSignalRAsync();

            Console.WriteLine($"✅ Initialization complete: {totalTime}ms");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error during initialization: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            ErrorMessage = $"Failed to load data: {ex.Message}";
            StateHasChanged(); // Update UI to show error
        }
    }

