    private async Task LoadFinishedData(string searchTerm = null, string sortOrder = null)
    {
        try
        {
            PaginatedResult<RepairServices> finishedResult;

            if (!string.IsNullOrWhiteSpace(searchTerm) || !string.IsNullOrWhiteSpace(sortOrder))
            {
                // Active search/sort bypasses cache
                finishedResult = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: currentFinishedPage,
                    pageSize: pageSizeFinished,
                    status: "Finished",
                    searchTerm: searchTerm,
                    sortBy: "reportNo",
                    sortDescending: sortOrder == "Descending"
                );
            }
            else
            {
                finishedResult = await Cache.GetOrSetAsync(
                    CacheKeys.FinishRepair(currentFinishedPage, pageSizeFinished),
                    () => RepairItemService.SearchRepairServicesAsync(
                        pageNumber: currentFinishedPage,
                        pageSize: pageSizeFinished,
                        status: "Finished",
                        sortBy: "reportNo",
                        sortDescending: true),
                    TimeSpan.FromMinutes(3)
                );
            }

            var finishedList = (finishedResult?.Items ?? new List<RepairServices>()).ToList();

            if (temporarilyVisibleFinishedItems.Any())
            {
                finishedRepairServices = finishedList
                    .Where(x => temporarilyVisibleFinishedItems.Contains(x.Id))
                    .ToList();
            }
            else
            {
                finishedRepairServices = finishedList;
            }

            // ✅ Use server-side total count
            totalFinishedPages = finishedResult?.TotalPages ?? 0;

            UpdateFinishedPagination();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading finished data: {ex.Message}");
        }
    }

