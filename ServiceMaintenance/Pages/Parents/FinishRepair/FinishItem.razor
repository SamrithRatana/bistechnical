        await LoadFinishedData();
        StateHasChanged();
    }




    private string GetCustomerType(string companyName)
    {
        if (string.IsNullOrEmpty(companyName))
            return "Unknown";

        // First check searched customers
        var customer = searchedCustomers?.FirstOrDefault(c =>
            c.CompanyName != null &&
            c.CompanyName.Equals(companyName, StringComparison.OrdinalIgnoreCase));

        if (customer != null)
            return customer.CustomerType ?? "Unknown";

        // If not found in searched customers, trigger a search
        // Note: This should ideally be done proactively when loading repair services
        _ = Task.Run(async () => await SearchCustomers(companyName));

        return "Unknown";
    }

