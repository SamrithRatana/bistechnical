    // ✅ OPTIMIZED ConfirmCustomerConfirm Method
    // Replace your existing method in finishItem.razor with this:

    private async Task ConfirmCustomerConfirm()
    {
        if (isSaving)
        {
            return; // Prevent double-click
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            Console.WriteLine($"🏁 Finishing item: {_selectedRepairService?.reportNo}");

            // ==========================================
            // STEP 1: SET USER ID
            // ==========================================
            if (Guid.TryParse(CurrentUserId, out Guid userGuid))
            {
                FinishItemBy.verifiedBy = userGuid;
                Console.WriteLine($"✅ Setting verifiedBy to: {userGuid}");
            }
            else
            {
                Console.WriteLine("⚠️ Could not parse user ID to Guid");
                FinishItemBy.verifiedBy = Guid.Empty;
            }

            // ==========================================
            // STEP 2: CRITICAL PATH - API CALL
            // ==========================================
            await FinishItemService.FinishItemAsync(FinishItemBy);
            Console.WriteLine("✅ Item finished in database");

            // ✅ Publish to RabbitMQ
            await MQ.PublishStatusChangeAsync(
                MessageQueueHelper.Queues.FinishItem,
                "FinishItem",
                FinishItemBy.Id,
                "Finished",
                _selectedRepairService?.reportNo,
                FinishItemBy.verifiedBy
            );

            // ✅ Invalidate Redis cache — Repairing list loses the item, Finished list gains it
            await Cache.InvalidateManyAsync(
                CacheKeys.RepairItem(currentPage, pageSize) + ":Repairing",
                CacheKeys.RepairItem(1, pageSize) + ":Repairing",
                CacheKeys.FinishRepair(1, pageSizeFinished),
                CacheKeys.FinishRepair(currentFinishedPage, pageSizeFinished),
                CacheKeys.DashboardStats
            );

            // ==========================================
            // STEP 3: OPTIMISTIC UI UPDATE (Immediate feedback)
            // ==========================================
            Guid finishedItemId = Guid.Empty;
            string reportNo = string.Empty;

            if (_selectedRepairService != null)
            {
                finishedItemId = _selectedRepairService.Id;
                reportNo = _selectedRepairService.reportNo;

                // Remove from main grid immediately
                filteredRepairServices = filteredRepairServices
                    .Where(x => x.Id != finishedItemId)
                    .ToList();

                totalItems--;
                totalPages = totalItems > 0
                    ? (int)Math.Ceiling(totalItems / (double)pageSize)
                    : 0;

                // Adjust current page if needed
                if (currentPage > totalPages && totalPages > 0)
                {
                    currentPage = totalPages;
                }

                // Mark as visible in finished section
                if (!temporarilyVisibleFinishedItems.Contains(finishedItemId))
                {
                    temporarilyVisibleFinishedItems.Add(finishedItemId);
                }

                // Update item's status locally for immediate card display
                _selectedRepairService.finishedDate = DateTime.UtcNow.AddHours(7);
                _selectedRepairService.Status = "Finished";
                _selectedRepairService.verifiedBy = userGuid;

                // Add to finished list at the beginning
                finishedRepairServices = new List<RepairServices> { _selectedRepairService }
                    .Concat(finishedRepairServices)
                    .ToList();

                UpdateFinishedPagination();

                Console.WriteLine($"✅ Optimistic UI update - {totalItems} items remaining");
            }

            // ==========================================
            // STEP 4: CLOSE DIALOG IMMEDIATELY
            // ==========================================
            isConfirmationDialogVisible = false;
            isSaving = false; // ✅ Reset immediately so user can continue
            StateHasChanged();

            Console.WriteLine("✅ Dialog closed - user can continue working");

            // ==========================================
            // STEP 5: SHOW SUCCESS MESSAGE IMMEDIATELY
            // ==========================================
            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Customization",
                Title = "Success",
                Text = $"Item {reportNo} marked as finished",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Success
            });

            // ==========================================
            // STEP 6: BACKGROUND TASKS (Non-blocking, parallel)
            // ==========================================
            _ = Task.Run(async () =>
            {
                var backgroundTasks = new List<Task>();

                // ✅ 1. Send notification (parallel)
                if (!string.IsNullOrEmpty(reportNo))
                {
                    backgroundTasks.Add(
                        StateManagementAction.SendNotificationForInspectItem("create", reportNo)
                            .ContinueWith(t =>
                            {
                                if (t.IsCompletedSuccessfully)
                                    Console.WriteLine("✅ Notification sent");
                                else
                                    Console.WriteLine($"⚠️ Notification failed: {t.Exception?.Message}");
                            })
                    );
                }

                // ✅ 2. SignalR broadcast (parallel)
                if (hubConnection?.State == HubConnectionState.Connected)
                {
                    backgroundTasks.Add(
                        hubConnection.SendAsync("BroadcastItemUpdate", "ItemCreated")
                            .ContinueWith(t =>
                            {
                                if (t.IsCompletedSuccessfully)
                                    Console.WriteLine("✅ SignalR broadcast sent");
                                else
                                    Console.WriteLine($"⚠️ SignalR failed: {t.Exception?.Message}");
                            })
                    );
                }

                // ✅ Wait for all parallel tasks to complete
                try
                {
                    await Task.WhenAll(backgroundTasks);
                    Console.WriteLine("✅ All notifications sent");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Some notifications failed: {ex.Message}");
                }

                // ✅ 3. Smart background refresh (only if UI might be stale)
                await Task.Delay(2000); // Wait longer for database consistency

                try
                {
                    // Check if optimistic update might have failed
                    var stillExists = filteredRepairServices.Any(x => x.Id == finishedItemId);

                    if (stillExists)
                    {
                        Console.WriteLine("⚠️ Item still in grid - optimistic update may have failed, refreshing...");
                    }

                    // Always refresh to ensure consistency, but don't block the UI
                    await InvokeAsync(async () =>
                    {
                        await LoadPageData();
                        StateHasChanged();
                    });

                    Console.WriteLine("✅ Background grid refresh completed");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Background refresh failed: {ex.Message}");
                }

                // ✅ 4. NO USER CACHE REFRESH - Not needed
                // The user who verified is already in the cache from login
                Console.WriteLine("ℹ️ Skipping user cache refresh - not needed for finish updates");
            });

            Console.WriteLine("✅ Finish operation completed successfully");
        }
        catch (HttpRequestException ex) when (ex.Message.Contains("timed out"))
        {
            Console.WriteLine($"⏱️ Finish operation timed out: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Timeout",
                Text = "Operation is taking longer than expected. Refreshing data...",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Warning
            });

            // Reload data to ensure consistency
            await LoadPageData();
            isConfirmationDialogVisible = false;
            isSaving = false;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"❌ Failed to finish item: {ex.Message}");
            Console.Error.WriteLine($"Stack trace: {ex.StackTrace}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = $"Failed to finish item: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });

            // Reload on error to ensure UI matches database state
            await LoadPageData();
            isConfirmationDialogVisible = false;
            isSaving = false;
        }
        finally
        {
            // ✅ Ensure saving flag is always reset
            if (isSaving)
            {
                isSaving = false;
                StateHasChanged();
            }

            Console.WriteLine("🏁 Finish operation finalized");
        }
    }




