    private async Task ToggleGridView()
    {
        isLoading = true;
        StateHasChanged(); // Update the UI to show the spinner

        await Task.Delay(300); // Optional delay to show spinner smoothly (you can remove it if unnecessary)

        showFinishedGrid = !showFinishedGrid;

        isLoading = false;
