    private async Task SearchCustomers(string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < 2)
        {
            searchedCustomers = new List<Customer>();
            return;
        }

        try
        {
            isSearchingCustomers = true;
            StateHasChanged();

            // ✅ Use paginated API with search
            var result = await CustomerService.GetCustomersPaginatedAsync(
                pageNumber: 1,
                pageSize: 20,
                searchTerm: searchTerm,
                isActive: true
            );

            searchedCustomers = result.Data?.ToList() ?? new List<Customer>();
            Console.WriteLine($"Found {searchedCustomers.Count} customers matching '{searchTerm}'");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error searching customers: {ex.Message}");
            searchedCustomers = new List<Customer>();
        }
        finally
        {
            isSearchingCustomers = false;
            StateHasChanged();
        }
    }
    private string GetUserNameById(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty)
            return "Unknown";

        // Convert Guid to string for dictionary lookup
        string userIdString = userId.Value.ToString();

        // Check if users are loaded
        if (!_usersLoaded)
            return "Loading...";

        // Lookup username from loaded users dictionary
        if (_allUsers.TryGetValue(userIdString, out string username))
            return username;

        return "Unknown User";
    }
