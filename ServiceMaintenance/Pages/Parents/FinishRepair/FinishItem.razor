    // Method 2: Internal search method for "Repairing" status
    private async Task PerformFinishSearchInternal(string searchValue)
    {
        try
        {
            // Search only "Repairing" status items (main grid)
            var repairingResult = await RepairItemService.SearchRepairServicesAsync(
                pageNumber: 1,
                pageSize: pageSize,
                status: "Repairing",
                searchTerm: searchValue.Trim(),
                sortBy: "reportNo",
                sortDescending: true
            );

            filteredRepairServices = repairingResult.Items ?? new List<RepairServices>();
            totalItems = repairingResult.TotalCount;
            totalPages = totalItems > 0 ? (int)Math.Ceiling(totalItems / (double)pageSize) : 0;
            currentPage = 1;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Finish search error: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Search Error",
                Text = $"Failed to search: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

    // Method 3: Real-time search as user types (with debouncing)
    private void OnFinishSearchInput(InputEventArgs args)
    {
        // Cancel previous timer
        _finishSearchDebounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(args.Value))
        {
            // If search is cleared, reload original data
            _ = Task.Run(async () =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadPageData();
                    StateHasChanged();
                });
            });
            return;
        }

        // Debounce: wait 500ms before searching
        _finishSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await PerformFinishSearchInternal(args.Value);
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Finish search error: {ex.Message}");
            }
        }, null, 500, Timeout.Infinite);
    }

    // Method 4: Clear search and reload data
    private async Task ClearFinishSearch()
    {
        FinishSearchValue = string.Empty;
        currentPage = 1;
        await LoadPageData();
        StateHasChanged();
    }
    private async Task ShowReportPreview(RepairServices selectedRepairService)
    {
        if (selectedRepairService == null)
        {
            await DialogNoRecordSelected.ShowAsync();
            return;
        }

        try
        {
            _selectedRepairService = selectedRepairService;

            // Open the sidebar immediately in "loading" state
            printSidebarReportNo = selectedRepairService.reportNo;
            printSidebarBase64 = null;
            isPrintSidebarOpen = true;
            StateHasChanged();

            var report = new Report2();

            string repairByUser = GetUserNameById(selectedRepairService.repairBy);
            string verifiedByUser = GetUserNameById(selectedRepairService.verifiedBy);

            var phoneNumberTasks = Task.WhenAll(
                GetUserPhoneNumberById(selectedRepairService.repairBy),
                GetUserPhoneNumberById(selectedRepairService.verifiedBy)
            );
            var phoneNumbers = await phoneNumberTasks;
            string repairByPhone = phoneNumbers[0];
            string verifiedByPhone = phoneNumbers[1];

            if (_selectedRepairService.SparePartItems != null && _selectedRepairService.SparePartItems.Any())
            {
                var validSpareParts = _selectedRepairService.SparePartItems
                    .Where(item => item.SparePartId.HasValue && item.SparePartId.Value != Guid.Empty)
                    .ToList();

                if (validSpareParts.Any())
                {
                    var fetchTasks = validSpareParts.Select(async item =>
                    {
                        try
                        {
                            var sparePartDetails = await SparePartService.GetSparePartByIdAsync(item.SparePartId.Value);
                            if (sparePartDetails != null)
                            {
                                item.ItemName = sparePartDetails.ItemName;
                                item.Description = sparePartDetails.ItemName;
                                item.SerialNumber = sparePartDetails.SerialNumber;
                                item.UseFor = sparePartDetails.UseFor;
                                return true;
                            }
                            return false;
                        }
                        catch (Exception ex)
                        {
                            Console.WriteLine($"❌ Error fetching spare part {item.SparePartId}: {ex.Message}");
                            return false;
                        }
                    }).ToList();

                    await Task.WhenAll(fetchTasks);
                }
            }

            report.SetParameters(
                _selectedRepairService,
                _selectedRepairService.ServiceLocation,
                _selectedRepairService.SparePartItems,
                _selectedRepairService.hasContract,
                repairByUser,
                verifiedByUser,
                repairByPhone,
                verifiedByPhone
            );

            HideReportParameters(report);

            byte[] reportData;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportData = ms.ToArray();
            }

            // Feed the PDF into the sidebar instead of downloading/printing directly
            printSidebarBase64 = Convert.ToBase64String(reportData);
            StateHasChanged();

            Console.WriteLine($"✅ Report generated successfully for sidebar preview: {selectedRepairService.reportNo}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error generating report: {ex.Message}");
            isPrintSidebarOpen = false;

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Report Error",
                Text = $"Failed to generate report: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }

    private async Task ShowReportPreviewFull(RepairServices selectedRepairService)
    {
        if (selectedRepairService == null)
        {
            await DialogNoRecordSelected.ShowAsync();
            return;
        }
        try
        {
            _selectedRepairService = selectedRepairService;
            // Create an instance of your report
            var report = new Report2();
            // Resolve RepairBy and VerifiedBy GUIDs to usernames and phone numbers
            string repairByUser = GetUserNameById(selectedRepairService.repairBy);
            string verifiedByUser = GetUserNameById(selectedRepairService.verifiedBy);
            string repairByPhone = await GetUserPhoneNumberById(selectedRepairService.repairBy);
            string verifiedByPhone = await GetUserPhoneNumberById(selectedRepairService.verifiedBy);
            // ✅ FIX: Fetch spare part details from API (same as ShowReportPreview)
            if (_selectedRepairService.SparePartItems != null && _selectedRepairService.SparePartItems.Any())
            {
                foreach (var item in _selectedRepairService.SparePartItems)
                {
                    if (!item.SparePartId.HasValue || item.SparePartId.Value == Guid.Empty)
                    {
                        Console.WriteLine("⚠ Skipping spare part item with no SparePartId");
                        continue;
                    }
                    try
                    {
                        // ✅ Fetch individual spare part by ID from API (NOT from cache)
                        var sparePartDetails = await SparePartService.GetSparePartByIdAsync(item.SparePartId.Value);
                        if (sparePartDetails != null)
                        {
                            item.ItemName = sparePartDetails.ItemName;
                            item.Description = sparePartDetails.ItemName;   // ← ADD THIS
                            item.SerialNumber = sparePartDetails.SerialNumber;
                            item.UseFor = sparePartDetails.UseFor;
                        }
                        else
                        {
                            Console.WriteLine($"⚠ Spare part {item.SparePartId} not found");
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"❌ Error fetching spare part {item.SparePartId}: {ex.Message}");
                    }
                }
            }
            // Pass parameters to the report
            report.SetParameters(
                _selectedRepairService,
                _selectedRepairService.ServiceLocation,
                _selectedRepairService.SparePartItems,
                _selectedRepairService.hasContract,
                repairByUser,
                verifiedByUser,
                repairByPhone,
                verifiedByPhone
            );
            // Hide parameters
            HideReportParameters(report);
            // Generate the report as a PDF byte array
            byte[] reportData;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportData = ms.ToArray();
            }
            // Create a meaningful filename with sanitized report number
            string sanitizedReportNo = selectedRepairService.reportNo?.Replace("/", "-").Replace("\\", "-") ?? "Report";
            string filename = $"ServiceReport_Full_{sanitizedReportNo}_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            // Convert to base64 and pass to JavaScript
            string base64Data = Convert.ToBase64String(reportData);
            // Call JavaScript function - it will handle mobile vs desktop
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.previewReportInNewTab", base64Data, filename);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating report: {ex.Message}");

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Report Error",
                Text = $"Failed to generate report: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
    }
