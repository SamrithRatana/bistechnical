@page "/finishItem"
@page "/finishItem/{ReportNo}"

@using ServiceMaintenance.Models
@using Microsoft.AspNetCore.SignalR.Client
@using System.Timers
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Spinner
@inject RepairItemService RepairItemService
@inject CustomerService CustomerService
@inject ServiceSparePart SparePartService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject StateManagementAction StateManagementAction

@inject FinishItemService FinishItemService
@inject IToastNotificationService ToastNotificationService
@inject GlobalUserService GlobalUserCache
@inject FinishItemService FinishItemService
@inject GlobalUserService GlobalUserCache
@inject PrintPreviewService PrintPreviewService

@inject CacheHelper Cache
@inject MessageQueueHelper MQ
@using ServiceMaintenance.Infrastructure.Shared.Caching
@using ServiceMaintenance.Infrastructure.Shared.Messaging
<DxToastProvider Name="Customization"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
@if (isSaving)
{
    <div class="spinner-wrapper">
        <SfSpinner Visible="true" />
        <p>Saving, please wait...</p>
    </div>
}
<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
            @if (CanCreate)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" Click="NewRepairService_Click" IconCssClass="far fa-file" CssClass="toolbar-item" Enabled="false" />
            }
            @if (CanEdit)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" Click="EditRepairService_Click" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="false" />

            }
            @if (CanDelete)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" Click="EditRepairService_Click" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="false" />
            }
            @if (CanExport)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                    <Items>
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ExportToPdf" IconCssClass="fas fa-file-pdf" />
                    </Items>
                </DxToolbarItem>
            }
            @if (CanPrint)
            {
                <DxToolbarItem Text="Print Report" Click="() => ShowReportPreview(_selectedRepairService)" CssClass="toolbar-item" IconCssClass="fas fa-print" />
            }
            @if (CanView)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]"
                               Click="ToggleGridView"
                               CssClass="toolbar-item"
                               IconCssClass="fas fa-check-circle"
                               Enabled="true" />
            }
        </DxToolbar>
    </div>
</div>
<br />
<SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>
@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical; // Default rendering mode

    // Set properties based on the active breakpoint
    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical; // Stack items vertically
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true; // Enable adaptive UI for medium screens
        renderingMode = RowDirection.Horizontal; // Use horizontal layout
    }
    else
    {
        enableAdaptiveUIMode = false;
    }
}
@if (CanAccess)
{
    @if (CanView)
    {

        @if (isLoading)
        {
            <div class="spinner-wrapper">
                <SfSpinner Visible="true" />
                <p>@Loc[nameof(ResourceStrings.TextLoading)]</p>
            </div>

        }
        else
        {
            @if (!showFinishedGrid)
            {
                <div style="margin-bottom: 15px; padding: 15px; background-color: #f9f9f9; border-radius: 4px;">
                    <div style="display: flex; gap: 10px; align-items: center;">

                        <SfTextBox @ref="FinishSearchBox"
                                   Placeholder="Search by Report No, Company, Serial Number..."
                                   ShowClearButton="true"
                                   Width="400px"
                                   @bind-Value="FinishSearchValue"
                                   Input="OnFinishSearchInput">
                        </SfTextBox>

                        <SfButton Content="Search"
                                  CssClass="e-btn e-primary"
                                  IconCss="fas fa-search"
                                  OnClick="PerformFinishSearch" />

                        <SfButton Content="Clear"
                                  CssClass="e-btn e-outline"
                                  IconCss="fas fa-times"
                                  OnClick="ClearFinishSearch" />
                    </div>

                    @if (!string.IsNullOrEmpty(FinishSearchValue))
                    {
                        <div style="margin-top: 10px; color: #666; font-size: 14px;">
                            <i class="fas fa-info-circle"></i>
                            Searching for: <strong>@FinishSearchValue</strong>
                        </div>
                    }
                </div>

                <div class="grid-container">
                    <SfGrid @ref="MyGrid"
                            DataSource="@filteredRepairServices"
                            AllowSorting="true"
                            ShowColumnChooser="true"
                            AllowExcelExport="true"
                            AllowPdfExport="true"
                            SelectionMode="GridSelectionMode.Single"
                            Toolbar="@ToolbarItems"
                            EnableAdaptiveUI="@enableAdaptiveUIMode"
                            RowRenderingMode="@renderingMode"
                            AllowResizing="true"
                            AllowFiltering="true"
                            Height="450"
                            AllowSelection="true">
                        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
                        <GridEvents RowSelected="RowSelectHandler" TValue="RepairServices"></GridEvents>
                        <GridPageSettings PageSize="10"></GridPageSettings>
                        <GridColumns>
                            <GridColumn Field="Id" HeaderText="Id" Width="150" Format="d" Visible="false" />
                            <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="150" />
                            <GridColumn Field="ServiceDate" HeaderText="@Loc[nameof(ResourceStrings.TextReceiveDate)]" Width="150" Format="dd/MM/yyyy HH:mm tt" />
                            <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" CustomAttributes="@(new Dictionary<string, object>() { { "class", "e-attr" } })" Width="200" />
                            <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="200" />
                            <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="200" />
                            <GridColumn Field="ServiceLocation" HeaderText="@Loc[nameof(ResourceStrings.TextServiceLocation)]" Width="200" />
                            <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="150" />
                            <GridColumn Field="repairBy" HeaderText="@Loc[nameof(ResourceStrings.TextRepairBy)]" Width="150">
                                <Template>
                                    @{
                                        var item = context as RepairServices;
                                        var username = GetUserNameById(item.repairBy);
                                    }
                                    @username
                                </Template>
                            </GridColumn>
                            <GridColumn Field="verifiedBy" HeaderText="@Loc[nameof(ResourceStrings.TextVerifyBy)]" Width="150">
                                <Template>
                                    @{
                                        var item = context as RepairServices;
                                        var username = GetUserNameById(item.verifiedBy);
                                    }
                                    @username
                                </Template>
                            </GridColumn>
                            <GridColumn Field="finishedDate" HeaderText="@Loc[nameof(ResourceStrings.TextFinishDate)]" Width="150" Format="dd/MM/yyyy HH:mm tt" Visible="@HasFinishDate()" />
                            <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" IsFrozen="true" Freeze="FreezeDirection.Right" Width="200">
                                <Template>
                                    @if (((context as RepairServices)?.finishedDate == null) && isAdmin)
                                    {
                                        <DxButton IconCssClass="fas fa-check"
                                                  CssClass="icon-button danger"
                                                  RenderStyle="ButtonRenderStyle.Primary"
                                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                                  Text="@Loc[nameof(ResourceStrings.TextApproved)]"
                                                  @onclick="() => OnApplyButtonClick(context as RepairServices)" />

                                        <DxButton IconCssClass="fas fa-eye"
                                                  CssClass="icon-button info"
                                                  RenderStyle="ButtonRenderStyle.Info"
                                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                                  Text="@Loc[nameof(ResourceStrings.TextView)]"
                                                  @onclick="() => ShowRepairServiceDetails(context as RepairServices)" />
                                    }
                                    else if ((context as RepairServices)?.finishedDate != null)
                                    {
                                        <DxButton IconCssClass="fas fa-print"
                                                  CssClass="icon-button secondary"
                                                  RenderStyle="ButtonRenderStyle.Secondary"
                                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                                  Text="Print"
                                                  Click="() => ShowReportPreviewFull(_selectedRepairService)" />
                                    }
                                </Template>
                            </GridColumn>
                        </GridColumns>
                    </SfGrid>
                    <!-- Pagination Controls -->
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; border-top: 1px solid #ddd; margin-top: 10px;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <button class="e-btn e-normal" @onclick="FirstPage" disabled="@(currentPage == 1)">
                                <i class="fas fa-angle-double-left"></i> First
                            </button>
                            <button class="e-btn e-normal" @onclick="PreviousPage" disabled="@(currentPage == 1)">
                                <i class="fas fa-angle-left"></i> Previous
                            </button>

                            <span style="padding: 0 15px; font-weight: 500;">
                                Page @currentPage of @totalPages
                            </span>

                            <button class="e-btn e-normal" @onclick="NextPage" disabled="@(currentPage >= totalPages)">
                                Next <i class="fas fa-angle-right"></i>
                            </button>
                            <button class="e-btn e-normal" @onclick="LastPage" disabled="@(currentPage >= totalPages)">
                                Last <i class="fas fa-angle-double-right"></i>
                            </button>
                        </div>

                        <div style="color: #666;">
                            Showing @Math.Min((currentPage - 1) * pageSize + 1, totalItems) - @Math.Min(currentPage * pageSize, totalItems) of @totalItems items
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div style="margin-bottom: 15px; padding: 15px; background-color: #f9f9f9; border-radius: 4px;">
                    <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                        <SfTextBox Placeholder="Search finished items by Report No, Company, Serial Number..."
                                   ShowClearButton="true"
                                   Width="300px"
                                   @bind-Value="FinishedSearchValue"
                                   Input="OnFinishedSearchInput">
                        </SfTextBox>

                        <SfDropDownList TValue="string" TItem="string" DataSource="@SortingType" Placeholder="Sorting order" Width="160px" @bind-Value="FinishedSortingValue">
                            <DropDownListEvents TValue="string" TItem="string" ValueChange="OnFinishedSorting"></DropDownListEvents>
                        </SfDropDownList>

                        <SfMultiSelect TValue="string[]" TItem="ServiceStatus"
                                       AllowFiltering="true"
                                       DataSource="@_serviceStatuses"
                                       Placeholder="Select Service Statuses"
                                       ShowClearButton="true"
                                       Width="220px"
                                       @bind-Value="FinishedFilteringValue">
                            <MultiSelectFieldSettings Text="Name" Value="Id" />
                            <MultiSelectEvents TValue="string[]" TItem="ServiceStatus" ValueChange="OnFinishedFiltering"></MultiSelectEvents>
                        </SfMultiSelect>

                        <SfButton Content="Search"
                                  CssClass="e-btn e-primary"
                                  IconCss="fas fa-search"
                                  OnClick="PerformFinishedSearch" />

                        <SfButton Content="Reset" CssClass="e-btn e-outline" OnClick="OnFinishedReset"></SfButton>
                    </div>

                    @if (!string.IsNullOrEmpty(FinishedSearchValue))
                    {
                        <div style="margin-top: 10px; color: #666; font-size: 14px;">
                            <i class="fas fa-info-circle"></i>
                            Searching for: <strong>@FinishedSearchValue</strong>
                        </div>
                    }
                </div>

                <div class="grid-container">
                    <SfGrid @ref="FinishedGrid"
                            DataSource="@PaginatedFinishedRepairServices"
                            AllowSorting="true"
                            ShowColumnChooser="true"
                            AllowExcelExport="true"
                            AllowPdfExport="true"
                            SelectionMode="GridSelectionMode.Single"
                            EnableAdaptiveUI="@enableAdaptiveUIMode"
                            RowRenderingMode="@renderingMode"
                            AllowResizing="true"
                            AllowFiltering="true"
                            Height="450"
                            AllowSelection="true">
                        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
                        <GridEvents RowSelected="FinishedRowSelectHandler" TValue="RepairServices"></GridEvents>
                        <GridColumns>
                            <GridColumn Field="Id" HeaderText="Id" Width="150" Format="d" Visible="false" />
                            <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="150" />
                            <GridColumn Field="ServiceDate" HeaderText="@Loc[nameof(ResourceStrings.TextReceiveDate)]" Width="150" Format="dd/MM/yyyy HH:mm tt" />
                            <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" CustomAttributes="@(new Dictionary<string, object>() { { "class", "e-attr" } })" Width="200" />
                            <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="200" />
                            <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="200" />
                            <GridColumn Field="ServiceLocation" HeaderText="@Loc[nameof(ResourceStrings.TextServiceLocation)]" Width="200" />
                            <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="150">
                                <Template>
                                    @{
                                        var service = context as RepairServices;
                                    }
                                    <span class="@GetStatusClass(service?.Status)">@(service?.Status ?? "N/A")</span>
                                </Template>
                            </GridColumn>
                            <GridColumn Field="finishedDate" HeaderText="@Loc[nameof(ResourceStrings.TextFinishDate)]" Width="150" Format="dd/MM/yyyy HH:mm tt" />
                            <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" IsFrozen="true" Freeze="FreezeDirection.Right" Width="120">
                                <Template>
                                    @{
                                        var service = context as RepairServices;
                                    }
                                    <DxButton IconCssClass="fas fa-print"
                                              CssClass="icon-button secondary"
                                              RenderStyle="ButtonRenderStyle.Secondary"
                                              RenderStyleMode="ButtonRenderStyleMode.Text"
                                              Text="Print"
                                              @onclick="() => ShowReportPreview(service)" />
                                </Template>
                            </GridColumn>
                        </GridColumns>
                    </SfGrid>

                    @if (PaginatedFinishedRepairServices == null || !PaginatedFinishedRepairServices.Any())
                    {
                        <div class="e-error" style="margin-top: 10px;">
                            <div class="e-error-content">No finished items found.</div>
                        </div>
                    }

                    <div style="display: flex; justify-content: center; align-items: center; gap: 15px; padding: 15px; border-top: 1px solid #ddd; margin-top: 10px;">
                        <SfButton CssClass="e-btn e-outline e-primary" @onclick="GoToPreviousFinishedPage" Disabled="@IsFirstFinishedPage">@Loc[nameof(ResourceStrings.TextPrevious)]</SfButton>
                        <span>Page @currentFinishedPage of @totalFinishedPages</span>
                        <SfButton CssClass="e-btn e-outline e-primary" @onclick="GoToNextFinishedPage" Disabled="@IsLastFinishedPage">@Loc[nameof(ResourceStrings.TextNext)]</SfButton>
                    </div>
                </div>
            }
        }
    }
}



<SfDialog @ref="ConfirmationDialog"
          IsModal="true"
          Width="400px"
          ShowCloseIcon="true"
          Visible="@isConfirmationDialogVisible">
    <DialogTemplates>
        <Header>
            <h2>@pageTitle</h2>
        </Header>
        <Content>
            <p>@Loc[nameof(ResourceStrings.Textfinishdiaconfirm)]</p>
        </Content>

        <FooterTemplate>
            <SfButton CssClass="e-btn custom-button" @onclick="ConfirmCustomerConfirm">Yes</SfButton>
            <SfButton CssClass="e-btn e-danger" @onclick="CancelConfirmationDialog">No</SfButton>
        </FooterTemplate>
    </DialogTemplates>
</SfDialog>


<SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
    <DialogTemplates>
        <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
        <Content>
            <div class="report-container">
                <div class="report-header">
                    <span>Repair Service Report</span>
                </div>
                <div class="report-body">
                    <table class="report-table">
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.reportNo</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceDate.ToString("yyyy-MM-dd HH:mm tt")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairDate)]:</strong></td>
                            <td class="report-value">
                                @(_selectedRepairService?.repairDate.HasValue == true
                                                                ? _selectedRepairService.repairDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                                                : "N/A")
                            </td>
                        </tr>

                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCompanyName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CompanyName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextAddress)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Address</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContactName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ContactName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPhoneNumber)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.PhoneNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextItemName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.itemName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextSerialNumber)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.serialNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCustomerReq)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CustomerRequest</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextInspection)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Inspection</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textsolution)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Solution</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextServiceLocation)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceLocation</td>
                        </tr>

                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPriority)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServicePriority</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextStatus)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Status</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContract)]:</strong></td>
                            <td class="report-value">@(_selectedRepairService?.hasContract == true ? "Yes" : "No")</td>
                        </tr>

                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairBy)]:</strong></td>
                            <td class="report-value">
                                @{
                                    var username = GetUserNameById(_selectedRepairService?.repairBy);
                                }
                                @username
                            </td>
                        </tr>
                    </table>
                    <hr />
                    @if (_selectedRepairService?.SparePartItems != null && _selectedRepairService.SparePartItems.Count > 0)
                    {
                        <h4>SparePart Details</h4>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>@Loc[nameof(ResourceStrings.TextImage)]</th>
                                    <th>@Loc[nameof(ResourceStrings.textDescription)]</th>
                                    <th>@Loc[nameof(ResourceStrings.TextQty)]</th>
                                    <th>@Loc[nameof(ResourceStrings.TextCondition)]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sparePart in _selectedRepairService.SparePartItems)
                                {
                                    var sparePartObject = _spareParts.FirstOrDefault(x => x.Id == sparePart.SparePartId);

                                    <tr>
                                        <td>
                                            @if (sparePartObject != null && !string.IsNullOrEmpty(sparePartObject.PictureUrl))
                                            {
                                                <img src="@sparePartObject.PictureUrl" alt="Spare Part Image" />
                                            }
                                            else
                                            {
                                                <span>No Image</span>
                                            }
                                        </td>
                                        <td>@sparePartObject?.ItemName</td>
                                        <td>@sparePart.UseFor</td>
                                        <td>@sparePart.Quantity</td>
                                        <td>@sparePart.Condition</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Close" IsPrimary="true" OnClick="@CloseDialog" />
    </DialogButtons>
</SfDialog>
<SfDialog @ref="DialogNoRecordSelected" IsModal="true" Width="250px" ShowCloseIcon="true" Visible="false">
    <DialogTemplates>
        <Header> Warning! </Header>
        <Content> @Loc[nameof(ResourceStrings.TextSelectRecord)] </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="OK" IsPrimary="true" OnClick="CloseDialogNoRecordSelected" />
    </DialogButtons>
</SfDialog>
<PrintPreviewSidebar IsOpen="@isPrintSidebarOpen"
              IsOpenChanged="@(v => isPrintSidebarOpen = v)"
              Base64Pdf="@printSidebarBase64"
              ReportNo="@printSidebarReportNo" />
@code {
    [Parameter] public string ReportNo { get; set; }
    private SfGrid<RepairServices> MyGrid;
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;
    private string activeBreakpoint { get; set; }
    public string[] ToolbarItems = new string[] { "ColumnChooser", "Search" };
    private IEnumerable<RepairServices> filteredRepairServices = new List<RepairServices>();
    private List<RepairServices> finishedRepairServices = new();
    private IEnumerable<ServiceStatus> _serviceStatuses;

    private bool isPrintSidebarOpen = false;
    private string printSidebarBase64;
    private string printSidebarReportNo;
    private HubConnection hubConnection;
    private string SearchValue { get; set; }
    private string SortingValue { get; set; }
    private string[] FilteringValue { get; set; }
    public List<string> SortingType = new List<string>() { "Ascending", "Descending" };
    private bool isLoading = true;
    private SfTextBox FinishSearchBox;
    private string FinishSearchValue { get; set; }
    private System.Threading.Timer _finishSearchDebounceTimer;
    private SfGrid<RepairServices> FinishedGrid;
    private System.Threading.Timer _finishedSearchDebounceTimer;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 0;
    private int totalItems = 0;
    private IEnumerable<RepairServices> PaginatedFinishedRepairServices;
    private int currentFinishedPage = 1;
    private int pageSizeFinished = 8;
    private int totalFinishedPages;
    private string FinishedSearchValue { get; set; }
    private string FinishedSortingValue { get; set; }
    private string[] FinishedFilteringValue { get; set; }

    private SfDialog ConfirmationDialog;
    private string pageTitle = "Edit Repair Service";
    private FinishItemRequest FinishItemBy = new FinishItemRequest();


    private RepairServices _selectedRepairService;
    private bool isConfirmationDialogVisible = false;
    private SfDialog DialogEdit;
    private SfDialog DialogNoRecordSelected;
    private bool showFinishedGrid = false;

    private bool isReportDialogVisible = false;
    private bool ReportViewerVisible { get; set; }
    private Report2 CurrentReport { get; set; }
    private Dictionary<string, string> _allUsers = new Dictionary<string, string>();
    private bool _usersLoaded = false;
    // ✅ OPTIMIZED: Only store essential spare parts (loaded on-demand)
    private IEnumerable<SparePartObject> _spareParts;

