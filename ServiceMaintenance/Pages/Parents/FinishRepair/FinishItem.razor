    // NEW: Filtering by status (local filtering on already loaded data)
    public void OnFinishedFiltering(MultiSelectChangeEventArgs<string[]> args)
    {
        FinishedFilteringValue = args.Value;

        if (FinishedFilteringValue != null && FinishedFilteringValue.Any())
        {
            // Filter the current finished items
            var filtered = finishedRepairServices
                .Where(service => FinishedFilteringValue.Contains(service.Status))
                .ToList();

            PaginatedFinishedRepairServices = filtered
                .Skip((currentFinishedPage - 1) * pageSizeFinished)
                .Take(pageSizeFinished);
        }
        else
        {
            UpdateFinishedPagination();
        }

        StateHasChanged();
    }

