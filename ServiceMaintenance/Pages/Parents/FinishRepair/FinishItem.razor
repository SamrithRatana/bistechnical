    }


    private void UpdateFinishedPagination()
    {
        if (finishedRepairServices == null || !finishedRepairServices.Any())
        {
            totalFinishedPages = 0;
            PaginatedFinishedRepairServices = new List<RepairServices>();
            return;
        }

        totalFinishedPages = (int)Math.Ceiling((double)finishedRepairServices.Count / pageSizeFinished);

        PaginatedFinishedRepairServices = finishedRepairServices
            .Skip((currentFinishedPage - 1) * pageSizeFinished)
            .Take(pageSizeFinished)
            .ToList();
    }

    private async void GoToPreviousFinishedPage()
    {
        if (currentFinishedPage > 1)
        {
            currentFinishedPage--;
            await LoadFinishedData(FinishedSearchValue, FinishedSortingValue); // ✅ Load new page
            StateHasChanged();
        }
    }

    private async void GoToNextFinishedPage()
    {
        if (currentFinishedPage < totalFinishedPages)
        {
            currentFinishedPage++;
            await LoadFinishedData(FinishedSearchValue, FinishedSortingValue); // ✅ Load new page
            StateHasChanged();
        }
    }

    private bool IsFirstFinishedPage => currentFinishedPage == 1;
    private bool IsLastFinishedPage => currentFinishedPage == totalFinishedPages;




