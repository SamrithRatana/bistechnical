    private async Task ShowRepairServiceDetails(RepairServices repairService)
    {
        _selectedRepairService = repairService;

        // ✅ PARALLEL: Fetch all spare parts concurrently
        if (_selectedRepairService.SparePartItems != null && _selectedRepairService.SparePartItems.Any())
        {
            var sparePartIds = _selectedRepairService.SparePartItems
                .Where(x => x.SparePartId.HasValue && x.SparePartId.Value != Guid.Empty)
                .Select(x => x.SparePartId.Value)
                .Distinct()
                .ToList();

            if (sparePartIds.Any())
            {
                Console.WriteLine($"🔍 Fetching {sparePartIds.Count} spare parts in parallel...");

                // ✅ Create all fetch tasks at once
                var fetchTasks = sparePartIds.Select(async id =>
                {
                    try
                    {
                        var sparePart = await SparePartService.GetSparePartByIdAsync(id);
                        if (sparePart != null)
                        {
                            Console.WriteLine($"✅ Fetched: {sparePart.ItemName}");
                            return sparePart;
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"❌ Error loading spare part {id}: {ex.Message}");
                    }
                    return null;
                }).ToList();

                // ✅ Wait for all fetches to complete in parallel
                var results = await Task.WhenAll(fetchTasks);

                // ✅ Filter out nulls and store results
                _spareParts = results.Where(sp => sp != null).ToList();

                Console.WriteLine($"✅ Loaded {_spareParts.Count()} spare parts successfully");
            }
            else
            {
                _spareParts = new List<SparePartObject>();
            }
        }
        else
        {
            _spareParts = new List<SparePartObject>();
        }

        isViewDialogVisible = true;
        await DialogEdit.ShowAsync();
    }

