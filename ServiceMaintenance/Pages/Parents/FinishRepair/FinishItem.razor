    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity.IsAuthenticated)
            {
                // ✅ Get user ID from claims instead of UserManager
                CurrentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                // ✅ Check if admin role from claims
                isAdmin = user.IsInRole("Admin");

                Console.WriteLine($"✅ Current User ID: {CurrentUserId}, IsAdmin: {isAdmin}");
            }

            await LoadAllUsersAsync();



            // Load initial page data
            await LoadPageData();

            // Load other necessary data
            _serviceStatuses = await RepairItemService.GetServiceStatusesAsync();

            // ✅ OPTIMIZED: Load only 10 spare parts initially instead of all


            // ✅ OPTIMIZED: Don't load customers on page load - use search instead
            // _customers will be loaded on-demand via SearchCustomers()

            UpdateFinishedPagination();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error initializing repair services: {ex.Message}");
        }

        isLoading = false;


        // SignalR setup
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/itemHub"))
            .Build();

        hubConnection.On<string>("ReceiveItemUpdate", async (message) =>
 {
     await Cache.InvalidateManyAsync(
         CacheKeys.RepairItem(currentPage, pageSize) + ":Repairing",
         CacheKeys.RepairItem(1, pageSize) + ":Repairing",
         CacheKeys.FinishRepair(1, pageSizeFinished),
         CacheKeys.DashboardStats
     );

     await LoadPageData();
     // ✅ Reload users when data changes
     _usersLoaded = false;
     await LoadAllUsersAsync();
     await InvokeAsync(StateHasChanged);
 });

        hubConnection.On<Guid>("BroadcastItemDelete", (deletedItemId) =>
        {
            filteredRepairServices = filteredRepairServices.Where(item => item.Id != deletedItemId).ToList();
            finishedRepairServices = finishedRepairServices.Where(item => item.Id != deletedItemId).ToList();
            totalItems--;
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();

        // Add auto-reconnection logic
        hubConnection.Closed += async (error) =>
        {
            await Task.Delay(new Random().Next(0, 5) * 1000);
            try
            {
                await hubConnection.StartAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Reconnection failed: {ex.Message}");
            }
        };
    }
