    private async Task LoadPageData()
    {
        try
        {
            // Load "Repairing" status items with pagination (cached)
            var repairingResult = await Cache.GetOrSetAsync(
                CacheKeys.RepairItem(currentPage, pageSize) + ":Repairing",
                () => RepairItemService.SearchRepairServicesAsync(
                    pageNumber: currentPage,
                    pageSize: pageSize,
                    status: "Repairing",
                    sortBy: "reportNo",
                    sortDescending: true),
                TimeSpan.FromMinutes(3)
            );

            // ✅ Only load current page of finished items (cached)
            var finishedResult = await Cache.GetOrSetAsync(
                CacheKeys.FinishRepair(1, pageSizeFinished),
                () => RepairItemService.SearchRepairServicesAsync(
                    pageNumber: 1,
                    pageSize: pageSizeFinished,
                    status: "Finished",
                    sortBy: "reportNo",
                    sortDescending: true),
                TimeSpan.FromMinutes(3)
            );

            // Update main grid data
            filteredRepairServices = repairingResult?.Items ?? new List<RepairServices>();
            totalItems = repairingResult?.TotalCount ?? 0;
            totalPages = totalItems > 0 ? (int)Math.Ceiling(totalItems / (double)pageSize) : 0;

            // Update finished items for card view
            var finishedList = (finishedResult?.Items ?? new List<RepairServices>()).ToList();

            if (temporarilyVisibleFinishedItems.Any())
            {
                finishedRepairServices = finishedList
                    .Where(x => temporarilyVisibleFinishedItems.Contains(x.Id))
                    .ToList();
            }
            else if (finishedList.Any())
            {
                // Show only the last finished item by default
                finishedRepairServices = new List<RepairServices> { finishedList.First() };
            }
            else
            {
                finishedRepairServices = new List<RepairServices>();
            }

            UpdateFinishedPagination();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading page data: {ex.Message}");
        }
    }
    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        await LoadPageData();
        StateHasChanged();
