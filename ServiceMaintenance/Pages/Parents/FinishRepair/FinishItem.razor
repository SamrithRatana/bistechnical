    // NEW: Real-time debounced search as user types in the finished grid search box
    private void OnFinishedSearchInput(InputEventArgs args)
    {
        _finishedSearchDebounceTimer?.Dispose();

        FinishedSearchValue = args.Value;

        if (string.IsNullOrWhiteSpace(args.Value))
        {
            _ = Task.Run(async () =>
            {
                await InvokeAsync(async () =>
                {
                    currentFinishedPage = 1;
                    await LoadFinishedData(null, FinishedSortingValue);
                    StateHasChanged();
                });
            });
            return;
        }

        _finishedSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    currentFinishedPage = 1;
                    await LoadFinishedData(args.Value, FinishedSortingValue);
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Finished search error: {ex.Message}");
            }
        }, null, 500, Timeout.Infinite);
    }

