@page "/inspection-list"

@using ServiceMaintenance.Models
@using Microsoft.AspNetCore.SignalR.Client
@using ServiceMaintenance.Services.Filters.GlobalSecurity
@using System.Timers
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@inject RepairItemService RepairItemService
@inject ServiceSparePart SparePartService
@inject InspectItemService InspectItemService
@inject AwaitingCustomerConfirmService AwaitingCustomerConfirmService
@inject AwaitingSparePartService AwaitingSparePartService
@inject JwtSessionService JwtSessionService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject StateManagementAction StateManagementAction
@inject GlobalUserService GlobalUserCache
@inject CacheHelper Cache
@inject MessageQueueHelper MQ
<DxToastProvider Name="Customization"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />

<!-- Loading Overlay -->
@if (isSaving)
{
    <div class="loading-overlay">
        <div class="loading-container">
            <div class="loading-spinner"></div>
            <div class="loading-text">
                <h4>Processing...</h4>
                <p>Please wait</p>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">

            @if (CanExport)
            {
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                    <Items>
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]"
                                       Click="ExportToExcel"
                                       IconCssClass="fas fa-file-excel" />
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]"
                                       Click="ExportToPdf"
                                       IconCssClass="fas fa-file-pdf" />
                    </Items>
                </DxToolbarItem>
            }

            @if (CanPrint)
            {
                <DxToolbarItem Text="Print Report"
                               Click="() => ShowReportPreview(_selectedRepairService)"
                               CssClass="toolbar-item"
                               IconCssClass="fas fa-print"
                               Enabled="@isRowSelected" />
            }

        </DxToolbar>
    </div>
</div>

<br />

<SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>
@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical;

    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical;
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Horizontal;
    }
    else
    {
        enableAdaptiveUIMode = false;
    }
}

@if (CanAccess)
{
    @if (CanView)
    {
        <h2>@Loc[nameof(ResourceStrings.TextInspectItemList)]</h2>

        <div style="margin-bottom: 15px; padding: 15px; background-color: #f9f9f9; border-radius: 4px;">
            <div style="display: flex; gap: 10px; align-items: center;">
                <SfTextBox @ref="InspectionSearchBox"
                           Placeholder="Search by Report No, Company, Serial Number..."
                           ShowClearButton="true"
                           Width="400px"
                           @bind-Value="InspectionSearchValue"
                           Input="OnInspectionSearchInput">
                </SfTextBox>
                <SfButton Content="Search"
                          CssClass="e-btn e-primary"
                          IconCss="fas fa-search"
                          OnClick="PerformInspectionSearch" />
                <SfButton Content="Clear"
                          CssClass="e-btn e-outline"
                          IconCss="fas fa-times"
                          OnClick="ClearInspectionSearch" />
            </div>
            @if (!string.IsNullOrEmpty(InspectionSearchValue))
            {
                <div style="margin-top: 10px; color: #666; font-size: 14px;">
                    <i class="fas fa-info-circle"></i>
                    Searching for: <strong>@InspectionSearchValue</strong>
                </div>
            }
        </div>

        <SfGrid @ref="MyGrid"
                DataSource="@filteredRepairServices2"
                AllowPaging="true"
                AllowSorting="true"
                ShowColumnChooser="true"
                AllowExcelExport="true"
                AllowPdfExport="true"
                AllowResizing="true"
                AllowFiltering="true"
                Height="400"
                SelectionMode="GridSelectionMode.Single"
                Toolbar=@ToolbarItems
                EnableAdaptiveUI="@enableAdaptiveUIMode"
                RowRenderingMode="@renderingMode"
                AllowSelection="true">
            <GridEvents TValue="RepairServices" RowSelected="RowSelectHandler"></GridEvents>
            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
            <GridPageSettings PageSize="10"></GridPageSettings>

            <GridTemplates>
                <DetailTemplate>
                    @{
                        var repairService = (context as RepairServices);
                    }
                    @if (repairService.SparePartItems == null || !repairService.SparePartItems.Any())
                    {
                        <div class="text-center">
                            <h5>The spare part is unavailable.</h5>
                        </div>
                    }
                    else
                    {
                        <div class="d-none d-md-block">
                            <table class="table table-bordered">
                                <thead class="thead-dark">
                                    <tr>
                                        <th class="text-center">Image</th>
                                        <th class="text-center">Item Name</th>
                                        <th class="text-center">UseFor</th>
                                        <th class="text-center">Quantity</th>
                                        <th class="text-center">Condition</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var part in repairService.SparePartItems)
                                    {
                                        var sparePart = GetSparePartById(part.SparePartId);
                                        if (sparePart == null) { continue; }
                                        <tr style="background-color: white;">
                                            <td class="text-center" style="vertical-align: middle;">
                                                <img src="@sparePart?.PictureUrl" alt="@sparePart?.ItemName" class="img-fluid sparePartImage" style="max-width: 50px;" />
                                            </td>
                                            <td class="text-start" style="vertical-align: middle;">@sparePart?.ItemName</td>
                                            <p class="card-text"><strong>UseFor:</strong> @sparePart?.UseFor</p>
                                            <td class="text-center" style="vertical-align: middle;">@part.Quantity</td>
                                            <td class="text-center" style="vertical-align: middle;">@part.Condition</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-block d-md-none">
                            <div class="container">
                                <div class="row">
                                    @foreach (var part in repairService.SparePartItems)
                                    {
                                        var sparePart = GetSparePartById(part.SparePartId);
                                        if (sparePart == null) { continue; }
                                        <div class="col-12 mb-4">
                                            <div class="card">
                                                <div class="row g-0">
                                                    <div class="col-4 d-flex align-items-center justify-content-center">
                                                        <img src="@sparePart?.PictureUrl" alt="@sparePart?.ItemName" class="img-fluid sparePartImage" />
                                                    </div>
                                                    <div class="col-8">
                                                        <div class="card-body">
                                                            <h5 class="card-title">@sparePart?.ItemName</h5>
                                                            <p class="card-text"><strong>UseFor:</strong> @sparePart?.UseFor</p>
                                                            <p class="card-text"><strong>Description:</strong> @part.Description</p>
                                                            <p class="card-text"><strong>Quantity:</strong> @part.Quantity</p>
                                                            <p class="card-text"><strong>Condition:</strong> @part.Condition</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </DetailTemplate>
            </GridTemplates>

            <GridColumns>
                <GridColumn Field="Id" HeaderText="Id" Width="150" Format="d" Visible="false" />
                <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="150" />
                <GridColumn Field="inspectDate" HeaderText="@Loc[nameof(ResourceStrings.TextInspectDate)]" Width="150" Format="dd/MM/yyyy HH:mm tt" />
                <GridColumn Field="Inspection" HeaderText="@Loc[nameof(ResourceStrings.TextInspection)]" CustomAttributes="@(new Dictionary<string, object>() { { "class", "e-attr" } })" Width="200" />
                <GridColumn Field="Solution" HeaderText="@Loc[nameof(ResourceStrings.Textsolution)]" CustomAttributes="@(new Dictionary<string, object>() { { "class", "e-attr" } })" Width="200" />
                <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="100">
                    <Template>
                        @{
                            var item = context as RepairServices;
                        }
                        <select @key="item.Id" 
                                class="status-badge-select @GetInspectionStatusBadgeClass(item.Status)"
                                value="@item.Status"
                                @onchange="async (e) => await OnInspectionStatusChanged(item, e.Value?.ToString())">
                            <option value="Inspection">វិនិច្ឆ័យរួចរាល់</option>
                            <option value="Inspecting">វិនិច្ឆ័យម្ដងទៀត</option>
                            <option value="Awaiting Sparepart">បញ្ជូនទៅផ្នែកស្តុក</option>
                            <option value="Awaiting Customer Confirm">បញ្ជូនទៅផ្នែកទីផ្សារ</option>
                        </select>
                    </Template>
                </GridColumn>
                <GridColumn Field="inspectBy" HeaderText="@Loc[nameof(ResourceStrings.TextInspectby)]" Width="150">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.inspectBy);
                        }
                        @username
                    </Template>
                </GridColumn>
                <GridColumn HeaderText="Actions" Width="120">
                    <Template>
                        @{
                            var item = context as RepairServices;
                        }
                        <DxButton IconCssClass="fas fa-eye"
                                  CssClass="icon-button info"
                                  RenderStyle="ButtonRenderStyle.Info"
                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                  Text="@Loc[nameof(ResourceStrings.TextView)]"
                                  Enabled="@(!isSaving)"
                                  @onclick="() => ShowRepairServiceDetails(item)" />
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>

        <!-- Pagination -->
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; border-top: 1px solid #ddd; margin-top: 10px;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <button class="e-btn e-normal" @onclick="FirstPage2" disabled="@(currentPage2 == 1)">
                    <i class="fas fa-angle-double-left"></i> First
                </button>
                <button class="e-btn e-normal" @onclick="PreviousPage2" disabled="@(currentPage2 == 1)">
                    <i class="fas fa-angle-left"></i> Previous
                </button>
                <span style="padding: 0 15px; font-weight: 500;">
                    Page @currentPage2 of @totalPages2
                </span>
                <button class="e-btn e-normal" @onclick="NextPage2" disabled="@(currentPage2 >= totalPages2)">
                    Next <i class="fas fa-angle-right"></i>
                </button>
                <button class="e-btn e-normal" @onclick="LastPage2" disabled="@(currentPage2 >= totalPages2)">
                    Last <i class="fas fa-angle-double-right"></i>
                </button>
            </div>
            <div style="color: #666;">
                Showing @Math.Min((currentPage2 - 1) * pageSize2 + 1, totalItems2) - @Math.Min(currentPage2 * pageSize2, totalItems2) of @totalItems2 items
            </div>
        </div>
    }
}

<!-- ═══════════════════════════════════════════════════════ -->
<!-- VIEW DETAILS DIALOG                                    -->
<!-- ═══════════════════════════════════════════════════════ -->
<SfDialog @ref="DialogView" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
    <DialogTemplates>
        <Header>View Information</Header>
        <Content>
            <div class="report-container">
                <div class="report-header">
                    <h3>Received Item Detail</h3>
                    <p><strong>ref no:</strong> @_selectedRepairService?.reportNo</p>
                </div>
                <div class="report-body">
                    <table class="report-table">
                        <tr>
                            <td class="report-label"><strong>Received Date:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceDate.ToString("dd/MM/yyyy HH:mm tt")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Inspect Date:</strong></td>
                            <td class="report-value">@_selectedRepairService?.inspectDate?.ToString("dd/MM/yyyy HH:mm tt")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>CompanyName:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CompanyName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Address:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Address</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Contact Name:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ContactName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Phone Number:</strong></td>
                            <td class="report-value">@_selectedRepairService?.PhoneNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Item Name:</strong></td>
                            <td class="report-value">@_selectedRepairService?.itemName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Serial Number:</strong></td>
                            <td class="report-value">@_selectedRepairService?.serialNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Customer Request:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CustomerRequest</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Service Type:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceType</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Has Contract:</strong></td>
                            <td class="report-value">@(_selectedRepairService?.hasContract == true ? "Yes" : "No")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Service Priority:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServicePriority</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Activities:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Status</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>Inspect By:</strong></td>
                            <td class="report-value">
                                @{
                                    var username = GetUserNameById(_selectedRepairService?.inspectBy);
                                }
                                @username
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Close" IsPrimary="true" OnClick="@CloseViewDialog" />
    </DialogButtons>
</SfDialog>

@code {
    [Inject] protected NavigationManager Navigation { get; set; }

    // ── Grid ──
    private SfGrid<RepairServices> MyGrid;
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;
    private string activeBreakpoint { get; set; }
    private IEnumerable<RepairServices> filteredRepairServices2;
    private HubConnection hubConnection;
    public string[] ToolbarItems = new string[] { "ColumnChooser", "Search" };

    // ── Dialogs ──
    private SfDialog DialogView;
    private bool isViewDialogVisible = false;

    // ── Row selection ──
    private bool isRowSelected = false;
    private RepairServices _selectedRepairService;

    // ── Spare parts (for detail template only) ──
    private IEnumerable<SparePartObject> _spareParts = Enumerable.Empty<SparePartObject>();

    // ── Status change saving flag ──
    private bool isSaving = false;

    // ── Pagination ──
    private int currentPage2 = 1;
    private int pageSize2 = 10;
    private int totalPages2 = 0;
    private int totalItems2 = 0;

    // ── Search ──
    private SfTextBox InspectionSearchBox;
    private string InspectionSearchValue { get; set; }
    private System.Threading.Timer _inspectionSearchDebounceTimer;

    // ── Users ──
    private Dictionary<string, string> _allUsers = new Dictionary<string, string>();
    private bool _usersLoaded = false;

    // ─────────────────────────────────────────────────────
    // LIFECYCLE
    // ─────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        try
        {
            await LoadAllUsersAsync();
            await LoadPageData2();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading data: {ex.Message}");
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/itemHub"))
            .Build();

        hubConnection.On<string>("ReceiveItemUpdate", async (message) =>
        {
            await Cache.InvalidateManyAsync(
                CacheKeys.InspectionItem(currentPage2, pageSize2),
                CacheKeys.DashboardStats
            );
            await LoadPageData2();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<Guid>("BroadcastItemDelete", (deletedItemId) =>
        {
            filteredRepairServices2 = filteredRepairServices2
                .Where(item => item.Id != deletedItemId).ToList();
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();

        hubConnection.Closed += async (error) =>
        {
            await Task.Delay(new Random().Next(0, 5) * 1000);
            try { await hubConnection.StartAsync(); }
            catch (Exception ex) { Console.WriteLine($"Reconnection failed: {ex.Message}"); }
        };
    }
    // ─────────────────────────────────────────────────────
    // DATA LOADING
    // ─────────────────────────────────────────────────────
    private async Task LoadAllUsersAsync()
    {
        if (_usersLoaded) return;
        try
        {
            _allUsers = await GlobalUserCache.GetUsersAsync();
            _usersLoaded = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading users: {ex.Message}");
            _allUsers = new Dictionary<string, string>();
        }
    }

    private async Task LoadPageData2()
    {
        try
        {
            var result = await Cache.GetOrSetAsync(
                CacheKeys.InspectionItem(currentPage2, pageSize2),
                () => RepairItemService.SearchRepairServicesAsync(
                    pageNumber: currentPage2,
                    pageSize: pageSize2,
                    status: "Inspection",
                    sortBy: "reportNo",
                    sortDescending: true),
                TimeSpan.FromMinutes(3)
            );

            filteredRepairServices2 = result?.Items ?? new List<RepairServices>();
            totalPages2 = result?.TotalPages ?? 0;
            totalItems2 = result?.TotalCount ?? 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading page data 2: {ex.Message}");
        }
    }

    // ─────────────────────────────────────────────────────
    // PAGINATION
    // ─────────────────────────────────────────────────────
    private async Task NextPage2() { if (currentPage2 < totalPages2) { currentPage2++; await LoadPageData2(); StateHasChanged(); } }
    private async Task PreviousPage2() { if (currentPage2 > 1) { currentPage2--; await LoadPageData2(); StateHasChanged(); } }
    private async Task FirstPage2() { currentPage2 = 1; await LoadPageData2(); StateHasChanged(); }
    private async Task LastPage2() { currentPage2 = totalPages2; await LoadPageData2(); StateHasChanged(); }

    // ─────────────────────────────────────────────────────
    // HELPERS
    // ─────────────────────────────────────────────────────
    private SparePartObject GetSparePartById(Guid? sparePartId)
    {
        if (!sparePartId.HasValue || sparePartId.Value == Guid.Empty) return null;
        return _spareParts.FirstOrDefault(sp => sp.Id == sparePartId.Value);
    }

    private string GetUserNameById(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty) return "Unknown";
        if (!_usersLoaded) return "Loading...";
        return _allUsers.TryGetValue(userId.Value.ToString(), out string username) ? username : "Unknown User";
    }

    private string GetInspectionStatusBadgeClass(string status) => status switch
    {
        "Inspection" => "badge-inspection",
        "Awaiting Sparepart" => "badge-awaiting-sparepart",
        "Awaiting Customer Confirm" => "badge-awaiting-customer",
        _ => "badge-default"
    };

    // ─────────────────────────────────────────────────────
    // GRID EVENTS
    // ─────────────────────────────────────────────────────
    private void RowSelectHandler(RowSelectEventArgs<RepairServices> args)
    {
        _selectedRepairService = args.Data;
        isRowSelected = _selectedRepairService != null;
        StateHasChanged();
    }

    // ─────────────────────────────────────────────────────
    // STATUS CHANGE (inline dropdown)
    // ─────────────────────────────────────────────────────
    private async Task OnInspectionStatusChanged(RepairServices item, string newStatus)
    {
        if (string.IsNullOrEmpty(newStatus) || newStatus == item.Status) return;

        if (newStatus == "Awaiting Sparepart")
        {
            try
            {
                var currentUserId = JwtSessionService.GetCurrentUserId();
                if (!currentUserId.HasValue)
                {
                    ToastNotificationService.ShowToast(new ToastOptions
                    {
                        ProviderName = "Error",
                        Title = "Authentication Error",
                        Text = "Session expired. Please login.",
                        ThemeMode = ToastThemeMode.Pastel,
                        RenderStyle = ToastRenderStyle.Danger
                    });
                    return;
                }

                item.Status = newStatus;
                isSaving = true;
                StateHasChanged();

                if (item.SparePartItems != null && item.SparePartItems.Any())
                {
                    var holdRequest = new InspectItemRequest
                    {
                        Id = item.Id,
                        Inspection = item.Inspection ?? string.Empty,
                        Solution = item.Solution ?? string.Empty,
                        InspectBy = item.inspectBy ?? Guid.Empty,
                        ServiceTypeId = item.ServiceTypeId ?? 1,
                        SpareParts = item.SparePartItems
                            .Where(sp => sp.SparePartId.HasValue && sp.SparePartId.Value != Guid.Empty)
                            .Select(sp => new SparePart
                            {
                                Id = sp.Id,
                                SparePartId = sp.SparePartId.Value,
                                Description = sp.Description ?? string.Empty,
                                Quantity = sp.Quantity,
                                Condition = sp.Condition ?? string.Empty,
                                ServiceId = item.Id,
                                IsHoldStatus = true
                            }).ToList()
                    };
                    await InspectItemService.UpdateInspectItemAsync(item.Id, holdRequest);
                }

                await AwaitingSparePartService.SetAwaitingSparePartAsync(
                    new AwaitingSparePartRequest
                    {
                        Id = item.Id,
                        SetAwaitingSparepartBy = currentUserId.Value
                    });

                // ✅ Cache Invalidation
                await Cache.InvalidateManyAsync(
                    CacheKeys.InspectionItem(currentPage2, pageSize2),
                    CacheKeys.InspectionItem(1, pageSize2),
                    CacheKeys.AwaitSparePart(1, pageSize2),
                    CacheKeys.DashboardStats
                );

                // ✅ RabbitMQ Publish — inspection-item queue
                await MQ.PublishStatusChangeAsync(
                    MessageQueueHelper.Queues.InspectionItem,
                    "InspectionItem",
                    item.Id,
                    "Awaiting Sparepart",
                    item.reportNo,
                    currentUserId.Value
                );

                // ✅ SignalR
                if (hubConnection?.State == HubConnectionState.Connected)
                    await hubConnection.SendAsync("BroadcastItemUpdate", "StatusChanged");

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = "ដាក់ការរង់ចាំគ្រឿងបន្លាស់",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });

                filteredRepairServices2 = filteredRepairServices2.Where(x => x.Id != item.Id).ToList();
                totalItems2--;
                totalPages2 = totalItems2 > 0 ? (int)Math.Ceiling(totalItems2 / (double)pageSize2) : 0;
                isSaving = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                item.Status = "Inspection";
                isSaving = false;
                StateHasChanged();
                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Error",
                    Title = "Error",
                    Text = $"Failed: {ex.Message}",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Danger
                });
            }
        }
        else if (newStatus == "Awaiting Customer Confirm")
        {
            try
            {
                var currentUserId = JwtSessionService.GetCurrentUserId();
                if (!currentUserId.HasValue)
                {
                    ToastNotificationService.ShowToast(new ToastOptions
                    {
                        ProviderName = "Error",
                        Title = "Authentication Error",
                        Text = "Session expired. Please login.",
                        ThemeMode = ToastThemeMode.Pastel,
                        RenderStyle = ToastRenderStyle.Danger
                    });
                    return;
                }

                item.Status = newStatus;
                isSaving = true;
                StateHasChanged();

                if (item.SparePartItems != null && item.SparePartItems.Any())
                {
                    var holdRequest = new InspectItemRequest
                    {
                        Id = item.Id,
                        Inspection = item.Inspection ?? string.Empty,
                        Solution = item.Solution ?? string.Empty,
                        InspectBy = item.inspectBy ?? Guid.Empty,
                        ServiceTypeId = item.ServiceTypeId ?? 1,
                        SpareParts = item.SparePartItems
                            .Where(sp => sp.SparePartId.HasValue && sp.SparePartId.Value != Guid.Empty)
                            .Select(sp => new SparePart
                            {
                                Id = sp.Id,
                                SparePartId = sp.SparePartId.Value,
                                Description = sp.Description ?? string.Empty,
                                Quantity = sp.Quantity,
                                Condition = sp.Condition ?? string.Empty,
                                ServiceId = item.Id,
                                IsHoldStatus = true
                            }).ToList()
                    };
                    await InspectItemService.UpdateInspectItemAsync(item.Id, holdRequest);
                }

                await AwaitingCustomerConfirmService.SetAwaitingCustomerConfirmAsync(
                    new AwaitingCustomerConfirmRequest
                    {
                        Id = item.Id,
                        SetAwaitingCustomerConfirmBy = currentUserId.Value
                    });

                // ✅ Cache Invalidation
                await Cache.InvalidateManyAsync(
                    CacheKeys.InspectionItem(currentPage2, pageSize2),
                    CacheKeys.InspectionItem(1, pageSize2),
                    CacheKeys.AwaitCustomer(1, pageSize2),
                    CacheKeys.DashboardStats
                );

                // ✅ RabbitMQ Publish — inspection-item queue
                await MQ.PublishStatusChangeAsync(
                    MessageQueueHelper.Queues.InspectionItem,
                    "InspectionItem",
                    item.Id,
                    "Awaiting Customer Confirm",
                    item.reportNo,
                    currentUserId.Value
                );

                // ✅ SignalR
                if (hubConnection?.State == HubConnectionState.Connected)
                    await hubConnection.SendAsync("BroadcastItemUpdate", "StatusChanged");

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = "រង់ចាំការបញ្ជាក់ពីអតិថិជន",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });

                filteredRepairServices2 = filteredRepairServices2.Where(x => x.Id != item.Id).ToList();
                totalItems2--;
                totalPages2 = totalItems2 > 0 ? (int)Math.Ceiling(totalItems2 / (double)pageSize2) : 0;
                isSaving = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                item.Status = "Inspection";
                isSaving = false;
                StateHasChanged();
                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Error",
                    Title = "Error",
                    Text = $"Failed: {ex.Message}",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Danger
                });
            }
        }
        else if (newStatus == "Inspecting")
        {
            try
            {
                isSaving = true;
                StateHasChanged();

                await RepairItemService.MoveBackToInspectingAsync(item.Id);

                // ✅ Cache Invalidation
                await Cache.InvalidateManyAsync(
                    CacheKeys.InspectionItem(currentPage2, pageSize2),
                    CacheKeys.InspectionItem(1, pageSize2),
                    CacheKeys.InspectItem(1, pageSize2),
                    CacheKeys.DashboardStats
                );

                // ✅ RabbitMQ Publish — inspection-item queue
                var currentUserId = JwtSessionService.GetCurrentUserId();
                await MQ.PublishStatusChangeAsync(
                    MessageQueueHelper.Queues.InspectionItem,
                    "InspectionItem",
                    item.Id,
                    "Inspecting",
                    item.reportNo,
                    currentUserId
                );

                // ✅ SignalR
                if (hubConnection?.State == HubConnectionState.Connected)
                    await hubConnection.SendAsync("BroadcastItemUpdate", "ItemUpdated");

                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Customization",
                    Title = "Success",
                    Text = "វិនិច្ឆ័យម្ដងទៀត",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Success
                });

                filteredRepairServices2 = filteredRepairServices2.Where(x => x.Id != item.Id).ToList();
                totalItems2--;
                totalPages2 = totalItems2 > 0 ? (int)Math.Ceiling(totalItems2 / (double)pageSize2) : 0;
                isSaving = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                item.Status = "Inspection";
                isSaving = false;
                StateHasChanged();
                ToastNotificationService.ShowToast(new ToastOptions
                {
                    ProviderName = "Error",
                    Title = "Error",
                    Text = $"Failed: {ex.Message}",
                    ThemeMode = ToastThemeMode.Pastel,
                    RenderStyle = ToastRenderStyle.Danger
                });
            }
        }
    }

