                        AllowPdfExport="true"
                        AllowResizing="true"
                        AllowFiltering="true"
                        OnRowSelected="RowSelectHandler"
                        OnActionBegin="ActionBeginHandler">
                    <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>

                    <GridEditSettings AllowEditing="true"
                                      Mode="EditMode.Normal"
                                      ShowDeleteConfirmDialog="true">
                    </GridEditSettings>

                    <GridEvents RowSelected="RowSelectHandler"
                                OnToolbarClick="ToolbarClickHandler"
                                PdfQueryCellInfoEvent="OnPdfQueryCellInfo"
                                ExcelQueryCellInfoEvent="OnExcelQueryCellInfo"
                                TValue="SparePartObject">
                    </GridEvents>

                    <GridColumns>
                        <GridColumn Field="Id" HeaderText="ID" Width="50" IsPrimaryKey="true" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Visible="false"></GridColumn>
                        <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextImage)]" Width="100" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                            <Template>
                                @{
                                    var partInfo = (context as SparePartObject);
                                    <div class="image-head">
                                        <img src="@UriHelper.ToAbsoluteUri($"{partInfo.PictureUrl}")" alt="Spare Part Image" />
                                    </div>
                                }
                            </Template>
                        </GridColumn>

                        <GridColumn Field="ItemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="150"></GridColumn>
                        <GridColumn Field="SerialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextPartNo)]" Width="150"></GridColumn>
                        <GridColumn Field="Description" HeaderText="@Loc[nameof(ResourceStrings.textDescription)]" Width="200" Visible="false"></GridColumn>
                        <GridColumn Field="UseFor" HeaderText="@Loc[nameof(ResourceStrings.TextUsefor)]" Width="150"></GridColumn>
                        <GridColumn Field="Quantity" HeaderText="Quantity" Width="180" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                            <Template>
                                @{
                                    var sparePart = context as SparePartObject;
                                    var stockLevel = sparePart.Quantity;
                                    var stockColor = GetStockLevelColor(stockLevel);
                                    var stockStatus = GetStockStatus(stockLevel);
                                }
                                <div class="stock-level-container">
                                    <div class="stock-text-display" @onclick="@(() => StartEditQuantity(sparePart))">
                                        <span class="stock-quantity-text">@stockLevel</span>
                                        <span class="stock-status-text">@stockStatus</span>
                                    </div>

                                    @* Progress bar *@
                                    <div class="stock-progress-bar">
                                        <div class="stock-progress-fill"
                                             style="width: @GetStockProgressWidth(stockLevel)%; background-color: @stockColor">
                                        </div>
                                    </div>
                                </div>
                            </Template>
                            <EditTemplate>
                                @{
                                    var sparePart = context as SparePartObject;
                                }
                                <SfNumericTextBox @bind-Value="@sparePart.Quantity"
                                                  TValue="int"
                                                  Min="0"
                                                  Step="1"
                                                  Format="n0"
                                                  ShowSpinButton="true"
                                                  Width="100%">
                                </SfNumericTextBox>
                            </EditTemplate>
                        </GridColumn>
                        <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextBarcode)]" Width="200">
                            <Template>
                                @{
                                    var sparePart = context as SparePartObject;
                                    var serialNumber = string.IsNullOrEmpty(sparePart.SerialNumber) ? "0" : sparePart.SerialNumber;
                                }
                                <SfBarcodeGenerator Width="200px" Height="100px"
                                                    Type="@BarcodeType.Code128"
                                                    ForeColor="black"
                                                    Value="@serialNumber">
                                </SfBarcodeGenerator>
                            </Template>
                        </GridColumn>
                        @* Set Stock Action Column *@
                        <GridColumn HeaderText="SET STOCK" Width="120" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                            <Template>
                                @{
                                    var sparePart = context as SparePartObject;
                                }
                                <button type="button"
                                        class="btn-set-stock-minimal"
                                        @onclick="@(() => StartEditQuantity(sparePart))"
                                        title="Set Stock">
                                    <i class="fas fa-boxes"></i>
                                    <span>Stock In</span>
                                </button>
                            </Template>
                        </GridColumn>
                        @* បន្ថែមក្រោម SET STOCK column *@
                        <GridColumn HeaderText="STOCK OUT" Width="130" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                            <Template>
                                @{
                                    var sparePart = context as SparePartObject;
                                }
                                <button type="button"
                                        class="btn-stock-out-minimal"
                                        @onclick="@(() => StartManualStockOut(sparePart))"
                                        title="Manual Stock Out"
                                        disabled="@(sparePart.Quantity <= 0)">
                                    <i class="fas fa-minus-circle"></i>
                                    <span>Stock Out</span>
                                </button>
                            </Template>
                        </GridColumn>

                    </GridColumns>
                </SfGrid>

                <div class="card shadow-sm rounded-lg mt-3">
                    <div class="card-body">
                        <div class="pagination-controls d-flex justify-content-between align-items-center">
                            <div class="pagination-info">
                                <span>Showing @GetStartRecord() to @GetEndRecord() of @totalCount items</span>
                            </div>
                            <div class="pagination-buttons">
                                <button class="btn btn-sm btn-outline-primary" @onclick="FirstPage" disabled="@IsFirstPage()">
                                    <i class="fas fa-angle-double-left"></i> First
                                </button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="PreviousPage" disabled="@IsFirstPage()">
                                    <i class="fas fa-angle-left"></i> Previous
                                </button>
                                <span class="mx-3">Page @currentPage of @totalPages</span>
                                <button class="btn btn-sm btn-outline-primary" @onclick="NextPage" disabled="@IsLastPage()">
                                    Next <i class="fas fa-angle-right"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="LastPage" disabled="@IsLastPage()">
                                    Last <i class="fas fa-angle-double-right"></i>
                                </button>
                            </div>
                            <div class="page-size-selector">
                                <label>Items per page:</label>
                                <select class="form-select form-select-sm" @onchange="OnPageSizeChanged" style="width: 80px; display: inline-block;">
                                    <option value="5" selected="@(pageSize == 5)">5</option>
                                    <option value="10" selected="@(pageSize == 10)">10</option>
                                    <option value="20" selected="@(pageSize == 20)">20</option>
                                    <option value="50" selected="@(pageSize == 50)">50</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <SfDialog @ref="DialogDelete" IsModal="true" Width="250px" ShowCloseIcon="true" Visible="false">
                    <DialogTemplates>
                        <Header> Confirm Delete </Header>
                        <Content> @Loc[nameof(ResourceStrings.Textconfirmdelete)] </Content>
                    </DialogTemplates>
                    <DialogButtons>
                        <DialogButton Content="Delete" IsPrimary="true" OnClick="ConfirmDeleteYes" />
                        <DialogButton Content="Cancel" IsPrimary="false" OnClick="ConfirmDeleteNo" />
                    </DialogButtons>
                </SfDialog>

                <SfDialog @ref="DialogNoRecordSelected" IsModal="true" Width="250px" ShowCloseIcon="true" Visible="false">
                    <DialogTemplates>
                        <Header> Warning! </Header>
                        <Content> @Loc[nameof(ResourceStrings.TextSelectRecord)] </Content>
                    </DialogTemplates>
                    <DialogButtons>
                        <DialogButton Content="OK" IsPrimary="true" OnClick="CloseDialogNoRecordSelected" />
                    </DialogButtons>
                </SfDialog>
                @* Add this dialog after your other dialogs *@
                <SfDialog @ref="DialogQuantityEdit" IsModal="true" Width="350px" ShowCloseIcon="true" Visible="@isQuantityEditVisible">
                    <DialogTemplates>
                        <Header>Stock In</Header>
                        <Content>
                            <div class="p-3">
                                <label class="form-label">Current Quantity: @editingItem?.Quantity</label>
                                <SfNumericTextBox @bind-Value="@newQuantity"
                                                  TValue="int"
                                                  Placeholder="Enter new quantity"
                                                  Min="0"
                                                  Step="1"
                                                  Format="n0"
                                                  ShowSpinButton="true"
                                                  Width="100%">
                                </SfNumericTextBox>
                            </div>
                        </Content>
                    </DialogTemplates>
                    <DialogButtons>
                        <DialogButton Content="Update" IsPrimary="true" OnClick="UpdateQuantity" />
                        <DialogButton Content="Cancel" OnClick="CancelQuantityEdit" />
                    </DialogButtons>
                </SfDialog>
                @* Manual Stock Out Dialog *@
                <SfDialog @ref="DialogManualStockOut"
                          IsModal="true"
                          Width="420px"
                          ShowCloseIcon="true"
                          Visible="@isManualStockOutVisible">
                    <DialogTemplates>
                        <Header>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <i class="fas fa-minus-circle text-danger"></i>
                                <span>Manual Stock Out</span>
                            </div>
                        </Header>
                        <Content>
                            <div class="p-3">
                                @if (stockOutItem != null)
                                {
                                    <div class="alert alert-warning py-2 mb-3">
                                        <i class="fas fa-box"></i>
                                        <strong> @stockOutItem.ItemName</strong>
                                        &nbsp;|&nbsp; Current Stock:
                                        <strong class="@(stockOutItem.Quantity <= CRITICAL_STOCK ? "text-danger" : "text-success")">
                                            @stockOutItem.Quantity
                                        </strong>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">
                                            Quantity to Remove <span class="text-danger">*</span>
                                        </label>
                                        <SfNumericTextBox @bind-Value="@stockOutQuantity"
                                                          TValue="int"
                                                          Placeholder="Enter quantity to deduct"
                                                          Min="1"
                                                          Max="@stockOutItem.Quantity"
                                                          Step="1"
                                                          Format="n0"
                                                          ShowSpinButton="true"
                                                          Width="100%">
                                        </SfNumericTextBox>
                                        @if (stockOutQuantity > stockOutItem.Quantity)
                                        {
                                            <small class="text-danger">
                                                <i class="fas fa-exclamation-triangle"></i>
                                                Cannot exceed available stock (@stockOutItem.Quantity)
                                            </small>
                                        }
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Reason / Note</label>
                                        <SfTextArea @bind-Value="@stockOutReason"
                                                    Placeholder="e.g. Used for internal repair, damaged, lost..."
                                                    RowCount="3"
                                                    FloatLabelType="FloatLabelType.Never"
                                                    Width="100%">
                                        </SfTextArea>
                                    </div>

                                    <div class="alert alert-info py-2 mb-0" style="font-size:0.85rem;">
                                        <i class="fas fa-info-circle"></i>
                                        After deduction: <strong>@Math.Max(0, stockOutItem.Quantity - stockOutQuantity)</strong> remaining
                                    </div>
                                }
                            </div>
                        </Content>
                    </DialogTemplates>
                    <DialogButtons>
                        <DialogButton Content="Confirm Stock Out"
                                      IsPrimary="true"
                                      OnClick="ConfirmManualStockOut"
                                      Disabled="@(stockOutQuantity <= 0 || stockOutQuantity > (stockOutItem?.Quantity ?? 0))" />
                        <DialogButton Content="Cancel"
                                      OnClick="CancelManualStockOut" />
                    </DialogButtons>
                </SfDialog>
                <SfDialog IsModal="true" Width="500px" ShowCloseIcon="false" Visible="@isAddDialogVisible">
                    <DialogTemplates>
                        <Header>
                            <div class="dialog-header">
                                <h2 class="dialog-title">@pageTitle</h2>
                                @if (isEditing)
                                {
                                    <SfButton class="custom-close-btn" IconCss="fa fa-barcode" @onclick="() => PopupVisible = true">
                                        Barcode
                                    </SfButton>
                                }
                            </div>
                            <DxPopup HeaderText="Barcode Generator"
                                     Width="300px"
                                     @bind-Visible="@PopupVisible">
                                <BodyContentTemplate>
                                    <div class="popup-body-content">
                                        <SfBarcodeGenerator Width="200px" Height="100px"
                                                            Type="@BarcodeType.Code128"
                                                            ForeColor="black"
                                                            Value="@sparePart.SerialNumber"
                                                            @ref="barcodeGenerator">
