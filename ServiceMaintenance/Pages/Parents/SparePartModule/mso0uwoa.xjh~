        }
        else
        {
            int minQty = filter switch
            {
                "out" => 0,
                "low" => 1,
                "good" => LOW_STOCK + 1,
                _ => 0
            };

            int maxQty = filter switch
            {
                "out" => 0,
                "low" => LOW_STOCK,
                "good" => int.MaxValue,
                _ => int.MaxValue
            };

            // Filter the spare parts
            var allParts = await sparePartService.GetSparePartsPagedAsync(1, 10000);
            var filteredParts = allParts.Items.Where(sp =>
                sp.Quantity >= minQty && sp.Quantity <= maxQty).ToList();

            spareParts = filteredParts.Skip((currentPage - 1) * pageSize)
                                     .Take(pageSize)
                                     .ToList();
            totalCount = filteredParts.Count;

            StateHasChanged();
        }
