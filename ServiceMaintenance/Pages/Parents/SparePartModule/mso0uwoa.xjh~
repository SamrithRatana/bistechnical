    private async Task<string> GenerateSerialNumber(string itemName)
    {
        if (string.IsNullOrEmpty(itemName)) return string.Empty;

        // Split itemName into words
        var words = itemName.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

        // Determine how many characters to take for initials
        int initialLength = words.Length switch
        {
            >= 4 => 4,
            3 => 3,
            2 => 2,
            _ => 1
        };

        var initials = string.Concat(words.Take(initialLength).Select(word => word[0])).ToUpper();

        // Extract context (numeric suffix) from the last word if present
        string context = string.Empty;
        var lastWord = words.Last();
        var digitMatch = System.Text.RegularExpressions.Regex.Match(lastWord, @"\d+$");
        if (digitMatch.Success)
        {
            context = digitMatch.Value;
        }

        string prefix = initials + context;

        // USE API TO GET EXISTING SERIAL NUMBERS
        try
        {
            var existingSerials = await sparePartService.GetSerialNumbersByPrefixAsync(prefix, 100);

            if (!existingSerials.Any())
            {
                return $"{prefix}-01";
            }

            // Find the maximum serial number
            var maxSerial = existingSerials
                .Where(sn => sn.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(sn => sn)
                .FirstOrDefault();

            int nextSerialNumber = 1;
            if (!string.IsNullOrEmpty(maxSerial))
            {
                var parts = maxSerial.Split('-');
                if (parts.Length == 2 && int.TryParse(parts[1], out int lastNumber))
                {
                    nextSerialNumber = lastNumber + 1;
                }
            }

            return $"{prefix}-{nextSerialNumber:D2}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating serial number: {ex.Message}");
            return $"{prefix}-01"; // Fallback
        }
    }


