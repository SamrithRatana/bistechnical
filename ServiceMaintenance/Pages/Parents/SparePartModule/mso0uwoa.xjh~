                                    {
                                        <div class="upload-steps">
                                            <span class="upload-step-pill @StepClass(UploadStep.GettingToken)">
                                                🔑 Token
                                            </span>
                                            <span style="color:#aaa">›</span>
                                            <span class="upload-step-pill @StepClass(UploadStep.UploadingToCloud)">
