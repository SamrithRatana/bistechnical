<DxLayoutBreakpoint DeviceSize="DeviceSize.XSmall" @bind-IsActive="@isXSmallScreen" />
<hr>

@if (CanAccess)
{
    @if (CanView)
    {
        <!-- Custom Search Box -->
        <div class="card shadow-sm rounded-lg mb-3">
            <div class="card-body">
                <div class="btn-group mb-3" role="group">
                    <button type="button"
                            class="btn @(stockFilter == "all" ? "btn-primary" : "btn-outline-primary")"
                            @onclick='() => FilterByStock("all")'>
