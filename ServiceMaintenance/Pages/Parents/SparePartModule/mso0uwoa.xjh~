    private async Task ProcessAndSaveImage()
    {
        if (pendingImageFile == null) return;

        KoompiUploadResult result;

        // Show reading status immediately
        uploadStatus = UploadStatusInfo.Reading();
        StateHasChanged();

        if (!string.IsNullOrEmpty(pendingImagePreviewUrl) &&
            pendingImagePreviewUrl.StartsWith("data:image"))
        {
            // Use cropped / filtered preview
            var (bytes, contentType, fileName) =
                ImageUploadHelper.ReadDataUrl(pendingImagePreviewUrl);

            result = await KoompiStorage.UploadAsync(
                bytes, fileName, contentType,
                async info =>
                {
                    uploadStatus = info;
                    await InvokeAsync(StateHasChanged);
                });
        }
        else
        {
            // Validate first
            if (!ImageUploadHelper.IsValidImageType(pendingImageFile))
                throw new Exception("Invalid image type.");

            if (!ImageUploadHelper.IsWithinSizeLimit(pendingImageFile))
                throw new Exception("File exceeds 5 MB limit.");

            var (bytes, contentType, fileName) =
                await ImageUploadHelper.ReadBrowserFileAsync(pendingImageFile);

            result = await KoompiStorage.UploadAsync(
                bytes, fileName, contentType,
                async info =>
                {
                    uploadStatus = info;
                    await InvokeAsync(StateHasChanged);
                });
        }

        if (!result.Success)
            throw new Exception(result.ErrorMessage);

        sparePart.PictureUrl = result.PublicUrl;
        pendingImageFile = null;
        pendingImagePreviewUrl = null;

        // Keep "success" visible briefly, then reset
        await Task.Delay(1500);
        uploadStatus = UploadStatusInfo.Idle();
    }

    // Simplified image resizing method for Docker compatibility
    private Image ResizeImageForDocker(Image originalImage, int targetWidth, int targetHeight)
    {
        try
        {
            var resizedBitmap = new Bitmap(targetWidth, targetHeight);

            using (var graphics = Graphics.FromImage(resizedBitmap))
            {
                // Use basic quality settings for Docker compatibility
                graphics.CompositingQuality = System.Drawing.Drawing2D.CompositingQuality.HighSpeed;
                graphics.InterpolationMode = System.Drawing.Drawing2D.InterpolationMode.Low;
                graphics.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.HighSpeed;

                // Simple resize without complex cropping
                graphics.DrawImage(originalImage, 0, 0, targetWidth, targetHeight);
            }

            return resizedBitmap;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Image resize failed: {ex.Message}");
            // Return original image if resize fails
            return new Bitmap(originalImage);
        }
    }
    private Image CropAndResizeImage(Image originalImage, int targetWidth, int targetHeight)
    {
        // Calculate the aspect ratios
        double originalAspect = (double)originalImage.Width / originalImage.Height;
        double targetAspect = (double)targetWidth / targetHeight;

        int cropWidth, cropHeight, cropX, cropY;

        if (originalAspect > targetAspect)
        {
            // Original is wider, crop from sides
            cropHeight = originalImage.Height;
            cropWidth = (int)(cropHeight * targetAspect);
            cropX = (originalImage.Width - cropWidth) / 2;
            cropY = 0;
        }
        else
        {
            // Original is taller, crop from top/bottom
            cropWidth = originalImage.Width;
            cropHeight = (int)(cropWidth / targetAspect);
            cropX = 0;
            cropY = (originalImage.Height - cropHeight) / 2;
        }

        // Create the cropped image
        var cropRectangle = new Rectangle(cropX, cropY, cropWidth, cropHeight);
        var croppedBitmap = new Bitmap(targetWidth, targetHeight);

        using (var graphics = Graphics.FromImage(croppedBitmap))
        {
            // Set high quality settings for better image quality
            graphics.CompositingQuality = System.Drawing.Drawing2D.CompositingQuality.HighQuality;
            graphics.InterpolationMode = System.Drawing.Drawing2D.InterpolationMode.HighQualityBicubic;
            graphics.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.HighQuality;

            // Draw the cropped and resized image
            graphics.DrawImage(originalImage,
                new Rectangle(0, 0, targetWidth, targetHeight),
                cropRectangle,
                GraphicsUnit.Pixel);
        }

        return croppedBitmap;
    }

