                            <div style="min-height: 250px;"></div>
                        </DxLoadingPanel>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm rounded-lg mb-3">
                    <div class="card-body">
                        <h5 class="mb-3">
                            <i class="fas fa-chart-bar"></i> Stock Overview
                        </h5>
                        <div class="row">
                            <div class="col-md-3 col-6 mb-3">
                                <div class="stock-summary-card out-of-stock">
                                    <div class="stock-summary-icon">
                                        <i class="fas fa-exclamation-triangle"></i>
                                    </div>
                                    <div class="stock-summary-details">
                                        <h3>@GetStockCount(0, 0)</h3>
                                        <p>Out of Stock</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3 col-6 mb-3">
                                <div class="stock-summary-card critical-stock">
                                    <div class="stock-summary-icon">
                                        <i class="fas fa-exclamation-circle"></i>
                                    </div>
                                    <div class="stock-summary-details">
                                        <h3>@GetStockCount(1, CRITICAL_STOCK)</h3>
                                        <p>Critical (≤@CRITICAL_STOCK)</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3 col-6 mb-3">
                                <div class="stock-summary-card low-stock">
                                    <div class="stock-summary-icon">
                                        <i class="fas fa-info-circle"></i>
                                    </div>
                                    <div class="stock-summary-details">
                                        <h3>@GetStockCount(CRITICAL_STOCK + 1, LOW_STOCK)</h3>
                                        <p>Low (@(CRITICAL_STOCK + 1)-@LOW_STOCK)</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3 col-6 mb-3">
                                <div class="stock-summary-card good-stock">
                                    <div class="stock-summary-icon">
                                        <i class="fas fa-check-circle"></i>
                                    </div>
                                    <div class="stock-summary-details">
                                        <h3>@GetStockCount(LOW_STOCK + 1, int.MaxValue)</h3>
                                        <p>Good Stock (>@LOW_STOCK)</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>nth
                </div>

                <SfGrid @ref="MyGrid"
