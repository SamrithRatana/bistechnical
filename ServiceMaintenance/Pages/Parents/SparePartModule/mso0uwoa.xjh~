    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        // Validate file type
        var allowedTypes = new[] { "image/jpeg", "image/jpg", "image/png", "image/gif", "image/webp" };
        var fileExtension = Path.GetExtension(file.Name).ToLower();
        var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp" };

        if (!allowedTypes.Contains(file.ContentType.ToLower()) &&
            !allowedExtensions.Contains(fileExtension))
        {
            ShowErrorToast("Please select a valid image file (JPEG, PNG, GIF, or WebP)");
            return;
        }

        // Validate file size (max 5MB)
        const int maxFileSize = 5 * 1024 * 1024;
        if (file.Size > maxFileSize)
        {
            ShowErrorToast("File size must be less than 5MB");
            return;
        }

        try
        {
            pendingImageFile = file;
            indicatorVisible = true;
            StateHasChanged();

            // FIXED: Added maxAllowedSize parameter
            using var stream = file.OpenReadStream(maxAllowedSize: maxFileSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            try
            {
                using var image = Image.FromStream(memoryStream);
                using var previewImage = ResizeImageForPreview(image, 300, 200);
                using var outputStream = new MemoryStream();

                // Save with proper JPEG encoder settings
                var jpegEncoder = GetEncoder(ImageFormat.Jpeg);
                var encoderParams = new EncoderParameters(1);
                encoderParams.Param[0] = new EncoderParameter(
                    System.Drawing.Imaging.Encoder.Quality, 85L);

                previewImage.Save(outputStream, jpegEncoder, encoderParams);
                var base64String = Convert.ToBase64String(outputStream.ToArray());
                pendingImagePreviewUrl = $"data:image/jpeg;base64,{base64String}";
            }
            catch (Exception imgEx)
            {
                Console.WriteLine($"Image processing error: {imgEx.Message}");

                // Fallback: Create base64 from original stream
                memoryStream.Position = 0;
                var bytes = memoryStream.ToArray();
                var base64String = Convert.ToBase64String(bytes);
                var mimeType = file.ContentType;
                pendingImagePreviewUrl = $"data:{mimeType};base64,{base64String}";
            }

            indicatorVisible = false;
            StateHasChanged();

            // Optional: Auto-open cropper on mobile
            if (isXSmallScreen)
            {
                await Task.Delay(300);
                await OpenCropperModal();
            }
        }
        catch (Exception ex)
        {
            indicatorVisible = false;
            Console.WriteLine($"Error loading image: {ex.Message}");
            ShowErrorToast($"Error loading image: {ex.Message}");
            pendingImageFile = null;
            pendingImagePreviewUrl = null;
            StateHasChanged();
        }
    }

    // Helper method to get JPEG encoder
    private ImageCodecInfo GetEncoder(ImageFormat format)
    {
        ImageCodecInfo[] codecs = ImageCodecInfo.GetImageDecoders();
        foreach (ImageCodecInfo codec in codecs)
        {
            if (codec.FormatID == format.Guid)
                return codec;
        }
        return null;
    }

    // Improved ResizeImageForPreview
    private Image ResizeImageForPreview(Image originalImage, int maxWidth, int maxHeight)
    {
        if (originalImage == null)
            throw new ArgumentNullException(nameof(originalImage));

        var ratioX = (double)maxWidth / originalImage.Width;
        var ratioY = (double)maxHeight / originalImage.Height;
        var ratio = Math.Min(ratioX, ratioY);

        var newWidth = (int)(originalImage.Width * ratio);
        var newHeight = (int)(originalImage.Height * ratio);

        var resizedBitmap = new Bitmap(newWidth, newHeight);

        using (var graphics = Graphics.FromImage(resizedBitmap))
        {
            graphics.CompositingQuality = System.Drawing.Drawing2D.CompositingQuality.HighQuality;
            graphics.InterpolationMode = System.Drawing.Drawing2D.InterpolationMode.HighQualityBicubic;
            graphics.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.HighQuality;
            graphics.PixelOffsetMode = System.Drawing.Drawing2D.PixelOffsetMode.HighQuality;

            graphics.DrawImage(originalImage, 0, 0, newWidth, newHeight);
        }

        return resizedBitmap;
    }

