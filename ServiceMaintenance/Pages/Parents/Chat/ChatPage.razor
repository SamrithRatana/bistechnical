            await JS.InvokeVoidAsync("alert", "Failed to delete message. Please try again.");
        }
    }

    // ✅ FIXED: File upload validation
    private async Task UploadAsync(InputFileChangeEventArgs e)
    {
        if (e.File == null) return;

        try
        {
            // Validate file size
            if (e.File.Size > MaxFileSize)
            {
                await JS.InvokeVoidAsync("alert", $"File size exceeds {MaxFileSize / 1024 / 1024}MB limit");
                return;
            }

            // Validate file type
            var extension = Path.GetExtension(e.File.Name).ToLowerInvariant();
            var isImage = AllowedImageExtensions.Contains(extension);
            var isAudio = AllowedAudioExtensions.Contains(extension);

            if (!isImage && !isAudio && extension != ".pdf" && extension != ".doc" && extension != ".docx")
            {
                await JS.InvokeVoidAsync("alert", "File type not allowed");
                return;
            }

            Logger.LogInformation("Uploading file: {FileName} ({Size} bytes)", e.File.Name, e.File.Size);

            var content = new MultipartFormDataContent();
            var fileStream = e.File.OpenReadStream(MaxFileSize);
            content.Add(new StreamContent(fileStream), "file", e.File.Name);

            var client = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            var response = await client.PostAsync("api/fileupload/upload", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<FileResult>();
                
                if (result != null && !string.IsNullOrEmpty(result.Url))
                {
                    // Send message with file attachment
                    await MsgSvc.SaveMessageAsync(new Message
                    {
                        UserID = _userId,
                        RecipientID = _recipientId,
                        Text = $"[File: {e.File.Name}]",
                        FileUrl = result.Url,
                        UserName = _userName,
                        When = DateTime.UtcNow
                    });

                    await RefreshAsync();
                    Logger.LogInformation("File uploaded successfully: {Url}", result.Url);
                }
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Failed to upload file");
                Logger.LogWarning("File upload failed: {StatusCode}", response.StatusCode);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading file");
            await JS.InvokeVoidAsync("alert", "Error uploading file. Please try again.");
        }
    }

    private void Reply(ChatMsg m)
    {
        _replyMsg = m;
        _replying = true;
    }

    private void CancelReply()
    {
        _replyMsg = null;
        _replying = false;
    }

    private async Task KeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendAsync();
        }
    }

    // ✅ FIXED: Optimized with single lookup
    // ✅ UPDATED: Use ProfilePictureUrl from API
    private string GetPic(string uid)
    {
        if (string.IsNullOrEmpty(uid))
            return "/images/default.png";

        if (_picCache.TryGetValue(uid, out var cached))
            return cached;

        var user = _users.FirstOrDefault(u => u.Id == uid);

        // Priority 1: Use ProfilePictureUrl from API
        if (!string.IsNullOrEmpty(user?.ProfilePictureUrl))
        {
            return _picCache[uid] = user.ProfilePictureUrl;
        }

        // Priority 2: Use ProfilePicture byte array (legacy)
        if (user?.ProfilePicture?.Length > 0)
        {
            var pic = $"data:image/png;base64,{Convert.ToBase64String(user.ProfilePicture)}";
            return _picCache[uid] = pic;
        }

        // Priority 3: Default image
        return _picCache[uid] = "/images/default.png";
    }

    private int GetUnreadCount(string senderId)
    {
        if (string.IsNullOrEmpty(senderId))
            return 0;

        return _unread.GetValueOrDefault(senderId.Trim(), 0);
    }

    private string GetLastMsg(string uid) =>
        _lastMsgs.TryGetValue(uid, out var m) ? TruncateText(m.Text, 50) : "No messages";

    private string GetLastTime(string uid)
    {
        if (!_lastMsgs.TryGetValue(uid, out var m))
            return "";

        var local = m.When.ToLocalTime();
        return local.Date == DateTime.Now.Date
            ? local.ToString("h:mm tt")
            : local.ToString("MMM d");
    }

    private string GetStatus(string uid) =>
        _users.FirstOrDefault(u => u.Id == uid)?.IsOnline == true ? "Online" : "Offline";

    // ✅ FIXED: Extension-based checks
    private bool IsImg(string url)
    {
        if (string.IsNullOrEmpty(url)) return false;
        var ext = Path.GetExtension(url).ToLowerInvariant();
        return AllowedImageExtensions.Contains(ext);
    }

    private bool IsAudio(string url)
    {
        if (string.IsNullOrEmpty(url)) return false;
        var ext = Path.GetExtension(url).ToLowerInvariant();
        return AllowedAudioExtensions.Contains(ext);
    }

    private bool IsReqMsg(string txt)
    {
        if (string.IsNullOrEmpty(txt)) return false;
        var decoded = System.Net.WebUtility.HtmlDecode(txt);
        return decoded.Contains("Request Edit", StringComparison.OrdinalIgnoreCase) ||
               decoded.Contains("Request Delete", StringComparison.OrdinalIgnoreCase);
    }

    private string GetReqAction(string txt)
    {
        if (string.IsNullOrEmpty(txt)) return null;
        var decoded = System.Net.WebUtility.HtmlDecode(txt);
        if (decoded.Contains("Request Edit", StringComparison.OrdinalIgnoreCase)) return "Edit";
        if (decoded.Contains("Request Delete", StringComparison.OrdinalIgnoreCase)) return "Delete";
        return null;
    }

    private Guid? GetServiceId(string txt)
    {
        if (string.IsNullOrWhiteSpace(txt)) return null;
        var decoded = System.Net.WebUtility.HtmlDecode(txt);
        var match = System.Text.RegularExpressions.Regex.Match(decoded,
            @"[0-9a-fA-F]{8}\-[0-9a-fA-F]{4}\-[0-9a-fA-F]{4}\-[0-9a-fA-F]{4}\-[0-9a-fA-F]{12}");
        return match.Success && Guid.TryParse(match.Value, out var g) ? g : null;
    }

    private string GetReportNo(string txt)
    {
        if (string.IsNullOrWhiteSpace(txt)) return "Unknown";
        var decoded = System.Net.WebUtility.HtmlDecode(txt);
        var match = System.Text.RegularExpressions.Regex.Match(decoded, @"ReportNo[:\s]*([0-9A-Za-z\-_]+)");
        return match.Success ? match.Groups[1].Value : "Unknown";
    }

    // ✅ NEW: HTML sanitization helper
    private string SanitizeHtml(string html)
    {
        if (string.IsNullOrEmpty(html))
            return string.Empty;

        // Basic HTML sanitization - in production, use a library like HtmlSanitizer
        return html;
    }

    private string TruncateText(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text ?? "";

        return text.Substring(0, maxLength) + "...";
    }

    private async Task EditReqAsync(ChatMsg m)
    {
        try
        {
            _reqMsg = m;
            var svcId = GetServiceId(m.Text);
            if (!svcId.HasValue) return;

            var reportNo = GetReportNo(m.Text);

            var svc = await RepairSvc.GetRepairServiceByIdAsync(svcId.Value);
            if (svc == null)
            {
                await JS.InvokeVoidAsync("alert", "Service not found");
                return;
            }

            _editService = svc;
            _showEdit = true;

            // ✅ Delete all request messages with this ReportNo (for all admins)
            await DeleteMessagesByReportNoAsync(reportNo);

            Logger.LogInformation($"✅ Opening edit for {reportNo} and clearing request messages");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading service for edit");
            await JS.InvokeVoidAsync("alert", "Failed to load service");
        }
    }
    private async Task DelReqAsync(ChatMsg m)
    {
        try
        {
            var svcId = GetServiceId(m.Text);
            if (!svcId.HasValue) return;

            var reportNo = GetReportNo(m.Text);
            var confirm = await JS.InvokeAsync<bool>("confirm",
                $"Delete service {reportNo}?\n\nThis cannot be undone.");
            if (!confirm) return;

            // Optimistic UI update
            _msgs.Remove(m);
            if (_msgGrid != null)
            {
                await _msgGrid.Refresh();
            }

            // Delete service
            await RepairSvc.DeleteRepairServiceAsync(svcId.Value);

            // ✅ Delete all request messages with this ReportNo (for all admins)
            await DeleteMessagesByReportNoAsync(reportNo);

            Logger.LogInformation($"✅ Service {reportNo} deleted and all request messages cleared");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting service request");
            await JS.InvokeVoidAsync("alert", "Failed to delete service");
            await RefreshAsync();
        }
    }

    private async Task CancelReqAsync(ChatMsg m)
    {
        try
        {
            var reportNo = GetReportNo(m.Text);
            var action = GetReqAction(m.Text);
            var confirm = await JS.InvokeAsync<bool>("confirm",
                $"Cancel {action} request for {reportNo}?");
            if (!confirm) return;

            // Remove from UI
            _msgs.Remove(m);
            if (_msgGrid != null)
            {
                await _msgGrid.Refresh();
            }

            // ✅ Delete all request messages with this ReportNo (for all admins)
            await DeleteMessagesByReportNoAsync(reportNo);

            Logger.LogInformation($"✅ Cancelled {action} request for {reportNo} and cleared all request messages");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cancelling request");
            await JS.InvokeVoidAsync("alert", "Failed to cancel request");
        }
    }

    private async Task OnEditCompleteAsync()
    {
        try
        {
            var currentReqMsg = _reqMsg;
            if (currentReqMsg == null)
            {
                _editService = null;
                return;
            }

            var reportNo = GetReportNo(currentReqMsg.Text);

            _editService = null;
            _reqMsg = null;

            // ✅ Delete all request messages with this ReportNo (for all admins)
            await DeleteMessagesByReportNoAsync(reportNo);

            Logger.LogInformation($"✅ Service {reportNo} updated and all request messages cleared");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error completing edit");
        }
    }
    private void Reload() => Nav.NavigateTo(Nav.Uri, true);

    // ✅ FIXED: Proper async disposal
    public async ValueTask DisposeAsync()
    {
        Logger.LogInformation("Chat page disposing");

        _cts?.Cancel();
        _cts?.Dispose();

        _autoRefreshTimer?.Dispose();
        _searchDebounceTimer?.Dispose();
        _refreshLock?.Dispose();

        await Task.CompletedTask;
    }

