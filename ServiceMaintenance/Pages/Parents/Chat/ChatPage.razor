            Logger.LogInformation("Refresh completed");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during refresh");
        }
        finally
        {
            _refreshing = false;
            _refreshLock.Release();
        }
    }

    private void SetupAutoRefresh()
