        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this message?");
            if (!confirmed) return;

            await MsgSvc.DeleteMessageAsync(m.Id);

            _msgs.Remove(m);

            if (_msgGrid != null)
            {
                await _msgGrid.Refresh();
            }

            Logger.LogInformation("Message {MessageId} deleted", m.Id);
        }
