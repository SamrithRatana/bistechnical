@page "/upload"

<h3>Upload Image</h3>

<InputFile OnChange="HandleFileSelected" accept="image/*" />

@if (!string.IsNullOrEmpty(uploadStatus))
{
    <p style="color: @statusColor"><b>@uploadStatus</b></p>
}

@if (!string.IsNullOrEmpty(uploadedUrl))
{
    <p>✅ URL: <a href="@uploadedUrl" target="_blank">@uploadedUrl</a></p>
    <img src="@uploadedUrl" style="max-width: 300px; margin-top: 10px;" />
}

@if (!string.IsNullOrEmpty(errorDetail))
{
    <pre style="color:red; background:#fff0f0; padding:10px; font-size:12px">@errorDetail</pre>
}

@code {
    private string uploadStatus = "";
    private string statusColor = "black";
    private string uploadedUrl = "";
    private string errorDetail = "";

    private const string ApiBase = "https://api-kconsole.koompi.cloud";
    private const string ApiKey = "sk_699fa29e4b2a75874a633742_yMbVmC5zpaYNF5pmwwTiExt89VBb3kFE";

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedUrl = "";
        errorDetail = "";
        statusColor = "orange";

        var file = e.File;
        if (file == null)
        {
            SetStatus("❌ No file selected.", "red");
            return;
        }

        SetStatus($"📁 File selected: {file.Name} ({file.Size} bytes)", "orange");

        try
        {
            // ── STEP A: Get Upload Token ──────────────────────────
            SetStatus("🔑 Getting upload token...", "orange");

            using var apiClient = new HttpClient();
            apiClient.DefaultRequestHeaders.Add("x-api-key", ApiKey);

            var tokenPayload = new
            {
                filename = file.Name,
                contentType = file.ContentType,
                size = file.Size,
                visibility = "public"
            };

            var tokenRes = await apiClient.PostAsJsonAsync($"{ApiBase}/api/storage/upload-token", tokenPayload);
            var tokenRaw = await tokenRes.Content.ReadAsStringAsync();

            if (!tokenRes.IsSuccessStatusCode)
                throw new Exception($"Token API {tokenRes.StatusCode}: {tokenRaw}");

            var tokenData = System.Text.Json.JsonSerializer.Deserialize<TokenResponse>(
                tokenRaw,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }
            );

            if (tokenData?.Success != true || tokenData.Data == null)
                throw new Exception($"Token response invalid: {tokenRaw}");

            SetStatus("⬆️ Uploading to cloud...", "orange");

            // ── STEP B: PUT Binary to R2 ──────────────────────────
            var buffer = new byte[file.Size];
            await using var stream = file.OpenReadStream(maxAllowedSize: 52_428_800); // 50MB max
            int totalRead = 0;
            while (totalRead < buffer.Length)
            {
                int read = await stream.ReadAsync(buffer, totalRead, buffer.Length - totalRead);
                if (read == 0) break;
                totalRead += read;
            }

            using var putClient = new HttpClient();
            using var byteContent = new ByteArrayContent(buffer, 0, totalRead);
            byteContent.Headers.ContentType =
      new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            byteContent.Headers.TryAddWithoutValidation("Cache-Control", "public, max-age=31536000");

            var putRes = await putClient.PutAsync(tokenData.Data.UploadUrl, byteContent);
            var putRaw = await putRes.Content.ReadAsStringAsync();

            if (!putRes.IsSuccessStatusCode)
                throw new Exception($"R2 PUT {putRes.StatusCode}: {putRaw}");

            // ── STEP C: Confirm Upload ────────────────────────────
            SetStatus("✅ Confirming upload...", "orange");

            var completeRes = await apiClient.PostAsJsonAsync(
                $"{ApiBase}/api/storage/complete",
                new { objectId = tokenData.Data.ObjectId }
            );
            var completeRaw = await completeRes.Content.ReadAsStringAsync();

            if (!completeRes.IsSuccessStatusCode)
                throw new Exception($"Complete API {completeRes.StatusCode}: {completeRaw}");

            uploadedUrl = $"https://storage.koompi.cloud/{tokenData.Data.Key}";
            SetStatus("🎉 Upload successful!", "green");
        }
        catch (Exception ex)
        {
            SetStatus("❌ Upload failed!", "red");
            errorDetail = ex.Message;
        }

        StateHasChanged();
    }

    private void SetStatus(string msg, string color)
    {
        uploadStatus = msg;
        statusColor = color;
        StateHasChanged();
    }

    // ── Models ────────────────────────────────────────────────────
    class TokenResponse
    {
        public bool Success { get; set; }
        public TokenData? Data { get; set; }
    }
    class TokenData
    {
        public string UploadUrl { get; set; } = "";
        public string ObjectId { get; set; } = "";
        public string Key { get; set; } = "";
    }
}