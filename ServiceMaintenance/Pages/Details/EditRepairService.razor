    // Customer search methods (keep as is)
    private void OnCustomerSearchInput(ChangeEventArgs e)
    {
        customerSearchTerm = e.Value.ToString();
        _customerSearchDebounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(customerSearchTerm) || customerSearchTerm.Length < 2)
        {
            _ = Task.Run(async () =>
            {
                await InvokeAsync(async () =>
                {
                    var initialResult = await CustomerService.GetCustomersPaginatedAsync(pageNumber: 1, pageSize: 10);
                    _customers = initialResult.Data;
                    IsCustomerDropdownVisible = false;
                    StateHasChanged();
                });
            });
            return;
        }

        _customerSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    var searchResult = await CustomerService.GetCustomersPaginatedAsync(
                        pageNumber: 1,
                        pageSize: 20,
                        searchTerm: customerSearchTerm
                    );

                    _customers = searchResult.Data;
                    IsCustomerDropdownVisible = _customers.Any();
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error in customer search: {ex.Message}");
            }
        }, null, 300, Timeout.Infinite);
    }

