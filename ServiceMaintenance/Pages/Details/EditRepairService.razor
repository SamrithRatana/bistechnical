    private async Task<Guid> ResolveCustomerId(string companyName)
    {
        try
        {
            Console.WriteLine($"🔍 Searching for customer: '{companyName}'");

            var searchResult = await CustomerService.GetCustomersPaginatedAsync(
                pageNumber: 1,
                pageSize: 100,
                searchTerm: companyName,
                isActive: null
            );

            if (searchResult?.Data != null && searchResult.Data.Any())
            {
                var customer = searchResult.Data.FirstOrDefault(c =>
                    c.CompanyName?.Trim().Equals(companyName.Trim(), StringComparison.OrdinalIgnoreCase) == true);

                if (customer != null)
                {
                    Console.WriteLine($"✅ Found exact match: {customer.Id}");
                    return customer.Id;
                }

                customer = searchResult.Data.FirstOrDefault(c =>
                    c.CompanyName?.Trim().Contains(companyName.Trim(), StringComparison.OrdinalIgnoreCase) == true);

                if (customer != null)
                {
                    Console.WriteLine($"✅ Found partial match: {customer.Id}");
                    return customer.Id;
                }
            }

            Console.WriteLine($"❌ Customer not found");
            return Guid.Empty;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Customer lookup error: {ex.Message}");
            return Guid.Empty;
        }
    }

    private async Task<Guid> ResolveItemId(string serialNumber)
    {
        try
        {
            Console.WriteLine($"🔍 Searching for item: '{serialNumber}'");

            var searchResult = await ItemService.SearchItemsAsync(
                pageNumber: 1,
                pageSize: 100,
                searchTerm: serialNumber,
                sortBy: "SerialNumber",
                sortDescending: false
            );

            if (searchResult?.Items != null && searchResult.Items.Any())
            {
                var item = searchResult.Items.FirstOrDefault(i =>
                    i.SerialNumber?.Trim().Equals(serialNumber.Trim(), StringComparison.OrdinalIgnoreCase) == true);

                if (item != null)
                {
                    Console.WriteLine($"✅ Found exact match: {item.Id}");
                    return item.Id;
                }
            }
            Console.WriteLine($"❌ Item not found");
            return Guid.Empty;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Item lookup error: {ex.Message}");
            return Guid.Empty;
        }
    }

    // ✅ REPLACE THE EXISTING HandleSubmit METHOD IN EditRepairServiceModal.razor WITH THIS:

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        successMessage = string.Empty;
        errorMessage = string.Empty;
        warningMessage = string.Empty;

        try
        {
            Console.WriteLine("=== SUBMITTING REPAIR SERVICE UPDATE ===");

            // ✅ VALIDATION
            if (EditModel.ServiceTypeId == 0)
            {
                errorMessage = "Please select a Service Type.";
                return;
            }

            if (EditModel.ServicePriorityId == 0)
            {
                errorMessage = "Please select a Service Priority.";
                return;
            }

            if (EditModel.StatusId == 0)
            {
                errorMessage = "Please select a Status.";
                return;
            }

            // =========================================================
            // ✅ CALL 1: PUT /api/technicalservices
            // Updates: companyName, customerId, address, contactName,
            //          phoneNumber, statusId, servicePriorityId,
            //          serviceLocation, serviceDate, customerRequest,
            //          hasContract, reportNo, itemId, spareparts
            // =========================================================
            var fullServiceUpdate = new RepairServices
            {
                Id = EditModel.Id,
                CustomerId = EditModel.CustomerId,
                CompanyName = EditModel.CompanyName,
                Address = EditModel.Address,
                ContactName = EditModel.ContactName,
                PhoneNumber = EditModel.PhoneNumber,
                itemId = EditModel.ItemId,
                reportNo = EditModel.ReportNo,
                ServiceDate = EditModel.ServiceDate,
                CustomerRequest = EditModel.CustomerRequest,
                Inspection = EditModel.Inspection,
                Solution = EditModel.Solution,
                ServiceLocation = EditModel.ServiceLocation,
                ServiceTypeId = EditModel.ServiceTypeId,        // ✅ int? in RepairServices
                ServicePriorityId = EditModel.ServicePriorityId, // ✅ int in RepairServices
                StatusId = EditModel.StatusId,                   // ✅ int in RepairServices
                hasContract = EditModel.HasContract,
                SparePartItems = EditModel.SparePartItems?
         .Where(sp => sp.SparePartId.HasValue && sp.SparePartId.Value != Guid.Empty)
         .Select(sp => new SparePartItem
         {
             Id = sp.Id,
             SparePartId = sp.SparePartId.Value,
             Description = sp.Description ?? string.Empty,
             Quantity = sp.Quantity,
             Condition = sp.Condition ?? string.Empty
         }).ToList() ?? new List<SparePartItem>()
            };

            Console.WriteLine($"📡 Calling UpdateRepairServiceAsync for service: {EditModel.Id}");
            await RepairItemService.UpdateRepairServiceAsync(fullServiceUpdate);
            Console.WriteLine("✅ Full service update successful (customer/status/priority saved)");

            // =========================================================
            // ✅ CALL 2: POST /api/inspectitem
            // Updates: inspection, solution, serviceTypeId, spareparts
            // (also triggers stock deduction logic on the backend)
            // =========================================================
            var inspectRequest = new InspectItemRequest
            {
                Id = EditModel.Id,
                Inspection = EditModel.Inspection,
                Solution = EditModel.Solution,
                ServiceTypeId = EditModel.ServiceTypeId
            };

            if (EditModel.SparePartItems != null && EditModel.SparePartItems.Any())
            {
                inspectRequest.SpareParts = EditModel.SparePartItems
                    .Where(sp => sp.SparePartId.HasValue && sp.SparePartId.Value != Guid.Empty)
                    .Select(sp => new SparePart
                    {
                        Id = sp.Id,
                        SparePartId = sp.SparePartId.Value,
                        Description = sp.Description ?? string.Empty,
                        Quantity = sp.Quantity,
                        Condition = sp.Condition ?? string.Empty,
                        ServiceId = EditModel.Id
                    })
                    .ToList();

                Console.WriteLine($"📦 Submitting {inspectRequest.SpareParts.Count} spare parts to inspect API:");
                foreach (var sp in inspectRequest.SpareParts)
                {
                    Console.WriteLine($"   - Item ID: {sp.Id}, Spare Part ID: {sp.SparePartId}, Qty: {sp.Quantity}");
                }
            }
            else
            {
                inspectRequest.SpareParts = new List<SparePart>();
            }

            Console.WriteLine($"📡 Calling UpdateInspectItemAsync for service: {EditModel.Id}");
            await InspectItemService.UpdateInspectItemAsync(EditModel.Id, inspectRequest);
            Console.WriteLine("✅ Inspect update successful - stock triggers executed");

            // =========================================================
            // ✅ CALL 3: Apply status-specific BIS service
            // =========================================================
            if (EditModel.StatusId > 0)
            {
                await ApplyStatusServiceAsync(EditModel.StatusId, EditModel.Id, EditModel.ReportNo);
            }

            // ✅ IMMEDIATE UI FEEDBACK
            successMessage = "Service updated successfully!";

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Customization",
                Title = "Success",
                Text = "Service updated successfully",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Success
            });

            await Task.Delay(1500);

            // ✅ BACKGROUND TASKS
            _ = Task.Run(async () =>
            {
                try
                {
                    if (!string.IsNullOrEmpty(EditModel.ReportNo))
                    {
                        await StateManagementAction.UpdateNotificationVisibility(EditModel.ReportNo, false);
                        Console.WriteLine("✅ Notification visibility updated");
                    }

                    await OnServiceUpdated.InvokeAsync();
                    Console.WriteLine("✅ Parent grid refreshed");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Background task error: {ex.Message}");
                }
            });

            // ✅ CLOSE MODAL
            await CloseModal();
        }
        catch (HttpRequestException httpEx)
        {
            var fullError = httpEx.Message;
            Console.WriteLine($"❌ HTTP Error: {fullError}");

            string displayMessage = "An error occurred while saving.";

            try
            {
                if (fullError.Contains("Insufficient stock"))
                {
                    var match = System.Text.RegularExpressions.Regex.Match(
                        fullError,
                        @"Insufficient stock for: ([^.]+)\.\s*Available: (\d+),\s*Required: (\d+)"
                    );

                    if (match.Success)
                    {
                        displayMessage = $"Insufficient stock for: {match.Groups[1].Value}. " +
                                         $"Available: {match.Groups[2].Value}, Required: {match.Groups[3].Value}";
                    }
                    else
                    {
                        var lines = fullError.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
                        var stockLine = lines.FirstOrDefault(l => l.Contains("Insufficient stock") && !l.Contains("Exception"));
                        displayMessage = stockLine?.Trim() ?? "Insufficient stock. Please check inventory.";
                    }
                }
                else if (fullError.Contains("status") || fullError.Contains("Status"))
                {
                    displayMessage = $"Failed to apply status: {fullError}";
                }
            }
            catch (Exception parseEx)
            {
                Console.WriteLine($"⚠️ Parse error: {parseEx.Message}");
            }

            errorMessage = displayMessage;

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = displayMessage,
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Save error: {ex.Message}");
            errorMessage = $"Update failed: {ex.Message}";

            ToastNotificationService.ShowToast(new ToastOptions
            {
                ProviderName = "Error",
                Title = "Error",
                Text = $"Failed to save: {ex.Message}",
                ThemeMode = ToastThemeMode.Pastel,
                RenderStyle = ToastRenderStyle.Danger
            });
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task CloseModal()
    {
        ShowModal = false;
        successMessage = string.Empty;
        errorMessage = string.Empty;
        warningMessage = string.Empty;
        customerSearchTerm = string.Empty;
        IsCustomerDropdownVisible = false;
        filteredSpareParts.Clear(); // ✅ Clear spare parts when closing
        _customerSearchDebounceTimer?.Dispose();
        _sparePartSearchDebounceTimer?.Dispose();
        await ShowModalChanged.InvokeAsync(false);
    }
    // ✅ ADD THESE HELPER METHODS FOR STOCK DISPLAY (add at the end of your @code block)
    private string GetStockColorForCombo(int quantity)
    {
        if (quantity <= 0) return "#dc3545"; // Red - Out of stock
        if (quantity <= 5) return "#ff6b6b";  // Light Red - Critical
        if (quantity <= 10) return "#ffc107"; // Yellow - Low
        return "#28a745"; // Green - Good
    }

    private string GetStockIconForCombo(int quantity)
    {
        if (quantity <= 0) return "fas fa-exclamation-triangle";
        if (quantity <= 5) return "fas fa-exclamation-circle";
        if (quantity <= 10) return "fas fa-info-circle";
        return "fas fa-check-circle";
    }

    private string GetStockTextForCombo(int quantity)
    {
        if (quantity <= 0) return "OUT OF STOCK";
        if (quantity <= 5) return "CRITICAL";
        if (quantity <= 10) return "LOW STOCK";
        return "IN STOCK";
    }
