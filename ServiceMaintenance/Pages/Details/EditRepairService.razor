        <div class="row">
            <div class="col-md-4">
                <img src="@selectedSparePartForView?.PictureUrl" alt="@selectedSparePartForView?.ItemName" 
                     style="width: 100%; height: auto; border-radius: 8px; object-fit: cover;" />
            </div>
            <div class="col-md-8">
                <div style="margin-top: 10px;">
                    <p><strong>Item Name:</strong> @selectedSparePartForView?.ItemName</p>
                    <p><strong>Serial Number:</strong> @selectedSparePartForView?.SerialNumber</p>
                    <p><strong>Description:</strong></p>
                    <p class="description-text">@selectedSparePartForView?.Description</p>
                    <p><strong>Use For:</strong> @selectedSparePartForView?.UseFor</p>
