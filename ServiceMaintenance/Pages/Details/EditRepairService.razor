                    <button type="button" class="btn btn-primary" @onclick="CloseSparePartDialog">Close</button>
                </div>
            </div>
        </div>
    </div>
</SfDialog>

@code {
    [Parameter] public bool ShowModal { get; set; }
    [Parameter] public EventCallback<bool> ShowModalChanged { get; set; }
    [Parameter] public RepairServices ServiceToEdit { get; set; }
    [Parameter] public EventCallback OnServiceUpdated { get; set; }

    private RepairServiceEditModel EditModel { get; set; }
    private List<ServiceType> serviceTypes = new();
    private List<ServicePriority> servicePriorities = new();
    private List<ServiceStatus> serviceStatuses = new();
    private bool isSubmitting = false;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;
    private string warningMessage = string.Empty;

    private List<SparePartObject> filteredSpareParts = new();
    private bool isSparePartLoading = false;
    private System.Threading.Timer _sparePartSearchDebounceTimer;
    private List<string> _repairConditions = new List<string> { "Fix", "Replace", "Free" };
    private bool isSparePartDialogVisible = false;
    private SparePartObject selectedSparePartForView;
    
    // Customer search variables
    private string customerSearchTerm = string.Empty;
    private bool IsCustomerDropdownVisible { get; set; } = false;
    private IEnumerable<Customer> _customers = new List<Customer>();
    private System.Threading.Timer _customerSearchDebounceTimer;

    private IEnumerable<Customer> FilteredCustomers => _customers;

    protected override async Task OnParametersSetAsync()
    {
        if (ShowModal)
        {
            if (ServiceToEdit == null)
            {
                errorMessage = "No service selected for editing.";
                return;
            }

            await LoadDropdownData();
            await LoadInitialCustomers();
            // ✅ DON'T load spare parts here - only load when needed
            await LoadEditModel();
        }
    }

    private async Task LoadDropdownData()
    {
        try
        {
            serviceTypes = (await RepairItemService.GetServiceTypesAsync())?.ToList() ?? new();
            servicePriorities = (await RepairItemService.GetServicePrioritiesAsync())?.ToList() ?? new();
            serviceStatuses = (await RepairItemService.GetServiceStatusesAsync())?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dropdown data: {ex.Message}");
            errorMessage = "Failed to load form options. Please try again.";
        }
    }

    private async Task LoadInitialCustomers()
    {
        try
        {
            var customerResult = await CustomerService.GetCustomersPaginatedAsync(pageNumber: 1, pageSize: 10);
            _customers = customerResult.Data;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading initial customers: {ex.Message}");
        }
    }

    private async Task LoadEditModel()
    {
        try
        {
            errorMessage = string.Empty;
            warningMessage = string.Empty;

            if (ServiceToEdit == null)
            {
                errorMessage = "Service data is missing.";
                Console.WriteLine("❌ ServiceToEdit is null in LoadEditModel");
                return;
            }

            Console.WriteLine($"🔍 Loading service: {ServiceToEdit.Id}");

            var fullService = await RepairItemService.GetRepairServiceByIdAsync(ServiceToEdit.Id);

            if (fullService == null)
            {
                errorMessage = "Service not found in database.";
                Console.WriteLine($"❌ GetRepairServiceByIdAsync returned null for ID: {ServiceToEdit.Id}");
                return;
            }

            Console.WriteLine($"✅ Service loaded: {fullService.reportNo}");

            var customerId = fullService.CustomerId;
            var itemId = fullService.itemId;

            if (customerId == Guid.Empty && !string.IsNullOrWhiteSpace(fullService.CompanyName))
            {
                customerId = await ResolveCustomerId(fullService.CompanyName.Trim());
            }

            if (itemId == Guid.Empty && !string.IsNullOrWhiteSpace(fullService.serialNumber))
            {
                itemId = await ResolveItemId(fullService.serialNumber.Trim());
            }

            var warnings = new List<string>();
            if (customerId == Guid.Empty)
            {
                warnings.Add($"Customer '{fullService.CompanyName}' not found");
            }
            if (itemId == Guid.Empty)
            {
                warnings.Add($"Item '{fullService.serialNumber}' not found");
            }

            if (warnings.Any())
            {
                warningMessage = $"{string.Join(". ", warnings)}. The update may fail if these IDs are required.";
            }

            EditModel = new RepairServiceEditModel
            {
                Id = fullService.Id,
                CustomerId = customerId,
                CompanyName = fullService.CompanyName,
                Address = fullService.Address,
                ContactName = fullService.ContactName,
                PhoneNumber = fullService.PhoneNumber,
                ItemId = itemId,
                ReportNo = fullService.reportNo,
                ServiceDate = fullService.ServiceDate,
                CustomerRequest = fullService.CustomerRequest,
                Inspection = fullService.Inspection,
                Solution = fullService.Solution,
                ServiceLocation = fullService.ServiceLocation,
                HasContract = fullService.hasContract,
                ServiceTypeId = serviceTypes.FirstOrDefault(t => t.Name == fullService.ServiceType)?.Id ?? 0,
                ServicePriorityId = servicePriorities.FirstOrDefault(p => p.Name == fullService.ServicePriority)?.Id ?? 0,
                StatusId = serviceStatuses.FirstOrDefault(s => s.Name == fullService.Status)?.Id ?? 0,
                SparePartItems = fullService.SparePartItems?.Select(sp => new SparePartEditModel
                {
                    Id = sp.Id, // ✅ ADD THIS LINE
                    SparePartId = sp.SparePartId,
                    Description = sp.Description ?? string.Empty,
                    Quantity = sp.Quantity,
                    Condition = sp.Condition ?? string.Empty
                }).ToList() ?? new()
            };

            // ✅ OPTIMIZED: Only load spare parts that are already selected
            await LoadSelectedSparePartsOnly(EditModel.SparePartItems);

            customerSearchTerm = fullService.CompanyName ?? string.Empty;

            Console.WriteLine($"✅ EditModel ready - CustomerId: {EditModel.CustomerId}, ItemId: {EditModel.ItemId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex.Message}");
            errorMessage = $"Failed to load service: {ex.Message}";
        }
    }

    // ✅ NEW: Only load selected spare parts by their IDs
    private async Task LoadSelectedSparePartsOnly(List<SparePartEditModel> spareParts)
    {
        try
        {
            filteredSpareParts.Clear();

            if (spareParts == null || !spareParts.Any())
            {
                Console.WriteLine("📦 No spare parts to load");
                return;
            }

            var sparePartIds = spareParts
                .Where(sp => sp.SparePartId.HasValue && sp.SparePartId.Value != Guid.Empty)
                .Select(sp => sp.SparePartId.Value)
                .Distinct()
                .ToList();

            if (!sparePartIds.Any())
            {
                Console.WriteLine("📦 No valid spare part IDs found");
                return;
            }

            Console.WriteLine($"🔍 Loading {sparePartIds.Count} spare parts by ID...");

            // ✅ Load only the specific spare parts by ID
            foreach (var sparePartId in sparePartIds)
            {
                try
                {
                    var sparePart = await SparePartService.GetSparePartByIdAsync(sparePartId);
                    if (sparePart != null)
                    {
                        filteredSpareParts.Add(sparePart);
                        Console.WriteLine($"✅ Loaded spare part: {sparePart.ItemName} (ID: {sparePartId})");
                    }
                    else
                    {
                        Console.WriteLine($"⚠️ Spare part not found: {sparePartId}");
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"❌ Error loading spare part {sparePartId}: {ex.Message}");
                }
            }

            Console.WriteLine($"✅ Total spare parts loaded: {filteredSpareParts.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in LoadSelectedSparePartsOnly: {ex.Message}");
            filteredSpareParts.Clear();
        }
    }

    private void AddSparePart()
    {
        if (EditModel.SparePartItems == null)
            EditModel.SparePartItems = new();

        EditModel.SparePartItems.Add(new SparePartEditModel
        {
            Id = Guid.Empty, // ✅ ADD THIS - Indicates new item
            SparePartId = null,
            Quantity = 0,
            Description = string.Empty,
            Condition = string.Empty
        });

        StateHasChanged();
    }

    private void RemoveSparePart(SparePartEditModel sparePart)
    {
        EditModel.SparePartItems?.Remove(sparePart);
    }

    // ✅ OPTIMIZED: Only search when user types
    private async Task OnFilteringSparePart(Syncfusion.Blazor.DropDowns.FilteringEventArgs args)
    {
        args.PreventDefaultAction = true;

        _sparePartSearchDebounceTimer?.Dispose();

        // ✅ Show loading state
        isSparePartLoading = true;
        StateHasChanged();

        // ✅ If search is empty, only show currently selected items
        if (string.IsNullOrWhiteSpace(args.Text))
        {
            isSparePartLoading = false;
            // Keep currently selected items in the list
            await EnsureSelectedSparePartsInFilteredList();
            StateHasChanged();
            return;
        }

        // ✅ Debounce: wait 300ms before searching
        _sparePartSearchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    Console.WriteLine($"🔍 Searching spare parts: '{args.Text}'");

                    // ✅ Search with the user's term
                    var searchResult = await SparePartService.SearchSparePartsAsync(
                        pageNumber: 1,
                        pageSize: 50, // Limit results to 50
                        searchTerm: args.Text.Trim()
                    );

                    Console.WriteLine($"📊 Search returned {searchResult.Items.Count} results");

                    filteredSpareParts = searchResult.Items.ToList();

                    // ✅ Ensure selected items remain in the list
                    await EnsureSelectedSparePartsInFilteredList();

                    isSparePartLoading = false;
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ Error in spare part search: {ex.Message}");
                isSparePartLoading = false;
                StateHasChanged();
            }
        }, null, 300, Timeout.Infinite);
    }

    // ✅ Ensure selected spare parts are always in the dropdown
    private async Task EnsureSelectedSparePartsInFilteredList()
    {
        if (EditModel.SparePartItems == null || !EditModel.SparePartItems.Any())
            return;

        var selectedIds = EditModel.SparePartItems
            .Where(sp => sp.SparePartId.HasValue && sp.SparePartId.Value != Guid.Empty)
            .Select(sp => sp.SparePartId.Value)
            .ToList();

        foreach (var selectedId in selectedIds)
        {
            // ✅ If selected item is not in filtered list, fetch it
            if (!filteredSpareParts.Any(sp => sp.Id == selectedId))
            {
                try
                {
                    Console.WriteLine($"🔍 Fetching missing selected spare part: {selectedId}");
                    var selectedSparePart = await SparePartService.GetSparePartByIdAsync(selectedId);
                    if (selectedSparePart != null)
                    {
                        filteredSpareParts.Insert(0, selectedSparePart);
                        Console.WriteLine($"✅ Added selected spare part to dropdown: {selectedSparePart.ItemName}");
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"❌ Error fetching spare part {selectedId}: {ex.Message}");
                }
            }
        }
    }
    private async Task ApplyStatusServiceAsync(int statusId, Guid serviceId, string reportNo)
    {
        var statusName = serviceStatuses.FirstOrDefault(s => s.Id == statusId)?.Name ?? string.Empty;
        var normalizedStatus = statusName.Trim().ToLower();

        Console.WriteLine($"🔄 Applying status service for: '{statusName}' (ID: {statusId})");

        // ✅ Get current user ID (same as await-customer Save() method)
        Guid currentUserId = Guid.Empty;
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity.IsAuthenticated)
            {
                var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userIdClaim) && Guid.TryParse(userIdClaim, out Guid parsedGuid))
                {
                    currentUserId = parsedGuid;
                    Console.WriteLine($"✅ Current user ID: {currentUserId}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ Could not get user ID: {ex.Message}");
        }

        try
        {
            switch (normalizedStatus)
            {
                case "awaiting customer confirmation":
                case "awaiting customer confirm":
                    await AwaitingCustomerConfirmService.SetAwaitingCustomerConfirmAsync(
                        new AwaitingCustomerConfirmRequest
                        {
                            Id = serviceId,                              // ✅ Use Id (not ServiceId)
                            SetAwaitingCustomerConfirmBy = currentUserId // ✅ Set who confirmed
                        });
                    Console.WriteLine("✅ AwaitingCustomerConfirm applied");
                    break;

                case "customer rejected":
                    await CustomerRejectedService.SetCustomerRejectedAsync(
                        new CustomerRejectedRequest
                        {
                            Id = serviceId,
                            SetCustomerRejectedBy = currentUserId
                        });
                    Console.WriteLine("✅ CustomerRejected applied");
                    break;

                case "awaiting spare part":
                case "awaiting sparepart":
                    await AwaitingSparePartService.SetAwaitingSparePartAsync(
                        new AwaitingSparePartRequest
                        {
                            Id = serviceId,
                            SetAwaitingSparepartBy = currentUserId
                        });
                    Console.WriteLine("✅ AwaitingSparePart applied");
                    break;

                case "third party repair":
                    await ThirdPartyRepairService.SetThirdPartyRepairAsync(
                        new ThirdPartyRepairRequest
                        {
                            Id = serviceId,
                            ThirdPartyRepairBy = currentUserId
                        });
                    Console.WriteLine("✅ ThirdPartyRepair applied");
                    break;

                case "unrepairable":
                    await UnrepairableService.SetUnrepairableAsync(
                        new UnrepairableRequest
                        {
                            Id = serviceId,
                            SetUnrepairableBy = currentUserId
                        });
                    Console.WriteLine("✅ Unrepairable applied");
                    break;

                default:
                    Console.WriteLine($"ℹ️ No BIS service mapped for status: '{statusName}' — skipping");
                    break;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"⚠️ Status service error for '{statusName}': {ex.Message}");
            throw;
        }
    }
