    private async Task PrintReport()
    {
        try
        {
            if (!filteredServices.Any())
            {
                await JSRuntime.InvokeVoidAsync("alert", "No data to print. Please adjust your filters.");
                return;
            }

            Console.WriteLine("=== STARTING PRINT REPORT ===");
            Console.WriteLine($"Filtered services count: {filteredServices.Count()}");

            // Create the report instance
            var report = new ServiceMaintenance.Pages.Reports.RentalAll();

            // Get current user name
            string currentUserName = await GetCurrentUserName();

            Console.WriteLine("Setting report data source...");

            // Set the data source using the simplified method
            report.SetDataSource(
                filteredServices,
                rentalItemLookup,
                userLookup,
                sparePartLookup,
                StartDate,
                EndDate,
                FilterUserId,
                currentUserName
            );

            Console.WriteLine("Exporting report to PDF...");

            byte[] reportBytes;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportBytes = ms.ToArray();
            }

            // Convert byte array to base64 string for JavaScript
            string base64Report = Convert.ToBase64String(reportBytes);

            // Use the existing blazorReportsPrint.printReport function
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.printReport", base64Report, "RentalServicesReport.pdf");

            Console.WriteLine("Print report completed successfully");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR in PrintReport: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");

            // Show user-friendly error message
            await JSRuntime.InvokeVoidAsync("alert", $"Error generating report: {ex.Message}");
        }
    }

