@page "/users-management/roles/{UserId}"
@using ServiceMaintenance.Services
@inject JwtUserManagementService UserManagementService
@inject NavigationManager NavigationManager
@attribute [Authorize(Roles = "SuperAdmin")]

<div class="manage-roles-container">
    <div class="page-header">
        <div>
            <h2 class="page-title">Manage User Roles</h2>
            <p class="page-subtitle">Assign and manage roles for user access control</p>
        </div>
        <button class="btn btn-secondary" @onclick="GoBack">
            ← Back to Users
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner"></div>
            <p>Loading user roles...</p>
        </div>
    }
    else if (userRoles == null)
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> Unable to load user roles
        </div>
        <button class="btn btn-secondary" @onclick="GoBack">Go Back</button>
    }
    else
    {
        @if (!string.IsNullOrEmpty(messageText))
        {
            <div class="alert @(messageType == "success" ? "alert-success" : "alert-danger")">
                @messageText
                <button class="btn-close-alert" @onclick="@(() => messageText = null)">×</button>
            </div>
        }

        <!-- User Info Card -->
        <div class="user-info-card">
            <div class="user-info-header">
                <div class="user-avatar">
                    <span>@GetInitials(userRoles.UserName)</span>
                </div>
                <div class="user-details">
                    <h3>@userRoles.UserName</h3>
                    <p class="user-id">User ID: @userRoles.UserId</p>
                </div>
            </div>
        </div>

        <!-- Roles Management Card -->
        <div class="roles-card">
            <div class="card-header">
                <h4>Available Roles</h4>
                <p>Select the roles you want to assign to this user</p>
            </div>

            <div class="roles-grid">
                @foreach (var role in userRoles.Roles)
                {
                    <div class="role-item @(role.IsAssigned ? "role-assigned" : "")">
                        <div class="role-checkbox-container">
                            <input type="checkbox"
                                   id="role-@role.Id"
                                   checked="@role.IsAssigned"
                                   @onchange="@(e => ToggleRole(role, (bool)e.Value))" />
                            <label for="role-@role.Id">
                                <span class="role-icon">@GetRoleIcon(role.Name)</span>
                                <div class="role-info">
                                    <span class="role-name">@role.Name</span>
                                    <span class="role-description">@GetRoleDescription(role.Name)</span>
                                </div>
                            </label>
                        </div>
                        @if (role.IsAssigned)
                        {
                            <span class="assigned-badge">✓ Assigned</span>
                        }
                    </div>
                }
            </div>

            <!-- Summary -->
            <div class="roles-summary">
                <div class="summary-item">
                    <span class="summary-label">Total Roles:</span>
                    <span class="summary-value">@userRoles.Roles.Count</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Assigned:</span>
                    <span class="summary-value assigned">@selectedRoles.Count</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Unassigned:</span>
                    <span class="summary-value">@(userRoles.Roles.Count - selectedRoles.Count)</span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="form-actions">
                <button class="btn btn-primary" @onclick="SaveRoles" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-small"></span>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>💾 Save Changes</span>
                    }
                </button>
                <button class="btn btn-secondary" @onclick="ResetChanges" disabled="@isSubmitting">
                    Reset
                </button>
                <button class="btn btn-outline" @onclick="GoBack" disabled="@isSubmitting">
                    Cancel
                </button>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions-card">
            <h4>Quick Actions</h4>
            <div class="quick-actions-grid">
                <button class="quick-action-btn" @onclick="SelectAllRoles" disabled="@isSubmitting">
                    <span class="action-icon">✓</span>
                    <span>Select All</span>
                </button>
                <button class="quick-action-btn" @onclick="DeselectAllRoles" disabled="@isSubmitting">
                    <span class="action-icon">✗</span>
                    <span>Deselect All</span>
                </button>
            </div>
        </div>
    }
</div>

