@code {
    [Parameter]
    public string UserId { get; set; }

    private UserRolesDto userRoles;
    private List<string> selectedRoles = new();
    private List<string> originalRoles = new();
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string messageText;
    private string messageType;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserRoles();
    }

    private async Task LoadUserRoles()
    {
        isLoading = true;

        var response = await UserManagementService.GetUserRolesAsync(UserId);

        if (response.Status == "Success" && response.Data != null)
        {
            userRoles = response.Data;

            // Initialize selected roles
            selectedRoles = userRoles.Roles
                .Where(r => r.IsAssigned)
                .Select(r => r.Name)
                .ToList();

            originalRoles = new List<string>(selectedRoles);
        }
        else
        {
            ShowMessage(response.Message ?? "Failed to load user roles", "error");
        }

        isLoading = false;
    }

    private void ToggleRole(RoleAssignmentDto role, bool isChecked)
    {
        role.IsAssigned = isChecked;

        if (isChecked && !selectedRoles.Contains(role.Name))
        {
            selectedRoles.Add(role.Name);
        }
        else if (!isChecked && selectedRoles.Contains(role.Name))
        {
            selectedRoles.Remove(role.Name);
        }

        StateHasChanged();
    }

    private async Task SaveRoles()
    {
        isSubmitting = true;
        messageText = null;

        try
        {
            var response = await UserManagementService.UpdateUserRolesAsync(UserId, selectedRoles);

            if (response.Status == "Success")
            {
                ShowMessage("Roles updated successfully", "success");
                originalRoles = new List<string>(selectedRoles);
            }
            else
            {
                ShowMessage(response.Message, "error");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}", "error");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ResetChanges()
    {
        selectedRoles = new List<string>(originalRoles);

        foreach (var role in userRoles.Roles)
        {
            role.IsAssigned = originalRoles.Contains(role.Name);
        }

        messageText = null;
        StateHasChanged();
    }

    private void SelectAllRoles()
    {
        foreach (var role in userRoles.Roles)
        {
            role.IsAssigned = true;
        }
        selectedRoles = userRoles.Roles.Select(r => r.Name).ToList();
        StateHasChanged();
    }

    private void DeselectAllRoles()
    {
        foreach (var role in userRoles.Roles)
        {
            role.IsAssigned = false;
        }
        selectedRoles.Clear();
        StateHasChanged();
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/users");
    }

    private void ShowMessage(string message, string type)
    {
        messageText = message;
        messageType = type;
        StateHasChanged();
    }

    private string GetInitials(string userName)
    {
        if (string.IsNullOrWhiteSpace(userName))
            return "U";

        var parts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();

        return userName.Length >= 2
            ? userName.Substring(0, 2).ToUpper()
            : userName[0].ToString().ToUpper();
    }

    private string GetRoleIcon(string roleName)
    {
        return roleName?.ToLower() switch
        {
            "admin" => "👑",
            "manager" => "📊",
            "user" => "👤",
            _ => "🔑"
        };
    }

    private string GetRoleDescription(string roleName)
    {
        return roleName?.ToLower() switch
        {
            "admin" => "Full system access and user management",
            "manager" => "Team management and reporting access",
            "user" => "Standard user access to the system",
            _ => "Custom role with specific permissions"
        };
    }
}