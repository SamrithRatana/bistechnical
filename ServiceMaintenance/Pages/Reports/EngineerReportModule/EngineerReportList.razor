@page "/engineer-report"
@using DXApplication1
@using ServiceMaintenance.Models
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@inject RepairItemService RepairService
@inject GlobalUserService UserCacheService
@inject IJSRuntime JSRuntime
@inject ServiceSparePart SparePartService
@inject CustomerService CustomerService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inherits PermissionBase
@if (CanAccess)
{
    <DxToastProvider Name="Customization"
                     MaxToastCount="5"
                     HorizontalAlignment="HorizontalAlignment.Right"
                     VerticalAlignment="VerticalEdge.Top"
                     AnimationType="@Animation" />

    <div class="card shadow-sm rounded-lg">
        <div class="card-body">
            <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                    <Items>
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ShowReportPreview2" IconCssClass="fas fa-file-pdf" />
                    </Items>
                </DxToolbarItem>
                <DxToolbarItem Text="Print Report" Click="ShowReportPreview" CssClass="toolbar-item" IconCssClass="fas fa-print" />
            </DxToolbar>
        </div>
    </div>
    <hr />

    <div class="container">
        <div class="row mb-3">
            <div class="col-md-12 text-end">
                <i class="fa @(IsFilterSectionVisible ? "fa-chevron-up" : "fa-chevron-down")"
                   @onclick="ToggleFilterSection"
                   style="cursor: pointer; font-size: 20px; color: #333;">
                </i>
            </div>
        </div>

        <div class="filter-section container" style="@($"display: {(IsFilterSectionVisible ? "block" : "none")};")">
            <!-- First Row -->
            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="font-weight-bold">Filter By:</label>
                    <SfDropDownList TItem="FilterModeOption" TValue="int"
                                    DataSource="@FilterModeOptions"
                                    @bind-Value="FilterMode"
                                    class="form-control">
                        <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
                    </SfDropDownList>
                </div>
                <div class="col-md-2">
                    <label class="font-weight-bold">@Loc[nameof(ResourceStrings.TextServiceLocation)]:</label>
                    <SfDropDownList TItem="string" TValue="string"
                                    DataSource="@ServiceLocationOptions"
                                    @bind-Value="SelectedServiceLocation"
                                    Placeholder="Select Location"
                                    class="form-control">
                    </SfDropDownList>
                </div>

                <!-- ✅ NEW: Service Type filter -->
                <div class="col-md-2">
                    <label class="font-weight-bold">Service Type:</label>
                    <SfDropDownList TItem="string" TValue="string"
                                    DataSource="@(new List<string> { "All" }.Concat(ServiceTypeOptions.Select(x => x.Name)).ToList())"
                                    @bind-Value="SelectedServiceType"
                                    Placeholder="Select Type"
                                    class="form-control">
                    </SfDropDownList>
                </div>

                <div class="col-md-2">
                    <label for="filterType" class="font-weight-bold">
                        @Loc[nameof(ResourceStrings.TextSearch)]
                    </label>
                    <InputSelect @bind-Value="FilterType" id="filterType" class="form-control">
                        <option value="1">@Loc[nameof(ResourceStrings.Textsingledate)]</option>
                        <option value="2">@Loc[nameof(ResourceStrings.Textdaterange)]</option>
                        <option value="3">@Loc[nameof(ResourceStrings.TextCompanyName)]</option>
                    </InputSelect>
                </div>

                @if (FilterType == 1)
                {
                    <div class="col-md-3">
                        <label for="filterDate" class="font-weight-bold">@Loc[nameof(ResourceStrings.Textfinddate)]:</label>
                        <SfDatePicker @bind-Value="SelectedDate" id="filterDate" class="form-control" Format="dd/MM/yyyy" />
                    </div>
                }
                else if (FilterType == 2)
                {
                    <div class="col-md-3">
                        <label for="filterStartDate" class="font-weight-bold">@Loc[nameof(ResourceStrings.Textfrom)]:</label>
                        <SfDatePicker @bind-Value="StartDate" id="filterStartDate" class="form-control" Format="dd/MM/yyyy" />
                    </div>
                    <div class="col-md-3">
                        <label for="filterEndDate" class="font-weight-bold">@Loc[nameof(ResourceStrings.TextTo)]:</label>
                        <SfDatePicker @bind-Value="EndDate" id="filterEndDate" class="form-control" Format="dd/MM/yyyy" />
                    </div>
                }
                else if (FilterType == 3)
                {
                    <div class="col-md-3">
                        <label for="companyNameFilter" class="font-weight-bold">
                            @Loc[nameof(ResourceStrings.TextCompanyName)]:
                        </label>
                        <div class="form-item" style="display: flex; flex-direction: column; align-items: flex-start;">
                            <input type="text" @bind="searchTerm"
                                   @oninput="OnSearchTermInput"
                                   @onclick="OnInputClick"
                                   @onblur="OnInputBlur"
                                   placeholder="Search by company..."
                                   class="form-control"
                                   style="height: 35px; font-size: 14px;" />
                            @if (IsDropdownVisible && FilteredCustomers.Any())
                            {
                                <div class="custom-dropdown" style="position: absolute; width: 300px; max-height: 300px; overflow-y: auto; border: 1px solid #ccc; background-color: white; z-index: 1000; margin-top: 35px;">
                                    <div style="display: flex; justify-content: space-between; padding: 5px;">
                                        <span @onclick="CloseDropdown"><strong>Click (x) to close</strong></span>
                                        <button class="btn btn-sm btn-link" @onclick="CloseDropdown" style="font-size: 14px; color: red;">X</button>
                                    </div>
                                    @foreach (var company in FilteredCustomers)
                                    {
                                        <div class="dropdown-item" @onclick="() => OnCompanySelect(company)">
                                            @company.CompanyName
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Second Row -->
            <!-- Second Row -->
            <div class="row mb-3 align-items-end">
                <div class="col-md-2">
                    <label for="statusFilter" class="font-weight-bold">@Loc[nameof(ResourceStrings.TextStatus)]:</label>
                    <SfMultiSelect TItem="ServiceStatusViewModel" TValue="string[]"
                                   Width="100%"
                                   Placeholder="Select Statuses"
                                   ShowSelectAll="true"
                                   Mode="VisualMode.CheckBox"
                                   DataSource="@StatusList"
                                   @bind-Value="SelectedStatuses">
                        <MultiSelectFieldSettings Text="DisplayName" Value="Value"></MultiSelectFieldSettings>
                    </SfMultiSelect>
                </div>

                <div class="col-md-2">
                    <label for="reportTypeFilter" class="font-weight-bold">Report Type:</label>
                    <SfDropDownList TItem="ReportTypeOption" TValue="int"
                                    DataSource="@ReportTypeOptions"
                                    @bind-Value="SelectedReportType"
                                    class="form-control">
                        <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
                    </SfDropDownList>
                </div>

                <div class="col-md-2">
                    <label class="font-weight-bold">Repair By (Engineer):</label>
                    <SfMultiSelect TItem="UserViewModel" TValue="string[]"
                                   Width="100%"
                                   Placeholder="Select Engineers"
                                   ShowSelectAll="true"
                                   Mode="VisualMode.CheckBox"
                                   DataSource="@UserList"
                                   @bind-Value="SelectedUsers">
                        <MultiSelectFieldSettings Text="UserName" Value="Id"></MultiSelectFieldSettings>
                    </SfMultiSelect>
                </div>

                <div class="col-md-2">
                    <label class="font-weight-bold">Report Options:</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="engReportOptions" id="engStandard"
                               value="standard"
                               checked="@(ReportMode == "standard")"
                               @onchange="@(() => ReportMode = "standard")">
                        <label class="form-check-label" for="engStandard">Standard Report</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="engReportOptions" id="engAlwaysCreated"
                               value="alwayscreated"
                               checked="@(ReportMode == "alwayscreated")"
                               @onchange="@(() => ReportMode = "alwayscreated")">
                        <label class="form-check-label" for="engAlwaysCreated">Always Created (ServiceDate)</label>
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="font-weight-bold">Filter Options:</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="engFilterByCustomerType"
                               @bind="FilterByCustomerType"
                               @bind:after="() => { if (!FilterByCustomerType) SelectedCustomerType = string.Empty; }">
                        <label class="form-check-label" for="engFilterByCustomerType">Customer Type</label>
                    </div>
                    @if (FilterByCustomerType)
                    {
                        <SfDropDownList TItem="CustomerService.CustomerTypeDto"
                                        TValue="string"
                                        DataSource="@_customerTypes"
                                        @bind-Value="SelectedCustomerType"
                                        Placeholder="All Types"
                                        AllowFiltering="true"
                                        class="form-control mt-1">
                            <DropDownListFieldSettings Text="Type" Value="Type"></DropDownListFieldSettings>
                        </SfDropDownList>
                        @if (!string.IsNullOrEmpty(SelectedCustomerType))
                        {
                            <small class="text-muted" style="cursor:pointer;"
                                   @onclick="() => SelectedCustomerType = string.Empty">
                                <i class="fas fa-times-circle"></i> Clear
                            </small>
                        }
                    }
                </div>

                <div class="col-md-2 d-flex flex-column">
                    <button class="btn btn-primary"
                            style="white-space: nowrap;"
                            @onclick="FetchReport"
                            disabled="@(IsLoading || SelectedStatuses == null || !SelectedStatuses.Any())">
                        @if (IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @Loc[nameof(ResourceStrings.TextFetchReport)]
                    </button>
                    @if (SelectedStatuses == null || !SelectedStatuses.Any())
                    {
                        <small class="text-danger mt-1" style="white-space: nowrap;">
                            <i class="fas fa-exclamation-circle"></i> Please select at least one status.
                        </small>
                    }
                </div>
            </div>
        </div>
    </div>

    <hr />

    @if (IsLoading)
    {
        <div class="text-center p-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading data...</p>
        </div>
    }
    else if (!HasFetchedData)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Please select filter criteria and click "Fetch Report" to load data.
        </div>
    }
    else if (FilteredRepairServices.Count == 0)
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> No data available for the selected criteria.
        </div>
    }
    else
    {
        <div class="mb-3">
            <small class="text-muted">
                Total: @FilteredRepairServices.Count record(s)
            </small>
        </div>

        <SfGrid @ref="MyGrid" DataSource="FilteredRepairServices"
                AllowPaging="true"
                AllowSorting="true"
                ShowColumnChooser="true"
                AllowExcelExport="true"
                AllowPdfExport="true"
                SelectionMode="GridSelectionMode.Single"
                Toolbar="@ToolbarItems"
                AllowResizing="true"
                AllowFiltering="true"
                Height="500"
                AllowSelection="true">

            <GridPageSettings PageSize="10" PageSizes="new int[] { 10, 25, 50, 100, 200 }"></GridPageSettings>
            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
            <GridEvents RowSelected="RowSelectHandler" OnRecordDoubleClick="RowDoubleClickHandler" TValue="RepairServices"></GridEvents>

            <GridColumns>
                <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="120"></GridColumn>
                <GridColumn Field="ServiceDate" HeaderText="@Loc[nameof(ResourceStrings.TextReceiveDate)]" Format="d" Width="120"></GridColumn>
                <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" Width="200"></GridColumn>
                <GridColumn Field="Address" HeaderText="@Loc[nameof(ResourceStrings.TextAddress)]" Width="250"></GridColumn>
                <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="150"></GridColumn>
                <GridColumn Field="SparePartExcelSummary" HeaderText="Sparepart Items" Width="250" Visible="true"></GridColumn>
                <GridColumn Field="ContactName" HeaderText="@Loc[nameof(ResourceStrings.TextContactName)]" Width="150"></GridColumn>
                <GridColumn Field="PhoneNumber" HeaderText="@Loc[nameof(ResourceStrings.TextPhoneNumber)]" Width="150"></GridColumn>
                <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="150" Visible="false"></GridColumn>
                <!-- ✅ NEW: Service Type column -->
                <GridColumn Field="ServiceType" HeaderText="Service Type" Width="130" Visible="true"></GridColumn>
                <GridColumn Field="repairBy" HeaderText="@Loc[nameof(ResourceStrings.TextRepairBy)]" Width="150">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.repairBy);
                        }
                        @username
                    </Template>
                </GridColumn>
                <GridColumn Field="verifiedBy" HeaderText="@Loc[nameof(ResourceStrings.TextVerifyBy)]" Width="150">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.verifiedBy);
                        }
                        @username
                    </Template>
                </GridColumn>
                <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" Width="200">
                    <Template>
                        @{
                            var service = context as RepairServices;
                        }
                        <DxButton IconCssClass="fas fa-eye"
                                  RenderStyle="ButtonRenderStyle.Info"
                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                  Text="@Loc[nameof(ResourceStrings.TextView)]"
                                  @onclick="async () => await ShowRepairServiceDetails(service)" />

                        <DxButton IconCssClass="fas fa-file-invoice"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  RenderStyleMode="ButtonRenderStyleMode.Text"
                                  Text="Preview"
                                  Click="async () => await ShowReportPreview(service)" />
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>
    }

    <!-- View Dialog -->
    <SfDialog @ref="DialogEdit" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
        <DialogTemplates>
            <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
            <Content>
                @if (_selectedRepairService != null)
                {
                    <div class="report-container">
                        <div class="report-body">
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong></td>
                                    <td>@_selectedRepairService.reportNo</td>
                                </tr>
                                <tr>
                                    <td><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                                    <td>@_selectedRepairService.ServiceDate.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                                <tr>
                                    <td><strong>@Loc[nameof(ResourceStrings.TextCompanyName)]:</strong></td>
                                    <td>@_selectedRepairService.CompanyName</td>
                                </tr>
                                <tr>
                                    <td><strong>@Loc[nameof(ResourceStrings.TextStatus)]:</strong></td>
                                    <td>@_selectedRepairService.Status</td>
                                </tr>
                                <!-- ✅ NEW: Service Type row in dialog -->
                                <tr>
                                    <td><strong>Service Type:</strong></td>
                                    <td>@_selectedRepairService.ServiceType</td>
                                </tr>
                                <tr>
                                    <td><strong>@Loc[nameof(ResourceStrings.TextRepairBy)]:</strong></td>
                                    <td>@GetUserNameById(_selectedRepairService.repairBy)</td>
                                </tr>
                            </table>

                            @if (_selectedRepairService.SparePartItems?.Count > 0)
                            {
                                <h6 class="mt-3">Spare Parts (@_selectedRepairService.SparePartItems.Count items)</h6>
                                <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Item Name</th>
                                                <th>Qty</th>
                                                <th>Condition</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var part in _selectedRepairService.SparePartItems)
                                            {
                                                <tr>
                                                    <td>@part.ItemName</td>
                                                    <td>@part.Quantity</td>
                                                    <td>@part.Condition</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                }
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Close" IsPrimary="true" OnClick="@CloseDialog" />
        </DialogButtons>
    </SfDialog>
}


@code {
    // Filter state
    private int FilterType = 1;
    private DateTime SelectedDate = DateTime.Today;
    private DateTime StartDate = DateTime.Today.AddMonths(-1);
    private DateTime EndDate = DateTime.Today;
    private int FilterMode = 2;
    private string SelectedServiceLocation = "All";
    private int SelectedReportType = 1;
    private string[] SelectedStatuses { get; set; } = Array.Empty<string>();
    private string[] SelectedUsers = Array.Empty<string>();
    private string _statusValidationMessage = string.Empty;
    private string ReportMode = "standard"; // "standard" | "alwayscreated"
                                            // Customer Type filter
    private bool FilterByCustomerType = false;
    private string SelectedCustomerType = string.Empty;
    private List<CustomerService.CustomerTypeDto> _customerTypes = new();
    // ✅ NEW: Service Type state
    private string SelectedServiceType = "All";
    private List<ServiceType> ServiceTypeOptions = new();

    // Data collections
    private List<RepairServices> FilteredRepairServices = new();
    private RepairServices _selectedRepairService;
    private Dictionary<string, string> UserMap = new();
    private Dictionary<Guid, string> SparePartNamesCache = new();
    private List<ServiceStatusViewModel> StatusList = new();
    private List<UserViewModel> UserList = new();

    // UI state
    private bool IsFilterSectionVisible = true;
    private bool isViewDialogVisible = false;
    private bool IsLoading = false;
    private bool HasFetchedData = false;

    // Cache for exports/reports
    private List<RepairServices> _allDataCache = new();
    private DateTime _cacheTimestamp = DateTime.MinValue;
    private bool _isCacheValid = false;

    // Customer search
    private string searchTerm = string.Empty;
    private bool IsDropdownVisible = false;
    private List<Customer> _loadedCustomers = new();
    private IEnumerable<Customer> FilteredCustomers => _loadedCustomers;
    private Customer _selectedCompany;

    // Grid and dialogs
    private SfGrid<RepairServices> MyGrid;
    private SfDialog DialogEdit;
    private string CurrentUserName;
    public string[] ToolbarItems = new string[] { "ColumnChooser", "Search" };
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;

    // Options
    private List<FilterModeOption> FilterModeOptions = new()
    {
        new FilterModeOption { Value = 1, Text = "Process" },
        new FilterModeOption { Value = 2, Text = "Status" }
    };

    private List<string> ServiceLocationOptions = new() { "All", "OnSite", "CompanyService" };

    private List<ReportTypeOption> ReportTypeOptions = new()
    {
        new ReportTypeOption { Value = 1, Text = "Standard Report" },
        new ReportTypeOption { Value = 2, Text = "Detail Report" }
    };

    private Dictionary<string, string> StatusTranslations = new()
    {
        { "Item Recieved", "ម៉ាស៊ីនចូល" },
        { "Finished", "ជួសជុលរួចរាល់" },
        { "Inspection", "កំពុងវិនិច្ឆ័យ" },
        { "Awaiting Customer Confirm", "រង់ចាំយល់ព្រមពីភ្ញៀវ" },
        { "Awaiting Sparepart", "រង់ចាំគ្រឿងបន្លាស់" },
        { "Repairing", "កំពុងជួសជុល" },
        { "Customer Rejected", "អតិថិជនមិនជួសជុល" },
        { "Unrepairable", "ជួសជុលមិនបាន" },
        { "Repair by Third-Party", "ជួសជុលខាងក្រៅ" }
    };

    protected override async Task OnPermissionsLoadedAsync()
    {
        Console.WriteLine($"🔐 EngineerReportPage - CanAccess: {CanAccess}");

        if (!CanAccess)
        {
            Console.WriteLine("❌ Access Denied");
            ShowError("You don't have permission to access this page");
            return;
        }

        await InitializePageData();
    }

    private async Task InitializePageData()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CurrentUserName = authState.User.Identity?.Name;

        var statuses = await RepairService.GetServiceStatusesAsync();
        StatusList = statuses.Select(s => new ServiceStatusViewModel
        {
            DisplayName = StatusTranslations.ContainsKey(s.Name)
                ? $"{s.Name} - {StatusTranslations[s.Name]}"
                : s.Name,
            Value = s.Name
        }).ToList();

        // ✅ NEW: Load service types
        var serviceTypes = await RepairService.GetServiceTypesAsync();
        ServiceTypeOptions = serviceTypes.ToList();
        _customerTypes = await CustomerService.GetAllCustomerTypesAsync();

        UserMap = await UserCacheService.GetUsersAsync();

        var usersWithDetails = await UserCacheService.GetUsersWithDetailsAsync();
        UserList = usersWithDetails.Values.Select(u => new UserViewModel
        {
            Id = u.Id,
            FirstName = u.FirstName,
            LastName = u.LastName,
            UserName = u.UserName,
            Email = u.Email,
            PhoneNumber = u.PhoneNumber,
            Roles = u.Roles,
            IsOnline = false
        }).ToList();
    }

    private void ToggleFilterSection()
    {
        IsFilterSectionVisible = !IsFilterSectionVisible;
    }

    // ─────────────────────────────────────────────────────────────
    // ✅ UPDATED: FetchReport — passes serviceType to API call
    // ─────────────────────────────────────────────────────────────
    private async Task FetchReport()
    {
        try
        {
            IsLoading = true;
            HasFetchedData = true;
            FilteredRepairServices.Clear();
            _isCacheValid = false;
            _allDataCache.Clear();

            bool isAlwaysCreated = ReportMode == "alwayscreated";

            DateTime? fromDate = null;
            DateTime? toDate = null;
            string companySearchTerm = null;

            if (FilterType == 1)
            {
                fromDate = SelectedDate.Date;
                toDate = SelectedDate.Date.AddDays(1).AddSeconds(-1);
            }
            else if (FilterType == 2)
            {
                fromDate = StartDate.Date;
                toDate = EndDate.Date.AddDays(1).AddSeconds(-1);
            }
            else if (FilterType == 3)
            {
                companySearchTerm = searchTerm;
            }

            string serviceLocationFilter = SelectedServiceLocation == "All" ? null : SelectedServiceLocation;
            string serviceTypeFilter = SelectedServiceType == "All" ? null : SelectedServiceType; // ✅ NEW

            Guid[] userGuids = null;
            if (SelectedUsers?.Any() == true)
            {
                userGuids = SelectedUsers
                    .Select(u => Guid.TryParse(u, out var guid) ? guid : Guid.Empty)
                    .Where(g => g != Guid.Empty)
                    .ToArray();
            }

            string[] userFilterStatuses = null;
            if (SelectedUsers?.Any() == true && SelectedStatuses?.Any() == true)
            {
                userFilterStatuses = SelectedStatuses;
            }

            var result = await RepairService.SearchRepairServicesAsync(
                pageNumber: 1,
                pageSize: int.MaxValue,
                searchTerm: companySearchTerm,
                serialNumber: null,
                status: (isAlwaysCreated || FilterMode == 2) && SelectedStatuses?.Any() == true
                    ? string.Join(",", SelectedStatuses)
                    : null,
                serviceType: serviceTypeFilter,        // ✅ NEW
                serviceLocation: serviceLocationFilter,
                fromDate: fromDate,
                toDate: toDate,
                hasContract: null,
                dateFilter: null,
                statusFilter: null,
                sortBy: "ServiceDate",
                sortDescending: true,
                useProcessDateFiltering: !isAlwaysCreated && FilterMode == 1,
                statusesForProcessFiltering: !isAlwaysCreated && FilterMode == 1 && SelectedStatuses?.Any() == true
                    ? SelectedStatuses
                    : null,
                userIds: userGuids,
                userFilterStatuses: userFilterStatuses,
                forceServiceDateOnly: isAlwaysCreated
            );

            var allServices = result.Items.ToList();

            if (FilterByCustomerType && !string.IsNullOrEmpty(SelectedCustomerType))
            {
                allServices = await ApplyCustomerTypeFilter(allServices);
                Console.WriteLine($"CustomerType '{SelectedCustomerType}' → {allServices.Count} records after filter");
            }

            PopulateUserNamesForServices(allServices);
            await LoadSparePartsForAllServices(allServices);

            FilteredRepairServices = allServices;
            _allDataCache = allServices;
            _cacheTimestamp = DateTime.Now;
            _isCacheValid = true;

            IsFilterSectionVisible = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in FetchReport: {ex.Message}");
