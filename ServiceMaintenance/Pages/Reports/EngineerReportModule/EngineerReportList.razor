    private async Task ShowReportPreview()
    {
        try
        {
            IsLoading = true;
            StateHasChanged();

            bool isAlwaysCreated = ReportMode == "alwayscreated";

            var allServicesForReport = _isCacheValid && _allDataCache.Any()
                ? _allDataCache
                : FilteredRepairServices;

            if (allServicesForReport == null || !allServicesForReport.Any())
            {
                Console.WriteLine("❌ No data to generate report");
                IsLoading = false;
                return;
            }

            if (FilterMode == 2 && SelectedStatuses?.Any() == true && SelectedUsers?.Any() == true)
            {
                var userGuids = SelectedUsers
                    .Select(u => Guid.TryParse(u, out var guid) ? guid : Guid.Empty)
                    .Where(g => g != Guid.Empty)
                    .ToHashSet();

                allServicesForReport = allServicesForReport.Where(s =>
                {
                    foreach (var status in SelectedStatuses)
                    {
                        switch (status)
                        {
                            case "Item Recieved":
                                if (s.createby != Guid.Empty && userGuids.Contains(s.createby)) return true;
                                break;
                            case "Inspection":
                                if (s.inspectBy.HasValue && userGuids.Contains(s.inspectBy.Value)) return true;
                                break;
                            case "Awaiting Customer Confirm":
                                if (s.setAwaitingCustomerConfirmBy.HasValue && userGuids.Contains(s.setAwaitingCustomerConfirmBy.Value)) return true;
                                break;
                            case "Awaiting Sparepart":
                                if (s.setAwaitingSparepartBy.HasValue && userGuids.Contains(s.setAwaitingSparepartBy.Value)) return true;
                                break;
                            case "Repairing":
                                if (s.repairBy.HasValue && userGuids.Contains(s.repairBy.Value)) return true;
                                break;
                            case "Finished":
                                if (s.verifiedBy.HasValue && userGuids.Contains(s.verifiedBy.Value)) return true;
                                break;
                            case "Customer Rejected":
                                if (s.setCustomerRejectedBy.HasValue && userGuids.Contains(s.setCustomerRejectedBy.Value)) return true;
                                break;
                            case "Unrepairable":
                                if (s.setUnrepairableBy.HasValue && userGuids.Contains(s.setUnrepairableBy.Value)) return true;
                                break;
                            case "Repair by Third-Party":
                                if (s.thirdPartyRepairBy.HasValue && userGuids.Contains(s.thirdPartyRepairBy.Value)) return true;
                                break;
                        }
                    }
                    return false;
                }).ToList();
            }

            foreach (var service in allServicesForReport)
            {
                await LoadSparePartNamesForService(service);
            }

            var repairByUsers = new List<string>();
            var verifiedByUsers = new List<string>();

            foreach (var service in allServicesForReport)
            {
                var repairByName = GetUserNameById(service.repairBy);
                var verifiedByName = GetUserNameById(service.verifiedBy);
                repairByUsers.Add(repairByName);
                verifiedByUsers.Add(verifiedByName);
                service.RepairByName = repairByName;
                service.VerifiedByName = verifiedByName;
            }

            byte[] reportData;

            if (SelectedReportType == 1)
            {
                var report = new EngineerReport2();

                if (FilterType == 1)
                {
                    report.Parameters["FromDate"].Value = SelectedDate;
                    report.Parameters["ToDate"].Value = SelectedDate;
                }
                else
                {
                    report.Parameters["FromDate"].Value = StartDate;
                    report.Parameters["ToDate"].Value = EndDate;
                }

                report.SetDataSource(
                    allServicesForReport,
                    repairByUsers,
                    verifiedByUsers,
                    CurrentUserName,
                    UserMap,
                    SelectedStatuses?.ToList()
                );

                report.Parameters["ServiceLocation"].Value = SelectedServiceLocation;

                using (var ms = new MemoryStream())
                {
                    report.ExportToPdf(ms);
                    reportData = ms.ToArray();
                }
            }
            else
            {
                var report = new EngineerReport();

                if (FilterType == 1)
                {
                    report.Parameters["FromDate"].Value = SelectedDate;
                    report.Parameters["ToDate"].Value = SelectedDate;
                }
                else
                {
                    report.Parameters["FromDate"].Value = StartDate;
                    report.Parameters["ToDate"].Value = EndDate;
                }

                report.SetDataSource(allServicesForReport, repairByUsers, verifiedByUsers, CurrentUserName, UserMap);
                report.Parameters["ServiceLocation"].Value = SelectedServiceLocation;

                using (var ms = new MemoryStream())
                {
                    report.ExportToPdf(ms);
                    reportData = ms.ToArray();
                }
            }

            string base64Report = Convert.ToBase64String(reportData);
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.printReport", base64Report, "EngineerReport.pdf");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating report: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

