    private async Task LoadSparePartsForAllServices(List<RepairServices> services)
    {
        var sparePartIds = services
            .SelectMany(s => s.SparePartItems ?? Enumerable.Empty<SparePartItem>())
            .Where(item => item.SparePartId.HasValue && item.SparePartId.Value != Guid.Empty)
            .Where(item => string.IsNullOrEmpty(item.ItemName))
            .Select(item => item.SparePartId.Value)
            .Distinct()
            .ToList();

        Console.WriteLine($"🔍 Need to load {sparePartIds.Count} spare part names");

        if (!sparePartIds.Any()) return;

        foreach (var sparePartId in sparePartIds)
        {
            if (!SparePartNamesCache.ContainsKey(sparePartId))
            {
                try
                {
                    var sparePart = await SparePartService.GetSparePartByIdAsync(sparePartId);
                    SparePartNamesCache[sparePartId] = sparePart?.ItemName ?? "Unknown";
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"❌ Error loading spare part {sparePartId}: {ex.Message}");
                    SparePartNamesCache[sparePartId] = "Unknown";
                }
            }
        }

        foreach (var service in services)
        {
            if (service.SparePartItems == null || !service.SparePartItems.Any()) continue;

            foreach (var item in service.SparePartItems)
            {
                if (string.IsNullOrEmpty(item.ItemName) &&
                    item.SparePartId.HasValue &&
                    SparePartNamesCache.ContainsKey(item.SparePartId.Value))
                {
                    item.ItemName = SparePartNamesCache[item.SparePartId.Value];
                }
            }
        }
    }

    private async Task<string> GetSparePartName(Guid? sparePartId)
    {
        if (!sparePartId.HasValue) return "Unknown";

        if (SparePartNamesCache.ContainsKey(sparePartId.Value))
            return SparePartNamesCache[sparePartId.Value];

        try
        {
            var sparePart = await SparePartService.GetSparePartByIdAsync(sparePartId.Value);
            var name = sparePart?.ItemName ?? "Unknown";
            SparePartNamesCache[sparePartId.Value] = name;
            return name;
        }
        catch
        {
            SparePartNamesCache[sparePartId.Value] = "Unknown";
            return "Unknown";
        }
    }

    private async Task LoadSparePartNamesForService(RepairServices service)
    {
        if (service?.SparePartItems == null) return;

        var itemsToLoad = service.SparePartItems
            .Where(item => string.IsNullOrEmpty(item.ItemName))
            .ToList();

        foreach (var item in itemsToLoad)
        {
            item.ItemName = await GetSparePartName(item.SparePartId);
        }
    }

    private System.Threading.CancellationTokenSource _searchCts;

    private async Task OnSearchTermInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;

        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();

        if (searchTerm.Length >= 2)
        {
            try
            {
                await Task.Delay(300, _searchCts.Token);
                var result = await CustomerService.GetCustomersPaginatedAsync(1, 20, searchTerm);
                _loadedCustomers = result.Data?.ToList() ?? new();
                IsDropdownVisible = _loadedCustomers.Any();
            }
            catch (OperationCanceledException) { }
        }
        else
        {
            _loadedCustomers.Clear();
            IsDropdownVisible = false;
        }
    }
    private async Task<List<RepairServices>> ApplyCustomerTypeFilter(List<RepairServices> services)
    {
        try
        {
            var matchingCompanyNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            int page = 1;
            bool hasMore = true;

            while (hasMore)
            {
                var pagedResponse = await CustomerService.GetCustomersPaginatedAsync(
                    pageNumber: page,
                    pageSize: 100,
                    isActive: true
                );

                if (pagedResponse?.Data != null && pagedResponse.Data.Any())
                {
                    foreach (var c in pagedResponse.Data)
                    {
                        if (!string.IsNullOrWhiteSpace(c.CompanyName) &&
                            c.CustomerType == SelectedCustomerType)
                        {
                            matchingCompanyNames.Add(c.CompanyName.Trim());
                        }
                    }
                    hasMore = pagedResponse.HasNext;
                    page++;
                }
                else
                {
                    hasMore = false;
                }
            }

            return services
                .Where(r => !string.IsNullOrWhiteSpace(r.CompanyName) &&
                            matchingCompanyNames.Contains(r.CompanyName.Trim()))
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in ApplyCustomerTypeFilter: {ex.Message}");
            return services;
        }
    }
