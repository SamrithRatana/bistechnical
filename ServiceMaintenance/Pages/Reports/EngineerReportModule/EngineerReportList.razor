                "Item Recieved" => GetUserNameById(service.createby),
                "ទទួលម៉ាស៊ីន" => GetUserNameById(service.createby),
                "Inspection" => GetUserNameById(service.inspectBy),
                "កំពុងវិនិច្ឆ័យ" => GetUserNameById(service.inspectBy),
                "Awaiting Customer Confirm" => GetUserNameById(service.setAwaitingCustomerConfirmBy),
                "រង់ចាំយល់ព្រមពីភ្ញៀវ" => GetUserNameById(service.setAwaitingCustomerConfirmBy),
                "Awaiting Sparepart" => GetUserNameById(service.setAwaitingSparepartBy),
                "រង់ចាំគ្រឿងបន្លាស់" => GetUserNameById(service.setAwaitingSparepartBy),
                "Repairing" => GetUserNameById(service.repairBy),
                "កំពុងជួសជុល" => GetUserNameById(service.repairBy),
                "Customer Rejected" => GetUserNameById(service.setCustomerRejectedBy),
                "អតិថិជនមិនជួសជុល" => GetUserNameById(service.setCustomerRejectedBy),
                "Unrepairable" => GetUserNameById(service.setUnrepairableBy),
                "ជួសជុលមិនបាន" => GetUserNameById(service.setUnrepairableBy),
                "Repair by Third-Party" => GetUserNameById(service.thirdPartyRepairBy),
                "ជួសជុលខាងក្រៅ" => GetUserNameById(service.thirdPartyRepairBy),
