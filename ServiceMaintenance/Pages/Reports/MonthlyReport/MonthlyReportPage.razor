    }
    private async Task EnrichWithCustomerTypes()
    {
        try
        {
            // Get unique company names from the filtered results only
            var companyNames = FilteredRepairServices
                .Select(s => s.CompanyName)
                .Distinct()
                .Where(cn => !string.IsNullOrWhiteSpace(cn))
                .ToList();

            if (!companyNames.Any())
            {
                Console.WriteLine("No companies to enrich");
                return;
            }

            Console.WriteLine($"⚡ Enriching customer types for {companyNames.Count} unique companies in parallel...");
            var startTime = DateTime.Now;

            // ✅ PARALLEL LOOKUP - All companies at once!
            var lookupTasks = companyNames.Select(async companyName =>
            {
                try
                {
                    var customerType = await CustomerService.GetCustomerTypeByCompanyName(companyName);
                    return new { companyName, customerType = string.IsNullOrEmpty(customerType) ? "Unknown" : customerType };
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"⚠️ Error looking up customer type for {companyName}: {ex.Message}");
                    return new { companyName, customerType = "Unknown" };
                }
            });

            var results = await Task.WhenAll(lookupTasks);

            // Apply results to all services with matching company names
            var customerTypeMap = results.ToDictionary(r => r.companyName, r => r.customerType);

            foreach (var service in FilteredRepairServices)
            {
                if (!string.IsNullOrWhiteSpace(service.CompanyName) &&
                    customerTypeMap.ContainsKey(service.CompanyName))
                {
                    service.CustomerType = customerTypeMap[service.CompanyName];
                }
                else
                {
                    service.CustomerType = "Unknown";
                }
            }

            var elapsed = (DateTime.Now - startTime).TotalMilliseconds;
            Console.WriteLine($"✅ Enriched {companyNames.Count} companies in {elapsed:F0}ms (parallel)");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error enriching customer types: {ex.Message}");
        }
    }

