    private bool HasDetailGridNextPage(string customerType)
    {
        return GetDetailGridCurrentPage(customerType) < GetDetailGridTotalPages(customerType);
    }

    // Load detail grid data for a specific customer type
    private void LoadDetailGridDataFromCache(string customerType, int pageNumber = 1, int pageSize = 10)
    {
        try
        {
            if (string.IsNullOrEmpty(customerType)) return;

            // Get all records for this customer type from cached data
            var allRecords = FilteredRepairServices
                .Where(r => (r.CustomerType ?? "Unknown") == customerType)
                .ToList();

            // Update total records
            DetailGridTotalRecords[customerType] = allRecords.Count;

            // Calculate pagination
            int skip = (pageNumber - 1) * pageSize;
            var pageData = allRecords
                .Skip(skip)
                .Take(pageSize)
                .ToList();

            // Store the data
            DetailGridData[customerType] = pageData;
            DetailGridCurrentPages[customerType] = pageNumber;
            DetailGridPageSizes[customerType] = pageSize;

            Console.WriteLine($"Loaded detail grid for {customerType}: Page {pageNumber}, {pageData.Count} records");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading detail grid data for {customerType}: {ex.Message}");
            InvokeAsync(StateHasChanged);

        }
    }

    // Enrich customer types for detail grid
    private async Task EnrichDetailGridCustomerTypes(List<RepairServices> services)
    {
        var companyNames = services
            .Select(s => s.CompanyName)
            .Distinct()
            .Where(cn => !string.IsNullOrWhiteSpace(cn))
            .ToList();

        foreach (var companyName in companyNames)
        {
            var customerType = await CustomerService.GetCustomerTypeByCompanyName(companyName);
            foreach (var service in services.Where(s => s.CompanyName == companyName))
            {
                service.CustomerType = string.IsNullOrEmpty(customerType) ? "Unknown" : customerType;
            }
        }
    }

