@page "/monthly-report"
@using System.Linq.Expressions
@using DXApplication1
@using ServiceMaintenance.Models
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@inject RepairItemService RepairService
@inject UserService UserService
@inject IJSRuntime JSRuntime
@inject ServiceSparePart SparePartService
@inject CustomerService CustomerService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inherits PermissionBase
@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical;

    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical;
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Horizontal;
    }
    else
    {
        enableAdaptiveUIMode = false;
    }
}
@if (CanAccess)
{
<DxToastProvider Name="Customization"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" IconCssClass="far fa-file" CssClass="toolbar-item" Enabled="false" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="false" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="false" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                <Items>
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ShowReportPreview2" IconCssClass="fas fa-file-pdf" />
                </Items>
            </DxToolbarItem>
            <DxToolbarItem Text="Print Report" Click="ShowReportPreview" CssClass="toolbar-item" IconCssClass="fas fa-print" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" Enabled="false" />
        </DxToolbar>
    </div>
</div>

<hr />

<div class="container">
    <div class="row mb-2">
        <div class="col-md-12 text-end">
            <i class="fa @(IsFilterSectionVisible ? "fa-chevron-up" : "fa-chevron-down")"
               @onclick="ToggleFilterSection"
               style="cursor: pointer; font-size: 20px; color: #333;">
            </i>
        </div>
    </div>

    <div class="filter-section container" style="@($"display: {(IsFilterSectionVisible ? "block" : "none")};")">
        <div class="row align-items-end g-2">
            <div class="col-md-3">
                <label for="filterStartDate" class="font-weight-bold">@Loc[nameof(ResourceStrings.Textfrom)]:</label>
                <SfDatePicker TValue="DateTime" @ref="@DateObj1" @bind-Value="StartDate" id="filterStartDate" class="form-control" Format="dd/MM/yyyy">
                    <DatePickerEvents TValue="DateTime" Focus="FocusHandler1"></DatePickerEvents>
                </SfDatePicker>
            </div>
            <div class="col-md-3">
                <label for="filterEndDate" class="font-weight-bold">@Loc[nameof(ResourceStrings.TextTo)]:</label>
                <SfDatePicker TValue="DateTime" @ref="@DateObj2" @bind-Value="EndDate" id="filterEndDate" class="form-control" Format="dd/MM/yyyy">
                    <DatePickerEvents TValue="DateTime" Focus="FocusHandler2"></DatePickerEvents>
                </SfDatePicker>
            </div>

            <div class="col-md-2">
                <label for="serviceLocationFilter" class="font-weight-bold">Service Location:</label>
                <InputSelect @bind-Value="SelectedServiceLocation" id="serviceLocationFilter" class="form-control">
                    @foreach (var location in ServiceLocationOptions)
                    {
                        <option value="@location">@location</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-2">
                <label for="customerTypeFilter" class="font-weight-bold">Customer Type:</label>
                <SfComboBox TValue="string"
                            TItem="CustomerService.CustomerTypeDto"
                            @bind-Value="SelectedCustomerType"
                            DataSource="@CustomerTypes"
                            Placeholder="Select or search..."
                            AllowFiltering="true"
                            FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                            PopupHeight="300px"
                            id="customerTypeFilter"
                            CssClass="form-control">
                    <ComboBoxFieldSettings Text="Type" Value="Type"></ComboBoxFieldSettings>
                    <ComboBoxEvents TValue="string"
                                    TItem="CustomerService.CustomerTypeDto"
                                    Filtering="OnCustomerTypeFiltering">
                    </ComboBoxEvents>
                </SfComboBox>
            </div>

            <div class="col-md-2 text-end">
                <button class="btn btn-primary" @onclick="FetchReport" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    @Loc[nameof(ResourceStrings.TextFetchReport)]
                </button>
            </div>
        </div>
    </div>
</div>

<hr />


    @if (IsLoading)
    {
        <div class="text-center p-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading report data...</p>
        </div>
    }
    else if (FilteredRepairServices.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            No data available for the selected criteria. Please adjust your filters and try again.
        </div>
    }
    else
    {


        <SfGrid DataSource="UniqueCustomerTypeRepairServices"
                AllowSorting="true"
                ShowColumnChooser="true"
                EnableAdaptiveUI="@enableAdaptiveUIMode"
                RowRenderingMode="@renderingMode"
                SelectionMode="GridSelectionMode.Single"
                Toolbar="@ToolbarItems"
                AllowResizing="true"
                Height="auto"
                AllowSelection="true">

            <GridEvents RowSelected="RowSelectHandler" OnRecordDoubleClick="RowDoubleClickHandler" TValue="RepairServices"></GridEvents>

            <GridTemplates>
                <DetailTemplate Context="detailContext">
                    @{
                        var item = detailContext as RepairServices;
                        var customerType = item?.CustomerType ?? "Unknown";

                        // Get paginated data for this customer type (will initialize if needed)
                        var detailGridData = GetDetailGridData(customerType);
                        var detailCurrentPage = GetDetailGridCurrentPage(customerType);
                        var detailPageSize = GetDetailGridPageSize(customerType);
                        var detailTotalRecords = GetDetailGridTotalRecords(customerType);
                        var detailTotalPages = GetDetailGridTotalPages(customerType);
                        var detailHasPrevious = HasDetailGridPreviousPage(customerType);
                        var detailHasNext = HasDetailGridNextPage(customerType);
                    }

                    <div class="detail-grid-container p-3" @key="@customerType">
                        <!-- Detail Grid -->
                        <SfGrid DataSource="@detailGridData"
                                AllowSorting="true"
                                Height="300"
                                EnableAdaptiveUI="@enableAdaptiveUIMode"
                                RowRenderingMode="@renderingMode"
                                SelectionMode="GridSelectionMode.Single"
                                AllowResizing="true"
                                AllowSelection="true">
                            <GridColumns>
                                <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" Width="300"></GridColumn>
                                <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="250"></GridColumn>
                                <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="150"></GridColumn>
                                <GridColumn Field="CustomerType" HeaderText="Customer Type" Width="120"></GridColumn>

                                <GridColumn HeaderText="Sparepart Items" Field="SparePartItems" Width="250">
                                    <Template Context="columnContext">
                                        @if ((columnContext as RepairServices)?.SparePartItems?.Any() != true)
                                        {
                                            <div>ជួសជុលមិនគិតលុយ</div>
                                        }
                                        else
                                        {
                                            @foreach (var spItem in (columnContext as RepairServices)?.SparePartItems ?? Enumerable.Empty<SparePartItem>())
                                            {
                                                var sparePartObject = _spareParts.FirstOrDefault(sp => sp.Id == spItem.SparePartId);
                                                <div>
                                                    @sparePartObject?.ItemName - @spItem.Quantity - @spItem.Description $
                                                </div>
                                            }
                                        }
                                    </Template>
                                </GridColumn>

                                <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" IsFrozen="true" Freeze="FreezeDirection.Right" Width="150">
                                    <Template Context="columnContext">
                                        @if ((columnContext as RepairServices)?.ServiceDate != null)
                                        {
                                            <DxButton IconCssClass="fas fa-eye"
                                                      CssClass="icon-button info"
                                                      RenderStyle="ButtonRenderStyle.Info"
                                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                                      Text="@Loc[nameof(ResourceStrings.TextView)]"
                                                      @onclick="() => ShowRepairServiceDetails(columnContext as RepairServices)" />
                                        }
                                    </Template>
                                </GridColumn>
                            </GridColumns>
                        </SfGrid>

                        <!-- Pagination Controls - Bottom -->
                        <div class="d-flex justify-content-between align-items-center mt-3" @key="@($"pagination-{customerType}")">
                            <div>
                                <strong>Showing @((detailCurrentPage - 1) * detailPageSize + 1) to @Math.Min(detailCurrentPage * detailPageSize, detailTotalRecords) of @detailTotalRecords records</strong>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <label class="me-2">Page Size:</label>
                                <select class="form-select form-select-sm"
                                        style="width: 80px;"
                                        value="@detailPageSize"
                                        @onchange="(e) => OnDetailGridPageSizeChanged(customerType, e)"
                                        @onclick:stopPropagation="true">
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                </select>

                                <div class="btn-group ms-3" role="group">
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => DetailGridFirstPage(customerType)"
                                            @onclick:stopPropagation="true"
                                            disabled="@(!detailHasPrevious)">
                                        <i class="fas fa-angle-double-left"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => DetailGridPreviousPage(customerType)"
                                            @onclick:stopPropagation="true"
                                            disabled="@(!detailHasPrevious)">
                                        <i class="fas fa-angle-left"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" disabled>
                                        @detailCurrentPage / @detailTotalPages
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => DetailGridNextPage(customerType)"
                                            @onclick:stopPropagation="true"
                                            disabled="@(!detailHasNext)">
                                        <i class="fas fa-angle-right"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => DetailGridLastPage(customerType)"
                                            @onclick:stopPropagation="true"
                                            disabled="@(!detailHasNext)">
                                        <i class="fas fa-angle-double-right"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </DetailTemplate>
            </GridTemplates>

            <GridColumns>
                <GridColumn Field="CustomerType" HeaderText="Customer Type" Width="250"></GridColumn>

                <GridColumn HeaderText="Fixed" Width="100">
                    <Template Context="columnContext">
                        @{
                            var item = columnContext as RepairServices;
                            var customerType = item?.CustomerType ?? "Unknown";
                            var count = FilteredRepairServices
                            .Count(r => (r.CustomerType ?? "Unknown") == customerType && r.Status == "Finished");
                        }
                        @count
                    </Template>
                </GridColumn>

                <GridColumn HeaderText="Customer Reject" Width="100">
                    <Template Context="columnContext">
                        @{
                            var item = columnContext as RepairServices;
                            var customerType = item?.CustomerType ?? "Unknown";
                            var count = FilteredRepairServices
                            .Count(r => (r.CustomerType ?? "Unknown") == customerType && r.Status == "Customer Rejected");
                        }
                        @count
                    </Template>
                </GridColumn>

                <GridColumn HeaderText="Unrepairable" Width="100">
                    <Template Context="columnContext">
                        @{
                            var item = columnContext as RepairServices;
                            var customerType = item?.CustomerType ?? "Unknown";
                            var count = FilteredRepairServices
                            .Count(r => (r.CustomerType ?? "Unknown") == customerType && r.Status == "Unrepairable");
                        }
                        @count
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>

        <SfGrid @ref="MyGrid" DataSource="FilteredRepairServices"
                PageSize="10"
                AllowSorting="true"
                ShowColumnChooser="true"
                EnableAdaptiveUI="@enableAdaptiveUIMode"
                RowRenderingMode="@renderingMode"
                SelectionMode="GridSelectionMode.Single"
                AllowExcelExport="true"
                Height="0"
                AllowSelection="true">
            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
            <GridEvents RowSelected="RowSelectHandler" OnRecordDoubleClick="RowDoubleClickHandler" TValue="RepairServices"></GridEvents>

            <GridColumns>
                <GridColumn Field="CompanyName" HeaderText="Number of Items Fixed" Width="500"></GridColumn>
                <GridColumn Field="ServiceDate" HeaderText="ServiceDate" Width="500" Format="dd/MM/yyyy" Visible="false"></GridColumn>
                <GridColumn Field="ServiceLocation" HeaderText="ServiceLocation" Width="500" Visible="false"></GridColumn>
                <GridColumn Field="Address" HeaderText="Address" Width="500" Visible="false"></GridColumn>
                <GridColumn Field="itemName" HeaderText="ItemName" Width="500" Visible="false"></GridColumn>
                <GridColumn Field="serialNumber" HeaderText="SerialNumber" Width="500" Visible="false"></GridColumn>
                <GridColumn Field="CustomerRequest" HeaderText="CustomerRequest" Width="500" Visible="false"></GridColumn>
                <GridColumn Field="Inspection" HeaderText="inspection" Width="500" Visible="false"></GridColumn>
                <GridColumn Field="Solution" HeaderText="Solution" Width="500" Visible="false"></GridColumn>
                <GridColumn Field="SparePartExcelSummary" HeaderText="SparePart" Width="500" Visible="false"></GridColumn>
            </GridColumns>

            <GridAggregates>
                <GridAggregate>
                    <GridAggregateColumns>
                        <GridAggregateColumn Field="CompanyName" Type="AggregateType.Custom">
                            <FooterTemplate>
                                @{
                                    var finishedCount = FilteredRepairServices.Count(s => s.Status == "Finished");
                                    var customerRejectedCount = FilteredRepairServices.Count(s => s.Status == "Customer Rejected");
                                    var unrepairableCount = FilteredRepairServices.Count(s => s.Status == "Unrepairable");
                                }
                                <div style="display: flex; justify-content: space-between; width: 63%; align-items: center;">
                                    <div style="text-align: left; flex-grow: 1;">
                                        <strong>Total Fixed:</strong>
                                        <strong style="font-weight: 900;">@finishedCount</strong>
                                    </div>
                                    <div style="text-align: right; padding-left: 20px;">
                                        <strong>Total Customer Rejected:</strong>
                                        <strong style="font-weight: 900;">@customerRejectedCount</strong>
                                    </div>
                                    <div style="text-align: right; padding-left: 300px;">
                                        <strong>Total Unrepairable:</strong>
                                        <strong style="font-weight: 900;">@unrepairableCount</strong>
                                    </div>
                                </div>
                            </FooterTemplate>
                        </GridAggregateColumn>
                    </GridAggregateColumns>
                </GridAggregate>
            </GridAggregates>
        </SfGrid>

    }

    <!-- View Details Dialog -->
    <SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
        <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
        <DialogTemplates>
            <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
            <Content>
                <div class="report-container">
                    <div class="report-header">
                        <span>Repair Service Report</span>
                    </div>
                    <div class="report-body">
                        <table class="report-table">
                            @if (_selectedRepairService?.reportNo != null)
                            {
                                <tr>
                                    <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong></td>
                                    <td class="report-value">@_selectedRepairService?.reportNo</td>
                                </tr>
                            }
                            @if (_selectedRepairService?.ServiceDate != null)
                            {
                                <tr>
                                    <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                                    <td class="report-value">@_selectedRepairService?.ServiceDate.ToString("yyyy-MM-dd HH:mm tt")</td>
                                </tr>
                            }
                            @if (_selectedRepairService?.repairDate.HasValue == true)
                            {
                                <tr>
                                    <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairDate)]:</strong></td>
                                    <td class="report-value">@_selectedRepairService.repairDate.Value.ToString("yyyy-MM-dd HH:mm tt")</td>
                                </tr>
                            }
                            @if (_selectedRepairService?.finishedDate.HasValue == true)
                            {
                                <tr>
                                    <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextFinishDate)]:</strong></td>
                                    <td class="report-value">@_selectedRepairService.finishedDate.Value.ToString("yyyy-MM-dd HH:mm tt")</td>
                                </tr>
                            }
                            <!-- Add other fields as needed -->
                        </table>
                    </div>
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Close" IsPrimary="true" OnClick="@CloseDialog" />
        </DialogButtons>
    </SfDialog>

    <SfDialog @ref="DialogNoRecordSelected" IsModal="true" Width="250px" ShowCloseIcon="true" Visible="false">
        <DialogTemplates>
            <Header> Warning! </Header>
            <Content> @Loc[nameof(ResourceStrings.TextSelectRecord)] </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="OK" IsPrimary="true" OnClick="CloseDialogNoRecordSelected" />
        </DialogButtons>
    </SfDialog>
}


@code {
    private DateTime StartDate = DateTime.Today;
    private DateTime EndDate = DateTime.Today;
    private List<RepairServices> FilteredRepairServices = new();
    private RepairServices _selectedRepairService;
    private Dictionary<string, string> UserMap = new();
    private Dictionary<string, string> _userCache = new();
    private bool _usersLoaded = false;
    private IEnumerable<SparePartObject> _spareParts = Enumerable.Empty<SparePartObject>();
    private bool isViewDialogVisible = false;
    private SfDialog DialogEdit;
    public string[] ToolbarItems = new string[] { "ColumnChooser", "Search" };
    private SfGrid<RepairServices> MyGrid;
    private string CurrentUserName;
    private SfDialog DialogNoRecordSelected;
    private bool IsFilterSectionVisible = true;
    private string activeBreakpoint { get; set; }
    SfDatePicker<DateTime> DateObj1;
    SfDatePicker<DateTime> DateObj2;
    private string SelectedCustomerType = "All";
    private List<string> CustomerTypeOptions = new() { "All" };
    private bool IsLoading = false;
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;
    private string SelectedServiceLocation = "All";
    private List<string> ServiceLocationOptions = new() { "All", "OnSite", "CompanyService" };
    private int CurrentPage = 1;
    private int PageSize = 10;
    private int TotalRecords = 0;
    private int TotalPages => TotalRecords > 0 ? (int)Math.Ceiling(TotalRecords / (double)PageSize) : 0;
    private bool HasPreviousPage => CurrentPage > 1;
    private bool HasNextPage => CurrentPage < TotalPages;
    private bool HasSearched = false;
    private DateTime _lastStartDate;
    private DateTime _lastEndDate;
    private string _lastServiceLocation = "All";
    private string _lastCustomerType = "All";
    private List<CustomerService.CustomerTypeDto> CustomerTypes = new();
    private int CustomerTypeCurrentPage = 1;
    private const int CustomerTypePageSize = 10;
    private bool HasMoreCustomerTypes = true;
    private Dictionary<Guid, SparePartObject> _sparePartsCache = new();
    private Dictionary<string, int> DetailGridCurrentPages = new();
    private Dictionary<string, int> DetailGridPageSizes = new();
    private Dictionary<string, List<RepairServices>> DetailGridData = new();
    private Dictionary<string, int> DetailGridTotalRecords = new();
    private const int DefaultDetailPageSize = 10;

    private IEnumerable<RepairServices> UniqueCustomerTypeRepairServices =>
        FilteredRepairServices
            .GroupBy(r => r.CustomerType ?? "Unknown")
            .Select(g => g.First())
            .ToList();

    public async void FocusHandler1(Syncfusion.Blazor.Calendars.FocusEventArgs args)
    {
        await this.DateObj1.ShowPopupAsync();
    }

    public async void FocusHandler2(Syncfusion.Blazor.Calendars.FocusEventArgs args)
    {
        await this.DateObj2.ShowPopupAsync();
    }

    private void ToggleFilterSection()
    {
        IsFilterSectionVisible = !IsFilterSectionVisible;
    }
    protected override async Task OnPermissionsLoadedAsync()
    {
        Console.WriteLine($"🔐 DailyReportPage - CanAccess: {CanAccess}");
        Console.WriteLine($"🔐 DailyReportPage - PermissionsLoaded: {PermissionsLoaded}");

        if (!CanAccess)
        {
            Console.WriteLine("❌ Access Denied - User does not have DailyReportPage.Access permission");
            ShowError("You don't have permission to access this page");
            return; // Stop initialization
        }

        // Only continue with initialization if user has access
        await InitializePageData();
    }

    // ✅ STEP 3: Move your initialization logic here
    private async Task InitializePageData()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authenticationState.User;

        if (user.Identity.IsAuthenticated)
        {
            CurrentUserName = user.Identity.Name;
        }

        // Set StartDate to the first day of the current month
        StartDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        EndDate = StartDate.AddMonths(1).AddDays(-1);
        await LoadAllUsersAsync();

        // ✅ Load customer types from dedicated CustomerType API
        await LoadCustomerTypes();
    }
    private async Task LoadAllUsersAsync()
    {
        if (_usersLoaded)
            return;

        try
        {
            Console.WriteLine("📥 Loading all users from API...");

            var users = await UserService.GetUsersAsync();
            _userCache = users.ToDictionary(u => u.Id, u => $"{u.LastName}");
            UserMap = _userCache; // Keep UserMap for compatibility

            _usersLoaded = true;
            Console.WriteLine($"✅ Loaded {_userCache.Count} users into cache");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading users: {ex.Message}");
            _userCache = new Dictionary<string, string>();
            UserMap = new Dictionary<string, string>();
        }
    }

    private async Task LoadCustomerTypes()
    {
        try
        {
            Console.WriteLine("Loading initial customer types (page 1, 10 items)...");

            // Add "All" option first
            CustomerTypes = new List<CustomerService.CustomerTypeDto>
            {
                new CustomerService.CustomerTypeDto
                {
                    Type = "All",
                    Description = "All Types",
                    IsActive = true
                }
            };

            // Load first page from API
            var pagedResponse = await CustomerService.GetCustomerTypesPaginatedAsync(
                pageNumber: 1,
                pageSize: CustomerTypePageSize,
                isActive: true
            );

            if (pagedResponse?.Data != null && pagedResponse.Data.Any())
            {
                CustomerTypes.AddRange(pagedResponse.Data.OrderBy(ct => ct.Type));
                HasMoreCustomerTypes = pagedResponse.HasNext;
                CustomerTypeCurrentPage = 1;

                Console.WriteLine($"✅ Loaded {pagedResponse.Data.Count()} customer types (page 1)");
            }

            SelectedCustomerType = "All";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading initial customer types: {ex.Message}");

            // Fallback to "All" option only
            CustomerTypes = new List<CustomerService.CustomerTypeDto>
            {
                new CustomerService.CustomerTypeDto
                {
                    Type = "All",
                    Description = "All Types",
                    IsActive = true
                }
            };
        }
    }
    private void OnCustomerTypeFiltering(Syncfusion.Blazor.DropDowns.FilteringEventArgs args)
    {
        args.PreventDefaultAction = true; // We handle filtering manually

        // Use Task.Run to avoid blocking UI and handle async operations
        _ = Task.Run(async () =>
        {
            try
            {
                if (string.IsNullOrEmpty(args.Text))
                {
                    // Reset to initial page when search is cleared
                    await InvokeAsync(async () =>
                    {
                        await LoadCustomerTypes();
                        StateHasChanged();
                    });
                }
                else
                {
                    // Search with the API (it will filter server-side)
                    Console.WriteLine($"Searching customer types with term: '{args.Text}'");

                    var searchResults = await CustomerService.GetCustomerTypesPaginatedAsync(
                        pageNumber: 1,
                        pageSize: 20, // Show more results when searching
                        searchTerm: args.Text,
                        isActive: true
                    );

                    await InvokeAsync(() =>
                    {
                        if (searchResults?.Data != null)
                        {
                            // Keep "All" option + search results
                            CustomerTypes = new List<CustomerService.CustomerTypeDto>
                            {
                                new CustomerService.CustomerTypeDto
                                {
                                    Type = "All",
                                    Description = "All Types",
                                    IsActive = true
