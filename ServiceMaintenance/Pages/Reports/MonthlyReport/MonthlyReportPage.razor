<script>
    // ✅ Namespace for report functions
    window.blazorReportsPrint = window.blazorReportsPrint || {};

    /**
     * ✅ Preview Report in New Tab (for Print Report button)
     * Opens PDF in new browser tab for preview and printing
     */
    window.blazorReportsPrint.previewReportInNewTab = function (base64Data, filename) {
        try {
            console.log('📄 previewReportInNewTab called');
            console.log('  Base64 length:', base64Data?.length || 0);
            console.log('  Filename:', filename);

            if (!base64Data) {
                console.error('❌ No base64 data provided');
                alert('Error: No report data to display');
                return;
            }

            // Convert base64 to byte array
            const binaryString = window.atob(base64Data);
            const bytes = new Uint8Array(binaryString.length);
            for (let i = 0; i < binaryString.length; i++) {
                bytes[i] = binaryString.charCodeAt(i);
            }

            // Create blob
            const blob = new Blob([bytes], { type: 'application/pdf' });
            console.log('✅ Blob created, size:', blob.size, 'bytes');

            // Create object URL
            const url = URL.createObjectURL(blob);
            console.log('✅ Object URL created:', url);

            // Open in new tab
            const newWindow = window.open(url, '_blank');

            if (newWindow) {
                console.log('✅ New window opened successfully');

                // Set title and trigger print after PDF loads
                newWindow.document.title = filename || 'Report';

                // Wait for PDF to load, then show print dialog
                setTimeout(function () {
                    newWindow.focus();
                    newWindow.print();
                }, 500);

                // Clean up object URL after 1 minute
                setTimeout(function () {
                    URL.revokeObjectURL(url);
                    console.log('🧹 Object URL cleaned up');
                }, 60000);
            } else {
                console.error('❌ Failed to open new window - popup might be blocked');
                alert('Please allow popups to preview the report.\n\nOr use the "Export to PDF" option to download instead.');

                // Fallback: trigger download
                downloadBlob(blob, filename);
                URL.revokeObjectURL(url);
            }

        } catch (error) {
            console.error('❌ Error in previewReportInNewTab:', error);
            alert('Error opening report preview: ' + error.message);
        }
    };

    /**
     * ✅ Print Report (alternative method using blob URL)
     * For when you have byte array instead of base64
     */
    window.printReport = function (reportData) {
        try {
            console.log('📄 printReport called, data length:', reportData?.length || 0);

            if (!reportData || reportData.length === 0) {
                console.error('❌ No report data provided');
                alert('Error: No report data to print');
                return;
            }

            // Create blob from byte array
            const blob = new Blob([reportData], { type: 'application/pdf' });
            console.log('✅ Blob created, size:', blob.size, 'bytes');

            // Create object URL
            const url = URL.createObjectURL(blob);
            console.log('✅ Object URL created');

            // Open in new window for preview and printing
            const printWindow = window.open(url, '_blank');

            if (printWindow) {
                console.log('✅ Print window opened successfully');

                // Wait for PDF to load, then trigger print dialog
                printWindow.onload = function () {
                    console.log('📄 PDF loaded, triggering print dialog');
                    setTimeout(function () {
                        printWindow.print();
                    }, 250);
                };

                // Clean up object URL after a delay
                setTimeout(function () {
                    URL.revokeObjectURL(url);
                    console.log('🧹 Object URL cleaned up');
                }, 60000);

            } else {
                console.error('❌ Failed to open print window - popup might be blocked');
                alert('Please allow popups to preview/print the report');
                URL.revokeObjectURL(url);
            }

        } catch (error) {
            console.error('❌ Error in printReport:', error);
            alert('Error opening print preview: ' + error.message);
        }
    };

    /**
     * ✅ Download PDF Report (for "Export to PDF" button)
     */
    window.downloadReportPdf = function (reportData, filename) {
        try {
            console.log('💾 downloadReportPdf called, data length:', reportData?.length || 0);

            if (!reportData || reportData.length === 0) {
                console.error('❌ No report data provided');
                alert('Error: No report data to download');
                return;
            }

            const blob = new Blob([reportData], { type: 'application/pdf' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = filename || 'DailyReport.pdf';

            // Trigger download
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            // Clean up
            setTimeout(function () {
                URL.revokeObjectURL(link.href);
                console.log('✅ Download triggered, URL cleaned up');
            }, 100);

        } catch (error) {
            console.error('❌ Error in downloadReportPdf:', error);
            alert('Error downloading PDF: ' + error.message);
        }
    };

    /**
     * Helper function to download blob
     */
    function downloadBlob(blob, filename) {
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = filename || 'Report.pdf';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        setTimeout(() => URL.revokeObjectURL(link.href), 100);
    }

    console.log('✅ blazorReportsPrint functions loaded');
</script>

