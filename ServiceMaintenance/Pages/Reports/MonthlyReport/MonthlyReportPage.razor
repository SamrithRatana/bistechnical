    private void DetailGridPreviousPage(string customerType)
    {
        var currentPage = GetDetailGridCurrentPage(customerType);
        if (currentPage > 1)
        {
            LoadDetailGridDataFromCache(customerType, currentPage - 1, GetDetailGridPageSize(customerType));
