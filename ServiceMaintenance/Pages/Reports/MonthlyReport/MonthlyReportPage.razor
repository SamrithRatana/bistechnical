    private int GetDetailGridTotalPages(string customerType)
    {
        var total = GetDetailGridTotalRecords(customerType);
        var pageSize = GetDetailGridPageSize(customerType);
        return total > 0 ? (int)Math.Ceiling(total / (double)pageSize) : 0;
    }

    private bool HasDetailGridPreviousPage(string customerType)
    {
        return GetDetailGridCurrentPage(customerType) > 1;
