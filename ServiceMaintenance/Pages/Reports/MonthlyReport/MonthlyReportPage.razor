    private async Task FetchReport()
    {
        try
        {
            IsLoading = true;
            HasSearched = true;
            FilteredRepairServices.Clear();

            DetailGridData.Clear();
            DetailGridCurrentPages.Clear();
            DetailGridPageSizes.Clear();
            DetailGridTotalRecords.Clear();

            StateHasChanged();

            _lastStartDate = StartDate.Date;
            _lastEndDate = EndDate.Date;
            _lastServiceLocation = SelectedServiceLocation;
            _lastCustomerType = SelectedCustomerType;

            Console.WriteLine($"📊 Fetching report - ServiceLocation: {_lastServiceLocation}, CustomerType: {_lastCustomerType}");
            Console.WriteLine($"📅 Date Range: {_lastStartDate:yyyy-MM-dd} to {_lastEndDate:yyyy-MM-dd}");

            // ✅ STEP 1: Get total count first
            // Always filter by STATUS directly (same as engineer report FilterMode==2)
            var firstPageResult = await RepairService.SearchRepairServicesAsync(
                pageNumber: 1,
                pageSize: 1,
                fromDate: _lastStartDate,
                toDate: _lastEndDate,
                useProcessDateFiltering: false,                          // ✅ ALWAYS false
                status: "Finished,Customer Rejected,Unrepairable",       // ✅ Filter by status directly
                serviceLocation: _lastServiceLocation != "All" ? _lastServiceLocation : null,
                sortBy: "reportNo",
                sortDescending: true
            );

            if (firstPageResult == null || firstPageResult.TotalCount == 0)
            {
                Console.WriteLine("⚠️ No records found");
                TotalRecords = 0;
                IsLoading = false;
                StateHasChanged();
                return;
            }

            TotalRecords = firstPageResult.TotalCount;
            Console.WriteLine($"📊 Total records from API: {TotalRecords}");

            int optimalPageSize = TotalRecords <= 100 ? TotalRecords : 100;
            int totalPages = (int)Math.Ceiling(TotalRecords / (double)optimalPageSize);

            Console.WriteLine($"🔄 Loading {TotalRecords} records in {totalPages} page(s) of {optimalPageSize}...");

            var allRecords = new List<RepairServices>();

            // ✅ STEP 2: Load all pages in parallel
            var loadTasks = new List<Task<PaginatedResult<RepairServices>>>();

            for (int page = 1; page <= totalPages; page++)
            {
                var pageTask = RepairService.SearchRepairServicesAsync(
                    pageNumber: page,
                    pageSize: optimalPageSize,
                    fromDate: _lastStartDate,
                    toDate: _lastEndDate,
                    useProcessDateFiltering: false,                      // ✅ ALWAYS false
                    status: "Finished,Customer Rejected,Unrepairable",   // ✅ Filter by status directly
                    serviceLocation: _lastServiceLocation != "All" ? _lastServiceLocation : null,
                    sortBy: "reportNo",
                    sortDescending: true
                );
                loadTasks.Add(pageTask);
            }

            var results = await Task.WhenAll(loadTasks);

            foreach (var result in results)
            {
                if (result?.Items != null)
                    allRecords.AddRange(result.Items);
            }

            Console.WriteLine($"✅ Loaded {allRecords.Count} records from API");

            // ✅ STEP 3: Client-side safety validation (double-check status)
            var beforeValidation = allRecords.Count;
            allRecords = allRecords
                .Where(s => s.Status == "Finished" || s.Status == "Customer Rejected" || s.Status == "Unrepairable")
                .ToList();

            if (beforeValidation != allRecords.Count)
                Console.WriteLine($"⚠️ Removed {beforeValidation - allRecords.Count} records with mismatched status");

            Console.WriteLine($"📊 Status breakdown:");
            Console.WriteLine($"  - Finished: {allRecords.Count(r => r.Status == "Finished")}");
            Console.WriteLine($"  - Customer Rejected: {allRecords.Count(r => r.Status == "Customer Rejected")}");
            Console.WriteLine($"  - Unrepairable: {allRecords.Count(r => r.Status == "Unrepairable")}");

            // ✅ STEP 4: Assign validated records
            FilteredRepairServices = allRecords;

            // ✅ STEP 5: Enrich with customer types
            await EnrichWithCustomerTypes();

            // ✅ STEP 6: Apply customer type filter if needed
            if (_lastCustomerType != "All")
            {
                Console.WriteLine($"🔍 Filtering by customer type: {_lastCustomerType}");
                var beforeCount = FilteredRepairServices.Count;
                FilteredRepairServices = FilteredRepairServices
                    .Where(s => s.CustomerType == _lastCustomerType)
                    .ToList();
                Console.WriteLine($"📊 Filtered from {beforeCount} to {FilteredRepairServices.Count} records");
            }

            // ✅ STEP 7: Load spare parts
            await LoadSparePartsForAllRecords();

            // ✅ STEP 8: Final summary
            Console.WriteLine($"📊 ===== FINAL SUMMARY =====");
            Console.WriteLine($"  Total Records   : {FilteredRepairServices.Count}");
            Console.WriteLine($"  Finished        : {FilteredRepairServices.Count(r => r.Status == "Finished")}");
            Console.WriteLine($"  Customer Rejected: {FilteredRepairServices.Count(r => r.Status == "Customer Rejected")}");
            Console.WriteLine($"  Unrepairable    : {FilteredRepairServices.Count(r => r.Status == "Unrepairable")}");
            Console.WriteLine($"==========================");

            IsFilterSectionVisible = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error fetching report: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            FilteredRepairServices.Clear();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
    private async Task LoadSparePartsForAllRecords()
    {
        var sparePartIds = FilteredRepairServices
            .SelectMany(s => s.SparePartItems ?? Enumerable.Empty<SparePartItem>())
            .Where(item => item.SparePartId.HasValue)
            .Select(item => item.SparePartId.Value)
            .Distinct()
            .ToList();

        if (!sparePartIds.Any())
        {
            Console.WriteLine("No spare parts to load");
            return;
        }

        Console.WriteLine($"🔧 Loading {sparePartIds.Count} unique spare parts...");

        // Load spare parts in parallel batches of 10
        var batchSize = 10;
        var batches = sparePartIds
            .Select((id, index) => new { id, index })
            .GroupBy(x => x.index / batchSize)
            .Select(g => g.Select(x => x.id).ToList())
            .ToList();

        foreach (var batch in batches)
        {
            var tasks = batch.Select(async sparePartId =>
            {
                if (!_sparePartsCache.ContainsKey(sparePartId))
                {
                    try
                    {
                        var sparePart = await SparePartService.GetSparePartByIdAsync(sparePartId);
                        if (sparePart != null)
                        {
                            _sparePartsCache[sparePartId] = sparePart;
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"⚠️ Error loading spare part {sparePartId}: {ex.Message}");
                    }
                }
            });

            await Task.WhenAll(tasks);
        }

        _spareParts = _sparePartsCache.Values;
        Console.WriteLine($"✅ Loaded {_sparePartsCache.Count} spare parts (cached)");
    }

