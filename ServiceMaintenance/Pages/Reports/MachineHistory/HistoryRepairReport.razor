    private async Task<string> GetUserPhoneNumberById(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty)
        {
            return "N/A";
        }

        try
        {
            // ✅ Use GlobalUserCacheService with auto-load
            return await GlobalUserCache.GetUserPhoneNumberByIdAsync(userId, autoLoad: true);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, $"❌ Error getting phone number for {userId}");
            return "N/A";
        }
    }

    private async Task ShowReportPreview2()
    {
        try
        {
            // ✅ Load all pages for export (only when user clicks export)
            var allData = await LoadAllPagesForExport();

            if (allData == null || !allData.Any())
            {
                Console.WriteLine("No data available for export");
                // Optionally show a toast/alert to user
                return;
            }

            // Create an instance of the report
            var report = new HistoryReport(); // Changed from DailyReport to match your other method

            // Lists to hold the user names for repairBy and verifiedBy
            var repairByUsers = new List<string>();
            var verifiedByUsers = new List<string>();

            // Iterate over all data and fetch user names for each one
            foreach (var service in allData)
            {
                // Get the user names based on the GUIDs
                var repairByName = GetUserNameById(service.repairBy);
                var verifiedByName = GetUserNameById(service.verifiedBy);

                // Add the user names to the lists
                repairByUsers.Add(repairByName);
                verifiedByUsers.Add(verifiedByName);

                // Set the user names in the service object for future reference in the report
                service.RepairByName = repairByName;
                service.VerifiedByName = verifiedByName;
            }

            // Set the current user's name in the report
            report.SetDataSource(allData, repairByUsers, verifiedByUsers, CurrentUserName);

            // Export the report to PDF format
            byte[] reportData;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportData = ms.ToArray();
            }

            // Convert byte array to base64 string for JavaScript
            string base64Report = Convert.ToBase64String(reportData);

            // Use the existing blazorReportsPrint.downloadPDF function
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.downloadPDF", base64Report, "HistoryReport.pdf");
        }
