@page "/history-report"
@using DXApplication1
@using ServiceMaintenance.Models
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@using Syncfusion.Blazor.DropDowns

@inject RepairItemService RepairService
@inject GlobalUserService GlobalUserCache
@inject ILogger<HistoryRepairReport> Logger
@inject IJSRuntime JSRuntime
@inject ServiceSparePart SparePartService
@inject CustomerService CustomerService
@inject ItemService ItemService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inherits PermissionBase
@{
    bool enableAdaptiveUIMode = activeBreakpoint == "Small" || activeBreakpoint == "Medium";
    RowDirection renderingMode = activeBreakpoint == "Small" ? RowDirection.Vertical : RowDirection.Horizontal;
}
@if (CanAccess)
{
<DxToastProvider Name="Customization"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />
<DxToastProvider Name="Error"
                 MaxToastCount="5"
                 HorizontalAlignment="HorizontalAlignment.Right"
                 VerticalAlignment="VerticalEdge.Top"
                 AnimationType="@Animation" />

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" IconCssClass="far fa-file" CssClass="toolbar-item" Enabled="false" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="false" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="false" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]" IconCssClass="fas fa-download">
                <Items>
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]" Click="ExportToExcel" IconCssClass="fas fa-file-excel" />
                    <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]" Click="ShowReportPreview2" IconCssClass="fas fa-file-pdf" />
                </Items>
            </DxToolbarItem>
            <DxToolbarItem Text="Print Report" Click="ShowReportPreview" CssClass="toolbar-item" IconCssClass="fas fa-print" />
            <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" Enabled="false" />
        </DxToolbar>
    </div>
</div>

<hr />

<div class="container">
    <!-- Expand/Collapse Button -->
    <div class="row mb-3">
        <div class="col-md-12 text-end">
            <i class="fa @(IsFilterSectionVisible ? "fa-chevron-up" : "fa-chevron-down")"
               @onclick="ToggleFilterSection"
               style="cursor: pointer; font-size: 20px; color: #333;">
            </i>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section container" style="@($"display: {(IsFilterSectionVisible ? "block" : "none")};")">
        <div class="row g-3 align-items-end mb-3">

                        @if (FilterOption == "1")
            {
                <div class="col-md-3">
                    <label class="font-weight-bold" style="font-size:12px;">Item Name:</label>
                    <div class="combo-input-container">
                        <div class="combo-wrapper">
                            <SfComboBox @ref="comboObj"
                                        @onclick="OnComboBoxClick"
                                        TValue="string"
                                        TItem="string"
                                        Placeholder="Type 2+ characters to search"
                                        FloatLabelType="FloatLabelType.Auto"
                                        FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains"
                                        AllowFiltering="true"
                                        AllowCustom="false"
                                        IgnoreAccent="true"
                                        @bind-Value="SelectedItemName"
                                        DataSource="@UniqueItemNames"
                                        Width="100%"
                                        PopupWidth="450px"
                                        PopupHeight="300px">
                                <ComboBoxEvents TValue="string"
                                                TItem="string"
                                                Filtering="OnItemFiltering">
                                </ComboBoxEvents>
                            </SfComboBox>
                        </div>
                    </div>
                </div>
            }


            <!-- Serial Number input -->
            <div class="col-md-3">
                <label for="serialNumberFilter" class="font-weight-bold" style="font-size:12px;">
                    @Loc[nameof(ResourceStrings.TextSerialNumber)]:
                </label>
                <SfTextBox @bind-Value="SerialNumber" id="serialNumberFilter" class="form-control" Placeholder="Enter serial number" />
                @if (FilterOption == "1" && string.IsNullOrWhiteSpace(SerialNumber) && IsFormSubmitted)
                {
                    <span class="text-danger" style="font-size: 12px;">Serial Number is required.</span>
                }
            </div>

            <!-- Radio Buttons -->
            <div class="col-md-4">
                <label class="font-weight-bold" style="font-size:12px;">Select options:</label>
                <InputRadioGroup @bind-Value="FilterOption" class="d-flex flex-wrap">
                    <div class="me-3">
                        <InputRadio Value="@("1")" /> Item Name + Serial Number (Default)
                    </div>
                    <div class="me-3">
                        <InputRadio Value="@("2")" /> Only Serial Number
                    </div>
                </InputRadioGroup>
            </div>

            <!-- Fetch Report Button -->
            <div class="col-auto">
                <button class="btn btn-primary" @onclick="FetchReport" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Loading...</span>
                    }
                    else
                    {
                        @Loc[nameof(ResourceStrings.TextFetchReport)]
                    }
                </button>
            </div>
        </div>
    </div>
</div>

<hr />

<SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>


    @if (IsLoading)
    {
        <div class="text-center p-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading repair history...</p>
        </div>
    }
    else if (!HasSearched)
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle me-2"></i>
            Please select filter criteria and click "Fetch Report" to view repair history.
        </div>
    }
    else if (CurrentPage == null || !CurrentPage.Items.Any())
    {
        <div class="alert alert-warning text-center">
            <i class="fas fa-exclamation-triangle me-2"></i>
            No data available for the selected criteria.
        </div>
    }
    else
    {
        <SfGrid @ref="MyGrid"
                DataSource="@CurrentPage.Items"
                AllowSorting="true"
                ShowColumnChooser="true"
                AllowExcelExport="true"
                AllowPdfExport="true"
                EnableAdaptiveUI="@enableAdaptiveUIMode"
                RowRenderingMode="@renderingMode"
                SelectionMode="GridSelectionMode.Single"
                Toolbar="@ToolbarItems"
                AllowResizing="true"
                AllowFiltering="true"
                Height="500"
                AllowSelection="true">
            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
            <GridEvents RowSelected="RowSelectHandler" OnRecordDoubleClick="RowDoubleClickHandler" TValue="RepairServices"></GridEvents>

            <GridColumns>
                <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="100" Format="dd/MM/yyyy HH:mm tt"></GridColumn>
                <GridColumn Field="finishedDate" HeaderText="@Loc[nameof(ResourceStrings.TextFinishDate)]" Width="100" Format="dd/MM/yyyy HH:mm tt"></GridColumn>
                <GridColumn Field="Inspection" HeaderText="@Loc[nameof(ResourceStrings.TextProblem)]" Width="150"></GridColumn>
                <GridColumn Field="Solution" HeaderText="@Loc[nameof(ResourceStrings.Textsolution)]" Width="600"></GridColumn>
                <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" IsFrozen="true" Freeze="FreezeDirection.Right" Width="120">
                    <Template>
                        @if ((context as RepairServices)?.ServiceDate != null)
                        {
                            <DxButton IconCssClass="fas fa-eye"
                                      CssClass="icon-button info"
                                      RenderStyle="ButtonRenderStyle.Info"
                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                      Text="@Loc[nameof(ResourceStrings.TextView)]"
                                      @onclick="() => ShowRepairServiceDetails(context as RepairServices)" />

                            <DxButton IconCssClass="fas fa-file-invoice"
                                      CssClass="icon-button secondary"
                                      RenderStyle="ButtonRenderStyle.Secondary"
                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                      Text="Preview"
                                      Click="() => ShowReportPreview(context as RepairServices)" />
                        }
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>

        <!-- ✅ Pagination Controls -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                <span>Showing @CurrentPage.Items.Count of @CurrentPage.TotalCount records</span>
            </div>
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(CurrentPage.HasPreviousPage ? "" : "disabled")">
                        <button class="page-link" @onclick="() => LoadPage(CurrentPageNumber - 1)" disabled="@(!CurrentPage.HasPreviousPage)">
                            <i class="fas fa-chevron-left"></i> Previous
                        </button>
                    </li>

                    @for (int i = Math.Max(1, CurrentPageNumber - 2); i <= Math.Min(CurrentPage.TotalPages, CurrentPageNumber + 2); i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(pageNum == CurrentPageNumber ? "active" : "")">
                            <button class="page-link" @onclick="() => LoadPage(pageNum)">@pageNum</button>
                        </li>
                    }

                    <li class="page-item @(CurrentPage.HasNextPage ? "" : "disabled")">
                        <button class="page-link" @onclick="() => LoadPage(CurrentPageNumber + 1)" disabled="@(!CurrentPage.HasNextPage)">
                            Next <i class="fas fa-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </nav>
            <div>
                <span>Page @CurrentPageNumber of @CurrentPage.TotalPages</span>
            </div>
        </div>
    }

<SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
    <DialogTemplates>
        <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
        <Content>
            <div class="report-container">
                <div class="report-header">
                    <span>Repair Service Report</span>
                </div>
                <div class="report-body">
                    <table class="report-table">
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.reportNo</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceDate.ToString("yyyy-MM-dd HH:mm tt")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairDate)]:</strong></td>
                            <td class="report-value">
                                @(_selectedRepairService?.repairDate.HasValue == true
                                                                ? _selectedRepairService.repairDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                                                : "N/A")
                            </td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCompanyName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CompanyName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextAddress)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Address</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContactName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ContactName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPhoneNumber)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.PhoneNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextItemName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.itemName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextSerialNumber)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.serialNumber</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCustomerReq)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CustomerRequest</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextInspection)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Inspection</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textsolution)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Solution</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextServiceLocation)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceLocation</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextPriority)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServicePriority</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextStatus)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Status</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContract)]:</strong></td>
                            <td class="report-value">@(_selectedRepairService?.hasContract == true ? "Yes" : "No")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairBy)]:</strong></td>
                            <td class="report-value">@GetUserNameById(_selectedRepairService?.repairBy)</td>
                        </tr>
                    </table>
                    <hr />
                    @if (_selectedRepairService?.SparePartItems != null && _selectedRepairService.SparePartItems.Count > 0)
                        {
                            <h4>SparePart Details</h4>
                            <table class="report-table">
                                <thead>
                                    <tr>
                                        <th>@Loc[nameof(ResourceStrings.TextImage)]</th>
                                        <th>@Loc[nameof(ResourceStrings.TextItemName)]</th>
                                        <th>@Loc[nameof(ResourceStrings.TextUsefor)]</th>
                                        <th>@Loc[nameof(ResourceStrings.TextQty)]</th>
                                        <th>@Loc[nameof(ResourceStrings.TextCondition)]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sparePart in _selectedRepairService.SparePartItems)
                                    {
                                        var sparePartObject = _spareParts.FirstOrDefault(x => x.Id == sparePart.SparePartId);
                                        <tr>
                                            <td>
                                                @if (sparePartObject != null && !string.IsNullOrEmpty(sparePartObject.PictureUrl))
                                                {
                                                    <img src="@sparePartObject.PictureUrl" alt="Spare Part Image" style="max-width: 100px;" />
                                                }
                                                else
                                                {
                                                    <span>No Image</span>
                                                }
                                            </td>
                                            <td>@sparePartObject?.ItemName</td>
                                            <td>@sparePart.UseFor</td>
                                            <td>@sparePart.Quantity</td>
                                            <td>@sparePart.Condition</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="Close" IsPrimary="true" OnClick="@CloseDialog" />
        </DialogButtons>
    </SfDialog>

    <SfDialog @ref="DialogNoRecordSelected" IsModal="true" Width="250px" ShowCloseIcon="true" Visible="false">
        <DialogTemplates>
            <Header> Warning! </Header>
            <Content> @Loc[nameof(ResourceStrings.TextSelectRecord)] </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="OK" IsPrimary="true" OnClick="CloseDialogNoRecordSelected" />
        </DialogButtons>
    </SfDialog>
}


@code {



    // These are NOT in the new optimized code (and not needed):
    private int FilterType = 1;
    private DateTime SelectedDate = DateTime.Today;
    private DateTime StartDate = DateTime.Today.AddMonths(-1);
    private DateTime EndDate = DateTime.Today;
    private string SelectedStatus = "";
    private int SerialFilterType = 3;
    private int CompanyFilterType = 3;
    private List<ServiceStatus> StatusList = new();
    private bool isDialogVisible = false;
    private string CompanyName = "";
   
    private List<Repairs> Printers = new List<Repairs>();
    private Repairs currentItem = new Repairs();
    private List<string> ItemNames = new List<string>();
    private string searchTerm = string.Empty;
    private bool IsDropdownVisible = false;

    // ✅ Pagination variables
    private PaginatedResult<RepairServices> CurrentPage;
    private int CurrentPageNumber = 1;
    private int PageSize = 10;
    private bool HasSearched = false;

    // Filter variables
    private string FilterOption = "1";
    private string SerialNumber = "";
    private string SelectedItemName = "";
    private List<string> UniqueItemNames = new List<string>();
    private System.Threading.Timer _debounceTimer;

    // UI State
    private bool IsLoading = false;
    private bool IsFormSubmitted = false;
    private bool IsFilterSectionVisible = true;
    private string activeBreakpoint { get; set; }

    // Dialog and Grid
    private RepairServices _selectedRepairService;
    private bool isViewDialogVisible = false;
    private SfDialog DialogEdit;
    private SfDialog DialogNoRecordSelected;
    private SfGrid<RepairServices> MyGrid;
    private SfComboBox<string, string> comboObj;

    // Data
    private List<SparePartObject> _spareParts = new();
    private string CurrentUserName;

    // Toolbar
    public string[] ToolbarItems = new string[] { "ColumnChooser", "Search" };
    ToastAnimationType Animation { get; set; } = ToastAnimationType.Slide;

    protected override async Task OnPermissionsLoadedAsync()
    {
        Console.WriteLine($"🔐 DailyReportPage - CanAccess: {CanAccess}");
        Console.WriteLine($"🔐 DailyReportPage - PermissionsLoaded: {PermissionsLoaded}");

        if (!CanAccess)
        {
            Console.WriteLine("❌ Access Denied - User does not have DailyReportPage.Access permission");
            ShowError("You don't have permission to access this page");
            return; // Stop initialization
        }

        // Only continue with initialization if user has access
        await InitializePageData();
    }

    // ✅ STEP 3: Move your initialization logic here
    private async Task InitializePageData()
    {
        try
        {
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authenticationState.User;

            if (user.Identity.IsAuthenticated)
            {
                CurrentUserName = user.Identity.Name;
            }

            // ✅ NEW: Use GlobalUserCacheService to load users
            try
            {
                await GlobalUserCache.GetUsersAsync();
               
            }
            catch (Exception ex)
            {
                Logger?.LogError(ex, "❌ Failed to initialize GlobalUserCache");
            }

            // Start empty – do not load all items initially
            UniqueItemNames = new List<string>();
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "❌ Error in OnInitializedAsync");
        }
    }

   
    // ✅ Load unique item names on-demand
    private async Task LoadUniqueItemNamesAsync(string searchTerm = null)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < 2)
            {
                // Load minimal default set (first 50 items)
                UniqueItemNames = await ItemService.GetUniqueItemNamesAsync(
                    null,
                    pageNumber: 1,
                    pageSize: 50
                );

                Console.WriteLine($"Loaded {UniqueItemNames.Count} default item names");
            }
            else
            {
                // Load filtered set
                UniqueItemNames = await ItemService.GetUniqueItemNamesAsync(
                    searchTerm,
                    pageNumber: 1,
                    pageSize: 50
                );

                Console.WriteLine($"Loaded {UniqueItemNames.Count} unique item names for search: {searchTerm}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading unique names: {ex.Message}");
            UniqueItemNames = new List<string>();
        }
    }
    private void OnItemFiltering(Syncfusion.Blazor.DropDowns.FilteringEventArgs args)
    {
        args.PreventDefaultAction = true;

        // Cancel previous timer
        _debounceTimer?.Dispose();

        var searchText = args.Text;

        // Clear list if less than 2 chars
        if (string.IsNullOrWhiteSpace(searchText) || searchText.Length < 2)
        {
            UniqueItemNames = new List<string>();
            InvokeAsync(async () =>
            {
                await comboObj.FilterAsync(UniqueItemNames);
                StateHasChanged();
            });
            return;
        }

        // Debounce 300ms then fetch + push to ComboBox
        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await LoadUniqueItemNamesAsync(searchText);

                    // ✅ THIS is the missing piece — push new data into the open popup
                    await comboObj.FilterAsync(UniqueItemNames);

                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error in debounced search: {ex.Message}");
            }
        }, null, 300, Timeout.Infinite);
    }
    // ✅ NEW: Method to open ComboBox programmatically
    private async Task OnComboBoxClick(MouseEventArgs args)
    {
        await comboObj.ShowPopupAsync();
    }
    private async Task FetchReport()
    {
        try
        {
            
            IsLoading = true;
            IsFormSubmitted = true;

            // Validate Serial Number (when FilterOption=1)
            if (FilterOption == "1" && string.IsNullOrWhiteSpace(SerialNumber))
            {
                IsLoading = false;
                return;
            }

            // Validate minimum length
            if (!string.IsNullOrWhiteSpace(SerialNumber) && SerialNumber.Length < 2)
            {
                IsLoading = false;
                return;
            }

            // Validate item name selection from dropdown
            if (FilterOption == "1" &&
                !string.IsNullOrWhiteSpace(SelectedItemName) &&
                !UniqueItemNames.Any(name =>
                    name.Equals(SelectedItemName, StringComparison.OrdinalIgnoreCase)))
            {
                IsLoading = false;

                

                return;
            }

            // Reset and load first page
            CurrentPageNumber = 1;
            await LoadPage(1);

            HasSearched = true;
            IsFilterSectionVisible = false;
            IsFormSubmitted = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching report: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }


    // ✅ Load specific page with API pagination
    private async Task LoadPage(int pageNumber)
    {
        if (pageNumber < 1) return;

        try
        {
            IsLoading = true;
            CurrentPageNumber = pageNumber;

            // ✅ Use SearchRepairServicesAsync with pagination
            CurrentPage = await RepairService.SearchRepairServicesAsync(
                pageNumber: pageNumber,
                pageSize: PageSize,
                serialNumber: !string.IsNullOrWhiteSpace(SerialNumber) ? SerialNumber : null,
                searchTerm: FilterOption == "1" && !string.IsNullOrWhiteSpace(SelectedItemName) ? SelectedItemName : null,
                sortBy: "finishedDate",
                sortDescending: true
            );

            // Load spare parts only for current page items
            if (CurrentPage.Items.Any())
            {
                await LoadSparePartsForCurrentPage();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading page: {ex.Message}");
            CurrentPage = new PaginatedResult<RepairServices>
            {
                Items = new List<RepairServices>(),
                TotalCount = 0,
                PageNumber = pageNumber,
                PageSize = PageSize,
                TotalPages = 0
            };
        }
        finally
        {
            IsLoading = false;
        }
    }

    // ✅ FIXED: Load ONLY spare parts needed for current page
    private async Task LoadSparePartsForCurrentPage()
    {
        if (!CurrentPage.Items.Any()) return;

        try
        {
            // Get unique spare part IDs from current page (filter out nulls)
            var sparePartIds = CurrentPage.Items
                .Where(s => s.SparePartItems != null)
                .SelectMany(s => s.SparePartItems)
                .Where(sp => sp.SparePartId.HasValue) // ✅ Filter out null IDs
                .Select(sp => sp.SparePartId.Value)   // ✅ Get the Guid value
                .Distinct()
                .ToList();

            if (!sparePartIds.Any()) return;

            // ✅ Only load spare parts we don't already have
            var missingIds = sparePartIds
                .Where(id => !_spareParts.Any(sp => sp.Id == id))
                .ToList();

            if (missingIds.Any())
            {
                // ✅ Load ONLY the missing spare parts by ID
                foreach (var id in missingIds)
                {
                    try
                    {
                        var sparePart = await SparePartService.GetSparePartByIdAsync(id); // Now id is Guid, not Guid?
                        if (sparePart != null && !_spareParts.Any(sp => sp.Id == id))
                        {
                            _spareParts.Add(sparePart);
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error loading spare part {id}: {ex.Message}");
                    }
                }

                Console.WriteLine($"Loaded {missingIds.Count} spare parts for current page");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading spare parts: {ex.Message}");
        }
    }

    // ✅ Load all pages only when exporting
    private async Task<List<RepairServices>> LoadAllPagesForExport()
    {
        var allItems = new List<RepairServices>();
        int currentPage = 1;
        int totalPages = 1;

        do
        {
            var page = await RepairService.SearchRepairServicesAsync(
                pageNumber: currentPage,
                pageSize: 100, // Larger page size for export
                serialNumber: !string.IsNullOrWhiteSpace(SerialNumber) ? SerialNumber : null,
                searchTerm: FilterOption == "1" && !string.IsNullOrWhiteSpace(SelectedItemName) ? SelectedItemName : null,
                sortBy: "finishedDate",
                sortDescending: true
            );

            allItems.AddRange(page.Items);
            totalPages = page.TotalPages;
            currentPage++;

        } while (currentPage <= totalPages);

        return allItems;
    }

