    public string GetUserNameById(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty)
        {
            return "None";
        }

        try
        {
            // ✅ Use GlobalUserCacheService instead of local UserMap
            var userName = GlobalUserCache.GetUserNameById(userId);

            if (string.IsNullOrEmpty(userName) || userName == "Unknown User")
            {
                Logger?.LogWarning($"⚠️ User name not found for {userId}");
                return "None";
            }

            return userName;
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, $"❌ Error getting user name for {userId}");
            return "None";
        }
    }

