            var allFilteredServices = ApplyExactCompanyFilter(allRecordsResult.Items.ToList());

            await LoadSparePartsForServicesOptimized(allFilteredServices);

            var report = new DailyReport();
            var repairByUsers = new List<string>();
            var verifiedByUsers = new List<string>();

            // ✅ Process user lookups using GlobalUserCacheService
            foreach (var service in allFilteredServices)
            {
                var repairByName = GetUserNameById(service.repairBy);
                var verifiedByName = GetUserNameById(service.verifiedBy);

                repairByUsers.Add(repairByName);
                verifiedByUsers.Add(verifiedByName);

                service.RepairByName = repairByName;
                service.VerifiedByName = verifiedByName;
            }

            if (CompanyFilterType == 1)
            {
                report.Parameters["FromDate"].Value = SelectedDate;
                report.Parameters["ToDate"].Value = SelectedDate;
            }
            else if (CompanyFilterType == 2)
            {
                report.Parameters["FromDate"].Value = StartDate;
                report.Parameters["ToDate"].Value = EndDate;
            }

            report.SetDataSource(allFilteredServices, repairByUsers, verifiedByUsers, CurrentUserName);

            byte[] reportData;
            using (var ms = new MemoryStream())
            {
                report.ExportToPdf(ms);
                reportData = ms.ToArray();
            }

            string base64Report = Convert.ToBase64String(reportData);
            await JSRuntime.InvokeVoidAsync("blazorReportsPrint.previewReportInNewTab", base64Report, "ServiceReport.pdf");

            Logger?.LogInformation($"✅ Generated daily report with {allFilteredServices.Count} records");
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "❌ Error generating report");
        }
        finally
        {
            IsLoading = false;
        }
    }
    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}