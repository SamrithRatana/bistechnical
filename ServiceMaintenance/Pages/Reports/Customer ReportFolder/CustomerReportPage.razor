    private async Task LoadSparePartsForService(RepairServices service)
    {
        if (service?.SparePartItems == null || !service.SparePartItems.Any())
            return;

        try
        {
            foreach (var item in service.SparePartItems)
            {
                // Check if SparePartId has a value
                if (!item.SparePartId.HasValue)
                    continue;

                var sparePartId = item.SparePartId.Value;

                if (!_sparePartsCache.ContainsKey(sparePartId))
                {
                    var sparePart = await SparePartService.GetSparePartByIdAsync(sparePartId);
                    if (sparePart != null)
                    {
                        _sparePartsCache[sparePartId] = sparePart;
                        item.ItemName = sparePart.ItemName;
                    }
                }
                else
                {
                    item.ItemName = _sparePartsCache[sparePartId].ItemName;
                }
            }

            LoadedSparePartIds.Add(service.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading spare parts: {ex.Message}");
        }
    }

