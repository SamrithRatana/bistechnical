    private async Task LoadSparePartsForServicesOptimized(List<RepairServices> services)
    {
        // Collect all unique spare part IDs
        var sparePartIds = services
            .SelectMany(s => s.SparePartItems ?? Enumerable.Empty<SparePartItem>())
            .Where(item => item.SparePartId.HasValue)
            .Select(item => item.SparePartId.Value)
            .Distinct()
            .ToList();

        if (!sparePartIds.Any()) return;

        // Load only spare parts that aren't already cached
        foreach (var sparePartId in sparePartIds)
        {
            if (!_sparePartsCache.ContainsKey(sparePartId))
            {
                try
                {
                    var sparePart = await SparePartService.GetSparePartByIdAsync(sparePartId);
                    if (sparePart != null)
                    {
                        _sparePartsCache[sparePartId] = sparePart;
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error loading spare part {sparePartId}: {ex.Message}");
                }
            }
        }

        // Populate spare part names from cache
        foreach (var service in services)
        {
            foreach (var item in service.SparePartItems ?? Enumerable.Empty<SparePartItem>())
            {
                if (item.SparePartId.HasValue && _sparePartsCache.ContainsKey(item.SparePartId.Value))
                {
                    var sparePart = _sparePartsCache[item.SparePartId.Value];
                    item.ItemName = sparePart.ItemName;
                    item.SerialNumber = sparePart.SerialNumber;
                    item.UseFor = sparePart.UseFor;
                }
            }
        }
    }
