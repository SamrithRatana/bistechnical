    private async Task LoadCustomersAsync(bool reset = false)
    {
        if (IsLoadingCustomers) return;

        try
        {
            IsLoadingCustomers = true;
            if (reset)
            {
                CurrentCustomerPage = 1;
                _customers.Clear();
            }

            var pagedResponse = await CustomerService.GetCustomersPaginatedAsync(
                pageNumber: CurrentCustomerPage,
                pageSize: CustomerPageSize,
                searchTerm: string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                isActive: true
            );

            if (pagedResponse?.Data != null)
            {
                var newCustomers = pagedResponse.Data
                    .Where(c => !string.IsNullOrWhiteSpace(c.CompanyName))
                    .ToList();

                if (reset)
                {
                    _customers = newCustomers;
                }
                else
                {
                    foreach (var customer in newCustomers)
                    {
                        if (!_customers.Any(c => c.CompanyName == customer.CompanyName))
                        {
                            _customers.Add(customer);
                        }
                    }
                }

                TotalCustomers = pagedResponse.TotalRecords;
                HasMoreCustomers = pagedResponse.HasNext;
            }
        }
        finally
        {
            IsLoadingCustomers = false;
        }
    }

