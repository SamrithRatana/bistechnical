    private string HighlightMatch(string text, string search)
    {
        if (string.IsNullOrWhiteSpace(search) || string.IsNullOrWhiteSpace(text))
            return System.Net.WebUtility.HtmlEncode(text ?? "");

        var result = new System.Text.StringBuilder();
        int lastIndex = 0;
        int searchLen = search.Length;
        string textLower = text.ToLower();
        string searchLower = search.ToLower();

        int idx;
        while ((idx = textLower.IndexOf(searchLower, lastIndex, StringComparison.OrdinalIgnoreCase)) >= 0)
        {
            // Append text before match (HTML-encoded)
            result.Append(System.Net.WebUtility.HtmlEncode(text.Substring(lastIndex, idx - lastIndex)));
            // Append highlighted match
            result.Append("<mark style=\"background-color: #FFD700; color: #000; padding: 0; font-weight: bold;\">");
            result.Append(System.Net.WebUtility.HtmlEncode(text.Substring(idx, searchLen)));
            result.Append("</mark>");
            lastIndex = idx + searchLen;
        }

        // Append remaining text
        result.Append(System.Net.WebUtility.HtmlEncode(text.Substring(lastIndex)));
        return result.ToString();
    }
    private async Task FetchReport()
    {
        // ✅ Validate: at least one status must be selected
        if (SelectedStatuses == null || SelectedStatuses.Length == 0)
        {
            ShowStatusValidationError = true;
            return;
        }

        ShowStatusValidationError = false; // clear once valid
        try
        {
            IsLoading = true;
            HasSearched = true;
            CurrentPage = 1;
            FilteredRepairServices.Clear();
            _allFilteredRecords.Clear();
            LoadedSparePartIds.Clear();

            string companySearchTerm = null;
            string serialSearchTerm = null;

            if (_selectedCompany != null && _useExactCompanyMatch)
                companySearchTerm = _selectedCompany.CompanyName;
            else if (!string.IsNullOrWhiteSpace(searchTerm))
                companySearchTerm = searchTerm.Trim();

            if (CompanyFilterType == 4 && !string.IsNullOrWhiteSpace(SerialNumber))
                serialSearchTerm = SerialNumber.Trim();

            _lastSearchCompany = companySearchTerm;
            _lastSearchSerial = serialSearchTerm;
            _lastSearchStatuses = SelectedStatuses;

            if (CompanyFilterType == 1)
            {
                _lastFromDate = SelectedDate;
                _lastToDate = SelectedDate;
            }
            else if (CompanyFilterType == 2)
            {
                _lastFromDate = StartDate;
                _lastToDate = EndDate;
            }
            else
            {
                _lastFromDate = null;
                _lastToDate = null;
            }

            // ✅ FIX: Fetch ALL records first, then apply exact filter, then paginate client-side
            var result = await RepairService.SearchRepairServicesAsync(
                pageNumber: 1,
                pageSize: int.MaxValue,  // fetch all
                searchTerm: _lastSearchCompany,
                serialNumber: _lastSearchSerial,
                status: _lastSearchStatuses != null && _lastSearchStatuses.Any()
                    ? string.Join(",", _lastSearchStatuses) : null,
                fromDate: _lastFromDate,
                toDate: _lastToDate,
                sortBy: "ServiceDate",
                sortDescending: true
            );

            // ✅ Apply exact filter on ALL records
            _allFilteredRecords = ApplyExactCompanyFilter(result.Items.ToList());
            TotalRecords = _allFilteredRecords.Count;

            // ✅ Paginate client-side
            FilteredRepairServices = _allFilteredRecords
                .Skip((CurrentPage - 1) * PageSize)
                .Take(PageSize)
                .ToList();

            IsFilterSectionVisible = false;
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "❌ Error fetching report");
        }
        finally
        {
            IsLoading = false;
        }
    }
    private List<RepairServices> ApplyExactCompanyFilter(List<RepairServices> services)
    {
        // ✅ ALWAYS apply exact filter when company is selected from dropdown
        if (!_useExactCompanyMatch || _selectedCompany == null)
        {
            Logger?.LogInformation($"ℹ️ No exact filter needed (_useExactCompanyMatch={_useExactCompanyMatch}, _selectedCompany={_selectedCompany != null})");
            return services;
        }

        var beforeCount = services.Count;
        var targetCompanyName = _selectedCompany.CompanyName;

        Logger?.LogInformation($"🎯 Applying EXACT company filter for: '{targetCompanyName}'");

        // ✅ Use exact string comparison (case-insensitive)
        var filtered = services
            .Where(r => !string.IsNullOrWhiteSpace(r.CompanyName) &&
                       r.CompanyName.Trim().Equals(targetCompanyName.Trim(), StringComparison.OrdinalIgnoreCase))
            .ToList();

        Logger?.LogInformation($"📊 Exact company filter results: {beforeCount} → {filtered.Count} records");

        if (filtered.Count == 0)
        {
            Logger?.LogWarning($"⚠️ No records found for exact company: '{targetCompanyName}'");
            // Log some example company names from the results to help debug
            var sampleNames = services.Take(5).Select(s => s.CompanyName).ToList();
            Logger?.LogWarning($"Sample company names in results: {string.Join(", ", sampleNames)}");
        }

        // ✅ Update total records to match filtered count

        return filtered;
    }
