@code {
    private DateTime? fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? toDate = DateTime.Today;
    private string searchTerm;
    private string statusFilter = "Finished";
    private string serviceTypeFilter = string.Empty;
    private string conditionFilter = string.Empty;
    private string sourceFilter = string.Empty;
    private string reportMode = "standard";
    private string sortBy = "usedquantity";
    private bool sortDescending = true;
    private int currentPage = 1;
    private int pageSize = 15;
    private bool includeManual = true;
    private HashSet<Guid> expandedRows = new();
    private bool ignoreDateFilter = false;

    private PaginatedResult<SparepartUsageSummary> result;
    private bool isLoading;
    private string errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await Search();
    }

    private async Task Search()
    {
        currentPage = 1;
        expandedRows.Clear();
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            result = await SparepartUsageService.GetSparepartUsageAsync(
     pageNumber: currentPage,
     pageSize: pageSize,
     fromDate: ignoreDateFilter ? null : fromDate,       // ← pass null when ignored
     toDate: ignoreDateFilter ? null : toDate,           // ← pass null when ignored
     searchTerm: searchTerm,
     status: string.IsNullOrEmpty(statusFilter) ? null : statusFilter,
     sortBy: sortBy,
     sortDescending: sortDescending,
     includeManualStockOut: includeManual,
     serviceType: string.IsNullOrEmpty(serviceTypeFilter) ? null : serviceTypeFilter,
     condition: string.IsNullOrEmpty(conditionFilter) ? null : conditionFilter,
     sourceFilter: string.IsNullOrEmpty(sourceFilter) ? null : sourceFilter,
     dateMode: reportMode
 );
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load data: {ex.Message}";
            Console.WriteLine($"[SparepartUsage] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleExpand(Guid id)
    {
        if (expandedRows.Contains(id))
            expandedRows.Remove(id);
        else
            expandedRows.Add(id);
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        expandedRows.Clear();
        await LoadData();
    }

    private async Task ToggleSortDir(bool desc)
    {
        sortDescending = desc;
        await Search();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    private void ResetFilters()
    {
        fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        toDate = DateTime.Today;
        searchTerm = null;
        statusFilter = "Finished";
        serviceTypeFilter = string.Empty;
        conditionFilter = string.Empty;
        sourceFilter = string.Empty;
        reportMode = "standard";
        sortBy = "usedquantity";
        sortDescending = true;
        currentPage = 1;
        result = null;
        ignoreDateFilter = false;
        expandedRows.Clear();
    }

    private bool IsThisMonth() =>
        fromDate == new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)
        && toDate?.Date == DateTime.Today;

    private enum QuickDate { Today, ThisWeek, ThisMonth, LastMonth, ThisYear }

    private void SetQuickDate(QuickDate q)
    {
        var today = DateTime.Today;
        (fromDate, toDate) = q switch
        {
            QuickDate.Today => (today, today),
            QuickDate.ThisWeek => (today.AddDays(-(int)today.DayOfWeek), today),
            QuickDate.ThisMonth => (new DateTime(today.Year, today.Month, 1), today),
            QuickDate.LastMonth => (new DateTime(today.Year, today.Month, 1).AddMonths(-1),
                                    new DateTime(today.Year, today.Month, 1).AddDays(-1)),
            QuickDate.ThisYear => (new DateTime(today.Year, 1, 1), today),
            _ => (fromDate, toDate)
        };
    }

    private string GetStatusClass(string status) => status switch
    {
        "Repairing" => "status-repairing",
        "Finished" => "status-finished",
        "Awaiting Sparepart" => "status-awaiting",
        "Awaiting Customer Confirm" => "status-awaiting",
        "Customer Rejected" => "status-rejected",
        "Repair by Third-Party" => "status-thirdparty",
        "Unrepairable" => "status-rejected",
        _ => "status-default"
    };

    // ✅ NEW: condition badge CSS class
    private string GetConditionClass(string condition) => condition switch
    {
        "Fix" => "cond-fix",
        "Replace" => "cond-replace",
        "Free" => "cond-free",
        _ => ""
    };

    private async Task ExportToExcel()
    {
        if (result == null) return;

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var allData = await SparepartUsageService.GetSparepartUsageAsync(
                pageNumber: 1,
                pageSize: int.MaxValue,
                fromDate: ignoreDateFilter ? null : fromDate,
                toDate: ignoreDateFilter ? null : toDate,
                searchTerm: searchTerm,
                status: string.IsNullOrEmpty(statusFilter) ? null : statusFilter,
                sortBy: sortBy,
                sortDescending: sortDescending,
                includeManualStockOut: includeManual,
                serviceType: string.IsNullOrEmpty(serviceTypeFilter) ? null : serviceTypeFilter,
                condition: string.IsNullOrEmpty(conditionFilter) ? null : conditionFilter,
                sourceFilter: string.IsNullOrEmpty(sourceFilter) ? null : sourceFilter,
                dateMode: reportMode
            );

            if (allData == null || !allData.Items.Any())
            {
                errorMessage = "No data to export.";
                return;
            }

            var firstItem = allData.Items.FirstOrDefault();
            Console.WriteLine($"[Export Debug] First item: '{firstItem?.ItemName}' " +
                              $"| Services count: {firstItem?.Services?.Count ?? -1}");

            var headers = new[]
            {
            "No",
            "Sparepart Name",
            "Sparepart Serial",
            "Stock Qty",
            "Total Used Qty",
            "Usage %",
            "Source",
            "Report No",
            "Machine Name",
            "Machine Serial",
            "Company",
            "Service Status",
            "Service Type",
            "Used Qty (per job)",
            "Condition",
            "Reason",
            "Date (Audit)"
        };

            var rows = new List<object[]>();
            int no = 1;

            foreach (var item in allData.Items)
            {
                var pct = item.StockQuantity > 0
                    ? Math.Round((double)item.UsedQuantity / item.StockQuantity * 100, 1)
                    : 100.0;

                var detailRows = item.Services;

                if (detailRows == null || detailRows.Count == 0)
                {
                    rows.Add(new object[]
                    {
                    no,
                    item.ItemName,
                    item.SerialNumber ?? "—",
                    item.StockQuantity,
                    item.UsedQuantity,
                    pct,
                    "—", "—", "—", "—", "—", "—", "—",
                    item.UsedQuantity,
                    "—", "—", "—"
                    });
                    no++;
                    continue;
                }

                bool isFirst = true;
                foreach (var svc in detailRows)
                {
                    bool isManual = svc.Source == "Manual";

                    rows.Add(new object[]
                    {
                    // Sparepart summary columns — first row only
                    isFirst ? (object)no                     : "",
                    isFirst ? item.ItemName                  : "",
                    isFirst ? (item.SerialNumber ?? "—")     : "",
                    isFirst ? (object)item.StockQuantity     : "",
                    isFirst ? (object)item.UsedQuantity      : "",
                    isFirst ? (object)pct                    : "",

                    // Service detail columns — every row
                    isManual ? "Manual" : "Service",
                    isManual ? "—" : (svc.ReportNo ?? "—"),
                    isManual ? "—" : (string.IsNullOrEmpty(svc.MachineItemName)    ? "—" : svc.MachineItemName),
                    isManual ? "—" : (string.IsNullOrEmpty(svc.MachineSerialNumber) ? "—" : svc.MachineSerialNumber),
                    svc.CompanyName ?? "—",
                    isManual ? "Stock Out" : (svc.ServiceStatus ?? "—"),
                    isManual || string.IsNullOrEmpty(svc.ServiceType) || svc.ServiceType == "—"
                        ? "—" : svc.ServiceType,
                    (object)svc.Quantity,
                    isManual ? "—" : (string.IsNullOrEmpty(svc.Condition) ? "N/A" : svc.Condition),
                    isManual && !string.IsNullOrEmpty(svc.Reason) && svc.Reason != "—"
                        ? svc.Reason : "—",
                    svc.ProcessDate.HasValue
                        ? svc.ProcessDate.Value.AddHours(7).ToString("dd MMM yyyy HH:mm")
                        : "—"
                    });

                    isFirst = false;
                }
                no++;
            }

            // Grand total row — 17 columns
            rows.Add(new object[]
            {
            "TOTAL", "", "",
            allData.Items.Sum(x => x.StockQuantity),
            allData.TotalUsedQuantity,
            "", "", "", "", "", "", "", "",
            allData.TotalUsedQuantity,
            "", "", ""
            });

            var dateRange = fromDate.HasValue || toDate.HasValue
                ? $"_{fromDate:yyyyMMdd}-{toDate:yyyyMMdd}"
                : $"_{DateTime.Today:yyyyMMdd}";

            await JS.InvokeVoidAsync("exportToExcel", rows, headers,
                $"SparepartUsage{dateRange}.xlsx", "Sparepart Usage");
        }
        catch (Exception ex)
        {
            errorMessage = $"Export failed: {ex.Message}";
            Console.WriteLine($"[Export Error] {ex}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
