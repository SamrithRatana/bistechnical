@code {
    private string searchTerm;
    private string statusFilter = string.Empty;
    private string serviceTypeFilter = string.Empty;
    private string sortBy = "holdqty";
    private bool sortDescending = true;
    private int currentPage = 1;
    private int pageSize = 15;

    private SparepartHoldResult result;
    private bool isLoading;
    private string errorMessage;
    private HashSet<Guid> expandedRows = new();

    protected override async Task OnInitializedAsync()
    {
        await Search();
    }

    private async Task Search()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            result = await SparepartHoldService.GetSparepartHoldAsync(
                pageNumber: currentPage,
                pageSize: pageSize,
                searchTerm: searchTerm,
                status: string.IsNullOrEmpty(statusFilter) ? null : statusFilter,
                serviceType: string.IsNullOrEmpty(serviceTypeFilter) ? null : serviceTypeFilter,
                sortBy: sortBy,
                sortDescending: sortDescending
            );
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadData();
    }

    private async Task ToggleSortDir(bool desc)
    {
        sortDescending = desc;
        await Search();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    private void ResetFilters()
    {
        searchTerm = null;
        statusFilter = string.Empty;
        serviceTypeFilter = string.Empty;
        sortBy = "holdqty";
        sortDescending = true;
        currentPage = 1;
        result = null;
    }

    private void ToggleExpand(Guid id)
    {
        if (expandedRows.Contains(id))
            expandedRows.Remove(id);
        else
            expandedRows.Add(id);
    }

    private string GetStatusClass(string status) => status switch
    {
        "Repairing"                  => "status-repairing",
        "Finished"                   => "status-finished",
        "Awaiting Sparepart"         => "status-awaiting",
        "Awaiting Customer Confirm"  => "status-awaiting",
        "Customer Rejected"          => "status-rejected",
        "Repair by Third-Party"      => "status-thirdparty",
        "Unrepairable"               => "status-rejected",
        _                            => "status-default"
    };
    private async Task ExportToExcel()
    {
        if (result == null) return;

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            // Fetch ALL pages
            var allData = await SparepartHoldService.GetSparepartHoldAsync(
                pageNumber: 1,
                pageSize: result.TotalCount,   // ← fetch everything
                searchTerm: searchTerm,
                status: string.IsNullOrEmpty(statusFilter) ? null : statusFilter,
                serviceType: string.IsNullOrEmpty(serviceTypeFilter) ? null : serviceTypeFilter,
                sortBy: sortBy,
                sortDescending: sortDescending
            );

            if (allData == null || !allData.Items.Any())
            {
                errorMessage = "No data to export.";
                return;
            }

            var headers = new[]
            {
            "No", "Sparepart Name", "Serial Number",
            "Current Stock", "Hold Qty", "Effective Stock", "Hold Jobs",
            "Report No", "Company", "Service Status", "Hold Qty (per job)", "Condition"
        };

            var rows = new List<object[]>();
            int no = 1;

            foreach (var item in allData.Items)
            {
                var effectiveStock = item.CurrentStock - item.TotalHoldQty;

                if (item.Services == null || !item.Services.Any())
                {
                    rows.Add(new object[]
                    {
                    no++, item.ItemName, item.SerialNumber ?? "—",
                    item.CurrentStock, item.TotalHoldQty, effectiveStock, item.HoldCount,
                    "", "", "", "", ""
                    });
                }
                else
                {
                    bool first = true;
                    foreach (var svc in item.Services)
                    {
                        rows.Add(new object[]
                        {
                        first ? (object)no : "",
                        first ? item.ItemName : "",
                        first ? (item.SerialNumber ?? "—") : "",
                        first ? (object)item.CurrentStock : "",
                        first ? (object)item.TotalHoldQty : "",
                        first ? (object)effectiveStock : "",
                        first ? (object)item.HoldCount : "",
                        svc.ReportNo,
                        svc.CompanyName,
                        svc.ServiceStatus,
                        svc.Quantity,
                        string.IsNullOrEmpty(svc.Condition) ? "N/A" : svc.Condition
                        });
                        first = false;
                    }
                    no++;
                }
            }

            var fileName = $"SparepartHold_{DateTime.Today:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("exportToExcel", rows, headers, fileName, "Sparepart Hold");
        }
        catch (Exception ex)
        {
            errorMessage = $"Export failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
