@page "/repair-report"
@using System.Globalization
@using ServiceMaintenance.Models
@using ServiceMaintenance.Services
@inject IJSRuntime JSRuntime
@inject RepairItemService RepairItemService
@inject GlobalUserService UserCacheService 
@inherits PermissionBase
@if (CanAccess)
{
<PageTitle>Monthly Repair Quantity Report</PageTitle>

    <div class="report-container">
        <!-- Filter Section -->
        <div class="filter-section">
            <div class="filter-header">
                <h3>📊 Report Filters</h3>
            </div>
            <div class="filter-body">
                <div class="filter-row">
                    <div class="filter-group">
                        <label class="filter-label">Filter Type</label>
                        <select class="filter-input" @bind="filterType">
                            <option value="year">By Year</option>
                            <option value="dateRange">By Date Range</option>
                        </select>
                    </div>

                    @if (filterType == "year")
                    {
                        <div class="filter-group">
                            <label class="filter-label">Report Year</label>
                            <select class="filter-input" @bind="selectedYear">
                                @for (int year = DateTime.Now.Year - 1; year <= DateTime.Now.Year + 1; year++)
                                {
                                    <option value="@year">@year</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <div class="filter-group">
                            <label class="filter-label">From Date</label>
                            <input type="date" class="filter-input" @bind="fromDate" @bind:format="yyyy-MM-dd" />
                        </div>

                        <div class="filter-group">
                            <label class="filter-label">To Date</label>
                            <input type="date" class="filter-input" @bind="toDate" @bind:format="yyyy-MM-dd" />
                        </div>
                    }
                    <div class="filter-group">

                        <label class="filter-label">

                            <input type="checkbox" @bind="showStatusFilter" style="margin-right: 5px;" />

                            Filter by Status

                        </label>

                        @if (!showStatusFilter || selectedStatusId == 0)

                        {

                            <small style="color: #e74c3c; font-size: 11px; margin-top: 4px;">

                                ⚠️ Required: select a status to generate

                            </small>

                        }

                    </div>

                    @if (showStatusFilter)
                    {
                        <div class="filter-group">
                            <label class="filter-label">Status (Optional)</label>
                            <select class="filter-input" @bind="selectedStatusId">
                                <option value="0">All Statuses</option>
                                @foreach (var status in availableStatuses)
                                {
                                    <option value="@status.Id">@status.Name</option>
                                }
                            </select>
                        </div>
                    }



                    <div class="filter-group">
                        <button class="btn-generate" @onclick="GenerateReport" disabled="@(isLoading || !IsFormValid())">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            else
                            {
                                <span>🔄</span>
                            }
                            Generate Report
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert-error">⚠️ @errorMessage</div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert-success">✅ @successMessage</div>
                }
            </div>
        </div>

        <!-- Report Header -->
        <div class="report-header">
            <div class="report-info">
                <h2>REPAIR QUANTITY SUMMARY REPORT</h2>
                <table class="info-table">
                    <tr>
                        <td class="label">DATE PREPARED</td>
                        <td class="value">@DateTime.Now.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <td class="label">REPORT YEAR</td>
                        <td class="value">
                            @if (filterType == "year")
                            {
                                @selectedYear
                            }
                            else
                            {
                                @($"{fromDate:dd/MM/yyyy} - {toDate:dd/MM/yyyy}")
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <button class="btn-print" @onclick="PrintReport">
            <span class="print-icon">🖨️</span> Print Report
        </button>

        @if (Engineers.Any())
        {
            <div class="table-wrapper">
                <table class="financial-table">
                    <thead>
                        <tr class="header-row">
                            <th class="col-name">Engineer Name</th>
                            <th class="col-type">Type</th>
                            <th class="col-month">Jan</th>
                            <th class="col-month">Feb</th>
                            <th class="col-month">Mar</th>
                            <th class="col-month">Apr</th>
                            <th class="col-month">May</th>
                            <th class="col-month">Jun</th>
                            <th class="col-month">Jul</th>
                            <th class="col-month">Aug</th>
                            <th class="col-month">Sep</th>
                            <th class="col-month">Oct</th>
                            <th class="col-month">Nov</th>
                            <th class="col-month">Dec</th>
                            <th class="col-total">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var engineer in Engineers)
                        {
                            <tr class="data-row">
                                <td class="engineer-cell" rowspan="2">@engineer.EngineerUserName</td>
                                <td class="type-cell">Onsite</td>
                                @{
                                    int onsiteTotal = 0;
                                }
                                @for (int i = 1; i <= 12; i++)
                                {
                                    var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(i);
                                    var data = GetMonthlyData(engineer, monthName);
                                    var onsite = data?.Onsite ?? 0;
                                    onsiteTotal += onsite;
                                    <td class="number-cell @(onsite > 0 ? "has-data" : "")">@onsite</td>
                                }
                                <td class="number-cell subtotal-cell">@onsiteTotal</td>
                            </tr>
                            <tr class="data-row">
                                <td class="type-cell">CompanyService</td>
                                @{
                                    int compSvcTotal = 0;
                                }
                                @for (int i = 1; i <= 12; i++)
                                {
                                    var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(i);
                                    var data = GetMonthlyData(engineer, monthName);
                                    var compSvc = data?.CompanyService ?? 0;
                                    compSvcTotal += compSvc;
                                    <td class="number-cell @(compSvc > 0 ? "has-data" : "")">@compSvc</td>
                                }
                                <td class="number-cell subtotal-cell">@compSvcTotal</td>
                            </tr>
                            <tr class="total-row">
                                <td class="engineer-cell-blank"></td>
                                <td class="type-cell total-label">Total</td>
                                @{
                                    int grandTotal = 0;
                                }
                                @for (int i = 1; i <= 12; i++)
                                {
                                    var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(i);
                                    var data = GetMonthlyData(engineer, monthName);
                                    var monthTotal = data?.Total ?? 0;
                                    grandTotal += monthTotal;
                                    <td class="number-cell total-value">@monthTotal</td>
                                }
                                <td class="number-cell total-value grand-total">@grandTotal</td>
                            </tr>
                            <tr class="spacing-row">
                                <td colspan="15">&nbsp;</td>
                            </tr>
                        }
                        <tr class="grand-total-row">
                            <td class="engineer-cell" colspan="2">GRAND TOTAL</td>
                            @{
                                int overallTotal = 0;
                            }
                            @for (int i = 1; i <= 12; i++)
                            {
                                var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(i);
                                var monthTotal = Engineers.Sum(e => GetMonthlyData(e, monthName)?.Total ?? 0);
                                overallTotal += monthTotal;
                                <td class="number-cell total-value grand-total-cell">@monthTotal</td>
                            }
                            <td class="number-cell total-value overall-total">@overallTotal</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="signature-section">
                <div class="signature-box">
                    <div class="signature-label">Technical Approval</div>
                    <div class="signature-line"></div>
                    <div class="signature-name">Name: _______________________</div>
                </div>
            </div>
        }
        else if (!isLoading)
        {
            <div class="no-data-message">
                <div class="no-data-icon">📊</div>
                <h3>No Data Available</h3>
                <p>Please select a year and click "Generate Report" to view data.</p>
            </div>
        }
    </div>

}

@code {
    private List<EngineerRepairReport> Engineers = new();
    private int selectedYear = DateTime.Now.Year;
    private int selectedStatusId = 0;
    private bool isLoading = false;
    private string errorMessage = "";
    private string successMessage = "";
    private Dictionary<string, string> _userCache = new();
    private bool _usersLoaded = false;
    private List<ServiceStatus> availableStatuses = new List<ServiceStatus>();
    private string filterType = "year";
    private DateTime fromDate = new DateTime(DateTime.Now.Year, 1, 1);
    private DateTime toDate = DateTime.Now;
    private bool showStatusFilter = false;
    protected override async Task OnPermissionsLoadedAsync()
    {
        Console.WriteLine($"🔐 DailyReportPage - CanAccess: {CanAccess}");
        Console.WriteLine($"🔐 DailyReportPage - PermissionsLoaded: {PermissionsLoaded}");

        if (!CanAccess)
        {
            Console.WriteLine("❌ Access Denied - User does not have DailyReportPage.Access permission");
            ShowError("You don't have permission to access this page");
            return; // Stop initialization
        }

        // Only continue with initialization if user has access
        await InitializePageData();
    }
    private async Task InitializePageData()
    {
        try
        {
            // ✅ STEP 1: Load users first
            await LoadAllUsersAsync();

            // ✅ STEP 2: Load statuses
            availableStatuses = (await RepairItemService.GetServiceStatusesAsync())?.ToList() ?? new List<ServiceStatus>();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading statuses: {ex.Message}";
        }
    }
    
    private async Task LoadAllUsersAsync()
    {
        if (_usersLoaded)
            return;

        try
        {
            Console.WriteLine("📥 Loading all users from UserCacheService...");
            _userCache = await UserCacheService.GetUsersAsync();
            _usersLoaded = true;
            Console.WriteLine($"✅ Loaded {_userCache.Count} users into cache");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading users: {ex.Message}");
            errorMessage = $"Error loading users: {ex.Message}";
            _userCache = new Dictionary<string, string>();
        }
    }
    private bool IsFormValid()
    {
        // Must have "Filter by Status" checked AND a specific status selected
        if (!showStatusFilter) return false;
        if (selectedStatusId == 0) return false;
        return true;
    }
    private async Task GenerateReport()
    {
        if (!IsFormValid())
        {
            errorMessage = "Please enable 'Filter by Status' and select a specific status before generating the report.";
            return;
        }
        try
        {
            isLoading = true;
            errorMessage = "";
            successMessage = "";
            Engineers.Clear();

            DateTime searchFromDate;
            DateTime searchToDate;

            if (filterType == "year")
            {
                searchFromDate = new DateTime(selectedYear, 1, 1);
                searchToDate = new DateTime(selectedYear, 12, 31);
            }
            else
            {
                if (fromDate > toDate)
                {
                    errorMessage = "From Date cannot be greater than To Date.";
                    return;
                }
                searchFromDate = fromDate;
                searchToDate = toDate;
            }

            string statusName = null;
            if (selectedStatusId > 0)
            {
                statusName = availableStatuses.FirstOrDefault(s => s.Id == selectedStatusId)?.Name;
            }

            var initialResult = await RepairItemService.SearchRepairServicesAsync(
                pageNumber: 1,
                pageSize: 1,
                fromDate: searchFromDate,
                toDate: searchToDate,
                status: statusName
            );

            if (initialResult == null || initialResult.TotalCount == 0)
            {
                errorMessage = $"No data found for selected period.";
                return;
            }

            var result = await RepairItemService.SearchRepairServicesAsync(
                pageNumber: 1,
                pageSize: initialResult.TotalCount,
                fromDate: searchFromDate,
                toDate: searchToDate,
                status: statusName
            );

            if (!_usersLoaded)
            {
                await LoadAllUsersAsync();
            }

            var servicesWithEngineer = result.Items
                .Where(s => GetEngineerGuidByStatus(s).HasValue)
                .ToList();

            if (!servicesWithEngineer.Any())
            {
                errorMessage = "No services found with engineer assignments for the selected status.";
                return;
            }

            var engineerGroups = servicesWithEngineer
                .GroupBy(s => GetEngineerGuidByStatus(s).Value)
                .OrderBy(g => g.Key);

            foreach (var engineerGroup in engineerGroups)
            {
                var engineerGuid = engineerGroup.Key;
                var engineerGuidString = engineerGuid.ToString();

                // ✅ Use cached users
                string engineerUsername = _userCache.TryGetValue(engineerGuidString, out string username)
                    ? username
                    : "Unknown Engineer";

                var engineerReport = new EngineerRepairReport
                {
                    EngineerUserName = engineerUsername,
                    MonthlyRepairs = new Dictionary<string, RepairData>()
                };

                for (int month = 1; month <= 12; month++)
                {
                    var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(month);
                    engineerReport.MonthlyRepairs[monthName] = new RepairData { Onsite = 0, CompanyService = 0 };
                }

                foreach (var service in engineerGroup)
                {
                    var serviceDate = GetDateByStatus(service);

                    if (!serviceDate.HasValue || serviceDate.Value < searchFromDate || serviceDate.Value > searchToDate)
                        continue;

                    var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(serviceDate.Value.Month);

                    if (engineerReport.MonthlyRepairs.ContainsKey(monthName))
                    {
                        var serviceLocation = service.ServiceLocation?.Trim() ?? "";

                        if (serviceLocation.Equals("Onsite", StringComparison.OrdinalIgnoreCase))
                        {
                            engineerReport.MonthlyRepairs[monthName].Onsite++;
                        }
                        else if (serviceLocation.Equals("CompanyService", StringComparison.OrdinalIgnoreCase))
                        {
                            engineerReport.MonthlyRepairs[monthName].CompanyService++;
                        }
                        else
                        {
                            engineerReport.MonthlyRepairs[monthName].CompanyService++;
                        }
                    }
                }

                var hasData = engineerReport.MonthlyRepairs.Values.Any(d => d.Total > 0);
                if (hasData && engineerUsername != "Unknown Engineer")
                {
                    Engineers.Add(engineerReport);
                }
            }

            Engineers = Engineers.OrderBy(e => e.EngineerUserName).ToList();

            var totalServices = Engineers
                .SelectMany(e => e.MonthlyRepairs.Values)
                .Sum(d => d.Total);
            var periodText = filterType == "year" ? $"year {selectedYear}" : $"period {searchFromDate:MM/dd/yyyy} - {searchToDate:MM/dd/yyyy}";
            successMessage = $"Report generated for {periodText}! Found {totalServices} services from {Engineers.Count} engineer(s).";

            if (Engineers.Count == 0)
            {
                errorMessage = $"No services found for the selected period with the selected filters.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error generating report: {ex.Message}";
            Engineers.Clear();
            Console.WriteLine($"Error details: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private Guid? GetEngineerGuidByStatus(RepairServices service)
    {
        var statusName = availableStatuses.FirstOrDefault(s => s.Id == selectedStatusId)?.Name;

        if (selectedStatusId == 0)
            return service.repairBy;

        return statusName switch
        {
            "Item Recieved" => service.createby,
            "Inspection" => service.inspectBy,
            "Awaiting Customer Confirm" => service.setAwaitingCustomerConfirmBy,
            "Awaiting Sparepart" => service.setAwaitingSparepartBy,
            "Repairing" => service.repairBy,
            "Finished" => service.repairBy,
            "Customer Rejected" => service.setCustomerRejectedBy,
            "Unrepairable" => service.setUnrepairableBy,
            "Repair by Third-Party" => service.thirdPartyRepairBy,
            _ => service.repairBy
        };
    }

    private DateTime? GetDateByStatus(RepairServices service)
    {
        if (selectedStatusId == 0)
            return service.ServiceDate;

        var statusName = availableStatuses.FirstOrDefault(s => s.Id == selectedStatusId)?.Name;

        return statusName switch
        {
            "Item Recieved" => service.ServiceDate,
            "Inspection" => service.inspectDate,
            "Awaiting Customer Confirm" => service.awaitingCustomerConfirmDate,
            "Awaiting Sparepart" => service.awaitingSparepartDate,
            "Repairing" => service.repairDate,
            "Finished" => service.finishedDate,
            "Customer Rejected" => service.customerRejectedDate,
            "Unrepairable" => service.unrepairableDate,
            "Repair by Third-Party" => service.thirdPartyRepairDate,
            _ => service.ServiceDate
        };
    }

    private RepairData GetMonthlyData(EngineerRepairReport engineer, string month)
    {
        return engineer.MonthlyRepairs.TryGetValue(month, out var data) ? data : null;
    }

    private void PrintReport()
    {
        JSRuntime.InvokeVoidAsync("window.print");
    }

    public class EngineerRepairReport
    {
        public string EngineerUserName { get; set; }
        public Dictionary<string, RepairData> MonthlyRepairs { get; set; } = new();
    }

    public class RepairData
    {
        public int Onsite { get; set; }
        public int CompanyService { get; set; }
        public int Total => Onsite + CompanyService;
    }
}

<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
.report-container { padding: 40px; background-color: #fff; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 1400px; margin: 0 auto; }
.filter-section { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 10px; padding: 20px; margin-bottom: 30px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
.filter-header h3 { color: white; margin-bottom: 15px; font-size: 18px; }
.filter-body { background: white; border-radius: 8px; padding: 20px; }
.filter-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; align-items: end; }
.filter-group { display: flex; flex-direction: column; }
.filter-label { font-size: 12px; font-weight: 600; color: #333; margin-bottom: 5px; }
.filter-input { padding: 8px 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px; transition: all 0.3s ease; }
.filter-input:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.1); }
.btn-generate { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 10px 20px; font-size: 13px; cursor: pointer; border-radius: 4px; font-weight: 600; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 8px; height: 38px; }
.btn-generate:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(102,126,234,0.3); }
.btn-generate:disabled { opacity: 0.6; cursor: not-allowed; }
.alert-error { background-color: #fee; color: #c33; padding: 10px 15px; border-radius: 4px; margin-top: 15px; font-size: 13px; border-left: 4px solid #c33; }
.alert-success { background-color: #efe; color: #363; padding: 10px 15px; border-radius: 4px; margin-top: 15px; font-size: 13px; border-left: 4px solid #363; }
.no-data-message { text-align: center; padding: 60px 20px; background: #f8f9fa; border-radius: 8px; margin-top: 20px; }
.no-data-icon { font-size: 64px; margin-bottom: 20px; }
.no-data-message h3 { color: #333; margin-bottom: 10px; }
.no-data-message p { color: #666; font-size: 14px; }

    .report-header {
        display: flex;
        justify-content: flex-end; /* Changed from space-between to flex-end */
        align-items: flex-start;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #000;
    }

    .company-info h1 {
        font-size: 24px;
        color: #000;
        font-weight: 600;
        margin-bottom: 10px;
        letter-spacing: -0.3px;
    }

    .btn-generate:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        background: #999;
    }

.report-info { text-align: right; }
.report-info h2 { font-size: 16px; color: #000; font-weight: 600; margin-bottom: 15px; letter-spacing: 0.5px; }
.info-table { border-collapse: collapse; margin-left: auto; }
.info-table td { padding: 6px 12px; font-size: 11px; border: none; }
.info-table .label { background-color: transparent; font-weight: 600; text-align: right; color: #333; padding-right: 15px; }
.info-table .value { background-color: transparent; text-align: left; min-width: 120px; border-bottom: 1px solid #000; }
.btn-print { background-color: #2c5aa0; color: white; border: none; padding: 10px 20px; font-size: 13px; cursor: pointer; border-radius: 3px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; font-weight: 500; }
.btn-print:hover { background-color: #234a85; }
.print-icon { font-size: 16px; }
.table-wrapper { overflow-x: auto; }
.financial-table { width: 100%; border-collapse: collapse; font-size: 11px; }
.financial-table th, .financial-table td { border: none; padding: 8px 10px; text-align: center; }
.header-row th { background-color: transparent; color: #000; font-weight: 600; padding: 10px; border-bottom: 2px solid #000; border-top: 2px solid #000; position: sticky; top: 0; z-index: 10; }
.col-name { width: 140px; text-align: left !important; padding-left: 0 !important; }
.col-type { width: 100px; text-align: left !important; padding-left: 20px !important; }
.col-month { width: 70px; }
.col-total { width: 80px; border-left: 2px solid #000; }
.engineer-cell { font-weight: 600; text-align: left !important; padding-left: 0 !important; background-color: transparent; vertical-align: middle; color: #000; }
.engineer-cell-blank { background-color: transparent; }
.type-cell { text-align: left !important; padding-left: 30px !important; background-color: transparent; font-weight: 400; color: #333; }
.total-label { font-weight: 600; background-color: transparent; color: #000; }
.number-cell { text-align: right !important; padding-right: 15px !important; font-family: 'Courier New', Consolas, monospace; background-color: transparent; color: #000; }
.number-cell.has-data { background-color: #f0f7ff; }
.subtotal-cell { border-left: 2px solid #000 !important; font-weight: 600; }
.data-row { background-color: transparent; }
.data-row:hover { background-color: #f8f9fa; }
.total-row { border-top: 1px solid #000; }
.total-row .number-cell { border-top: 1px solid #000; }
.total-value { font-weight: 600; background-color: transparent; border-left: 1px solid #ccc; }
.grand-total { font-weight: 700; border-left: 2px solid #000; }
.spacing-row { height: 20px; background-color: transparent; }
.spacing-row td { border: none; border-bottom: 1px solid #ccc; }
.grand-total-row { background-color: #f0f0f0; font-weight: 700; border-top: 3px double #000; }
.grand-total-cell { font-weight: 700; background-color: #e8e8e8; }
.overall-total { background-color: #d0d0d0; font-weight: 700; font-size: 13px; }
.signature-section { margin-top: 40px; display: flex; justify-content: flex-end; padding-right: 20px; }
.signature-box { text-align: center; min-width: 250px; }
.signature-label { font-size: 12px; font-weight: 600; color: #333; margin-bottom: 100px; }
.signature-line { border-bottom: 1px solid #000; margin: 0 20px 5px 20px; }
.signature-name { font-size: 11px; color: #333; text-align: left; padding-left: 20px; }

@@media print {
    @@page { size: landscape; margin: 0.5cm; }
    body * { visibility: hidden; }
    .report-container, .report-container * { visibility: visible; }
    .report-container { position: absolute; left: 0; top: 0; padding: 10px; max-width: 100%; width: 100%; }
    .filter-section, .btn-print, .btn-generate { display: none !important; visibility: hidden !important; }
    .report-header { margin-bottom: 15px; padding-bottom: 10px; }
    .company-info h1 { font-size: 20px; }
    .report-info h2 { font-size: 14px; }
    .financial-table { font-size: 9px; }
    .financial-table th, .financial-table td { padding: 4px 6px; }
