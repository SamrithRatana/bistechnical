    // ─────────────────────────────────────────────────────────────
    // Builds a deterministic cache key from every filter that affects
    // the result set. Must match exactly what's passed to SearchRepairServicesAsync.
    // ─────────────────────────────────────────────────────────────
    private string BuildReportCacheKey(int page, int size)
    {
        bool isAlwaysCreated = ReportMode == "alwayscreated";

        var statusPart = (isAlwaysCreated || _lastFilterMode == 2) && _lastSelectedStatuses?.Any() == true
            ? string.Join("-", _lastSelectedStatuses.OrderBy(s => s))
            : "none";

        var keyParts = new[]
        {
        $"page{page}",
        $"size{size}",
        $"company{_lastCompanyName ?? "all"}",
        $"loc{_lastServiceLocation}",
        $"type{_lastServiceType}",
        $"from{_lastFromDate:yyyyMMdd}",
        $"to{_lastToDate:yyyyMMdd}",
        $"mode{_lastFilterMode}",
        $"report{ReportMode}",
        $"custtype{_lastSelectedCustomerType}",
        $"status{statusPart}"
    };

        // Uses your existing PrefixRepairItem so the queue consumers'
        // InvalidateByPrefixAsync(CacheKeys.PrefixRepairItem) already
        // wipes these out automatically on any repair status change.
        return $"{CacheKeys.PrefixRepairItem}dailyreport:{string.Join(":", keyParts)}";
    }
    private async Task<List<RepairServices>> ApplyCustomerTypeFilter(List<RepairServices> services)
    {
        try
        {
            var matchingCompanyNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            int page = 1;
            bool hasMore = true;

            while (hasMore)
            {
                var pagedResponse = await CustomerService.GetCustomersPaginatedAsync(
                    pageNumber: page,
                    pageSize: 100,
                    isActive: true
                );

                if (pagedResponse?.Data != null && pagedResponse.Data.Any())
                {
                    foreach (var c in pagedResponse.Data)
                    {
                        if (!string.IsNullOrWhiteSpace(c.CompanyName) &&
                            c.CustomerType == SelectedCustomerType)
                        {
                            matchingCompanyNames.Add(c.CompanyName.Trim());
                        }
                    }
                    hasMore = pagedResponse.HasNext;
                    page++;
                }
                else
                {
                    hasMore = false;
                }
            }

            return services
                .Where(r => !string.IsNullOrWhiteSpace(r.CompanyName) &&
                            matchingCompanyNames.Contains(r.CompanyName.Trim()))
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in ApplyCustomerTypeFilter: {ex.Message}");
            return services;
        }
    }

