@page "/daily-report"
@using System.Linq.Expressions
@using ServiceMaintenance.Models
@using ServiceMaintenance.Pages.Reports
@using ServiceMaintenance.Services
@inject RepairItemService RepairService
@inject GlobalUserService GlobalUserCache
@inject IJSRuntime JSRuntime
@inject ServiceSparePart SparePartService
@inject CustomerService CustomerService
@inject CacheHelper Cache
@inherits PermissionBase
@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical;

    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical;
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Horizontal;
    }
    else
    {
        enableAdaptiveUIMode = false;
    }
}
@if (CanAccess)
{
    <DxToastProvider Name="Customization"
                     MaxToastCount="5"
                     HorizontalAlignment="HorizontalAlignment.Right"
                     VerticalAlignment="VerticalEdge.Top"
                     AnimationType="@Animation" />
    <DxToastProvider Name="Error"
                     MaxToastCount="5"
                     HorizontalAlignment="HorizontalAlignment.Right"
                     VerticalAlignment="VerticalEdge.Top"
                     AnimationType="@Animation" />

    <div class="card shadow-sm rounded-lg">
        <div class="card-body">
            <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">

                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextNew)]" IconCssClass="far fa-file" CssClass="toolbar-item" Enabled="false" />
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextEdit)]" IconCssClass="far fa-edit" CssClass="toolbar-item" Enabled="false" />
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextDelete)]" IconCssClass="fas fa-trash-alt" CssClass="toolbar-item" Enabled="false" />

                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextExport)]"
                               IconCssClass="@(IsExporting ? "fas fa-spinner fa-spin" : "fas fa-download")"
                               Enabled="@(!IsExporting)">
                    <Items>
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToExcel)]"
                                       Click="ExportToExcel"
                                       IconCssClass="fas fa-file-excel"
                                       Enabled="@(!IsExporting)" />
                        <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextToPdf)]"
                                       Click="ShowReportPreview2"
                                       IconCssClass="fas fa-file-pdf" />
                    </Items>
                </DxToolbarItem>

                <DxToolbarItem Text="Print Report" Click="ShowReportPreview" CssClass="toolbar-item" IconCssClass="fas fa-print" />
                <DxToolbarItem Text="@Loc[nameof(ResourceStrings.TextCheckList)]" CssClass="toolbar-item" IconCssClass="fas fa-check-circle" Enabled="false" />
            </DxToolbar>
        </div>
    </div>
    <hr />
    <div class="container">
        <div class="row mb-3">
            <div class="col-md-12 text-end">
                <i class="fa @(IsFilterSectionVisible ? "fa-chevron-up" : "fa-chevron-down")"
                   @onclick="ToggleFilterSection"
                   style="cursor: pointer; font-size: 20px; color: #333;">
                </i>
            </div>
        </div>

        <div class="filter-section container" style="@($"display: {(IsFilterSectionVisible ? "block" : "none")};")">
            <div class="row align-items-end mb-3">
                <!-- Filter Mode -->
                <div class="col-md-2">
                    <label class="font-weight-bold">Filter By:</label>
                    <SfDropDownList TItem="FilterModeOption" TValue="int"
                                    DataSource="@FilterModeOptions"
                                    @bind-Value="FilterMode"
                                    class="form-control">
                        <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
                    </SfDropDownList>
                </div>

                <!-- Service Location -->
                <div class="col-md-2">
                    <label class="font-weight-bold">@Loc[nameof(ResourceStrings.TextServiceLocation)]:</label>
                    <SfDropDownList TItem="string" TValue="string"
                                    DataSource="@ServiceLocationOptions"
                                    @bind-Value="SelectedServiceLocation"
                                    Placeholder="Select Location"
                                    class="form-control">
                    </SfDropDownList>
                </div>

                <!-- ✅ NEW: Service Type filter -->
                <div class="col-md-2">
                    <label class="font-weight-bold">Service Type:</label>
                    <SfDropDownList TItem="string" TValue="string"
                                    DataSource="@(new List<string> { "All" }.Concat(ServiceTypeOptions.Select(x => x.Name)).ToList())"
                                    @bind-Value="SelectedServiceType"
                                    Placeholder="Select Type"
                                    class="form-control">
                    </SfDropDownList>
                </div>

                @if (FilterMode == 1)
                {
                    @if (FilterType == 1)
                    {
                        <div class="col-md-2">
                            <label class="font-weight-bold">@Loc[nameof(ResourceStrings.Textfinddate)]:</label>
                            <SfDatePicker @bind-Value="SelectedDate" class="form-control" Format="dd/MM/yyyy" />
                        </div>
                    }
                    else if (FilterType == 2)
                    {
                        <div class="col-md-2">
                            <label class="font-weight-bold">@Loc[nameof(ResourceStrings.Textfrom)]:</label>
                            <SfDatePicker TValue="DateTime" @ref="@DateObj1" @bind-Value="StartDate" class="form-control" Format="dd/MM/yyyy">
                                <DatePickerEvents TValue="DateTime" Focus="FocusHandler1"></DatePickerEvents>
                            </SfDatePicker>
                        </div>
                        <div class="col-md-2">
                            <label class="font-weight-bold">@Loc[nameof(ResourceStrings.TextTo)]:</label>
                            <SfDatePicker TValue="DateTime" @ref="@DateObj2" @bind-Value="EndDate" class="form-control" Format="dd/MM/yyyy">
                                <DatePickerEvents TValue="DateTime" Focus="FocusHandler2"></DatePickerEvents>
                            </SfDatePicker>
                        </div>
                    }
                    else if (FilterType == 3)
                    {
                        <div class="col-md-2">
                            <label class="font-weight-bold">@Loc[nameof(ResourceStrings.Textsearchserial)]:</label>
                            <SfDropDownList TItem="SerialFilterOption" TValue="int"
                                            DataSource="@SerialFilterOptions"
                                            @bind-Value="SerialFilterType"
                                            class="form-control">
                                <DropDownListFieldSettings Text="Text" Value="Value"></DropDownListFieldSettings>
                            </SfDropDownList>
                        </div>

                        @if (SerialFilterType == 1)
                        {
                            <div class="col-md-2">
                                <label class="font-weight-bold">@Loc[nameof(ResourceStrings.Textfinddate)]:</label>
                                <SfDatePicker @bind-Value="SelectedDate" class="form-control" Format="dd/MM/yyyy" />
                            </div>
                        }
                        else if (SerialFilterType == 2)
                        {
                            <div class="col-md-2">
                                <label class="font-weight-bold">@Loc[nameof(ResourceStrings.Textfrom)]:</label>
                                <SfDatePicker @bind-Value="StartDate" class="form-control" Format="dd/MM/yyyy" />
                            </div>
                            <div class="col-md-2">
                                <label class="font-weight-bold">@Loc[nameof(ResourceStrings.TextTo)]:</label>
                                <SfDatePicker @bind-Value="EndDate" class="form-control" Format="dd/MM/yyyy" />
                            </div>
                        }
                    }
                }
                else if (FilterMode == 2)
                {
                    <div class="col-md-2">
                        <label class="font-weight-bold">@Loc[nameof(ResourceStrings.Textfrom)]:</label>
                        <SfDatePicker @bind-Value="StartDate" class="form-control" Format="dd/MM/yyyy" />
                    </div>
                    <div class="col-md-2">
                        <label class="font-weight-bold">@Loc[nameof(ResourceStrings.TextTo)]:</label>
                        <SfDatePicker @bind-Value="EndDate" class="form-control" Format="dd/MM/yyyy" />
                    </div>
                }

                <!-- Status Selection -->
                <div class="col-md-2">
                    <label class="font-weight-bold">@Loc[nameof(ResourceStrings.TextStatus)]:</label>
                    <SfMultiSelect TItem="ServiceStatusViewModel" TValue="string[]"
                                   Width="100%"
                                   Placeholder="Select Statuses"
                                   ShowSelectAll="true"
                                   SelectAllText="Select All"
                                   UnSelectAllText="Unselect All"
                                   Mode="VisualMode.CheckBox"
                                   DataSource="@StatusList"
                                   @bind-Value="SelectedStatuses">
                        <MultiSelectFieldSettings Text="DisplayName" Value="Value"></MultiSelectFieldSettings>
                    </SfMultiSelect>
                </div>

                <!-- Fetch Report Button -->
                <div class="col-md-2 d-flex flex-column align-items-start">
                    <button class="btn btn-primary w-100"
                            @onclick="FetchReport"
                            disabled="@(SelectedStatuses == null || SelectedStatuses.Length == 0)">
                        @Loc[nameof(ResourceStrings.TextFetchReport)]
                    </button>
                    @if (ShowStatusValidationError)
                    {
                        <small class="text-danger mt-1">
                            <i class="fas fa-exclamation-circle"></i> Please select at least one status.
                        </small>
                    }
                </div>

                <div class="col-md-3">
                    <label class="font-weight-bold">Report Options:</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="reportOptions" id="standardReport"
                               value="standard"
                               checked="@(ReportMode == "standard")"
                               @onchange="@(() => { ReportMode = "standard"; ShowAwaitingDetailsInReport = false; })">
                        <label class="form-check-label" for="standardReport">Standard Report</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="reportOptions" id="detailedReport"
                               value="detailed"
                               checked="@(ReportMode == "detailed")"
                               @onchange="@(() => { ReportMode = "detailed"; ShowAwaitingDetailsInReport = true; })">
                        <label class="form-check-label" for="detailedReport">Show Awaiting Details Separately</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="reportOptions" id="alwaysCreated"
                               value="alwayscreated"
                               checked="@(ReportMode == "alwayscreated")"
                               @onchange="@(() => { ReportMode = "alwayscreated"; ShowAwaitingDetailsInReport = false; })">
                        <label class="form-check-label" for="alwaysCreated">Always Created (ServiceDate)</label>
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="font-weight-bold">Filter Options:</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="filterByCompany"
                               @bind="FilterByCompany">
                        <label class="form-check-label" for="filterByCompany" style="font-family:'Khmer OS'">
                            @Loc[nameof(ResourceStrings.TextCompanyName)]
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="filterByCustomerType"
                               @bind="FilterByCustomerType"
                               @bind:after="() => { if (!FilterByCustomerType) SelectedCustomerType = string.Empty; }">
                        <label class="form-check-label" for="filterByCustomerType">Customer Type</label>
                    </div>
                </div>

                @if (FilterByCustomerType)
                {
                    <div class="col-md-2">
                        <label class="font-weight-bold">Customer Type:</label>
                        <SfDropDownList TItem="CustomerService.CustomerTypeDto"
                                        TValue="string"
                                        DataSource="@_customerTypes"
                                        @bind-Value="SelectedCustomerType"
                                        Placeholder="All Types"
                                        AllowFiltering="true"
                                        class="form-control">
                            <DropDownListFieldSettings Text="Type" Value="Type"></DropDownListFieldSettings>
                        </SfDropDownList>
                        @if (!string.IsNullOrEmpty(SelectedCustomerType))
                        {
                            <small class="text-muted" style="cursor:pointer;"
                                   @onclick="() => SelectedCustomerType = string.Empty">
                                <i class="fas fa-times-circle"></i> Clear
                            </small>
                        }
                    </div>
                }

                @if (FilterByCompany)
                {
                    <div class="col-md-3">
                        <label class="font-weight-bold" style="font-family:'Khmer OS'">
                            @Loc[nameof(ResourceStrings.TextCompanyName)]:
                        </label>
                        <div class="form-item" style="position: relative;">
                            <input type="text"
                                   @bind="reportSearchTerm"
                                   @oninput="OnReportSearchTermInput"
                                   @onclick="OnReportInputClick"
                                   @onblur="OnReportInputBlur"
                                   placeholder="Search by company..."
                                   class="form-control"
                                   style="height: 35px; font-size: 14px; font-family: 'Khmer OS'" />

                            @if (IsReportDropdownVisible && FilteredCustomersForReport.Any())
                            {
                                <div class="custom-dropdown"
                                     style="position: absolute; width: 100%; max-height: 300px; overflow-y: auto;
                                border: 1px solid #ccc; background-color: white; z-index: 1000;
                                border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">

                                    <div style="display: flex; justify-content: space-between; align-items: center;
                                    padding: 8px 12px; background-color: #f8f9fa; border-bottom: 1px solid #dee2e6;">
                                        <span style="font-size: 12px; color: #6c757d;">
                                            <strong>Select a company (Page @CustomerCurrentPage of @CustomerTotalPages)</strong>
                                        </span>
                                        <button class="btn btn-sm btn-link p-0"
                                                @onclick="CloseReportDropdown"
                                                style="font-size: 16px; color: #dc3545; border: none; background: none;
                                           font-weight: bold; line-height: 1;">
                                            ×
                                        </button>
                                    </div>

                                    @foreach (var company in FilteredCustomersForReport)
                                    {
                                        <div class="dropdown-item px-3 py-2"
                                             @onclick="() => OnReportCompanySelect(company)"
                                             style="cursor: pointer; border-bottom: 1px solid #f0f0f0; font-family:'Khmer OS';">
                                            <div class="fw-medium">@company.CompanyName</div>
                                        </div>
                                    }

                                    @if (CustomerHasMore)
                                    {
                                        <div class="text-center p-2 border-top">
                                            <button class="btn btn-sm btn-link" @onclick="() => LoadMoreCustomers(reportSearchTerm)">
                                                <i class="fas fa-chevron-down"></i> Load More
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <hr />

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading repair services...</p>
        </div>
    }
    else if (!HasSearched)
    {
        <div class="alert alert-info">
            Please select filter criteria and click "Fetch Report" to view data.
        </div>
    }
    else if (FilteredRepairServices.Count == 0)
    {
        <div class="alert alert-warning">
            No data available for the selected criteria.
        </div>
    }
    else
    {
        <SfGrid @ref="MyGrid" DataSource="FilteredRepairServices"
                PageSize="10"
                AllowSorting="true"
                ShowColumnChooser="true"
                AllowExcelExport="true"
                AllowPdfExport="true"
                EnableAdaptiveUI="@enableAdaptiveUIMode"
                RowRenderingMode="@renderingMode"
                SelectionMode="GridSelectionMode.Single"
                Toolbar="@ToolbarItems"
                AllowResizing="true"
                AllowFiltering="true"
                Height="500"
                AllowSelection="true">
            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
            <GridEvents RowSelected="RowSelectHandler" OnRecordDoubleClick="RowDoubleClickHandler" TValue="RepairServices"></GridEvents>

            <GridColumns>
                <GridColumn Field="reportNo" HeaderText="@Loc[nameof(ResourceStrings.Textref)]" Width="150"></GridColumn>
                <GridColumn Field="ServiceDate" HeaderText="@Loc[nameof(ResourceStrings.TextReceiveDate)]" Format="dd/MM/yyyy HH:mm tt" Width="180"></GridColumn>
                <GridColumn Field="finishedDate"
                            HeaderText="@Loc[nameof(ResourceStrings.TextFinishDate)]"
                            Format="dd/MM/yyyy HH:mm tt"
                            Width="180"
                            Visible="false">
                </GridColumn>
                <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" Width="500"></GridColumn>
                <GridColumn Field="Address" HeaderText="@Loc[nameof(ResourceStrings.TextAddress)]" Width="250" Visible="false"></GridColumn>
                <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextItemName)]" Width="300"></GridColumn>
                <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="150"></GridColumn>
                <GridColumn Field="CustomerRequest" HeaderText="@Loc[nameof(ResourceStrings.TextCustomerReq)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="inspection" HeaderText="@Loc[nameof(ResourceStrings.TextInspection)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="Solution" HeaderText="@Loc[nameof(ResourceStrings.Textsolution)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="inspectDate" HeaderText="@Loc[nameof(ResourceStrings.TextInspectDate)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="inspectBy" HeaderText="@Loc[nameof(ResourceStrings.TextInspectby)]" Visible="false" Width="150">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.inspectBy);
                        }
                        @username
                    </Template>
                </GridColumn>
                <GridColumn Field="awaitingCustomerConfirmDate" HeaderText="@Loc[nameof(ResourceStrings.TextawaitingCustomerConfirmDate)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="setAwaitingCustomerConfirmBy" HeaderText="@Loc[nameof(ResourceStrings.TextsetAwaitingCustomerConfirmBy)]" Visible="false" Width="150">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.setAwaitingCustomerConfirmBy);
                        }
                        @username
                    </Template>
                </GridColumn>
                <GridColumn Field="awaitingSparepartDate" HeaderText="@Loc[nameof(ResourceStrings.TextSparePart)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="setAwaitingCustomerConfirmBy" HeaderText="@Loc[nameof(ResourceStrings.TextsetAwaitingSparePartBy)]" Visible="false" Width="150">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.setAwaitingSparepartBy);
                        }
                        @username
                    </Template>
                </GridColumn>
                <GridColumn Field="ContactName" HeaderText="@Loc[nameof(ResourceStrings.TextContactName)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="PhoneNumber" HeaderText="@Loc[nameof(ResourceStrings.TextPhoneNumber)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="Status" HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="150" Visible="true">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var khmerStatus = GetKhmerStatus(item.Status);
                        }
                        @khmerStatus
                    </Template>
                </GridColumn>
                <GridColumn Field="ServiceType" HeaderText="Service Type" Width="130" Visible="true"></GridColumn>
                <GridColumn Field="ServiceLocation" HeaderText="@Loc[nameof(ResourceStrings.TextServiceLocation)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="ServicePriority" HeaderText="@Loc[nameof(ResourceStrings.TextPriority)]" Width="150" Visible="false"></GridColumn>
                <GridColumn Field="RepairByName"
                            HeaderText="@Loc[nameof(ResourceStrings.TextRepairBy)]"
                            Width="150"
                            Visible="false">
                </GridColumn>
                <GridColumn Field="repairBy" HeaderText="@Loc[nameof(ResourceStrings.TextRepairBy)]" Width="150" Visible="false">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.repairBy);
                        }
                        @username
                    </Template>
                </GridColumn>
                <GridColumn Field="verifiedBy" HeaderText="@Loc[nameof(ResourceStrings.TextVerifyBy)]" Width="150" Visible="false">
                    <Template>
                        @{
                            var item = context as RepairServices;
                            var username = GetUserNameById(item.verifiedBy);
                        }
                        @username
                    </Template>
                </GridColumn>
                <GridColumn Field="SparePartExcelSummary" HeaderText="Sparepart Items (Excel)" Width="250" Visible="false"></GridColumn>
                <GridColumn Field="CustomerRequest" HeaderText="@Loc[nameof(ResourceStrings.TextCustomerReq)]" Width="250" Visible="false"></GridColumn>
                <GridColumn Field="Inspection" HeaderText="@Loc[nameof(ResourceStrings.TextInspection)]" Width="250" Visible="false"></GridColumn>
                <GridColumn Field="Solution" HeaderText="@Loc[nameof(ResourceStrings.Textsolution)]" Width="250" Visible="false"></GridColumn>
                <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextAction)]" IsFrozen="true" Freeze="FreezeDirection.Right" Width="200">
                    <Template>
                        @if ((context as RepairServices)?.ServiceDate != null)
                        {
                            <DxButton IconCssClass="fas fa-eye"
                                      CssClass="icon-button info"
                                      RenderStyle="ButtonRenderStyle.Info"
                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                      Text="@Loc[nameof(ResourceStrings.TextView)]"
                                      @onclick="() => ShowRepairServiceDetails(context as RepairServices)" />

                            <DxButton IconCssClass="fas fa-file-invoice"
                                      CssClass="icon-button secondary"
                                      RenderStyle="ButtonRenderStyle.Secondary"
                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                      Text="Preview"
                                      Click="() => ShowReportPreview(_selectedRepairService)" />
                        }
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <strong>Showing @((CurrentPage - 1) * PageSize + 1) to @Math.Min(CurrentPage * PageSize, TotalRecords) of @TotalRecords records</strong>
            </div>
            <div class="d-flex align-items-center gap-2">
                <label class="me-2">Page Size:</label>
                <select class="form-select form-select-sm" style="width: 80px;" @onchange="OnPageSizeChanged">
                    <option value="10" selected="@(PageSize == 10)">10</option>
                    <option value="25" selected="@(PageSize == 25)">25</option>
                    <option value="50" selected="@(PageSize == 50)">50</option>
                    <option value="100" selected="@(PageSize == 100)">100</option>
                </select>

                <div class="btn-group ms-3" role="group">
                    <button class="btn btn-sm btn-outline-primary" @onclick="FirstPage" disabled="@(!HasPreviousPage || IsLoading)">
                        <i class="fas fa-angle-double-left"></i> First
                    </button>
                    <button class="btn btn-sm btn-outline-primary" @onclick="PreviousPage" disabled="@(!HasPreviousPage || IsLoading)">
                        <i class="fas fa-angle-left"></i> Previous
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" disabled>
                        Page @CurrentPage of @TotalPages
                    </button>
                    <button class="btn btn-sm btn-outline-primary" @onclick="NextPage" disabled="@(!HasNextPage || IsLoading)">
                        Next <i class="fas fa-angle-right"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-primary" @onclick="LastPage" disabled="@(!HasNextPage || IsLoading)">
                        Last <i class="fas fa-angle-double-right"></i>
                    </button>
                </div>
            </div>
        </div>
    }

<SfDialog @ref="DialogEdit" Target="#target" Width="600px" IsModal="true" ShowCloseIcon="true" @bind-Visible="@isViewDialogVisible">
    <DialogEvents OnOverlayModalClick="@OverlayClick"></DialogEvents>
    <DialogTemplates>
        <Header>@Loc[nameof(ResourceStrings.TextViewInfo)]</Header>
        <Content>
            <div class="report-container">
                <div class="report-header">
                    <span>Repair Service Report</span>
                </div>
                <div class="report-body">
                    <table class="report-table">
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.Textref)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.reportNo</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextReceiveDate)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ServiceDate.ToString("yyyy-MM-dd HH:mm tt")</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextRepairDate)]:</strong></td>
                            <td class="report-value">
                                @(_selectedRepairService?.repairDate.HasValue == true
                                                                ? _selectedRepairService.repairDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                                                : "N/A")
                                                                    </td>
                                                                </tr>
                                                                <tr>
                                                                    <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextFinishDate)]:</strong></td>
                                                                    <td class="report-value">
                                @(_selectedRepairService?.finishedDate.HasValue == true
                                                                ? _selectedRepairService.finishedDate.Value.ToString("yyyy-MM-dd HH:mm tt")
                                                                : "N/A")
                            </td>
                        </tr>

                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextCompanyName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.CompanyName</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextAddress)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.Address</td>
                        </tr>
                        <tr>
                            <td class="report-label"><strong>@Loc[nameof(ResourceStrings.TextContactName)]:</strong></td>
                            <td class="report-value">@_selectedRepairService?.ContactName</td>
                        </tr>
