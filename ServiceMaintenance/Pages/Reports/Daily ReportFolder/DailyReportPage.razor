    public string GetUserNameById(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty)
            return "None";

        string userIdString = userId.Value.ToString();

        if (!_usersLoaded)
            return "Loading...";

        if (_userCache.TryGetValue(userIdString, out string username))
            return username;

        return "Unknown User";
    }
