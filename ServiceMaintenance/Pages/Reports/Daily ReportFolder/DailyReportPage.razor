    private async Task LoadSparePartsForCurrentPage()
    {
        var sparePartIds = FilteredRepairServices
            .SelectMany(s => s.SparePartItems ?? Enumerable.Empty<SparePartItem>())
            .Where(item => item.SparePartId.HasValue)
            .Select(item => item.SparePartId.Value)
            .Distinct()
            .ToList();

        if (!sparePartIds.Any()) return;

        foreach (var sparePartId in sparePartIds)
        {
            if (!_spareParts.Any(sp => sp.Id == sparePartId))
            {
                try
                {
                    var sparePart = await SparePartService.GetSparePartByIdAsync(sparePartId);
                    if (sparePart != null)
                    {
                        _spareParts = _spareParts.Append(sparePart);
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error loading spare part {sparePartId}: {ex.Message}");
                }
            }
        }

        foreach (var service in FilteredRepairServices)
        {
            foreach (var item in service.SparePartItems ?? Enumerable.Empty<SparePartItem>())
            {
                if (item.SparePartId.HasValue)
                {
                    var sparePart = _spareParts.FirstOrDefault(sp => sp.Id == item.SparePartId.Value);
                    if (sparePart != null)
                    {
                        item.ItemName = sparePart.ItemName;
                    }
                }
            }
        }
    }

    private async Task LoadMoreCustomers(string searchTerm = null)
    {
        if (!CustomerHasMore) return;

        CustomerCurrentPage++;
        var result = await CustomerService.GetCustomersPaginatedAsync(
            pageNumber: CustomerCurrentPage,
            pageSize: CustomerPageSize,
            searchTerm: searchTerm
        );

        if (result?.Data != null && result.Data.Any())
        {
            _customers.AddRange(result.Data);
            CustomerTotalPages = result.TotalPages;
            CustomerHasMore = CustomerCurrentPage < CustomerTotalPages;
        }
        else
        {
            CustomerHasMore = false;
        }

        StateHasChanged();
    }

    private async Task LoadMoreSpareParts(string searchTerm = null)
    {
        if (!SparePartHasMore) return;

        SparePartCurrentPage++;
        var result = await SparePartService.GetSparePartsPagedAsync(
            pageNumber: SparePartCurrentPage,
            pageSize: SparePartPageSize
        );

        if (result?.Items != null && result.Items.Any())
        {
            _spareParts = _spareParts.Concat(result.Items).ToList();
            SparePartTotalPages = result.TotalPages;
            SparePartHasMore = SparePartCurrentPage < SparePartTotalPages;
        }
        else
        {
            SparePartHasMore = false;
        }

        StateHasChanged();
    }

    private async Task SearchCustomers(string searchTerm)
    {
        CustomerCurrentPage = 1;
        CustomerHasMore = true;

        var result = await CustomerService.GetCustomersPaginatedAsync(
            pageNumber: CustomerCurrentPage,
            pageSize: CustomerPageSize,
            searchTerm: searchTerm
        );

        if (result?.Data != null)
        {
            _customers = result.Data.ToList();
            CustomerTotalPages = result.TotalPages;
            CustomerHasMore = CustomerCurrentPage < CustomerTotalPages;
        }

        StateHasChanged();
    }

