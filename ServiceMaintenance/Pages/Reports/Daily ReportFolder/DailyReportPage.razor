    private async Task LoadSparePartsForServices(List<RepairServices> services)
    {
        var sparePartIds = services
            .SelectMany(s => s.SparePartItems ?? Enumerable.Empty<SparePartItem>())
            .Where(item => item.SparePartId.HasValue)
            .Select(item => item.SparePartId.Value)
            .Distinct()
            .ToList();

        if (!sparePartIds.Any()) return;

        foreach (var sparePartId in sparePartIds)
        {
            if (!_spareParts.Any(sp => sp.Id == sparePartId))
            {
                try
                {
                    var sparePart = await SparePartService.GetSparePartByIdAsync(sparePartId);
                    if (sparePart != null)
                    {
                        _spareParts = _spareParts.Append(sparePart);
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error loading spare part {sparePartId}: {ex.Message}");
                }
            }
        }

        foreach (var service in services)
        {
            foreach (var item in service.SparePartItems ?? Enumerable.Empty<SparePartItem>())
            {
                if (item.SparePartId.HasValue)
                {
                    var sparePart = _spareParts.FirstOrDefault(sp => sp.Id == item.SparePartId.Value);
                    if (sparePart != null)
                    {
                        item.ItemName = sparePart.ItemName;
                    }
                }
            }
        }
    }

