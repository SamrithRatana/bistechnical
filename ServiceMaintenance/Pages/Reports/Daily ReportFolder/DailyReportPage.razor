    // ─────────────────────────────────────────────────────────────
    // ✅ UPDATED: FetchReport — captures _lastServiceType and passes
    //             serviceType to every SearchRepairServicesAsync call
    // ─────────────────────────────────────────────────────────────
    private async Task FetchReport()
    {
        if (SelectedStatuses == null || SelectedStatuses.Length == 0)
        {
            ShowStatusValidationError = true;
            return;
        }

        ShowStatusValidationError = false;
        try
        {
            IsLoading = true;
            HasSearched = true;
            CurrentPage = 1;
            FilteredRepairServices.Clear();
            _allFilteredRecords.Clear();

            bool isAlwaysCreated = ReportMode == "alwayscreated";

            _lastCompanyName = FilterByCompany && _selectedReportCompany != null
                ? _selectedReportCompany.CompanyName
                : null;
            _lastServiceLocation = SelectedServiceLocation;
            _lastServiceType = SelectedServiceType;
            _lastFromDate = (FilterMode == 1 || FilterMode == 2) ? StartDate : (DateTime?)null;
            _lastToDate = (FilterMode == 1 || FilterMode == 2) ? EndDate : (DateTime?)null;
            _lastFilterMode = FilterMode;
            _lastSelectedStatuses = SelectedStatuses;
            _lastSelectedCustomerType = FilterByCustomerType ? SelectedCustomerType : "";

            Console.WriteLine($"Fetching page {CurrentPage} | Location: {_lastServiceLocation} | ServiceType: {_lastServiceType} | ReportMode: {ReportMode} | CustomerType: {_lastSelectedCustomerType}");

            // ─── BRANCH A: CustomerType filter active → uncached, fetch ALL, filter, paginate in-memory ───
            if (FilterByCustomerType && !string.IsNullOrEmpty(SelectedCustomerType))
            {
                var allResult = await RepairService.SearchRepairServicesAsync(
                    pageNumber: 1,
                    pageSize: int.MaxValue,
                    searchTerm: _lastCompanyName,
                    serialNumber: null,
                    status: (isAlwaysCreated || _lastFilterMode == 2) && _lastSelectedStatuses?.Any() == true
                        ? string.Join(",", _lastSelectedStatuses)
                        : null,
                    serviceType: _lastServiceType != "All" ? _lastServiceType : null,
                    serviceLocation: _lastServiceLocation != "All" ? _lastServiceLocation : null,
                    fromDate: _lastFromDate,
                    toDate: _lastToDate,
                    hasContract: null,
                    dateFilter: null,
                    statusFilter: null,
                    sortBy: "ServiceDate",
                    sortDescending: true,
                    useProcessDateFiltering: !isAlwaysCreated && _lastFilterMode == 1,
                    statusesForProcessFiltering: !isAlwaysCreated && _lastFilterMode == 1 && _lastSelectedStatuses?.Any() == true
                        ? _lastSelectedStatuses
                        : null,
                    forceServiceDateOnly: isAlwaysCreated
                );

                _allFilteredRecords = await ApplyCustomerTypeFilter(allResult.Items.ToList());
                TotalRecords = _allFilteredRecords.Count;

                FilteredRepairServices = _allFilteredRecords
                    .Skip((CurrentPage - 1) * PageSize)
                    .Take(PageSize)
                    .ToList();

                Console.WriteLine($"CustomerType filter applied: {allResult.Items.Count} → {_allFilteredRecords.Count} records. Showing page {CurrentPage} ({FilteredRepairServices.Count} items).");
            }
            // ─── BRANCH B: No CustomerType filter → cached server-side pagination ───
            else
            {
                var cacheKey = BuildReportCacheKey(CurrentPage, PageSize);

                var result = await Cache.GetOrSetAsync(
                    cacheKey,
                    async () => await RepairService.SearchRepairServicesAsync(
                        pageNumber: CurrentPage,
                        pageSize: PageSize,
                        searchTerm: _lastCompanyName,
                        serialNumber: null,
                        status: (isAlwaysCreated || _lastFilterMode == 2) && _lastSelectedStatuses?.Any() == true
                            ? string.Join(",", _lastSelectedStatuses)
                            : null,
                        serviceType: _lastServiceType != "All" ? _lastServiceType : null,
                        serviceLocation: _lastServiceLocation != "All" ? _lastServiceLocation : null,
                        fromDate: _lastFromDate,
                        toDate: _lastToDate,
                        hasContract: null,
                        dateFilter: null,
                        statusFilter: null,
                        sortBy: "ServiceDate",
                        sortDescending: true,
                        useProcessDateFiltering: !isAlwaysCreated && _lastFilterMode == 1,
                        statusesForProcessFiltering: !isAlwaysCreated && _lastFilterMode == 1 && _lastSelectedStatuses?.Any() == true
                            ? _lastSelectedStatuses
                            : null,
                        forceServiceDateOnly: isAlwaysCreated
                    ),
                    expiry: TimeSpan.FromMinutes(2) // short TTL — report data is operational, not static
                );

                FilteredRepairServices = result.Items.ToList();
                TotalRecords = result.TotalCount;

                Console.WriteLine($"Server-side page {CurrentPage}: {FilteredRepairServices.Count} items. Total: {TotalRecords} (cache key: {cacheKey})");
            }

            PopulateUserNamesForServices(FilteredRepairServices);
            await LoadSparePartsForCurrentPage();

            IsFilterSectionVisible = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in FetchReport: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    // ─────────────────────────────────────────────────────────────
    // ✅ UPDATED: LoadPageData — passes serviceType in both branches
    // ─────────────────────────────────────────────────────────────
    private async Task LoadPageData()
    {
        if (!HasSearched) return;

        try
        {
            IsLoading = true;
            FilteredRepairServices.Clear();

            // ─── BRANCH A: CustomerType filter active → paginate from in-memory list (uncached) ───
            if (!string.IsNullOrEmpty(_lastSelectedCustomerType) && _allFilteredRecords.Any())
            {
                FilteredRepairServices = _allFilteredRecords
                    .Skip((CurrentPage - 1) * PageSize)
                    .Take(PageSize)
                    .ToList();

                Console.WriteLine($"CustomerType in-memory page {CurrentPage}: {FilteredRepairServices.Count} items of {_allFilteredRecords.Count} total.");

                PopulateUserNamesForServices(FilteredRepairServices);
                await LoadSparePartsForCurrentPage();
                return;
            }

            // ─── BRANCH B: Normal cached server-side pagination ───
            bool isAlwaysCreated = ReportMode == "alwayscreated";
            var cacheKey = BuildReportCacheKey(CurrentPage, PageSize);

            Console.WriteLine($"LoadPageData: page {CurrentPage}, ReportMode: {ReportMode}, cache key: {cacheKey}");

            var result = await Cache.GetOrSetAsync(
                cacheKey,
                async () => await RepairService.SearchRepairServicesAsync(
                    pageNumber: CurrentPage,
                    pageSize: PageSize,
                    searchTerm: _lastCompanyName,
                    serialNumber: null,
                    status: (isAlwaysCreated || _lastFilterMode == 2) && _lastSelectedStatuses?.Any() == true
                        ? string.Join(",", _lastSelectedStatuses)
                        : null,
                    serviceType: _lastServiceType != "All" ? _lastServiceType : null,
                    serviceLocation: _lastServiceLocation != "All" ? _lastServiceLocation : null,
                    fromDate: _lastFromDate,
                    toDate: _lastToDate,
                    hasContract: null,
                    dateFilter: null,
                    statusFilter: null,
