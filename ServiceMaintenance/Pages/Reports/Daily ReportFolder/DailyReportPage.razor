    private static readonly Dictionary<int, string> StatusMap = new()
    {
        { 2, "Inspection" },
        { 3, "Awaiting Customer Confirm" },
        { 4, "Awaiting Sparepart" },
        { 7, "Customer Rejected" },
        { 8, "Unrepairable" },
        { 9, "Repair by Third-Party" }
    };

    private List<RepairServices> CreateReportDataWithAwaitingDetails(List<RepairServices> originalServices)
    {
        var expandedServices = new List<RepairServices>();

        foreach (var service in originalServices)
        {
            var statusEntries = new List<(int statusId, string statusName, DateTime date)>();

            foreach (var kvp in StatusMap)
            {
                var date = GetDateForStatus(service, kvp.Key);
                if (date.HasValue)
                {
                    statusEntries.Add((kvp.Key, kvp.Value, date.Value));
                }
            }

            statusEntries = statusEntries.OrderBy(x => x.date).ToList();

            for (int i = 0; i < statusEntries.Count; i++)
            {
                var entry = statusEntries[i];
                var displayStatus = i == 0 ? entry.statusName : $"{entry.statusName} (Historical)";
                expandedServices.Add(CreateAwaitingDetailEntry(service, displayStatus, entry.date));
            }

            if (!statusEntries.Any())
            {
                expandedServices.Add(service);
            }
        }

        return expandedServices;
    }

    private DateTime? GetDateForStatus(RepairServices service, int statusId)
    {
        return statusId switch
        {
            1 => service.ServiceDate,
            2 => service.inspectDate,
            3 => service.awaitingCustomerConfirmDate,
            4 => service.awaitingSparepartDate,
            5 => service.repairDate,
            6 => service.finishedDate,
            7 => service.customerRejectedDate,
            8 => service.unrepairableDate,
            9 => service.thirdPartyRepairDate,
            _ => null
        };
    }

    private RepairServices CreateAwaitingDetailEntry(RepairServices originalService, string status, DateTime statusDate)
    {
        return new RepairServices
        {
            Id = Guid.NewGuid(),
            reportNo = originalService.reportNo,
            ServiceDate = statusDate,
            ServiceDateFormatted = statusDate.ToString("dd-MM-yyyy"),
            CompanyName = originalService.CompanyName,
            Address = originalService.Address,
            ContactName = originalService.ContactName,
            PhoneNumber = originalService.PhoneNumber,
            itemName = originalService.itemName,
            serialNumber = originalService.serialNumber,
            CustomerRequest = originalService.CustomerRequest,
            Inspection = originalService.Inspection,
            Solution = originalService.Solution,
            ServiceLocation = originalService.ServiceLocation,
            ServiceType = originalService.ServiceType,
            ServicePriority = originalService.ServicePriority,
            Status = status,
            hasContract = originalService.hasContract,
            isThirdPartyRepair = originalService.isThirdPartyRepair,
            repairBy = originalService.repairBy,
            verifiedBy = originalService.verifiedBy,
            CustomerId = originalService.CustomerId,
            itemId = originalService.itemId,
            SparePartItems = originalService.SparePartItems,
            InspectItems = originalService.InspectItems
        };
    }

