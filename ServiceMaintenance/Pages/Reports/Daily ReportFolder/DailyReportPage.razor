    private void PopulateUserNamesForServices(List<RepairServices> services)
    {
        foreach (var service in services)
        {
            service.RepairByName = service.repairBy.HasValue && service.repairBy.Value != Guid.Empty
                ? GetUserNameById(service.repairBy)
                : service.setAwaitingCustomerConfirmBy.HasValue && service.setAwaitingCustomerConfirmBy.Value != Guid.Empty
                ? GetUserNameById(service.setAwaitingCustomerConfirmBy)
                : service.setAwaitingSparepartBy.HasValue && service.setAwaitingSparepartBy.Value != Guid.Empty
                ? GetUserNameById(service.setAwaitingSparepartBy)
                : service.thirdPartyRepairBy.HasValue && service.thirdPartyRepairBy.Value != Guid.Empty
                ? GetUserNameById(service.thirdPartyRepairBy)
                : "None";

            service.VerifiedByName = GetUserNameById(service.verifiedBy);
        }
