@page "/users-management/edit/{UserId}"
@using ServiceMaintenance.Services
@inject JwtUserManagementService UserManagementService
@inject NavigationManager NavigationManager
@attribute [Authorize(Roles = "SuperAdmin")]

<div class="edit-user-container">
    <div class="page-header">
        <h2 class="page-title">Edit User</h2>
        <p class="page-subtitle">Update user information and details</p>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner"></div>
            <p>Loading user data...</p>
        </div>
    }
    else if (user == null)
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> User not found
        </div>
        <button class="btn btn-secondary" @onclick="GoBack">Go Back</button>
    }
    else
    {
        @if (!string.IsNullOrEmpty(messageText))
        {
            <div class="alert @(messageType == "success" ? "alert-success" : "alert-danger")">
                @messageText
                <button class="btn-close-alert" @onclick="@(() => messageText = null)">×</button>
            </div>
        }

        <div class="form-card">
            <EditForm Model="updateUser" OnValidSubmit="UpdateUser">
                <DataAnnotationsValidator />

                <!-- User Info Display -->
                <div class="info-section">
                    <div class="info-item">
                        <span class="info-label">User ID:</span>
                        <span class="info-value">@user.Id</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Current Status:</span>
                        @if (user.IsLocked)
                        {
                            <span class="status-badge status-locked">Locked</span>
                        }
                        else
                        {
                            <span class="status-badge status-active">Active</span>
                        }
                    </div>
                </div>

                <!-- Personal Information -->
                <div class="form-section">
                    <h5 class="section-title">Personal Information</h5>
                    <div class="form-row">
                        <div class="form-group">
                            <label>First Name</label>
                            <InputText @bind-Value="updateUser.FirstName" class="form-input" placeholder="Enter first name" />
                            <ValidationMessage For="@(() => updateUser.FirstName)" />
                        </div>
                        <div class="form-group">
                            <label>Last Name</label>
                            <InputText @bind-Value="updateUser.LastName" class="form-input" placeholder="Enter last name" />
                            <ValidationMessage For="@(() => updateUser.LastName)" />
                        </div>
                    </div>
                </div>

                <!-- Account Details -->
                <div class="form-section">
                    <h5 class="section-title">Account Details</h5>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Username *</label>
                            <InputText @bind-Value="updateUser.UserName" class="form-input" placeholder="Enter username" />
                            <ValidationMessage For="@(() => updateUser.UserName)" />
                        </div>
                        <div class="form-group">
                            <label>Email *</label>
                            <InputText @bind-Value="updateUser.Email" type="email" class="form-input" placeholder="user@example.com" />
                            <ValidationMessage For="@(() => updateUser.Email)" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <InputText @bind-Value="updateUser.PhoneNumber" class="form-input" placeholder="+1 (555) 000-0000" />
                    </div>
                </div>

                <!-- Current Roles Display -->
                <div class="form-section">
                    <h5 class="section-title">Current Roles</h5>
                    <div class="roles-display">
                        @if (user.Roles != null && user.Roles.Any())
                        {
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge badge-@role.ToLower()">@role</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No roles assigned</span>
                        }
                    </div>
                    <button type="button" class="btn btn-link" @onclick="NavigateToRoles">
                        Manage Roles →
                    </button>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-small"></span>
                            <span>Updating...</span>
                        }
                        else
                        {
                            <span>Update User</span>
                        }
                    </button>
                    <button type="button" @onclick="NavigateToPasswordReset" class="btn btn-warning" disabled="@isSubmitting">
                        Reset Password
                    </button>
                    <button type="button" @onclick="GoBack" class="btn btn-secondary" disabled="@isSubmitting">
                        Cancel
                    </button>
                </div>
            </EditForm>
        </div>
    }
</div>

<!-- Password Reset Modal -->
@if (showPasswordModal)
{
    <div class="modal-overlay" @onclick="CancelPasswordReset">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>Reset User Password</h3>
            <p>Enter a new password for <strong>@user?.UserName</strong></p>

            <div class="form-group">
                <label>New Password</label>
                <input type="password" @bind="newPassword" class="form-input" placeholder="Enter new password" />
                <small class="form-text">Minimum 6 characters, at least one uppercase, lowercase, and digit</small>
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <input type="password" @bind="confirmPassword" class="form-input" placeholder="Confirm new password" />
            </div>

            @if (!string.IsNullOrEmpty(passwordError))
            {
                <div class="alert alert-danger">@passwordError</div>
            }

            <div class="modal-actions">
                <button class="btn btn-primary" @onclick="ResetPassword" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-small"></span>
                        <span>Resetting...</span>
                    }
                    else
                    {
                        <span>Reset Password</span>
                    }
                </button>
                <button class="btn btn-secondary" @onclick="CancelPasswordReset" disabled="@isSubmitting">Cancel</button>
            </div>
        </div>
    </div>
}

