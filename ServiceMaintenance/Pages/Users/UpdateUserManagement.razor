@code {
    [Parameter]
    public string UserId { get; set; }

    private UserDto user;
    private UpdateUserDto updateUser = new();
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string messageText;
    private string messageType;

    // Password reset modal
    private bool showPasswordModal = false;
    private string newPassword = "";
    private string confirmPassword = "";
    private string passwordError;

    protected override async Task OnInitializedAsync()
    {
        await LoadUser();
    }

    private async Task LoadUser()
    {
        isLoading = true;

        var response = await UserManagementService.GetUserByIdAsync(UserId);

        if (response.Status == "Success" && response.Data != null)
        {
            user = response.Data;

            // Populate update model
            updateUser = new UpdateUserDto
            {
                UserName = user.UserName,
                Email = user.Email,
                FirstName = user.FirstName,
                LastName = user.LastName,
                PhoneNumber = user.PhoneNumber
            };
        }
        else
        {
            ShowMessage(response.Message ?? "Failed to load user", "error");
        }

        isLoading = false;
    }

    private async Task UpdateUser()
    {
        isSubmitting = true;
        messageText = null;

        try
        {
            var response = await UserManagementService.UpdateUserAsync(UserId, updateUser);

            if (response.Status == "Success")
            {
                ShowMessage("User updated successfully", "success");
                await LoadUser(); // Reload to show updated data
            }
            else
            {
                ShowMessage(response.Message, "error");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}", "error");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void NavigateToPasswordReset()
    {
        newPassword = "";
        confirmPassword = "";
        passwordError = null;
        showPasswordModal = true;
    }

    private void CancelPasswordReset()
    {
        showPasswordModal = false;
        newPassword = "";
        confirmPassword = "";
        passwordError = null;
    }

    private async Task ResetPassword()
    {
        passwordError = null;

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            passwordError = "Password is required";
            return;
        }

        if (newPassword != confirmPassword)
        {
            passwordError = "Passwords do not match";
            return;
        }

        if (newPassword.Length < 6)
        {
            passwordError = "Password must be at least 6 characters";
            return;
        }

        isSubmitting = true;

        try
        {
            var response = await UserManagementService.ResetUserPasswordAsync(UserId, newPassword);

            if (response.Status == "Success")
            {
                ShowMessage("Password reset successfully", "success");
                CancelPasswordReset();
            }
            else
            {
                passwordError = response.Message;
            }
        }
        catch (Exception ex)
        {
            passwordError = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void NavigateToRoles()
    {
        NavigationManager.NavigateTo($"/users/roles/{UserId}");
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/users");
    }

    private void ShowMessage(string message, string type)
    {
        messageText = message;
        messageType = type;
        StateHasChanged();
    }
}