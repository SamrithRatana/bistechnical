@code {
    private List<UserDto> users = new();
    private PaginationInfo pagination;
    private bool isLoading = true;
    private string searchQuery = "";
    private int currentPage = 1;
    private int pageSize = 10;
    private string messageText;
    private string messageType;

    // Delete modal
    private bool showDeleteModal = false;
    private string userToDeleteId;
    private string userToDeleteName;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        StateHasChanged();

        var response = await UserManagementService.GetAllUsersAsync(currentPage, pageSize);

        if (response.Status == "Success")
        {
            users = response.Data;
            pagination = response.Pagination;
        }
        else
        {
            ShowMessage(response.Message, "error");
        }

        isLoading = false;
    }

    private async Task SearchUsers()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            await LoadUsers();
            return;
        }

        isLoading = true;
        var response = await UserManagementService.SearchUsersAsync(searchQuery, currentPage, pageSize);

        if (response.Status == "Success")
        {
            users = response.Data;
            pagination = response.Pagination;
        }
        else
        {
            ShowMessage(response.Message, "error");
        }

        isLoading = false;
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchUsers();
        }
    }

    private async Task ClearSearch()
    {
        searchQuery = "";
        currentPage = 1;
        await LoadUsers();
    }

    private async Task PreviousPage()
    {
        if (pagination?.HasPrevious == true)
        {
            currentPage--;
            await (string.IsNullOrWhiteSpace(searchQuery) ? LoadUsers() : SearchUsers());
        }
    }

    private async Task NextPage()
    {
        if (pagination?.HasNext == true)
        {
            currentPage++;
            await (string.IsNullOrWhiteSpace(searchQuery) ? LoadUsers() : SearchUsers());
        }
    }

    private void NavigateToCreate() => NavigationManager.NavigateTo("/users-management/create");
    private void NavigateToEdit(string userId) => NavigationManager.NavigateTo($"/users-management/edit/{userId}");
    private void NavigateToRoles(string userId) => NavigationManager.NavigateTo($"/users-management/roles/{userId}");

    private void ConfirmDelete(string userId, string userName)
    {
        userToDeleteId = userId;
        userToDeleteName = userName;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        userToDeleteId = null;
        userToDeleteName = null;
    }

    private async Task DeleteUser()
    {
        showDeleteModal = false;

        var response = await UserManagementService.DeleteUserAsync(userToDeleteId);

        if (response.Status == "Success")
        {
            ShowMessage($"User {userToDeleteName} deleted successfully", "success");
            await LoadUsers();
        }
        else
        {
            ShowMessage(response.Message, "error");
        }
    }

    private async Task LockUser(string userId)
    {
        var response = await UserManagementService.LockUserAsync(userId);

        if (response.Status == "Success")
        {
            ShowMessage("User locked successfully", "success");
            await LoadUsers();
        }
        else
        {
            ShowMessage(response.Message, "error");
        }
    }

    private async Task UnlockUser(string userId)
    {
        var response = await UserManagementService.UnlockUserAsync(userId);

        if (response.Status == "Success")
        {
            ShowMessage("User unlocked successfully", "success");
            await LoadUsers();
        }
        else
        {
            ShowMessage(response.Message, "error");
        }
    }

    private void ShowMessage(string message, string type)
    {
        messageText = message;
        messageType = type;
        StateHasChanged();
    }
}