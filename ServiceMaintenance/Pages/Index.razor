    private async Task NavigateToPage(string routeUrl)
    {
        try
        {
            currentDialogType = routeUrl;
            dialogCurrentPage = 1;
            await LoadDialogData(routeUrl);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dialog data: {ex.Message}");
            dialogData = new List<RepairServices>();
        }
    }

    private async Task LoadDialogData(string routeUrl)
    {
        isDialogLoading = true;
        StateHasChanged();

        try
        {
            if (routeUrl == "/reports/today")
            {
                var result = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: dialogCurrentPage,
                    pageSize: dialogPageSize,
                    dateFilter: "Today");
                dialogData = result?.Items?.ToList() ?? new List<RepairServices>();
                dialogTotalPages = result?.TotalPages ?? 1;
                dialogTotalCount = result?.TotalCount ?? 0;
                dialogPaginatedResult = result;
                isTodayDialogVisible = true;
            }
            else if (routeUrl == "/services/receiveitem")
            {
                var result = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: dialogCurrentPage,
                    pageSize: dialogPageSize,
                    status: "Item Recieved");
                dialogData = result?.Items?.ToList() ?? new List<RepairServices>();
                dialogTotalPages = result?.TotalPages ?? 1;
                dialogTotalCount = result?.TotalCount ?? 0;
                dialogPaginatedResult = result;
                isReceiveItemDialogVisible = true;
            }
            else if (routeUrl == "/services/finished")
            {
                var startOfMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
                var endOfMonth = startOfMonth.AddMonths(1).AddDays(-1);
                var result = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: dialogCurrentPage,
                    pageSize: dialogPageSize,
                    status: "Finished",
                    fromDate: startOfMonth,
                    toDate: endOfMonth);
                dialogData = result?.Items?.ToList() ?? new List<RepairServices>();
                dialogTotalPages = result?.TotalPages ?? 1;
                dialogTotalCount = result?.TotalCount ?? 0;
                dialogPaginatedResult = result;
                isFinishedThisMonthDialogVisible = true;
            }
            else if (routeUrl == "/customer/waiting-customer")
            {
                var result = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: dialogCurrentPage,
                    pageSize: dialogPageSize,
                    status: "Awaiting Customer Confirm");
                dialogData = result?.Items?.ToList() ?? new List<RepairServices>();
                dialogTotalPages = result?.TotalPages ?? 1;
                dialogTotalCount = result?.TotalCount ?? 0;
                dialogPaginatedResult = result;
                isWaitingCustomerDialogVisible = true;
            }
            else if (routeUrl == "/customer/waiting-spare")
            {
                var result = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: dialogCurrentPage,
                    pageSize: dialogPageSize,
                    status: "Awaiting Sparepart");
                dialogData = result?.Items?.ToList() ?? new List<RepairServices>();
                dialogTotalPages = result?.TotalPages ?? 1;
                dialogTotalCount = result?.TotalCount ?? 0;
                dialogPaginatedResult = result;
                isWaitingSpareDialogVisible = true;
            }
            else if (!string.IsNullOrEmpty(routeUrl))
            {
                NavigationManager.NavigateTo(routeUrl);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dialog data: {ex.Message}");
            dialogData = new List<RepairServices>();
        }
        finally
        {
            isDialogLoading = false;
            StateHasChanged();
        }
    }

