@page "/"
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.SignalR.Client
@using ServiceMaintenance.Resources
@using ServiceMaintenance.Services
@using Syncfusion.Blazor.Navigations
@inject GlobalUserService GlobalUserCache
@inject RepairItemService RepairItemService
@inject IRedisService Redis
@inject CacheHelper Cache
@inject MessageQueueHelper MQ
@attribute [Authorize]

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-4 g-4">
    @foreach (var statistic in statistics)
    {
        <div class="col">
            <div class="card statistic-card" style="cursor: @(string.IsNullOrEmpty(statistic.RouteUrl) ? "default" : "pointer")"
                 @onclick="() => NavigateToPage(statistic.RouteUrl)">
                <div class="card-body p-3">
                    <div class="row">
                        <div class="col-8">
                            <div class="numbers">
                                <p class="text-sm mb-0 text-capitalize font-weight-bold text-truncate"
                                   style="max-width: 100%;"
                                   title="@statistic.Title">
                                    @statistic.Title
                                </p>
                                <h5 class="font-weight-bolder mb-0">
                                    <span class="@statistic.ValueClass">@statistic.Value</span>
                                    @if (!string.IsNullOrEmpty(statistic.Trend))
                                    {
                                        <span class="@statistic.TrendClass text-sm font-weight-bolder">@statistic.Trend</span>
                                    }
                                </h5>
                            </div>
                        </div>
                        <div class="col-4 text-end">
                            <div class="icon icon-shape bg-gradient-primary shadow text-center border-radius-md">
                                <i class="@statistic.IconClass text-lg opacity-10" aria-hidden="true"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<SfMediaQuery @bind-ActiveBreakPoint="activeBreakpoint"></SfMediaQuery>

@{
    bool enableAdaptiveUIMode = false;
    RowDirection renderingMode = RowDirection.Vertical;

    if (activeBreakpoint == "Small")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Vertical;
    }
    else if (activeBreakpoint == "Medium")
    {
        enableAdaptiveUIMode = true;
        renderingMode = RowDirection.Horizontal;
    }
    else
    {
        enableAdaptiveUIMode = false;
    }
}

<div class="repair-grid">
    <div class="filter-container">
        <SfButton Content="Export" IconCss="fas fa-download" OnClick="ShowExportDialog" CssClass="toolbar-item" style="margin-right:10px;" />

        <SfDialog @bind-Visible="@isDialogExportVisible" Width="270px" Height="150px" ShowCloseIcon="true">
            <div class="p-3">
                <SfButton Content="Excel" IconCss="fas fa-file-excel" OnClick="ExportToExcel" CssClass="toolbar-item" style="margin-right:10px;" />
                <SfButton Content="PDF" IconCss="fas fa-file-pdf" OnClick="ExportToPdf" CssClass="toolbar-item" style="margin-right:10px;" />
            </div>
        </SfDialog>

        <select class="form-control filter-select" @onchange="OnFilterChange">
            <option value="All" selected="@IsSelected("All")">All</option>
            <option value="Today" selected="@IsSelected("Today")">Today</option>
            <option value="Yesterday" selected="@IsSelected("Yesterday")">Yesterday</option>
            <option value="LastWeek" selected="@IsSelected("LastWeek")">Last Week</option>
            <option value="LastMonth" selected="@IsSelected("LastMonth")">Last Month</option>
            <option value="Draft" selected="@IsSelected("Draft")">Draft</option>
            <option value="Complete" selected="@IsSelected("Complete")">Complete</option>
            <option value="Custom" selected="@IsSelected("Custom")">Custom Date</option>
        </select>

        <SfDialog @bind-Visible="@isDialogVisible" Width="400px" Height="400px" Title="Custom Date Filter">
            <div class="p-3">
                <div class="mb-3">
                    <label>From Date:</label>
                    <SfDatePicker @bind-Value="@fromDate" Placeholder="Select From Date"></SfDatePicker>
                </div>

                <div class="mb-3">
                    <label>To Date:</label>
                    <SfDatePicker @bind-Value="@toDate" Placeholder="Select To Date"></SfDatePicker>
                </div>

                <div class="mb-3">
                    <label>Status:</label>
                    <select class="form-control" @bind="selectedStatus">
                        <option value="">All</option>
                        <option value="Draft">Draft</option>
                        <option value="Complete">Complete</option>
                    </select>
                </div>

                <button class="btn btn-primary" @onclick="ApplyCustomFilter">Apply</button>
                <button class="btn btn-secondary" @onclick="CloseDialog">Cancel</button>
            </div>
        </SfDialog>
    </div>

    @if (isLoading)
    {
        <div class="text-center p-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <SfGrid @ref="MyGrid"
                DataSource="@gridData"
                AllowSorting="true"
                SelectionMode="GridSelectionMode.Single"
                EnableAdaptiveUI="@enableAdaptiveUIMode"
                RowRenderingMode="@renderingMode"
                AllowSelection="true"
                AllowFiltering="true"
                AllowExcelExport="true"
                AllowPdfExport="true"
                Height="500"
                AllowResizing="true"
                AllowPaging="true">
            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>
            <GridEvents RowSelected="RowSelectHandler"
                        TValue="RepairServices"></GridEvents>
            <GridPageSettings PageSize="@pageSize"
                              PageCount="5"
                              PageSizes="new int[] { 10, 20, 50, 100 }"></GridPageSettings>
            <GridColumns>
                <GridColumn Field="ServiceDate" HeaderText="@Loc[nameof(ResourceStrings.TextReceiveDate)]" Width="180" Format="dd/MM/yyyy HH:mm tt" />
                <GridColumn Field="CompanyName" HeaderText="@Loc[nameof(ResourceStrings.TextCompanyName)]" Width="380" />
                <GridColumn Field="itemName" HeaderText="@Loc[nameof(ResourceStrings.TextModel)]" Width="250" />
                <GridColumn Field="serialNumber" HeaderText="@Loc[nameof(ResourceStrings.TextSerialNumber)]" Width="150" />

                <GridColumn Field="ServicePriority" HeaderText="@Loc[nameof(ResourceStrings.TextPriority)]" Width="150" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                    <Template>
                        @{
                            var repairService = (RepairServices)context;
                            var priorityClass = repairService.ServicePriority switch
                            {
                                "Low" => "priority-low",
                                "Normal" => "priority-normal",
                                "High" => "priority-high",
                                _ => "priority-default"
                            };
                        }
                        <span class="priority-badge @priorityClass">
                            @repairService.ServicePriority
                        </span>
                    </Template>
                </GridColumn>

                <GridColumn HeaderText="@Loc[nameof(ResourceStrings.TextStatus)]" Width="150" IsFrozen="true" Freeze="FreezeDirection.Right" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                    <Template>
                        @{
                            var repairService = (RepairServices)context;
                            var (statusClass, statusGif, statusText) = GetStatusInfo(repairService.Status);
                        }
                        <span class="status-badge @statusClass" @onclick="() => StatusColumnClickHandler(repairService)">
                            @statusText
                        </span>
                        <img class="status-gif" src="@statusGif" alt="Status Icon" />
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>

        @if (paginatedResult != null)
        {
            <div class="d-flex justify-content-between align-items-center mt-3 px-3">
                <div class="pagination-info">
                    <span>Showing <strong>@((dialogCurrentPage - 1) * dialogPageSize + 1)</strong> to <strong>@(Math.Min(dialogCurrentPage * dialogPageSize, dialogTotalCount))</strong> of <strong>@dialogTotalCount</strong> items</span>
                </div>

                <nav aria-label="Page navigation">
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage - 1)" disabled="@(currentPage == 1)">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                        </li>

                        @foreach (var pageNum in GetPageNumbers())
                        {
                            @if (pageNum == -1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                            else
                            {
                                var currentPageNum = pageNum;
                                <li class="page-item @(currentPage == currentPageNum ? "active" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(currentPageNum)">
                                        @currentPageNum
                                    </button>
                                </li>
                            }
                        }

                        <li class="page-item @(currentPage >= paginatedResult.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage + 1)" disabled="@(currentPage >= paginatedResult.TotalPages)">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

<hr />
<ServiceMaintenance.Pages.Details.Member />
<hr />

<SfDialog Width="1200px" IsModal="true" ShowCloseIcon="true" @bind-Visible="isTodayDialogVisible" Header="Today's Reports">
    <DialogEvents OnOverlayModalClick="@(() => isTodayDialogVisible = false)"></DialogEvents>
    <div class="dialog-content">
        @if (isDialogLoading)
        {
            <div class="text-center p-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>Company Name</th>
                            <th>Report No</th>
                            <th>Status</th>
                            <th>Received Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dialogData?.Any() == true)
                        {
                            @foreach (var item in dialogData)
                            {
                                <tr style="cursor: pointer;" @onclick="() => NavigateToService(item.Id)">
                                    <td class="text-start text-danger">@item.CompanyName</td>
                                    <td class="text-start">@item.reportNo</td>
                                    <td class="text-start">@item.Status</td>
                                    <td class="text-start">@item.ServiceDate.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">No records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (dialogTotalPages > 0 && dialogData?.Any() == true)
            {
                <div class="d-flex justify-content-between align-items-center mt-3 px-3">
                    <div class="pagination-info">
                        <span>Showing <strong>@((dialogCurrentPage - 1) * dialogPageSize + 1)</strong> to <strong>@(Math.Min(dialogCurrentPage * dialogPageSize, dialogTotalCount))</strong> of <strong>@dialogTotalCount</strong> items</span>
                    </div>

                    <nav aria-label="Dialog pagination">
                        <ul class="pagination mb-0">
                            <li class="page-item @(dialogCurrentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => GoToDialogPage(dialogCurrentPage - 1)" disabled="@(dialogCurrentPage == 1)">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                            </li>

                            @foreach (var pageNum in GetDialogPageNumbers())
                            {
                                @if (pageNum == -1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                                else
                                {
                                    var currentPageNum = pageNum;
                                    <li class="page-item @(dialogCurrentPage == currentPageNum ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToDialogPage(currentPageNum)">
                                            @currentPageNum
                                        </button>
                                    </li>
                                }
                            }

                            <li class="page-item @(dialogCurrentPage >= dialogPaginatedResult.TotalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => GoToDialogPage(dialogCurrentPage + 1)" disabled="@(dialogCurrentPage >= dialogPaginatedResult.TotalPages)">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</SfDialog>

<SfDialog @bind-Visible="isReceiveItemDialogVisible"
          Width="90%"
          Height="80%"
          IsModal="true"
          ShowCloseIcon="true">
    <DialogTemplates>
        <Header>Received Items</Header>
        <Content>
            <SfGrid DataSource="@dialogData"
                    AllowPaging="false"
                    Height="500">
                <GridColumns>
                    <GridColumn Field="@nameof(RepairServices.CompanyName)" HeaderText="Company"></GridColumn>
                    <GridColumn Field="@nameof(RepairServices.reportNo)" HeaderText="Report No"></GridColumn>
                    <GridColumn Field="@nameof(RepairServices.Status)" HeaderText="Status"></GridColumn>
                    <GridColumn Field="@nameof(RepairServices.ServiceDate)" HeaderText="Date" Format="yyyy-MM-dd"></GridColumn>
                </GridColumns>
            </SfGrid>
        </Content>
        <FooterTemplate>
            <div class="dialog-footer-pagination">
                <div class="pagination-info">
                    <span>Showing <strong>@((dialogCurrentPage - 1) * dialogPageSize + 1)</strong> to <strong>@(Math.Min(dialogCurrentPage * dialogPageSize, dialogTotalCount))</strong> of <strong>@dialogTotalCount</strong> items</span>
                </div>
                <div class="pagination-controls">
                    <button class="e-btn e-small"
                            @onclick="PreviousDialogPage"
                            disabled="@(dialogCurrentPage <= 1)">
                        Previous
                    </button>

                    <span class="page-numbers">
                        @for (int i = 1; i <= dialogTotalPages; i++)
                        {
                            int pageNum = i;
                            <button class="e-btn e-small @(dialogCurrentPage == pageNum ? "e-active" : "")"
                                    @onclick="() => GoToDialogPage(pageNum)">
                                @pageNum
                            </button>
                        }
                    </span>

                    <button class="e-btn e-small"
                            @onclick="NextDialogPage"
                            disabled="@(dialogCurrentPage >= dialogTotalPages)">
                        Next
                    </button>
                </div>
            </div>
        </FooterTemplate>
    </DialogTemplates>
</SfDialog>

