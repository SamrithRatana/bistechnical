    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAllUsersAsync();
            await LoadStatisticsData();
            StateHasChanged();
            await LoadGridData();
            await SetupSignalR();

            updateTimer = new System.Timers.Timer(3000);
            updateTimer.Elapsed += async (sender, e) => await ToggleStatistic();
            updateTimer.AutoReset = true;
            updateTimer.Start();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in OnInitializedAsync: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
    // ✅ Load all users once at startup
    private async Task LoadAllUsersAsync()
    {
        if (_usersLoaded)
            return;

        try
        {
            Console.WriteLine("📥 Loading all users from API...");

            // Get all users from GlobalUserCache
            _allUsers = await GlobalUserCache.GetUsersAsync();

            _usersLoaded = true;
            Console.WriteLine($"✅ Loaded {_allUsers.Count} users into cache");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading users: {ex.Message}");
            _allUsers = new Dictionary<string, string>();
        }
    }

    // ✅ Get username by GUID (works for ANY user GUID field)
    private string GetUserNameDisplay(Guid? userId)
    {
        if (!userId.HasValue || userId.Value == Guid.Empty)
            return "Unknown";

        // Convert Guid to string for dictionary lookup
        string userIdString = userId.Value.ToString();

        // Check if users are loaded
        if (!_usersLoaded)
            return "Loading...";

        // Lookup username from loaded users dictionary
        if (_allUsers.TryGetValue(userIdString, out string username))
            return username;

        return "Unknown User";
    }
    private async Task LoadStatisticsData()
    {
        try
        {
            // ✅ Try Redis Cache first
            var cachedStats = await Cache.GetOrSetAsync(
                CacheKeys.DashboardStats,
                async () =>
                {
                    Console.WriteLine("📥 Loading fresh dashboard statistics...");

                    var todayTask = RepairItemService.SearchRepairServicesAsync(
                        pageNumber: 1, pageSize: 1, dateFilter: "Today");

                    var receivedTask = RepairItemService.SearchRepairServicesAsync(
                        pageNumber: 1, pageSize: 1, status: "Item Recieved");

                    var awaitingCustomerTask = RepairItemService.SearchRepairServicesAsync(
                        pageNumber: 1, pageSize: 1, status: "Awaiting Customer Confirm");

                    var awaitingSpareTask = RepairItemService.SearchRepairServicesAsync(
                        pageNumber: 1, pageSize: 1, status: "Awaiting Sparepart");

                    var startOfMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
                    var endOfMonth = startOfMonth.AddMonths(1).AddDays(-1);
                    var finishedTask = RepairItemService.SearchRepairServicesAsync(
                        pageNumber: 1, pageSize: 1, status: "Finished",
                        fromDate: startOfMonth, toDate: endOfMonth);

                    // ✅ All parallel
                    await Task.WhenAll(todayTask, receivedTask,
                        awaitingCustomerTask, awaitingSpareTask, finishedTask);

                    return new DashboardStatistics
                    {
                        TodayCount = (await todayTask)?.TotalCount ?? 0,
                        ReceivedCount = (await receivedTask)?.TotalCount ?? 0,
                        WaitingCustomerCount = (await awaitingCustomerTask)?.TotalCount ?? 0,
                        WaitingSpareCount = (await awaitingSpareTask)?.TotalCount ?? 0,
                        FinishedThisMonthCount = (await finishedTask)?.TotalCount ?? 0
                    };
                },
                TimeSpan.FromMinutes(2)
            );

            if (cachedStats != null)
            {
                _todayCount = cachedStats.TodayCount;
                _receivedCount = cachedStats.ReceivedCount;
                _finishedThisMonthCount = cachedStats.FinishedThisMonthCount;
                waitingCustomerCount = cachedStats.WaitingCustomerCount;
                waitingSpareCount = cachedStats.WaitingSpareCount;
                Console.WriteLine("✅ Statistics loaded");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading statistics: {ex.Message}");
        }
    }
    private async Task LoadGridData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var cacheKey = $"dashboard:grid:{selectedFilter}:page{currentPage}:size{pageSize}";

            string dateFilter = null;
            string statusFilter = null;
            DateTime? apiFromDate = null;
            DateTime? apiToDate = null;

            switch (selectedFilter)
            {
                case "Today": dateFilter = "Today"; break;
                case "Yesterday": dateFilter = "Yesterday"; break;
                case "LastWeek": dateFilter = "LastWeek"; break;
                case "LastMonth": dateFilter = "LastMonth"; break;
                case "Draft": statusFilter = "Draft"; dateFilter = "All"; break;
                case "Complete": statusFilter = "Complete"; dateFilter = "All"; break;
                case "Custom":
                    apiFromDate = fromDate;
                    apiToDate = toDate;
                    statusFilter = string.IsNullOrEmpty(selectedStatus) ? null : selectedStatus;
                    break;
                case "All":
                default: dateFilter = "All"; break;
            }

            paginatedResult = await Cache.GetOrSetAsync(
                cacheKey,
                () => RepairItemService.SearchRepairServicesAsync(
                    pageNumber: currentPage,
                    pageSize: pageSize,
                    dateFilter: dateFilter,
                    statusFilter: statusFilter,
                    fromDate: apiFromDate,
                    toDate: apiToDate),
                selectedFilter == "Today"
                    ? TimeSpan.FromMinutes(1)
                    : TimeSpan.FromMinutes(5)
            );

            gridData = paginatedResult?.Items ?? new List<RepairServices>();
            Console.WriteLine($"✅ Grid loaded: {gridData.Count} items");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading grid data: {ex.Message}");
            gridData = new List<RepairServices>();
            paginatedResult = new PaginatedResult<RepairServices>
            {
                Items = new List<RepairServices>(),
                TotalCount = 0,
                PageNumber = currentPage,
                PageSize = pageSize,
                TotalPages = 0
            };
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SetupSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/itemHub"))
            .Build();

        hubConnection.On<string>("ReceiveItemUpdate", async (message) =>
        {
            // ✅ Invalidate all dashboard cache
            await Cache.InvalidateManyAsync(
                CacheKeys.DashboardStats,
                $"dashboard:grid:{selectedFilter}:page{currentPage}:size{pageSize}"
            );

            await LoadStatisticsData();
            await LoadGridData();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<Guid>("BroadcastItemDelete", async (deletedItemId) =>
        {
            // ✅ Invalidate all dashboard cache
            await Cache.InvalidateManyAsync(
                CacheKeys.DashboardStats,
                $"dashboard:grid:{selectedFilter}:page{currentPage}:size{pageSize}"
            );

            await LoadStatisticsData();
            await LoadGridData();
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();

        hubConnection.Closed += async (error) =>
        {
            await Task.Delay(new Random().Next(0, 5) * 1000);
            try { await hubConnection.StartAsync(); }
            catch (Exception ex) { Console.WriteLine($"Reconnection failed: {ex.Message}"); }
        };
    }

    private async Task OnFilterChange(Microsoft.AspNetCore.Components.ChangeEventArgs args)
    {
        selectedFilter = args?.Value?.ToString() ?? "Today";

        if (selectedFilter == "Custom")
        {
            isDialogVisible = true;
        }
        else
        {
            // ✅ Invalidate cache for new filter
            await Cache.InvalidateByPrefixAsync(
                $"dashboard:grid:{selectedFilter}");
            currentPage = 1;
            await LoadGridData();
        }
    }

    private async Task ApplyCustomFilter()
    {
        if (fromDate.HasValue && toDate.HasValue)
        {
            await Cache.InvalidateByPrefixAsync("dashboard:grid:Custom");
            currentPage = 1;
            await LoadGridData();
            CloseDialog();
        }
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > (paginatedResult?.TotalPages ?? 1) || page == currentPage)
            return;

        currentPage = page;
        await LoadGridData();
    }

    private List<int> GetPageNumbers()
    {
        var pages = new List<int>();
        var totalPages = paginatedResult?.TotalPages ?? 1;

        if (totalPages <= 7)
        {
            for (int i = 1; i <= totalPages; i++)
            {
                pages.Add(i);
            }
        }
        else
        {
            pages.Add(1);

            if (currentPage <= 4)
            {
                for (int i = 2; i <= 5; i++)
                {
                    pages.Add(i);
                }
                pages.Add(-1);
                pages.Add(totalPages);
            }
            else if (currentPage >= totalPages - 3)
            {
                pages.Add(-1);
                for (int i = totalPages - 4; i <= totalPages; i++)
                {
                    pages.Add(i);
                }
            }
            else
            {
                pages.Add(-1);
                for (int i = currentPage - 1; i <= currentPage + 1; i++)
                {
                    pages.Add(i);
                }
                pages.Add(-1);
                pages.Add(totalPages);
            }
        }

        return pages;
    }

