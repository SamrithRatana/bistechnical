@code {
    private SfGrid<RepairServices> MyGrid;
    private PaginatedResult<RepairServices> paginatedResult;
    private List<RepairServices> gridData = new();
    private List<RepairServices> dialogData = new();
    private PaginatedResult<RepairServices> dialogPaginatedResult;
    private int dialogCurrentPage = 1;
    private int dialogPageSize = 10;
    private string currentDialogType = "";
    private int dialogTotalPages = 1;
    private int dialogTotalCount = 0;
    private Dictionary<string, string> _allUsers = new Dictionary<string, string>();
