<body>
    @{
        var isIEOrEdgeLegacy = Context.Request.Headers["User-Agent"]
            .Any(userAgent => userAgent.Contains("MSIE") || userAgent.Contains("Trident") || userAgent.Contains("Edge/"));
    }
    @if(isIEOrEdgeLegacy)
    {
        <component type="typeof(ServiceMaintenance.Shared.BrowserNotSupported)" render-mode="Static" />
    }
    else
    {
        @RenderBody()

        <div id="blazor-error-ui">
            <environment include="Staging,Production">
                An error has occurred. This application may no longer respond until reloaded.
            </environment>
            <environment include="Development">
                An unhandled exception has occurred. See browser dev tools for details.
            </environment>
            <a href="" class="reload">Reload</a>
            <a class="dismiss">🗙</a>
        </div>

        <script src="_framework/blazor.server.js"></script>
        <script src="~/js/voiceRecorder2.js"></script>
        <script src="js/site.js"></script>
        <script>
                        window.scrollToBottom = function(elementId) {
                var element = document.getElementById(elementId);
                if (element) {
                    element.scrollTop = element.scrollHeight;

                    // Also use smooth scroll for better UX
                    element.scrollTo({
                        top: element.scrollHeight,
                        behavior: 'smooth'
                    });
                }
            };
                        window.preventEnterDefault = function(elementId) {
                console.log('preventEnterDefault called for:', elementId);
            };

           
        </script>
        <script>
                        window.addOutsideClickListener = (dotNetHelper) => {
                document.addEventListener('click', function(event) {
                    const envelopeDropdown = document.getElementById('envelopeDropdown');
                    const notificationDropdown = document.querySelector('.notification-dropdown-menu');

                    const envelopeButton = event.target.closest('.notification-icon-wrapper:has(.fa-envelope)');
                    const bellButton = event.target.closest('.notification-icon-wrapper:has(.fa-bell)');

                    const clickedInsideEnvelope = envelopeDropdown && envelopeDropdown.contains(event.target);
                    const clickedInsideNotification = notificationDropdown && notificationDropdown.contains(event.target);

                    // Close dropdowns if clicked outside
                    if (!envelopeButton && !clickedInsideEnvelope && !bellButton && !clickedInsideNotification) {
                        dotNetHelper.invokeMethodAsync('CloseNotificationDropdown');
                    }
                });
            };
        </script>
        <script>
                       // Enhanced Print/Export Helper for BlazorReports
            window.blazorReportsPrint = {
                // Detect mobile device
                isMobileDevice: function () {
                    return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)
                        || window.innerWidth <= 768;
                },

                // Convert base64 to Blob
                base64ToBlob: function (base64Data) {
                    const binaryString = window.atob(base64Data);
                    const bytes = new Uint8Array(binaryString.length);
                    for (let i = 0; i < binaryString.length; i++) {
                        bytes[i] = binaryString.charCodeAt(i);
                    }
                    return new Blob([bytes], { type: 'application/pdf' });
                },

                // Download PDF
                downloadPDF: function (base64Data, filename = 'report.pdf') {
                    try {
                        const blob = this.base64ToBlob(base64Data);
                        const url = URL.createObjectURL(blob);

                        const link = document.createElement('a');
                        link.href = url;
                        link.download = filename;
                        link.style.display = 'none';
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);

                        setTimeout(() => URL.revokeObjectURL(url), 100);
                        console.log('PDF downloaded:', filename);
                        return true;
                    } catch (error) {
                        console.error('Download error:', error);
                        alert('Error downloading report: ' + error.message);
                        return false;
                    }
                },

                // Open PDF in mobile browser
                openPDFInMobileBrowser: function (base64Data, filename = 'report.pdf') {
                    try {
                        const blob = this.base64ToBlob(base64Data);
                        const blobUrl = URL.createObjectURL(blob);

                        const pdfWindow = window.open(blobUrl, '_blank');

                        if (!pdfWindow) {
                            console.warn('Popup blocked - downloading instead');
                            URL.revokeObjectURL(blobUrl);
                            return this.downloadPDF(base64Data, filename);
                        }

                        setTimeout(() => URL.revokeObjectURL(blobUrl), 120000);
                        return true;
                    } catch (error) {
                        console.error('Error opening PDF:', error);
                        return this.downloadPDF(base64Data, filename);
                    }
                },

                // Print via hidden iframe (desktop)
                printViaIframe: function (base64Data) {
                    try {
                        const blob = this.base64ToBlob(base64Data);
                        const blobUrl = URL.createObjectURL(blob);

                        const iframe = document.createElement('iframe');
                        iframe.style.position = 'fixed';
                        iframe.style.right = '0';
                        iframe.style.bottom = '0';
                        iframe.style.width = '0';
                        iframe.style.height = '0';
                        iframe.style.border = 'none';
                        iframe.src = blobUrl;

                        document.body.appendChild(iframe);

                        const cleanup = () => {
                            if (document.body.contains(iframe)) {
                                document.body.removeChild(iframe);
                            }
                            URL.revokeObjectURL(blobUrl);
                        };

                        iframe.onload = function () {
                            setTimeout(() => {
                                try {
                                    iframe.contentWindow.focus();
                                    iframe.contentWindow.print();

                                    // Cleanup after print dialog closes
                                    iframe.contentWindow.onafterprint = () => {
                                        setTimeout(cleanup, 100);
                                    };

                                    // Fallback cleanup
                                    setTimeout(cleanup, 300000); // 5 minutes
                                } catch (e) {
                                    console.error('Print error:', e);
                                    cleanup();
                                }
                            }, 500);
                        };

                        // Safety cleanup
                        setTimeout(cleanup, 600000); // 10 minutes

                        return true;
                    } catch (error) {
                        console.error('Iframe print error:', error);
                        return false;
                    }
                },

                // Main print function
                printReport: function (base64Data, filename = 'report.pdf') {
                    try {
                        if (this.isMobileDevice()) {
                            console.log('Mobile: Opening PDF in browser');
                            return this.openPDFInMobileBrowser(base64Data, filename);
                        } else {
                            console.log('Desktop: Showing print dialog');
                            return this.printViaIframe(base64Data);
                        }
                    } catch (error) {
                        console.error('Print error:', error);
                        alert('Error processing report: ' + error.message);
                        return false;
                    }
                },

                // Preview/print function
                previewReportInNewTab: function (base64Data, filename = 'report.pdf') {
                    try {
                        if (this.isMobileDevice()) {
                            console.log('Mobile: Opening PDF in browser');
                            return this.openPDFInMobileBrowser(base64Data, filename);
                        } else {
                            console.log('Desktop: Showing print dialog');
                            return this.printViaIframe(base64Data);
                        }
                    } catch (error) {
                        console.error('Preview error:', error);
                        alert('Error previewing report: ' + error.message);
                        return false;
                    }
                }
            };

            // Legacy support
            window.printReport = function (base64Data, filename) {
                return window.blazorReportsPrint.printReport(base64Data, filename || 'report.pdf');
            };

            window.previewReportInNewTab = function (base64Data, filename) {
                return window.blazorReportsPrint.previewReportInNewTab(base64Data, filename || 'report.pdf');
            };
        </script>

        
       <script>
            window.cropperInterop = {
                cropper: null,
                currentFilter: "none",

                // Initialize cropper
                initCropper: function (imgId) {
                    console.log("Initializing cropper for:", imgId);

                    var image = document.getElementById(imgId);
                    if (!image) {
                        console.error("Image element not found:", imgId);
                        return;
                    }

                    // Destroy existing cropper if any
                    if (window.cropperInterop.cropper) {
                        window.cropperInterop.cropper.destroy();
                    }

                    // Wait for image to load
                    if (!image.complete) {
                        image.onload = function() {
                            window.cropperInterop._createCropper(image);
                        };
                    } else {
                        window.cropperInterop._createCropper(image);
                    }
                },

                _createCropper: function(image) {
                    try {
                        window.cropperInterop.cropper = new Cropper(image, {
                            aspectRatio: 3 / 2,
                            viewMode: 1,
                            autoCropArea: 1,
                            movable: true,
                            zoomable: true,
                            rotatable: true,
                            scalable: true,
                            cropBoxResizable: true,
                            cropBoxMovable: true,
                            minCropBoxWidth: 30,
                            minCropBoxHeight: 20,
                            responsive: true,
                            restore: true,
                            guides: true,
                            center: true,
                            highlight: true,
                            background: true,
                            modal: true,
                            ready: function() {
                                console.log("Cropper is ready");
                            }
                        });

                        // Reset filter
                        window.cropperInterop.currentFilter = "none";

                        console.log("Cropper initialized successfully");
                    } catch (error) {
                        console.error("Error creating cropper:", error);
                    }
                },

                // Cropper actions
                cropperAction: function (action) {
                    console.log("Cropper action:", action);

                    if (!window.cropperInterop.cropper) {
                        console.error("Cropper not initialized");
                        return;
                    }

                    try {
                        switch (action) {
                            case "zoomIn":
                                window.cropperInterop.cropper.zoom(0.1);
                                break;

                            case "zoomOut":
                                window.cropperInterop.cropper.zoom(-0.1);
                                break;

                            case "rotateLeft":
                                window.cropperInterop.cropper.rotate(-90);
                                break;

                            case "rotateRight":
                                window.cropperInterop.cropper.rotate(90);
                                break;

                            case "reset":
                                window.cropperInterop.cropper.reset();
                                window.cropperInterop.cropper.clear();
                                window.cropperInterop.cropper.crop();
                                break;

                            case "setCropBox":
                                var containerData = window.cropperInterop.cropper.getContainerData();
                                window.cropperInterop.cropper.setCropBoxData({
                                    left: containerData.width * 0.1,
                                    top: containerData.height * 0.1,
                                    width: containerData.width * 0.8,
                                    height: containerData.height * 0.8
                                });
                                break;

                            case "revertDefault":
                                window.cropperInterop.cropper.reset();
                                window.cropperInterop.currentFilter = "none";
                                var img = window.cropperInterop.cropper.image;
                                if (img) {
                                    img.style.filter = "";
                                }
                                break;

                            // Filter actions
                            case "filterGrayscale":
                                window.cropperInterop._applyFilter("grayscale(1)");
                                break;
                            case "filterBrightnessPlus":
                                window.cropperInterop._applyFilter("brightness(1.3)");
                                break;
                            case "filterBrightnessMinus":
                                window.cropperInterop._applyFilter("brightness(0.7)");
                                break;
                            case "filterContrastPlus":
                                window.cropperInterop._applyFilter("contrast(1.5)");
                                break;
                            case "filterContrastMinus":
                                window.cropperInterop._applyFilter("contrast(0.7)");
                                break;
                            case "filterSepia":
                                window.cropperInterop._applyFilter("sepia(1)");
                                break;
                            case "filterInvert":
                                window.cropperInterop._applyFilter("invert(1)");
                                break;
                            case "filterBlur":
                                window.cropperInterop._applyFilter("blur(2px)");
                                break;
                            case "filterHueRotate":
                                window.cropperInterop._applyFilter("hue-rotate(90deg)");
                                break;
                            case "filterSaturate":
                                window.cropperInterop._applyFilter("saturate(2)");
                                break;
                            case "filterOpacity":
                                window.cropperInterop._applyFilter("opacity(0.5)");
                                break;
                            case "filterNone":
                                window.cropperInterop._applyFilter("");
                                break;

                            default:
                                console.warn("Unknown action:", action);
                        }
                    } catch (error) {
                        console.error("Error in cropperAction:", error);
                    }
                },

                _applyFilter: function(filterCss) {
                    window.cropperInterop.currentFilter = filterCss;
                    var img = window.cropperInterop.cropper.image;
                    if (img) {
                        img.style.filter = filterCss;
                        console.log("Applied filter:", filterCss);
                    }
                },

                // Get cropped image with filter
                getCroppedImage: function (filterKey) {
                    console.log("Getting cropped image with filter:", filterKey);

                    if (!window.cropperInterop.cropper) {
                        console.error("Cropper not initialized");
                        return null;
                    }

                    try {
                        var filterCss = window.cropperInterop._getCanvasFilter(filterKey);

                        // Get cropped canvas
                        var canvas = window.cropperInterop.cropper.getCroppedCanvas({
                            width: 300,
                            height: 200,
                            imageSmoothingEnabled: true,
                            imageSmoothingQuality: "high",
                            fillColor: "#fff"
                        });

                        if (!canvas) {
                            console.error("Failed to get cropped canvas");
                            return null;
                        }

                        // Apply filter to canvas
                        if (filterCss && filterCss !== "none") {
                            var filteredCanvas = document.createElement("canvas");
                            filteredCanvas.width = canvas.width;
                            filteredCanvas.height = canvas.height;
                            var ctx = filteredCanvas.getContext("2d");

                            ctx.filter = filterCss;
                            ctx.drawImage(canvas, 0, 0, canvas.width, canvas.height);

                            var result = filteredCanvas.toDataURL("image/jpeg", 0.85);
                            console.log("Cropped image created with filter");
                            return result;
                        } else {
                            var result = canvas.toDataURL("image/jpeg", 0.85);
                            console.log("Cropped image created without filter");
                            return result;
                        }
                    } catch (error) {
                        console.error("Error in getCroppedImage:", error);
                        return null;
                    }
                },

                _getCanvasFilter: function (filterKey) {
                    // Use current filter if no specific key provided
                    if (!filterKey || filterKey === "none") {
                        return window.cropperInterop.currentFilter || "none";
                    }

                    switch (filterKey) {
                        case "filterGrayscale": return "grayscale(1)";
                        case "filterBrightnessPlus": return "brightness(1.3)";
                        case "filterBrightnessMinus": return "brightness(0.7)";
                        case "filterContrastPlus": return "contrast(1.5)";
                        case "filterContrastMinus": return "contrast(0.7)";
                        case "filterSepia": return "sepia(1)";
                        case "filterInvert": return "invert(1)";
                        case "filterBlur": return "blur(2px)";
                        case "filterHueRotate": return "hue-rotate(90deg)";
                        case "filterSaturate": return "saturate(2)";
                        case "filterOpacity": return "opacity(0.5)";
                        case "filterNone": return "none";
                        default: return "none";
                    }
                },

                // Destroy cropper
                destroyCropper: function () {
                    console.log("Destroying cropper");

                    if (window.cropperInterop.cropper) {
                        try {
                            window.cropperInterop.cropper.destroy();
                            window.cropperInterop.cropper = null;
                            window.cropperInterop.currentFilter = "none";
                            console.log("Cropper destroyed");
                        } catch (error) {
                            console.error("Error destroying cropper:", error);
                        }
                    }
                }
            };
            
       </script>
        <script>
                       window.downloadFileFromBase64 = function (base64, fileName, mimeType) {
                const link = document.createElement('a');
                link.href = `data:${mimeType};base64,${base64}`;
                link.download = fileName;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            };
        </script>

    }
</body>
