@page
@using Microsoft.Extensions.Localization
@using ServiceMaintenance
@inject IStringLocalizer<App> Loc
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Service Maintenance</title>
    <style>
        /* Complete Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            width: 100%;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            overflow: hidden;
            background: #0f0f1e;
        }

        /* Main Container */
        .auth-login-container {
            display: flex;
            min-height: 100vh;
            max-height: 100vh;
            width: 100%;
            position: relative;
            background-image: url('/images/backgroundSmart.jpg');
            background-position: center center;
            background-repeat: no-repeat;
            background-size: cover;
            overflow: hidden;
        }

            .auth-login-container::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.3);
                z-index: 0;
            }
        /* Left Side - Enhanced Illustration Panel - HIDDEN */
        .auth-left-panel {
            display: none;
        }

            /* Animated gradient background */
            .auth-left-panel::before {
                content: '';
                position: absolute;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
                border-radius: 50%;
                top: -200px;
                right: -200px;
                animation: pulse 4s ease-in-out infinite;
            }

            .auth-left-panel::after {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
                border-radius: 50%;
                bottom: -150px;
                left: -150px;
                animation: pulse 6s ease-in-out infinite;
            }



        .auth-illustration-wrapper {
            position: relative;
            z-index: 1;
            max-width: 520px;
            width: 100%;
            text-align: center;
        }

        .auth-brand-section {
            margin-bottom: 3rem;
        }

        .auth-brand-logo {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            border: 2px solid rgba(255, 255, 255, 0.2);
        }

            .auth-brand-logo svg {
                width: 40px;
                height: 40px;
                color: #ffffff;
            }

        .auth-brand-title {
            font-size: 36px;
            font-weight: 800;
            color: #ffffff;
            margin-bottom: 0.75rem;
            letter-spacing: -0.5px;
        }

        .auth-brand-tagline {
            font-size: 18px;
            color: rgba(255, 255, 255, 0.9);
            font-weight: 400;
            line-height: 1.6;
        }

        .auth-illustration-image {
            width: 100%;
            max-width: 400px;
            height: auto;
            filter: drop-shadow(0 25px 50px rgba(0, 0, 0, 0.3));
            animation: float 4s ease-in-out infinite;
            margin: 0 auto;
        }

        /* Right Side - Modern Form Panel */
        .auth-form-panel {
            flex: 1;
            background: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.5rem;
            overflow: hidden;
            min-height: 100vh;
            max-height: 100vh;
            position: relative;
            width: 100%;
        }

            /* Decorative background elements */
            .auth-form-panel::before {
                content: '';
                position: absolute;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
                border-radius: 50%;
                top: -200px;
                right: -200px;
                animation: pulse 4s ease-in-out infinite;
            }

            .auth-form-panel::after {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
                border-radius: 50%;
                bottom: -150px;
                left: -150px;
                animation: pulse 6s ease-in-out infinite;
            }

        .auth-form-wrapper {
            width: 100%;
            max-width: 440px;
            max-height: 95vh;
            position: relative;
            z-index: 1;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 2rem 2rem;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
            overflow-y: auto;
        }

            /* Custom scrollbar for form wrapper */
            .auth-form-wrapper::-webkit-scrollbar {
                width: 6px;
            }

            .auth-form-wrapper::-webkit-scrollbar-track {
                background: rgba(0, 0, 0, 0.05);
                border-radius: 10px;
            }

            .auth-form-wrapper::-webkit-scrollbar-thumb {
                background: rgba(99, 102, 241, 0.3);
                border-radius: 10px;
            }

                .auth-form-wrapper::-webkit-scrollbar-thumb:hover {
                    background: rgba(99, 102, 241, 0.5);
                }

        /* Mobile Logo */
        .auth-mobile-logo-wrapper {
            display: none;
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .auth-mobile-brand-logo {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
        }

            .auth-mobile-brand-logo svg {
                width: 36px;
                height: 36px;
                color: #ffffff;
            }

        .auth-mobile-brand-title {
            font-size: 24px;
            font-weight: 700;
            color: #1e293b;
        }

        /* Welcome Header */
        .auth-welcome-header {
            margin-bottom: 1.5rem;
        }

        .auth-welcome-title {
            font-size: 28px;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 0.375rem;
            letter-spacing: -0.5px;
        }

        .auth-welcome-subtitle {
            font-size: 14px;
            color: #64748b;
            font-weight: 400;
        }

        /* Input Groups */
        .auth-input-group {
            margin-bottom: 1rem;
            width: 100%;
        }

        .auth-input-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #334155;
            margin-bottom: 0.4rem;
        }

        .auth-input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            width: 100%;
        }

        .auth-input-icon {
            position: absolute;
            left: 1.125rem;
            color: #94a3b8;
            pointer-events: none;
            z-index: 1;
            width: 20px;
            height: 20px;
            transition: color 0.2s ease;
        }

        .auth-form-input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.75rem;
            font-size: 14px;
            color: #0f172a;
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            outline: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: inherit;
            font-weight: 500;
        }

            .auth-form-input::placeholder {
                color: #cbd5e1;
                font-weight: 400;
            }

            .auth-form-input:focus {
                background: #ffffff;
                border-color: #6366f1;
                box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            }

                .auth-form-input:focus + .auth-input-icon {
                    color: #6366f1;
                }

        /* Remember & Forgot Row */
        .auth-options-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.25rem;
        }

        .auth-remember-wrapper {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .auth-checkbox {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: #6366f1;
        }

        .auth-remember-label {
            font-size: 13px;
            color: #475569;
            font-weight: 500;
            cursor: pointer;
        }

        .auth-forgot-link {
            font-size: 13px;
            color: #6366f1;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s ease;
        }

            .auth-forgot-link:hover {
                color: #4f46e5;
            }

        .auth-submit-button {
            width: 100%;
            padding: 0.875rem;
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
            position: relative;
            overflow: hidden;
        }

            .auth-submit-button::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
                transition: left 0.5s ease;
            }

            .auth-submit-button:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 28px rgba(99, 102, 241, 0.5);
            }

                .auth-submit-button:hover::before {
                    left: 100%;
                }

            .auth-submit-button:active {
                transform: translateY(0);
            }

        /* Divider */
        .auth-divider {
            display: flex;
            align-items: center;
            margin: 1.25rem 0;
        }

        .auth-divider-line {
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

        .auth-divider-text {
            padding: 0 0.875rem;
            font-size: 12px;
            color: #94a3b8;
            font-weight: 500;
        }

        /* Error Messages */
        .auth-error-message {
            padding: 0.75rem 1rem;
            margin-bottom: 1rem;
            background: #fef2f2;
            color: #dc2626;
            border: 2px solid #fecaca;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .auth-error-message::before {
                content: '⚠';
                font-size: 16px;
            }

        .auth-field-error {
            display: block;
            color: #dc2626;
            font-size: 12px;
            margin-top: 0.375rem;
            margin-left: 0.25rem;
            font-weight: 500;
        }

        .auth-text-danger {
            color: #dc2626;
            font-size: 13px;
            margin-bottom: 1rem;
            font-weight: 500;
        }

        /* Footer */
        .auth-footer-section {
            margin-top: 1.5rem;
        }

        .auth-footer-divider {
            width: 100%;
            height: 1px;
            background: #e2e8f0;
            margin-bottom: 0.875rem;
        }

        .auth-footer-content {
            text-align: center;
        }

        .auth-footer-copyright {
            font-size: 11px;
            color: #64748b;
            font-weight: 500;
            display: block;
            margin-bottom: 0.25rem;
        }

        .auth-footer-brand-name {
            font-size: 10px;
            color: #94a3b8;
            font-weight: 500;
        }

    </style>
</head>
<body>
    <div class="auth-login-container">
        <!-- Left Side - Illustration Panel -->
        <div class="auth-left-panel">
            <div class="auth-illustration-wrapper">
                <div class="auth-brand-section">
                    <div class="auth-brand-logo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                        </svg>
                    </div>
                    <h2 class="auth-brand-title">Service Maintenance</h2>
                    <p class="auth-brand-tagline">Professional repair & maintenance management system for your business</p>
                </div>

                <svg class="auth-illustration-image" viewBox="0 0 500 420" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Modern Laptop -->
                    <g filter="url(#shadow1)">
                        <rect x="120" y="120" width="260" height="180" rx="12" fill="#ffffff" />
                        <rect x="135" y="135" width="230" height="140" rx="4" fill="#e0e7ff" />

                        <!-- Screen Content - Dashboard -->
                        <rect x="150" y="150" width="80" height="8" rx="4" fill="#6366f1" opacity="0.6" />
                        <rect x="150" y="165" width="60" height="6" rx="3" fill="#8b5cf6" opacity="0.4" />

                        <rect x="150" y="185" width="200" height="35" rx="6" fill="#ffffff" opacity="0.9" />
                        <circle cx="165" cy="202" r="8" fill="#6366f1" />
                        <rect x="180" y="195" width="80" height="4" rx="2" fill="#cbd5e1" />
                        <rect x="180" y="205" width="60" height="4" rx="2" fill="#e0e7ff" />

                        <rect x="150" y="230" width="200" height="35" rx="6" fill="#ffffff" opacity="0.9" />
                        <circle cx="165" cy="247" r="8" fill="#8b5cf6" />
                        <rect x="180" y="240" width="90" height="4" rx="2" fill="#cbd5e1" />
                        <rect x="180" y="250" width="70" height="4" rx="2" fill="#e0e7ff" />
                    </g>

                    <!-- Laptop Base -->
                    <path d="M80 300 L420 300 L400 315 L100 315 Z" fill="#ffffff" opacity="0.95" />

                    <!-- Floating Elements -->
                    <g opacity="0.9">
                        <circle cx="420" cy="180" r="35" fill="#ffffff" opacity="0.3" />
                        <circle cx="90" cy="140" r="25" fill="#ffffff" opacity="0.25" />
                        <circle cx="410" cy="280" r="20" fill="#ffffff" opacity="0.2" />
                    </g>

                    <!-- Tools Icons -->
                    <g transform="translate(50, 200)">
                        <circle cx="0" cy="0" r="22" fill="#ffffff" opacity="0.9" />
                        <path d="M-8 -8 L8 8 M8 -8 L-8 8" stroke="#6366f1" stroke-width="3" stroke-linecap="round" />
                    </g>

                    <g transform="translate(430, 220)">
                        <circle cx="0" cy="0" r="18" fill="#ffffff" opacity="0.85" />
                        <circle cx="0" cy="0" r="6" fill="#8b5cf6" />
                    </g>

                    <defs>
                        <filter id="shadow1" x="100" y="110" width="300" height="220">
                            <feGaussianBlur in="SourceAlpha" stdDeviation="8" />
                            <feOffset dx="0" dy="10" result="offsetblur" />
                            <feComponentTransfer>
                                <feFuncA type="linear" slope="0.3" />
                            </feComponentTransfer>
                            <feMerge>
                                <feMergeNode />
                                <feMergeNode in="SourceGraphic" />
                            </feMerge>
                        </filter>
                    </defs>
                </svg>
            </div>
        </div>

        <!-- Right Side - Login Form -->
        <div class="auth-form-panel">
            <div class="auth-form-wrapper">
                <!-- Mobile Logo -->
                <div class="auth-mobile-logo-wrapper">
                    <div class="auth-mobile-brand-logo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                        </svg>
                    </div>
                    <h2 class="auth-mobile-brand-title">Service Maintenance</h2>
                </div>

                <div class="auth-form-card">
                    <!-- Logo Section -->
                    <div style="text-align: center; margin-bottom: 2rem;">
                        <div style="margin: 0 auto 1rem;">
                            <img src="~/images/CAM.jpg" alt="Service Maintenance Logo" style="height: 80px; width: auto;" />
                        </div>
                        <h2 style="font-size: 24px; font-weight: 700; color: #1e293b; margin-bottom: 0.5rem;">Service Maintenance</h2>
                        <p style="font-size: 14px; color: #64748b; font-weight: 400;">Enter your credentials to access your account</p>
                    </div>


                    <form id="account" method="post" asp-page="/Account/Login" asp-area="Identity" asp-route-returnUrl="@Model.ReturnUrl">
                        <div asp-validation-summary="ModelOnly" class="auth-text-danger" role="alert"></div>

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="auth-error-message">
                                @TempData["ErrorMessage"]
                            </div>
                        }

                        <!-- Email Input -->
                        <div class="auth-input-group">
                            <label class="auth-input-label">Email Address</label>
                            <div class="auth-input-wrapper">
                                <svg class="auth-input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                    <polyline points="22,6 12,13 2,6" />
                                </svg>
                                <input asp-for="Input.Email"
                                       class="auth-form-input"
                                       placeholder="your.email@example.com"
                                       required
                                       autocomplete="username" />
                            </div>
                            <span asp-validation-for="Input.Email" class="auth-field-error"></span>
                        </div>

                        <!-- Password Input -->
                        <div class="auth-input-group">
                            <label class="auth-input-label">Password</label>
                            <div class="auth-input-wrapper">
                                <svg class="auth-input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                                <input asp-for="Input.Password"
                                       class="auth-form-input"
                                       type="password"
                                       placeholder="Enter your password"
                                       required
                                       autocomplete="current-password"/>
                            </div>
                            <span asp-validation-for="Input.Password" class="auth-field-error"></span>
                        </div>

                        <!-- Remember Me & Forgot Password -->
                        <div class="auth-options-row">
                            <div class="auth-remember-wrapper">
                                <input type="checkbox" id="rememberMe" class="auth-checkbox" />
                                <label for="rememberMe" class="auth-remember-label">Remember me</label>
                            </div>
                            <a asp-page="./ForgotPassword" class="auth-forgot-link">Forgot Password?</a>
                        </div>

                        <!-- Login Button -->
                        <button type="submit" class="auth-submit-button">Sign In</button>
                    </form>
                </div>

                <!-- Footer -->
                <div class="auth-footer-section">
                    <div class="auth-footer-divider"></div>
                    <div class="auth-footer-content">
                        <span class="auth-footer-copyright">© 2026 Service Maintenance. All Rights Reserved</span>
                        <span class="auth-footer-brand-name">BIS Repair & Maintenance System v2.1.0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>