@code {
    private string drawerClass => ToggleOn ? "show" : "";
    private int notificationCount = 0;
    private int totalUnreadMessages = 0;

    [Inject] private GlobalArticleCacheService GlobalArticleCache { get; set; }
    [Inject] private JwtHttpClientService JwtHttpClientService { get; set; }

    private bool IsDarkMode { get; set; }
    private bool IsProfileMenuVisible { get; set; }
    private List<Article> articles = new List<Article>();
    private List<UserMessagePreview> userMessages = new List<UserMessagePreview>();
    private string dropdownClass => IsProfileMenuVisible ? "show" : "";

    [Parameter] public bool ToggleOn { get; set; }
    [Parameter] public EventCallback<bool> ToggleOnChanged { get; set; }

    @inject IJSRuntime JSRuntime

    private bool showEnvelopeDropdown = false;
    private string envelopeDropdownClass => showEnvelopeDropdown ? "show" : "";

    private bool showNotificationDropdown = false;
    private string notificationDropdownClass => showNotificationDropdown ? "show" : "";

    private bool isSignedIn = false;
    private string userName;

    private RepairServices selectedRepairService;
    private SfDialog DialogEdit;
    private bool isViewDialogVisible = false;
    private string currentUsername = "";

    private string currentUserId;
    private UserDto currentUser;
    private string userProfilePictureUrl;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get authentication state
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (!user.Identity.IsAuthenticated)
                return;

            isSignedIn = true;
            currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            userName = user.Identity.Name ?? "Unknown User";

            if (string.IsNullOrEmpty(currentUserId))
                return;

            // Load user details
            currentUser = await UserService.GetApplicationUserAsync(currentUserId);
            if (currentUser != null)
            {
                var fullName = $"{currentUser.FirstName} {currentUser.LastName}".Trim();
                userName = !string.IsNullOrEmpty(fullName) ? fullName : currentUser.UserName ?? userName;
                currentUsername = currentUser.UserName ?? user.Identity.Name ?? "Unknown User";
            }
            else
            {
                currentUsername = user.Identity.Name ?? "Unknown User";
            }

            // Load profile picture from JWT API
            try
            {
                var profileResponse = await JwtHttpClientService.GetAsync("api/Auth/profile");
                if (profileResponse.IsSuccessStatusCode)
                {
                    var profileData = await profileResponse.Content.ReadFromJsonAsync<ProfileApiResponse>();
                    userProfilePictureUrl = profileData?.Data?.ProfilePictureUrl;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading profile picture: {ex.Message}");
                userProfilePictureUrl = null;
            }

            // Load notifications (static, no real-time)
            try
            {
                articles = await GlobalArticleCache.GetArticlesAsync(excludeUsername: currentUsername);
                notificationCount = articles.Count(a => !a.IsRead && a.Username != currentUsername);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading articles: {ex.Message}");
            }

            // Load message conversations
            await LoadUserMessagesWithUnreadCounts();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in OnInitializedAsync: {ex.Message}");
        }
    }

    private async Task LoadUserMessagesWithUnreadCounts()
    {
        try
        {
            if (string.IsNullOrEmpty(currentUserId))
            {
                totalUnreadMessages = 0;
                userMessages = new List<UserMessagePreview>();
                return;
            }

            // Get unread counts
            var unreadCountsResponse = await JwtMessageService.GetUnreadCountsAsync(currentUserId);
            var unreadCountsBySenderId = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

            if (unreadCountsResponse?.Status == "Success" && unreadCountsResponse.Data != null)
            {
                unreadCountsBySenderId = new Dictionary<string, int>(
                    unreadCountsResponse.Data,
                    StringComparer.OrdinalIgnoreCase
                );
            }

            totalUnreadMessages = unreadCountsBySenderId.Values.Sum();

            // Load conversations for dropdown display
            var conversationsResponse = await JwtMessageService.GetAllConversationsAsync(currentUserId);
            userMessages = new List<UserMessagePreview>();

            if (conversationsResponse?.Status == "Success" && conversationsResponse.Data != null && conversationsResponse.Data.Any())
            {
                foreach (var conversation in conversationsResponse.Data)
                {
                    try
                    {
                        var otherUser = await UserService.GetApplicationUserAsync(conversation.OtherUserId);
                        if (otherUser == null) continue;

                        int unreadCount = unreadCountsBySenderId.GetValueOrDefault(conversation.OtherUserId, 0);

                        var lastMessageText = GetMessagePreviewText(
                            conversation.LastMessageText,
                            conversation.LastMessageFileUrl,
                            conversation.LastMessageAudioUrl
                        );

                        userMessages.Add(new UserMessagePreview
                        {
                            UserId = otherUser.Id,
                            UserName = otherUser.UserName ?? "Unknown User",
                            ProfilePicture = "/images/default-profile.png",
                            LastMessageText = lastMessageText,
                            LastMessageTime = conversation.LastMessageTime,
                            UnreadCount = unreadCount,
                            IsOnline = false
                        });
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error processing conversation: {ex.Message}");
                    }
                }

                userMessages = userMessages
                    .OrderByDescending(u => u.UnreadCount)
                    .ThenByDescending(u => u.LastMessageTime)
                    .ToList();
            }
            else if (unreadCountsBySenderId.Any())
            {
                // Fallback: build list from unread counts alone
                foreach (var kvp in unreadCountsBySenderId.Where(x => x.Value > 0))
                {
                    try
                    {
                        var otherUser = await UserService.GetApplicationUserAsync(kvp.Key);
                        if (otherUser != null)
                        {
                            userMessages.Add(new UserMessagePreview
                            {
                                UserId = otherUser.Id,
                                UserName = otherUser.UserName ?? "Unknown User",
                                ProfilePicture = "/images/default-profile.png",
                                LastMessageText = "New message",
                                LastMessageTime = DateTime.UtcNow,
                                UnreadCount = kvp.Value,
                                IsOnline = false
                            });
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error loading user {kvp.Key}: {ex.Message}");
                    }
                }

                userMessages = userMessages.OrderByDescending(u => u.UnreadCount).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in LoadUserMessagesWithUnreadCounts: {ex.Message}");
            totalUnreadMessages = 0;
            userMessages = new List<UserMessagePreview>();
        }
    }

    private bool IsImageFile(string fileUrl)
    {
        if (string.IsNullOrEmpty(fileUrl)) return false;
        return fileUrl.Contains("image/", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".gif", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".webp", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsVideoFile(string fileUrl)
    {
        if (string.IsNullOrEmpty(fileUrl)) return false;
        return fileUrl.Contains("video/", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".webm", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".avi", StringComparison.OrdinalIgnoreCase)
            || fileUrl.EndsWith(".mov", StringComparison.OrdinalIgnoreCase);
    }

    private string GetMessagePreviewText(string messageText, string fileUrl, string audioUrl)
    {
        if (!string.IsNullOrEmpty(audioUrl)) return "🎤 Sent a voice message";
        if (!string.IsNullOrEmpty(fileUrl))
        {
            if (IsImageFile(fileUrl)) return "📷 Sent a photo";
            if (IsVideoFile(fileUrl)) return "🎥 Sent a video";
            return "📎 Sent an attachment";
        }
        return TruncateMessage(messageText, 50);
    }

    private string TruncateMessage(string message, int maxLength)
    {
        if (string.IsNullOrEmpty(message)) return "No message";
        var decoded = System.Net.WebUtility.HtmlDecode(message);
        return decoded.Length <= maxLength ? decoded : decoded.Substring(0, maxLength) + "...";
    }

    private void ToggleEnvelopeDropdown()
    {
        showEnvelopeDropdown = !showEnvelopeDropdown;
        if (showEnvelopeDropdown && showNotificationDropdown)
            showNotificationDropdown = false;
        StateHasChanged();
    }

    private void NavigateToChat(string userId)
    {
        try
        {
            var userMsg = userMessages.FirstOrDefault(u => u.UserId == userId);
            if (userMsg != null && userMsg.UnreadCount > 0)
            {
                int previousUnreadCount = userMsg.UnreadCount;
                userMsg.UnreadCount = 0;
                totalUnreadMessages = Math.Max(0, totalUnreadMessages - previousUnreadCount);
                StateHasChanged();

                // Mark as read in background (fire and forget)
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await JwtMessageService.MarkMessagesAsReadAsync(currentUserId, userId);
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Mark-as-read failed: {ex.Message}");
                    }
                });
            }

            showEnvelopeDropdown = false;
            StateHasChanged();
            Navigation.NavigateTo($"/chat/{userId}", forceLoad: false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in NavigateToChat: {ex.Message}");
            showEnvelopeDropdown = false;
            Navigation.NavigateTo($"/chat/{userId}", forceLoad: false);
        }
    }

    [JSInvokable]
    public void CloseNotificationDropdown()
    {
        showNotificationDropdown = false;
        showEnvelopeDropdown = false;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync(
                "addOutsideClickListener",
                DotNetObjectReference.Create(this)
            );
        }
    }

    private async Task MarkAsRead(Article notification)
    {
        if (notification.IsRead) return;
        await GlobalArticleCache.MarkAsReadAsync(notification.Id);
        notificationCount = articles.Count(a => !a.IsRead && a.Username != currentUsername);
        StateHasChanged();
    }

    private async Task DeleteNotification(int notificationId)
    {
        await GlobalArticleCache.DeleteArticleAsync(notificationId);
        articles = articles.Where(a => a.Id != notificationId).ToList();
        notificationCount = articles.Count(a => !a.IsRead && a.Username != currentUsername);
        StateHasChanged();
    }

    private async Task ClearAllNotifications()
    {
        await GlobalArticleCache.ClearAllArticlesAsync();
        articles = new List<Article>();
        notificationCount = 0;
        StateHasChanged();
    }

    private void ToggleNotificationDropdown()
    {
        showNotificationDropdown = !showNotificationDropdown;
        if (showNotificationDropdown && showEnvelopeDropdown)
            showEnvelopeDropdown = false;
        if (showNotificationDropdown)
            notificationCount = articles.Count(a => !a.IsRead && a.Username != currentUsername);
        StateHasChanged();
    }

    private void NavigateToModule(Article notification)
    {
        if (string.IsNullOrEmpty(notification.ArticleHeading)) return;
        var moduleName = ExtractModuleNameFromHeading(notification.ArticleHeading);
        var reportNo = ExtractReportNoFromHeading(notification.ArticleHeading);
        if (!string.IsNullOrEmpty(moduleName))
        {
            var route = string.IsNullOrEmpty(reportNo) ? $"/{moduleName}" : $"/{moduleName}/{reportNo}";
            Navigation.NavigateTo(route);
        }
    }

    private string ExtractModuleNameFromHeading(string articleHeading)
    {
        if (string.IsNullOrEmpty(articleHeading)) return null;
        var match = System.Text.RegularExpressions.Regex.Match(articleHeading, @"Successfully in (?<moduleName>[^\s]+)");
        return match.Success ? match.Groups["moduleName"].Value : null;
    }

    private string ExtractReportNoFromHeading(string articleHeading)
    {
        if (string.IsNullOrEmpty(articleHeading)) return null;
        var match = System.Text.RegularExpressions.Regex.Match(articleHeading, @"\(Ref No:\s*(?<reportNo>[^)]+)\)");
        return match.Success ? match.Groups["reportNo"].Value : null;
    }

    private async Task HandleAccept(Article notification)
    {
        try
        {
            var reportNo = ExtractReportNoFromHeading(notification.ArticleHeading);
            if (!string.IsNullOrEmpty(reportNo))
                Navigation.NavigateTo($"/inspect-item/{reportNo}");

            notification.IsActionVisible = false;
            await GlobalArticleCache.UpdateArticleVisibilityAsync(notification.Id, false);
            showNotificationDropdown = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in HandleAccept: {ex.Message}");
            showNotificationDropdown = false;
        }
    }

    private async Task HandleInfo(Article notification)
    {
        var reportNo = ExtractReportNoFromHeading(notification.ArticleHeading);
        if (!string.IsNullOrEmpty(reportNo))
        {
            try
            {
                var searchResult = await RepairItemService.SearchRepairServicesAsync(
                    pageNumber: 1, pageSize: 1, searchTerm: reportNo);

                selectedRepairService = searchResult.Items.FirstOrDefault();
                if (selectedRepairService != null)
                {
                    isViewDialogVisible = true;
                    await DialogEdit.ShowAsync();
                    showNotificationDropdown = false;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading repair service: {ex.Message}");
            }
        }
    }

    private void OverlayClick(OverlayModalClickEventArgs args) => isViewDialogVisible = false;
    private void CloseDialog() => isViewDialogVisible = false;
    void ClickHome() => Navigation.NavigateTo("/");
    async Task OnToggleClick() => await Toggle();

    async Task Toggle(bool? value = null)
    {
        var newValue = value ?? !ToggleOn;
        if (ToggleOn != newValue)
        {
            ToggleOn = newValue;
            await ToggleOnChanged.InvokeAsync(ToggleOn);
        }
    }

    void ToggleProfileMenu() => IsProfileMenuVisible = !IsProfileMenuVisible;

    private string GetRelativeTime(DateTime timestamp)
    {
        DateTime now = DateTime.UtcNow;
        DateTime utcTimestamp = timestamp.Kind == DateTimeKind.Utc
            ? timestamp
            : timestamp.ToUniversalTime();

        var timeDiff = now - utcTimestamp;

        if (timeDiff.TotalSeconds < 0) return "just now";
        if (timeDiff.TotalSeconds < 60) return $"{(int)timeDiff.TotalSeconds}s ago";
        if (timeDiff.TotalMinutes < 60) return $"{(int)timeDiff.TotalMinutes}m ago";
        if (timeDiff.TotalHours < 24) return $"{(int)timeDiff.TotalHours}h ago";
        if (timeDiff.TotalDays < 7) return $"{(int)timeDiff.TotalDays}d ago";
        if (timeDiff.TotalDays < 30) return $"{(int)(timeDiff.TotalDays / 7)}w ago";

        return utcTimestamp.ToLocalTime().ToString("MMM d, yyyy");
    }

