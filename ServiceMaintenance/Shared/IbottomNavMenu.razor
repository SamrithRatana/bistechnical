@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using ServiceMaintenance.Models
@using ServiceMaintenance.Services
@inject NavigationManager UriHelper
@using Syncfusion.Blazor.Lists
@inject IServiceProvider _serviceProvider

<div class="bottom-nav-bar">
    <AuthorizeView>
        <Authorized>
            <a class="nav-link" href="/" @onclick="NavigateToHome">
                <i class="fas fa-home"></i>
                Home
            </a>
            <a class="nav-link" href="#" @onclick="ToggleMessagesOverlay">
                <i class="fas fa-envelope"></i>
                Messages
                @if (totalUnreadMessages > 0)
                {
                    <span class="notification-badge">@totalUnreadMessages</span>
                }
            </a>

            <a class="nav-link" href="#" @onclick="ToggleNotificationDropdown">
                <i class="fa fa-bell"></i>
                Notification
                @if (notificationCount > 0)
                {
                    <span class="notification-badge">@notificationCount</span>
                }
            </a>

            <a class="nav-link" @onclick="ToggleSettingsDrawer">
                <i class="fas fa-cog"></i>
                Settings
            </a>
        </Authorized>
        <NotAuthorized>
            <a class="nav-link" href="/identity/account/login">
                <i class="fas fa-sign-in-alt"></i>
                Login
            </a>
            <a class="nav-link" href="/identity/account/register">
                <i class="fas fa-user-plus"></i>
                Register
            </a>
        </NotAuthorized>
    </AuthorizeView>
</div>

<div class="notification-overlay @notificationDropdownClass">
    <div class="notification-header">
        <button @onclick="ToggleNotificationDropdown" class="back-button">
            <i class="fas fa-arrow-left"></i> Back
        </button>
        <h2>Notifications</h2>
        @if (notificationCount > 0)
        {
            <button @onclick="ClearNotifications" class="clear-button">Clear All</button>
        }
    </div>
    <div class="notification-content">
        @if (articles.Any())
        {
            @foreach (var notification in articles)
            {
                <div class="dropdown-item @(!notification.IsRead ? "unread-notification" : "read-notification")" @onclick="() => MarkAsRead(notification)">
                    <div class="notification-profile-picture">
                        @if (!string.IsNullOrEmpty(notification.ProfilePicture))
                        {
                            <img src="data:image/png;base64,@notification.ProfilePicture" alt="@notification.Username" class="profile-img" />
                        }
                        else
                        {
                            <img src="/images/default-profile.png" alt="@notification.Username" class="profile-img" />
                        }
                    </div>
                    <div class="notification-text">
                        <strong>@notification.Username</strong>
                        <p>@notification.ArticleHeading</p>
                        <span>@notification.ArticleContent</span>
                    </div>
                    <div class="notification-time">
                        <span>@GetRelativeTime(notification.Timestamp)</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="dropdown-item no-notifications">
                <p>No notifications.</p>
            </div>
        }
    </div>
</div>

<div class="messages-overlay @messagesOverlayClass">
    <div class="notification-header">
        <button @onclick="ToggleMessagesOverlay" class="back-button">
            <i class="fas fa-arrow-left"></i> Back
        </button>
        <h2>Messages</h2>
    </div>
    <div class="notification-content">
        @if (userMessages != null && userMessages.Any())
        {
            @foreach (var userMsg in userMessages)
            {
                <div class="message-item-mobile" @onclick="() => NavigateToChat(userMsg.UserId)">
                    <div class="message-avatar-wrapper">
                        @if (!string.IsNullOrEmpty(userMsg.ProfilePicture))
                        {
                            <img src="@userMsg.ProfilePicture" alt="@userMsg.UserName" class="message-avatar-mobile" />
                        }
                        else
                        {
                            <img src="/images/default-profile.png" alt="@userMsg.UserName" class="message-avatar-mobile" />
                        }
                        @if (userMsg.IsOnline)
                        {
                            <span class="online-indicator-mobile"></span>
                        }
                    </div>
                    <div class="message-content-mobile">
                        <div class="message-username-mobile">@userMsg.UserName</div>
                        <p class="message-text-mobile">@userMsg.LastMessageText</p>
                        <div class="message-time-mobile">@GetRelativeTime(userMsg.LastMessageTime)</div>
                    </div>
                    @if (userMsg.UnreadCount > 0)
                    {
                        <span class="message-unread-badge-mobile">@userMsg.UnreadCount</span>
                    }
                </div>
            }
        }
        else
        {
            <div class="no-messages-mobile">
                <i class="fas fa-comments"></i>
                <p>No conversations yet</p>
            </div>
        }
    </div>
</div>

<AuthorizeView>
    <Authorized>
        <div class="settings-drawer @drawerClass" @ref="drawerElement">
            <div class="drawer-profile">
                <div class="profile-img">
                    @if (!string.IsNullOrEmpty(profilePictureUrl) && profilePictureUrl != "/images/avatar.jpg")
                    {
                        <img src="@profilePictureUrl?v=@DateTime.UtcNow.Ticks"
                             alt="Profile"
                             onerror="this.src='/images/avatar.jpg'" />
                    }
                    else
                    {
                        <img src="/images/avatar.jpg" alt="Default Profile" />
                    }
                </div>
                <div class="profile-info">
                    <h2 class="profile-title">@userName</h2>
                    <p class="profile-subtitle">@currentUser?.Email</p>
                </div>
            </div>

            <button class="drawer-item" @onclick="dr1">
                <i class="fas fa-question-circle"></i>
                Help & Support
            </button>

            <button class="drawer-item" @onclick="dr2">
                <i class="fas fa-user-shield"></i>
                Privacy
            </button>

            <button class="drawer-item" @onclick="dr3">
                <i class="fas fa-file-contract"></i>
                Terms & Conditions
            </button>

            <a class="drawer-item" href="/identity/account/logout" style="text-decoration:none">
                <i class="fas fa-sign-out-alt"></i>
                Log out
            </a>

            <button class="drawer-item" @onclick="CloseDrawer">
                <i class="fas fa-times"></i>
                Close
            </button>
        </div>
    </Authorized>
</AuthorizeView>

<style>
    .bottom-nav-bar {
        /* Style for your bottom navigation bar */
    }

    .nav-item-profile {
        display: flex;
        align-items: center;
    }

        .nav-item-profile .rounded-circle {
            border-radius: 50%;
            width: 40px;
            height: 40px;
            object-fit: cover;
            margin-right: 10px;
        }

    .username {
        font-weight: bold;
    }

    .notification-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #fff;
        z-index: 1050;
        overflow-y: auto;
        opacity: 0;
        transform: translateY(100%);
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

        .notification-overlay.show-fullscreen {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

    .notification-header {
        display: flex;
        align-items: center;
        padding: 10px;
        border-bottom: 1px solid #ddd;
        background-color: #f7f7f7;
    }

    .back-button {
        border: none;
        background: none;
        color: #333;
        font-size: 1.2rem;
        cursor: pointer;
        margin-right: 10px;
    }

    .notification-header h2 {
        font-size: 1.2rem;
        font-weight: bold;
        margin: 0;
        color: #333;
    }

    .notification-badge {
        position: absolute;
        top: -5px;
        right: -10px;
        margin-right: 28px;
        background-color: red;
        color: white;
        border-radius: 50%;
        padding: 0.3em 0.6em;
        font-size: 0.8em;
    }

    .notification-content {
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
        overflow-y: auto;
    }

    .notification-overlay .dropdown-item {
        padding: 10px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        transition: background 0.2s ease;
        width: 100%;
    }

        .notification-overlay .dropdown-item:last-child {
            border-bottom: none;
        }

        .notification-overlay .dropdown-item:hover {
            background: #f9f9f9;
        }

    .notification-profile-picture img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        margin-right: 10px;
        flex-shrink: 0;
    }

    .notification-text {
        flex-grow: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
    }

        .notification-text strong {
            font-weight: 600;
            font-size: 1rem;
        }

        .notification-text p,
        .notification-text span {
            margin: 0;
            color: #666;
            font-size: 0.9rem;
            white-space: normal;
        }

    .nav-link {
        position: relative;
    }

    .badge {
        position: absolute;
        top: -5px;
        right: -5px;
        background-color: red;
        color: white;
        border-radius: 50%;
        padding: 5px 10px;
        font-size: 0.8rem;
    }

    .clear-button {
        background-color: #f44336;
        color: white;
        border: none;
        padding: 5px 10px;
        cursor: pointer;
        font-size: 0.9rem;
        border-radius: 3px;
    }

        .clear-button:hover {
            background-color: #d32f2f;
        }

    .unread-notification {
        background-color: #f0f8ff;
    }

    .read-notification {
        background-color: white;
    }

    .settings-drawer {
        transition: transform 0.3s ease, opacity 0.3s ease, visibility 0.3s ease;
        transform: translateX(100%);
        opacity: 0;
        visibility: hidden;
    }

        .settings-drawer.open {
            transform: translateX(0);
            opacity: 1;
            visibility: visible;
        }

        .settings-drawer.closed {
            transform: translateX(100%);
            opacity: 0;
            visibility: hidden;
        }

    .messages-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: #fff;
        z-index: 1050;
        overflow-y: auto;
        opacity: 0;
        transform: translateY(100%);
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

        .messages-overlay.show-fullscreen {
            display: flex;
            flex-direction: column;
            opacity: 1;
            transform: translateY(0);
        }

    .message-item-mobile {
        display: flex;
        align-items: center;
        padding: 12px 15px;
        border-bottom: 1px solid #f0f0f0;
        cursor: pointer;
        transition: background-color 0.2s ease;
        gap: 12px;
    }

        .message-item-mobile:hover {
            background-color: #f8f9fa;
        }

        .message-item-mobile:last-child {
            border-bottom: none;
        }

    .message-avatar-wrapper {
        position: relative;
        flex-shrink: 0;
    }

    .message-avatar-mobile {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e0e0e0;
    }

    .online-indicator-mobile {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background-color: #28a745;
        border: 2px solid #fff;
        position: absolute;
        bottom: 2px;
        right: 2px;
    }

    .message-content-mobile {
        flex: 1;
        min-width: 0;
    }

    .message-username-mobile {
        font-weight: 600;
        font-size: 16px;
        color: #333;
        margin-bottom: 4px;
    }

    .message-text-mobile {
        font-size: 14px;
        color: #666;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin: 0;
    }

    .message-time-mobile {
        font-size: 12px;
        color: #999;
        margin-top: 4px;
    }

    .message-unread-badge-mobile {
        background-color: #007bff;
        color: white;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 600;
        flex-shrink: 0;
    }

    .no-messages-mobile {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 20px;
        color: #888;
        width: 100%;
        height: 100%;
        flex: 1;
    }

        .no-messages-mobile i {
            font-size: 80px;
            color: #ddd;
            margin-bottom: 20px;
            display: block;
        }

        .no-messages-mobile p {
            margin: 0;
            font-size: 16px;
            color: #999;
        }
</style>

<script>
    window.addClickDrawer = function (drawerElement) {
        document.addEventListener('click', function (event) {
            let drawer = drawerElement;
            if (drawer && drawer.classList.contains('open') && !drawer.contains(event.target) && !event.target.closest('.nav-link')) {
                closeDrawer();
                location.reload();
            }
        });
    };

    function closeDrawer() {
        let drawer = document.querySelector('.settings-drawer');
        if (drawer) {
            drawer.classList.remove('open');
            drawer.classList.add('closed');
        }
    }
</script>
